{#
  Generic modal to create/edit an item from a dynamic Radarr schema.
  Expected variables:
    modal_id       : modal id (ex: 'modal-indexer')
    modal_title_add: add title (ex: 'Add an indexer')
    modal_title_edit: edit title (ex: 'Edit the indexer')
    schema_url     : URL of the GET schema endpoint (ex: instance_path('radarr_indexers_schema'))
    save_url_add   : POST URL to create (ex: instance_path('radarr_indexer_add'))
    save_url_edit  : POST URL to edit — __ID__ is replaced by the id (ex: '{{ app.request.getBasePath() }}/medias/' + INSTANCE_SLUG + '/radarr/indexeurs/__ID__/modifier')
    test_url       : (optional) POST URL to test (ex: '{{ app.request.getBasePath() }}/medias/' + INSTANCE_SLUG + '/radarr/indexeurs/__ID__/tester')
    mode           : 'default' | 'notification' — notifications show triggers instead of RSS/search options
#}
<div class="modal modal-blur fade" id="{{ modal_id }}" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="{{ modal_id }}-title">{{ modal_title_add }}</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">

        <div id="{{ modal_id }}-feedback" class="alert d-none mb-3"></div>

        {# Implementation selector (hidden in edit mode) #}
        <div id="{{ modal_id }}-impl-wrap" class="mb-3">
          <label class="form-label fw-medium">{{ 'media.arr_admin.schema_modal.type'|trans }}</label>
          <select id="{{ modal_id }}-impl-select" class="form-select">
            <option value="">{{ 'media.arr_admin.schema_modal.type_placeholder'|trans }}</option>
          </select>
        </div>

        {# Name field (always present) #}
        <div class="mb-3">
          <label class="form-label fw-medium">{{ 'media.arr_admin.schema_modal.name_label'|trans }} <span class="text-danger">*</span></label>
          <input type="text" id="{{ modal_id }}-name" class="form-control" placeholder="{{ 'media.arr_admin.schema_modal.name_placeholder'|trans }}">
        </div>

        {% if (mode ?? 'default') == 'notification' %}
        {# Notification triggers (filled dynamically from the supportsOn* schema) #}
        <div id="{{ modal_id }}-triggers" class="d-none mb-3">
          <label class="form-label fw-medium">{{ 'media.arr_admin.schema_modal.triggers_label'|trans }}</label>
          <div id="{{ modal_id }}-triggers-list" class="row g-2"></div>
        </div>
        {% else %}
        {# Global options (RSS, auto search, interactive search, priority) #}
        <div id="{{ modal_id }}-global-opts" class="d-none mb-3">
          <div class="d-flex flex-wrap gap-3">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="{{ modal_id }}-enableRss" checked>
              <label class="form-check-label" for="{{ modal_id }}-enableRss">{{ 'media.arr_admin.schema_modal.opt_rss'|trans }}</label>
            </div>
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="{{ modal_id }}-enableAutoSearch" checked>
              <label class="form-check-label" for="{{ modal_id }}-enableAutoSearch">{{ 'media.arr_admin.schema_modal.opt_auto_search'|trans }}</label>
            </div>
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="{{ modal_id }}-enableInteractive" checked>
              <label class="form-check-label" for="{{ modal_id }}-enableInteractive">{{ 'media.arr_admin.schema_modal.opt_interactive_search'|trans }}</label>
            </div>
            <div class="d-flex align-items-center gap-2">
              <label class="form-label mb-0 small" for="{{ modal_id }}-priority">{{ 'media.arr_admin.schema_modal.opt_priority'|trans }}</label>
              <input type="number" class="form-control form-control-sm" id="{{ modal_id }}-priority" value="25" style="width:70px;">
            </div>
          </div>
        </div>
        {% endif %}

        {# Dynamic fields generated from the schema #}
        <div id="{{ modal_id }}-fields"></div>

      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'media.arr_admin.schema_modal.cancel'|trans }}</button>
        {% if test_url is defined and test_url %}
        <button type="button" class="btn btn-outline-primary" id="{{ modal_id }}-test" disabled>
          <span class="spinner-border spinner-border-sm d-none me-1" id="{{ modal_id }}-test-spinner"></span>
          {{ 'media.arr_admin.schema_modal.test'|trans }}
        </button>
        {% endif %}
        <button type="button" class="btn btn-primary" id="{{ modal_id }}-save" disabled>
          <span class="spinner-border spinner-border-sm d-none me-1" id="{{ modal_id }}-spinner"></span>
          {{ 'media.arr_admin.schema_modal.save'|trans }}
        </button>
      </div>
    </div>
  </div>
</div>

<script>
(function () {
  var MID        = {{ modal_id|json_encode|raw }};
  var SCHEMA_URL = {{ schema_url|json_encode|raw }};
  var SAVE_ADD   = {{ save_url_add|json_encode|raw }};
  var SAVE_EDIT  = {{ save_url_edit|json_encode|raw }};
  var TEST_URL   = {{ (test_url ?? '')|json_encode|raw }};
  var MODE       = {{ (mode ?? 'default')|json_encode|raw }};
  var TITLE_ADD  = {{ modal_title_add|json_encode|raw }};
  var TITLE_EDIT = {{ modal_title_edit|json_encode|raw }};

  var I18N = {
    path_placeholder: {{ 'media.arr_admin.schema_modal.path_placeholder'|trans|json_encode|raw }},
    csv_help: {{ 'media.arr_admin.schema_modal.csv_help'|trans|json_encode|raw }},
    csv_placeholder: {{ 'media.arr_admin.schema_modal.csv_placeholder'|trans|json_encode|raw }},
    cats_placeholder: {{ 'media.arr_admin.schema_modal.cats_placeholder'|trans|json_encode|raw }},
    trigger: {
      onGrab: {{ 'media.arr_admin.schema_modal.trigger.on_grab'|trans|json_encode|raw }},
      onDownload: {{ 'media.arr_admin.schema_modal.trigger.on_download'|trans|json_encode|raw }},
      onUpgrade: {{ 'media.arr_admin.schema_modal.trigger.on_upgrade'|trans|json_encode|raw }},
      onRename: {{ 'media.arr_admin.schema_modal.trigger.on_rename'|trans|json_encode|raw }},
      onMovieAdded: {{ 'media.arr_admin.schema_modal.trigger.on_movie_added'|trans|json_encode|raw }},
      onMovieDelete: {{ 'media.arr_admin.schema_modal.trigger.on_movie_delete'|trans|json_encode|raw }},
      onMovieFileDelete: {{ 'media.arr_admin.schema_modal.trigger.on_movie_file_delete'|trans|json_encode|raw }},
      onMovieFileDeleteForUpgrade: {{ 'media.arr_admin.schema_modal.trigger.on_movie_file_delete_for_upgrade'|trans|json_encode|raw }},
      onHealthIssue: {{ 'media.arr_admin.schema_modal.trigger.on_health_issue'|trans|json_encode|raw }},
      onHealthRestored: {{ 'media.arr_admin.schema_modal.trigger.on_health_restored'|trans|json_encode|raw }},
      onApplicationUpdate: {{ 'media.arr_admin.schema_modal.trigger.on_application_update'|trans|json_encode|raw }},
      onManualInteractionRequired: {{ 'media.arr_admin.schema_modal.trigger.on_manual_interaction_required'|trans|json_encode|raw }},
      includeHealthWarnings: {{ 'media.arr_admin.schema_modal.trigger.include_health_warnings'|trans|json_encode|raw }}
    },
    newznab: {
      tv: {{ 'media.arr_admin.schema_modal.newznab.tv'|trans|json_encode|raw }},
      films: {{ 'media.arr_admin.schema_modal.newznab.films'|trans|json_encode|raw }},
      audio: {{ 'media.arr_admin.schema_modal.newznab.audio'|trans|json_encode|raw }},
      pc: {{ 'media.arr_admin.schema_modal.newznab.pc'|trans|json_encode|raw }},
      tv_sport: {{ 'media.arr_admin.schema_modal.newznab.tv_sport'|trans|json_encode|raw }},
      xxx: {{ 'media.arr_admin.schema_modal.newznab.xxx'|trans|json_encode|raw }},
      books: {{ 'media.arr_admin.schema_modal.newznab.books'|trans|json_encode|raw }},
      other: {{ 'media.arr_admin.schema_modal.newznab.other'|trans|json_encode|raw }},
      films_foreign: {{ 'media.arr_admin.schema_modal.newznab.films_foreign'|trans|json_encode|raw }},
      films_other: {{ 'media.arr_admin.schema_modal.newznab.films_other'|trans|json_encode|raw }},
      films_sd: {{ 'media.arr_admin.schema_modal.newznab.films_sd'|trans|json_encode|raw }},
      films_hd: {{ 'media.arr_admin.schema_modal.newznab.films_hd'|trans|json_encode|raw }},
      films_uhd: {{ 'media.arr_admin.schema_modal.newznab.films_uhd'|trans|json_encode|raw }},
      films_bluray: {{ 'media.arr_admin.schema_modal.newznab.films_bluray'|trans|json_encode|raw }},
      films_3d: {{ 'media.arr_admin.schema_modal.newznab.films_3d'|trans|json_encode|raw }},
      films_dvd: {{ 'media.arr_admin.schema_modal.newznab.films_dvd'|trans|json_encode|raw }},
      films_webdl: {{ 'media.arr_admin.schema_modal.newznab.films_webdl'|trans|json_encode|raw }},
      anime: {{ 'media.arr_admin.schema_modal.newznab.anime'|trans|json_encode|raw }},
      doc: {{ 'media.arr_admin.schema_modal.newznab.doc'|trans|json_encode|raw }},
      tv_webdl: {{ 'media.arr_admin.schema_modal.newznab.tv_webdl'|trans|json_encode|raw }},
      tv_foreign: {{ 'media.arr_admin.schema_modal.newznab.tv_foreign'|trans|json_encode|raw }},
      tv_sd: {{ 'media.arr_admin.schema_modal.newznab.tv_sd'|trans|json_encode|raw }},
      tv_hd: {{ 'media.arr_admin.schema_modal.newznab.tv_hd'|trans|json_encode|raw }},
      tv_uhd: {{ 'media.arr_admin.schema_modal.newznab.tv_uhd'|trans|json_encode|raw }},
      tv_other: {{ 'media.arr_admin.schema_modal.newznab.tv_other'|trans|json_encode|raw }},
      tv_sport_sub: {{ 'media.arr_admin.schema_modal.newznab.tv_sport_sub'|trans|json_encode|raw }},
      tv_anime: {{ 'media.arr_admin.schema_modal.newznab.tv_anime'|trans|json_encode|raw }},
      tv_doc: {{ 'media.arr_admin.schema_modal.newznab.tv_doc'|trans|json_encode|raw }}
    },
    error_schema_http_tpl: {{ 'media.arr_admin.schema_modal.error_schema_http_tpl'|trans({status: '__STATUS__'})|json_encode|raw }},
    error_schema_none_radarr: {{ 'media.arr_admin.schema_modal.error_schema_none_radarr'|trans|json_encode|raw }},
    error_schema_none_sonarr: {{ 'media.arr_admin.schema_modal.error_schema_none_sonarr'|trans|json_encode|raw }},
    error_schema_generic: {{ 'media.arr_admin.schema_modal.error_schema_generic'|trans|json_encode|raw }},
    error_name_required: {{ 'media.arr_admin.schema_modal.error_name_required'|trans|json_encode|raw }},
    error_impl_missing: {{ 'media.arr_admin.schema_modal.error_impl_missing'|trans|json_encode|raw }},
    error_form_init: {{ 'media.arr_admin.schema_modal.error_form_init'|trans|json_encode|raw }},
    error_save: {{ 'media.arr_admin.schema_modal.error_save'|trans|json_encode|raw }},
    error_network_tpl: {{ 'media.arr_admin.schema_modal.error_network_tpl'|trans({message: '__MSG__'})|json_encode|raw }},
    error_network_test: {{ 'media.arr_admin.schema_modal.error_network_test'|trans|json_encode|raw }},
    test_success: {{ 'media.arr_admin.schema_modal.test_success'|trans|json_encode|raw }},
    test_failure: {{ 'media.arr_admin.schema_modal.test_failure'|trans|json_encode|raw }}
  };

  var modalEl = document.getElementById(MID);
  if (!modalEl) return;

  var schemaCache = null;
  var currentImpl = null;
  var editingItem = null;

  function el(id) { return document.getElementById(MID + '-' + id); }

  // Standard Newznab mapping (Prowlarr/Torznab indexer categories) — translated labels
  var NEWZNAB_CATS = {
    1000: I18N.newznab.tv,
    2000: I18N.newznab.films,
    3000: I18N.newznab.audio,
    4000: I18N.newznab.pc,
    5000: I18N.newznab.tv_sport,
    6000: I18N.newznab.xxx,
    7000: I18N.newznab.books,
    8000: I18N.newznab.other,
    2010: I18N.newznab.films_foreign,
    2020: I18N.newznab.films_other,
    2030: I18N.newznab.films_sd,
    2040: I18N.newznab.films_hd,
    2045: I18N.newznab.films_uhd,
    2050: I18N.newznab.films_bluray,
    2060: I18N.newznab.films_3d,
    2070: I18N.newznab.films_dvd,
    2080: I18N.newznab.films_webdl,
    5070: I18N.newznab.anime,
    5080: I18N.newznab.doc,
    1010: I18N.newznab.tv_webdl,
    1020: I18N.newznab.tv_foreign,
    1030: I18N.newznab.tv_sd,
    1040: I18N.newznab.tv_hd,
    1045: I18N.newznab.tv_uhd,
    1050: I18N.newznab.tv_other,
    1060: I18N.newznab.tv_sport_sub,
    1070: I18N.newznab.tv_anime,
    1080: I18N.newznab.tv_doc
  };

  // ── Render a field ────────────────────────────────────────────────────
  function renderField(field, existingFields) {
    if (field.hidden) return '';
    var id  = MID + '-f-' + field.name;
    var existing = existingFields ? existingFields.find(function(f){ return f.name === field.name; }) : null;
    var val = existing !== undefined && existing !== null ? (existing.value != null ? existing.value : (field.value != null ? field.value : '')) : (field.value != null ? field.value : '');
    var isArray = Array.isArray(val);
    var options = field.selectOptions || [];

    var input = '';
    switch (field.type) {
      case 'checkbox':
        return '<div class="mb-3 d-flex align-items-center gap-2">' +
          '<input class="form-check-input schema-field" type="checkbox" id="' + id + '" data-name="' + field.name + '" data-field-type="checkbox"' + (val ? ' checked' : '') + '>' +
          '<label class="form-check-label" for="' + id + '">' + (field.label != null ? field.label : field.name) + '</label>' +
          (field.helpText ? '<small class="text-muted ms-2">' + field.helpText + '</small>' : '') +
          '</div>';

      case 'select': {
        // Determine effective options: schema options or Newznab mapping
        var effectiveOpts = options;
        if (isArray && options.length > 0) {
          // Check whether the options match the existing values
          var optValues = new Set(options.map(function(o){ return o.value; }));
          var anyMatch = val.some(function(v){ return optValues.has(v); });
          if (!anyMatch && val.some(function(v){ return NEWZNAB_CATS[v]; })) {
            // The schema options don't match → use the Newznab mapping
            effectiveOpts = val.map(function(v){ return {value: v, name: NEWZNAB_CATS[v] || ('#' + v)}; });
          }
        }

        if (isArray && effectiveOpts.length > 0) {
          // Multi-select → aligned checkbox grid
          // If we have known schema options, show them all; otherwise just those checked + common Newznab
          var displayOpts = effectiveOpts;
          if (effectiveOpts === options && options.length > 0) {
            displayOpts = options;
          } else if (val.some(function(v){ return NEWZNAB_CATS[v]; })) {
            // Show all known Newznab categories to allow selection
            var allNewznab = Object.entries(NEWZNAB_CATS)
              .filter(function(entry){ var k = entry[0]; return Math.floor(k/1000) === Math.floor(val[0]/1000) || val.indexOf(Number(k)) !== -1; })
              .map(function(entry){ return {value: Number(entry[0]), name: entry[1]}; })
              .sort(function(a,b){ return a.value - b.value; });
            displayOpts = allNewznab.length > 0 ? allNewznab : effectiveOpts;
          }
          var checks = displayOpts.map(function(o){
            var checked = val.indexOf(o.value) !== -1 ? ' checked' : '';
            return '<div class="form-check" style="min-width:180px;">' +
              '<input class="form-check-input schema-multi" type="checkbox" id="' + id + '-' + o.value + '" data-val="' + o.value + '"' + checked + '>' +
              '<label class="form-check-label" for="' + id + '-' + o.value + '">' + o.name + ' <small class="text-muted">(' + o.value + ')</small></label>' +
              '</div>';
          }).join('');
          input = '<div class="schema-field d-flex flex-wrap gap-1" data-name="' + field.name + '" data-field-type="multicheck" id="' + id + '">' + checks + '</div>';
        } else if (isArray && val.some(function(v){ return NEWZNAB_CATS[v]; })) {
          // Multi-select with no schema options but known Newznab values → Newznab checkboxes
          var mainCat = val.length > 0 ? Math.floor(val[0] / 1000) * 1000 : 2000;
          var allNewznab2 = Object.entries(NEWZNAB_CATS)
            .map(function(entry){ return {value: Number(entry[0]), name: entry[1]}; })
            .filter(function(o){ return Math.floor(o.value / 1000) * 1000 === mainCat || val.indexOf(o.value) !== -1; })
            .sort(function(a,b){ return a.value - b.value; });
          var checks2 = allNewznab2.map(function(o){
            var checked = val.indexOf(o.value) !== -1 ? ' checked' : '';
            return '<div class="form-check" style="min-width:180px;">' +
              '<input class="form-check-input schema-multi" type="checkbox" id="' + id + '-' + o.value + '" data-val="' + o.value + '"' + checked + '>' +
              '<label class="form-check-label" for="' + id + '-' + o.value + '">' + o.name + ' <small class="text-muted">(' + o.value + ')</small></label>' +
              '</div>';
          }).join('');
          input = '<div class="schema-field d-flex flex-wrap gap-1" data-name="' + field.name + '" data-field-type="multicheck" id="' + id + '">' + checks2 + '</div>';
        } else if (isArray) {
          input = '<input class="form-control schema-field" type="text" id="' + id + '" data-name="' + field.name + '" data-field-type="csv" value="' + val.join(', ') + '" placeholder="' + I18N.cats_placeholder + '">';
          if (!field.helpText) field.helpText = I18N.csv_help;
        } else if (options.length > 0) {
          var opts = options.map(function(o){
            return '<option value="' + o.value + '"' + (o.value == val ? ' selected' : '') + '>' + o.name + (o.hint ? ' ' + o.hint : '') + '</option>';
          }).join('');
          input = '<select class="form-select schema-field" id="' + id + '" data-name="' + field.name + '" data-field-type="select">' + opts + '</select>';
        } else {
          input = '<input class="form-control schema-field" type="text" id="' + id + '" data-name="' + field.name + '" data-field-type="text" value="' + (val != null ? val : '') + '">';
        }
        break;
      }

      case 'tag':
      case 'tagSelect':
        if (isArray) val = val.join(', ');
        input = '<input class="form-control schema-field" type="text" id="' + id + '" data-name="' + field.name + '" data-field-type="csv" value="' + (val != null ? val : '') + '" placeholder="' + I18N.csv_placeholder + '">';
        if (!field.helpText) field.helpText = I18N.csv_help;
        break;

      case 'number':
        input = '<input class="form-control schema-field" type="number" id="' + id + '" data-name="' + field.name + '" data-field-type="number" value="' + (isArray ? '' : (val != null ? val : '')) + '">';
        break;

      case 'password':
        input = '<input class="form-control schema-field" type="password" id="' + id + '" data-name="' + field.name + '" data-field-type="password" value="' + (isArray ? '' : (val != null ? val : '')) + '" autocomplete="new-password">';
        break;

      case 'path':
        input = '<input class="form-control schema-field" type="text" id="' + id + '" data-name="' + field.name + '" data-field-type="text" value="' + (isArray ? '' : (val != null ? val : '')) + '" placeholder="' + I18N.path_placeholder + '">';
        break;

      case 'url':
        input = '<input class="form-control schema-field" type="url" id="' + id + '" data-name="' + field.name + '" data-field-type="text" value="' + (isArray ? '' : (val != null ? val : '')) + '" placeholder="https://...">';
        break;

      default:
        input = '<input class="form-control schema-field" type="text" id="' + id + '" data-name="' + field.name + '" data-field-type="text" value="' + (isArray ? val.join(', ') : (val != null ? val : '')) + '">';
    }

    return '<div class="mb-3">' +
      '<label class="form-label" for="' + id + '">' + (field.label != null ? field.label : field.name) + (field.required ? ' <span class="text-danger">*</span>' : '') + '</label>' +
      input +
      (field.helpText ? '<small class="text-muted">' + field.helpText + '</small>' : '') +
      '</div>';
  }

  // ── Populate implementations select ─────────────────────────────────────
  function loadSchema() {
    if (schemaCache) return Promise.resolve(schemaCache);
    return fetch(SCHEMA_URL, {headers: {'X-Requested-With': 'XMLHttpRequest'}})
      .then(function(r){
        if (!r.ok) { showFeedback(I18N.error_schema_http_tpl.replace('__STATUS__', r.status), 'danger'); return []; }
        return r.json();
      })
      .then(function(data){
        schemaCache = Array.isArray(data) ? data : [];
        // Auto-detect Radarr vs Sonarr from the schema URL to show the right message
        if (!schemaCache.length) {
          var isSonarr = SCHEMA_URL.indexOf('{{ app.request.getBasePath() }}/medias/' + INSTANCE_SLUG + '/sonarr/') !== -1;
          showFeedback(isSonarr ? I18N.error_schema_none_sonarr : I18N.error_schema_none_radarr, 'warning');
        }
        return schemaCache;
      })
      .catch(function(err){
        console.error('loadSchema error:', err);
        showFeedback(I18N.error_schema_generic, 'danger');
        return [];
      });
  }

  function populateImplSelect(schemas) {
    var sel = el('impl-select');
    sel.innerHTML = '<option value="">' + {{ 'media.arr_admin.schema_modal.type_placeholder'|trans|json_encode|raw }} + '</option>';
    schemas.forEach(function(s, i){
      var opt = document.createElement('option');
      opt.value = i;
      opt.textContent = s.name || s.implementationName || s.implementation || '?';
      sel.appendChild(opt);
    });
  }

  // Notification trigger labels (translated via I18N)
  var TRIGGER_LABELS = I18N.trigger;

  function renderTriggers(schema, existingItem) {
    var wrap = el('triggers-list');
    if (!wrap) return;
    wrap.innerHTML = '';
    Object.entries(TRIGGER_LABELS).forEach(function(entry){
      var key = entry[0];
      var label = entry[1];
      var supportsKey = 'supports' + key.charAt(0).toUpperCase() + key.slice(1);
      // Show if schema supports it, or always show includeHealthWarnings
      if (key !== 'includeHealthWarnings' && schema[supportsKey] === false) return;
      var checked = existingItem ? (existingItem[key] != null ? existingItem[key] : false) : false;
      var col = document.createElement('div');
      col.className = 'col-6';
      col.innerHTML = '<div class="form-check"><input class="form-check-input notif-trigger" type="checkbox" id="' + MID + '-t-' + key + '" data-trigger="' + key + '"' + (checked ? ' checked' : '') + '>' +
        '<label class="form-check-label small" for="' + MID + '-t-' + key + '">' + label + '</label></div>';
      wrap.appendChild(col);
    });
    el('triggers').classList.remove('d-none');
  }

  function renderFields(schema, existingFields) {
    currentImpl = schema;
    var container = el('fields');
    container.innerHTML = (schema.fields || [])
      .filter(function(f){ return !f.hidden; })
      .map(function(f){ return renderField(f, existingFields); })
      .join('');
    el('save').disabled = false;
    if (el('test')) el('test').disabled = false;
    if (MODE === 'notification') {
      renderTriggers(schema, editingItem);
    } else {
      el('global-opts').classList.remove('d-none');
    }
  }

  // ── Value collection — includes ALL fields (including hidden) ───
  function collectPayload() {
    if (!currentImpl) return null;
    var name = el('name').value.trim();
    if (!name) { showFeedback(I18N.error_name_required, 'warning'); return null; }

    // Collect visible field values from the DOM
    var visibleValues = {};
    document.querySelectorAll('#' + MID + ' .schema-field').forEach(function(input){
      var ft = input.dataset.fieldType;
      if (ft === 'checkbox') {
        visibleValues[input.dataset.name] = input.checked;
      } else if (ft === 'number') {
        visibleValues[input.dataset.name] = input.value !== '' ? Number(input.value) : null;
      } else if (ft === 'csv') {
        var raw = input.value.trim();
        if (!raw) { visibleValues[input.dataset.name] = []; }
        else {
          var parts = raw.split(',').map(function(s){ return s.trim(); }).filter(Boolean);
          visibleValues[input.dataset.name] = parts.every(function(p){ return /^\d+$/.test(p); })
            ? parts.map(Number)
            : parts;
        }
      } else if (ft === 'multicheck') {
        // Multi-select checkboxes → array of checked values
        var checked = [];
        input.querySelectorAll('.schema-multi:checked').forEach(function(cb){
          var v = cb.dataset.val;
          checked.push(/^\d+$/.test(v) ? Number(v) : v);
        });
        visibleValues[input.dataset.name] = checked;
      } else if (ft === 'select') {
        var v = input.value;
        visibleValues[input.dataset.name] = /^\d+$/.test(v) ? Number(v) : v;
      } else {
        visibleValues[input.dataset.name] = input.value;
      }
    });

    // Build the complete fields array (visible + hidden with default values)
    var fields = (currentImpl.fields || []).map(function(f){
      var editField = editingItem && editingItem.fields ? editingItem.fields.find(function(ef){ return ef.name === f.name; }) : null;
      return {
        name: f.name,
        value: f.name in visibleValues ? visibleValues[f.name] : ((editField && editField.value != null) ? editField.value : (f.value != null ? f.value : null))
      };
    });

    // Complete payload with all schema metadata
    var payload = {
      name: name,
      implementation: currentImpl.implementation,
      implementationName: currentImpl.implementationName != null ? currentImpl.implementationName : currentImpl.implementation,
      configContract: currentImpl.configContract,
      tags: editingItem && editingItem.tags ? editingItem.tags : [],
      fields: fields
    };

    if (MODE === 'notification') {
      // Collect triggers from checkboxes
      document.querySelectorAll('#' + MID + ' .notif-trigger').forEach(function(cb){
        payload[cb.dataset.trigger] = cb.checked;
      });
    } else {
      payload.enableRss = el('enableRss').checked;
      payload.enableAutomaticSearch = el('enableAutoSearch').checked;
      payload.enableInteractiveSearch = el('enableInteractive').checked;
      payload.protocol = currentImpl.protocol != null ? currentImpl.protocol : (editingItem && editingItem.protocol ? editingItem.protocol : 'torrent');
      payload.priority = parseInt(el('priority').value) || 25;
    }

    if (editingItem) payload.id = editingItem.id;

    return payload;
  }

  // ── Feedback ────────────────────────────────────────────────────────────
  function showFeedback(msg, type) {
    if (!type) type = 'danger';
    var fb = el('feedback');
    fb.className = 'alert alert-' + type + ' mt-3';
    fb.textContent = msg;
    fb.classList.remove('d-none');
  }

  // ── Initialization via events ────────────────────────────────────────
  modalEl.addEventListener('show.bs.modal', function(e){
    try {
      var _raw = e.relatedTarget && e.relatedTarget.dataset ? e.relatedTarget.dataset.editItem : null;
      editingItem = _raw ? JSON.parse(_raw) : null;
      el('feedback').classList.add('d-none');
      el('save').disabled = true;
      if (el('test')) el('test').disabled = true;

      loadSchema().then(function(schemas){
        if (editingItem) {
          document.getElementById(MID + '-title').textContent = TITLE_EDIT;
          el('impl-wrap').classList.add('d-none');
          el('name').value = editingItem.name != null ? editingItem.name : '';
          if (MODE !== 'notification') {
            el('enableRss').checked = editingItem.enableRss != null ? editingItem.enableRss : true;
            el('enableAutoSearch').checked = editingItem.enableAutomaticSearch != null ? editingItem.enableAutomaticSearch : true;
            el('enableInteractive').checked = editingItem.enableInteractiveSearch != null ? editingItem.enableInteractiveSearch : true;
            el('priority').value = editingItem.priority != null ? editingItem.priority : 25;
          }
          var schema = schemas.find(function(s){ return s.implementation === editingItem.implementation; }) || schemas[0];
          if (schema) renderFields(schema, editingItem.fields || []);
          else showFeedback(I18N.error_impl_missing, 'warning');
        } else {
          document.getElementById(MID + '-title').textContent = TITLE_ADD;
          el('impl-wrap').classList.remove('d-none');
          el('name').value = '';
          el('fields').innerHTML = '';
          if (MODE === 'notification') {
            if (el('triggers')) el('triggers').classList.add('d-none');
          } else {
            el('global-opts').classList.add('d-none');
            el('enableRss').checked = true;
            el('enableAutoSearch').checked = true;
            el('enableInteractive').checked = true;
            el('priority').value = 25;
          }
          populateImplSelect(schemas);
        }
      });
    } catch (err) {
      console.error('show.bs.modal error:', err);
      showFeedback(I18N.error_form_init, 'danger');
    }
  });

  // Implementation change → re-render the fields
  modalEl.addEventListener('change', function(e){
    if (e.target.id !== MID + '-impl-select') return;
    var idx = parseInt(e.target.value);
    if (isNaN(idx)) { el('fields').innerHTML = ''; el('save').disabled = true; return; }
    loadSchema().then(function(schemas){ renderFields(schemas[idx], null); });
  });

  // Save
  el('save').onclick = function(){
    var payload = collectPayload();
    if (!payload) return;

    var spinner = el('spinner');
    el('save').disabled = true;
    spinner.classList.remove('d-none');

    var url = editingItem
      ? SAVE_EDIT.replace('__ID__', editingItem.id)
      : SAVE_ADD;

    fetch(url, {
      method: 'POST',
      headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
      body: JSON.stringify(payload)
    }).then(function(r){ return r.json(); }).then(function(data){
      if (data.ok) {
        // Success: reload the page immediately
        location.reload();
      } else {
        showFeedback(data.error || I18N.error_save, 'danger');
        el('save').disabled = false;
      }
      spinner.classList.add('d-none');
    }).catch(function(err){
      console.error('Save error:', err);
      showFeedback(I18N.error_network_tpl.replace('__MSG__', (err.message || err)), 'danger');
      el('save').disabled = false;
      spinner.classList.add('d-none');
    });
  };

  // Tester (si test_url fourni)
  if (TEST_URL && el('test')) {
    el('test').onclick = function(){
      var payload = collectPayload();
      if (!payload) return;

      var testBtn = el('test');
      var spinner = el('test-spinner');
      testBtn.disabled = true;
      spinner.classList.remove('d-none');

      // Pour un item existant, on teste via son ID ; sinon on envoie le payload complet
      var url = editingItem
        ? TEST_URL.replace('__ID__', editingItem.id)
        : TEST_URL.replace('__ID__', '0');

      fetch(url, {
        method: 'POST',
        headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
        body: JSON.stringify(payload)
      }).then(function(r){ return r.json(); }).then(function(data){
        showFeedback(data.ok ? I18N.test_success : (data.error || I18N.test_failure), data.ok ? 'success' : 'danger');
        testBtn.disabled = false;
        spinner.classList.add('d-none');
      }).catch(function(){
        showFeedback(I18N.error_network_test, 'danger');
        testBtn.disabled = false;
        spinner.classList.add('d-none');
      });
    };
  }
})();
</script>
