{% extends 'base.html.twig' %}

{% block title %}{{ 'media.arr_admin.exclusions.title_radarr'|trans }}{% endblock %}

{% block body %}
<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <h2 class="page-title">{{ 'media.arr_admin.exclusions.page_title'|trans }}</h2>
      </div>
      <div class="col-auto ms-auto">
        {% include 'media/_radarr_nav.html.twig' %}
      </div>
    </div>
  </div>
</div>

<div class="page-body">
<div class="container-xl">

{% if error %}
<div class="alert alert-danger">{{ 'media.arr_admin.exclusions.error_unreachable_radarr'|trans }}</div>
{% endif %}

<div id="excl-feedback" class="alert d-none mb-3"></div>

{# Form ajout #}
<div class="card mb-3">
  <div class="card-header">
    <h3 class="card-title">{{ 'media.arr_admin.exclusions.add_card_title'|trans }}</h3>
  </div>
  <div class="card-body">
    <form id="form-add-exclusion" class="row g-2 align-items-end">
      <div class="col-sm-3">
        <label class="form-label">{{ 'media.arr_admin.exclusions.tmdb_id'|trans }}</label>
        <input type="number" name="tmdbId" class="form-control" placeholder="{{ 'media.arr_admin.exclusions.tmdb_id_placeholder'|trans }}" required>
      </div>
      <div class="col-sm-5">
        <label class="form-label">{{ 'media.arr_admin.exclusions.movie_title'|trans }}</label>
        <input type="text" name="movieTitle" class="form-control" placeholder="{{ 'media.arr_admin.exclusions.movie_title_placeholder'|trans }}" required>
      </div>
      <div class="col-sm-2">
        <label class="form-label">{{ 'media.arr_admin.exclusions.year'|trans }}</label>
        <input type="number" name="year" class="form-control" placeholder="{{ "now"|date('Y') }}" min="1900" max="2099">
      </div>
      <div class="col-sm-2">
        <button type="submit" class="btn btn-success w-100">{{ 'media.arr_admin.exclusions.add_button'|trans }}</button>
      </div>
    </form>
  </div>
</div>

{# Table #}
<div class="card">
  <div class="card-header">
    <h3 class="card-title">{{ 'media.arr_admin.exclusions.list_card_title'|trans }}</h3>
    <div class="card-options gap-2">
      <button id="btn-bulk-delete" class="btn btn-ghost-danger btn-sm d-none">
        {{ 'media.arr_admin.exclusions.bulk_delete'|trans }}
      </button>
      <span class="badge bg-secondary-lt">{{ (exclusions.totalRecords ?? exclusions|length) }} {{ 'media.arr_admin.exclusions.total_suffix'|trans }}</span>
    </div>
  </div>
  <div class="card-body p-0">
    {% set records = exclusions.records ?? exclusions %}
    {% if records is empty %}
      <div class="text-muted text-center py-5">{{ 'media.arr_admin.exclusions.empty'|trans }}</div>
    {% else %}
      <div class="table-responsive">
        <table class="table table-vcenter table-hover mb-0">
          <thead>
            <tr>
              <th><input type="checkbox" id="check-all" class="form-check-input"></th>
              <th>{{ 'media.arr_admin.exclusions.col_title'|trans }}</th>
              <th>{{ 'media.arr_admin.exclusions.col_year'|trans }}</th>
              <th>{{ 'media.arr_admin.exclusions.col_tmdb'|trans }}</th>
              <th class="text-end">{{ 'media.arr_admin.exclusions.col_actions'|trans }}</th>
            </tr>
          </thead>
          <tbody>
            {% for ex in records %}
            <tr>
              <td><input type="checkbox" class="form-check-input check-row" value="{{ ex.id }}"></td>
              <td class="fw-medium">{{ ex.movieTitle ?? '—' }}</td>
              <td class="text-muted">{{ ex.year ?? '—' }}</td>
              <td class="text-muted small">{{ ex.tmdbId ?? '—' }}</td>
              <td class="text-end">
                <button class="btn btn-ghost-danger btn-sm btn-excl-delete" data-id="{{ ex.id }}">
                  {{ 'media.arr_admin.exclusions.btn_delete'|trans }}
                </button>
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endif %}
  </div>
  {% if exclusions.totalPages is defined and exclusions.totalPages > 1 %}
  <div class="card-footer d-flex align-items-center">
    <p class="m-0 text-muted">{{ 'media.arr_admin.exclusions.page_label_tpl'|trans({page: page, total: exclusions.totalPages}) }}</p>
    <ul class="pagination m-0 ms-auto">
      {% if page > 1 %}
      <li class="page-item"><a class="page-link" href="?page={{ page - 1 }}">«</a></li>
      {% endif %}
      {% if page < exclusions.totalPages %}
      <li class="page-item"><a class="page-link" href="?page={{ page + 1 }}">»</a></li>
      {% endif %}
    </ul>
  </div>
  {% endif %}
</div>

</div>
</div>
{% endblock %}

{% block javascripts %}
<script>
(function(){
var _I18N = {
  bulk_confirm_tpl: {{ 'media.arr_admin.exclusions.bulk_confirm_tpl'|trans({count: '__COUNT__'})|json_encode|raw }},
  delete_confirm: {{ 'media.arr_admin.exclusions.delete_confirm'|trans|json_encode|raw }},
  delete_error: {{ 'media.arr_admin.exclusions.delete_error'|trans|json_encode|raw }},
  generic_error: {{ 'media.arr_admin.exclusions.generic_error'|trans|json_encode|raw }},
  added_ok: {{ 'media.arr_admin.exclusions.added_ok'|trans|json_encode|raw }},
  add_error: {{ 'media.arr_admin.exclusions.add_error'|trans|json_encode|raw }}
};
var feedback = document.getElementById('excl-feedback');
function showFeedback(msg, type) {
  type = type || 'success';
  feedback.className = 'alert alert-' + type + ' mb-3';
  feedback.textContent = msg;
  feedback.classList.remove('d-none');
  setTimeout(function() { feedback.classList.add('d-none'); }, 4000);
}

// Check all
var checkAll = document.getElementById('check-all');
if (checkAll) {
  checkAll.addEventListener('change', function() {
    document.querySelectorAll('.check-row').forEach(function(c) { c.checked = checkAll.checked; });
    updateBulkBtn();
  });
  document.querySelectorAll('.check-row').forEach(function(c) { c.addEventListener('change', updateBulkBtn); });
}

function updateBulkBtn() {
  var checked = document.querySelectorAll('.check-row:checked');
  var btn = document.getElementById('btn-bulk-delete');
  if (btn) btn.classList.toggle('d-none', checked.length === 0);
}

// Bulk delete
var bulkBtn = document.getElementById('btn-bulk-delete');
if (bulkBtn) {
  bulkBtn.addEventListener('click', function() {
    var ids = Array.prototype.slice.call(document.querySelectorAll('.check-row:checked')).map(function(c) { return parseInt(c.value); });
    if (!confirm(_I18N.bulk_confirm_tpl.replace('__COUNT__', ids.length))) return;
    fetch('{{ instance_path('radarr_exclusion_bulk_delete') }}', {
      method: 'POST',
      headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
      body: JSON.stringify({ids: ids}),
    }).then(function(r) { return r.json(); }).then(function(data) {
      if (data.ok) location.reload();
      else showFeedback(_I18N.delete_error, 'danger');
    });
  });
}

// Supprimer ligne
document.querySelectorAll('.btn-excl-delete').forEach(function(btn) {
  btn.addEventListener('click', function() {
    if (!confirm(_I18N.delete_confirm)) return;
    fetch('{{ app.request.getBasePath() }}/medias/' + INSTANCE_SLUG + '/radarr/exclusions/' + btn.dataset.id + '/supprimer', {
      method: 'POST',
      headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
      body: '{}',
    }).then(function(r) { return r.json(); }).then(function(data) {
      if (data.ok) location.reload();
      else showFeedback(_I18N.generic_error, 'danger');
    });
  });
});

// Form ajout
document.getElementById('form-add-exclusion').addEventListener('submit', function(e) {
  e.preventDefault();
  var fd = new FormData(e.target);
  var body = {
    tmdbId: parseInt(fd.get('tmdbId')),
    movieTitle: fd.get('movieTitle'),
    year: parseInt(fd.get('year') || 0),
  };
  var formEl = e.target;
  fetch('{{ instance_path('radarr_exclusion_add') }}', {
    method: 'POST',
    headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
    body: JSON.stringify(body),
  }).then(function(r) { return r.json(); }).then(function(data) {
    if (data.ok) {
      showFeedback(_I18N.added_ok);
      formEl.reset();
      setTimeout(function() { location.reload(); }, 1000);
    } else {
      showFeedback(_I18N.add_error, 'danger');
    }
  });
});
})();
</script>
{% endblock %}
