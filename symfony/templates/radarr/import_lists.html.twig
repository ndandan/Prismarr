{% extends 'base.html.twig' %}

{% block title %}{{ 'media.arr_admin.import_lists.title_radarr'|trans }}{% endblock %}

{% block body %}
<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <h2 class="page-title">{{ 'media.arr_admin.import_lists.page_title'|trans }}</h2>
      </div>
      <div class="col-auto ms-auto d-flex gap-2 align-items-center">
        <button class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#modal-il">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14m-7-7h14"/></svg>
          {{ 'media.arr_admin.import_lists.add'|trans }}
        </button>
        <a href="{{ instance_path('radarr_suggestions') }}" class="btn btn-ghost-primary btn-sm">{{ 'media.arr_admin.import_lists.suggestions'|trans }}</a>
        {% include 'media/_radarr_nav.html.twig' %}
      </div>
    </div>
  </div>
</div>

<div class="page-body">
<div class="container-xl">

{% if error %}
<div class="alert alert-danger">{{ 'media.arr_admin.import_lists.error_unreachable_radarr'|trans }}</div>
{% endif %}

<div id="il-feedback" class="alert d-none mb-3"></div>

<div class="card">
  <div class="card-header">
    <h3 class="card-title">{{ 'media.arr_admin.import_lists.card_title'|trans }}</h3>
    <div class="card-options">
      <span class="badge bg-secondary-lt">{{ lists|length }}</span>
    </div>
  </div>
  <div class="card-body p-0">
    {% if lists is empty %}
      <div class="text-muted text-center py-5">{{ 'media.arr_admin.import_lists.empty'|trans }}</div>
    {% else %}
      <div class="table-responsive">
        <table class="table table-vcenter mb-0">
          <thead>
            <tr>
              <th>{{ 'media.arr_admin.import_lists.col_name'|trans }}</th>
              <th>{{ 'media.arr_admin.import_lists.col_type'|trans }}</th>
              <th>{{ 'media.arr_admin.import_lists.col_enabled'|trans }}</th>
              <th>{{ 'media.arr_admin.import_lists.col_quality_profile'|trans }}</th>
              <th>{{ 'media.arr_admin.import_lists.col_root_folder'|trans }}</th>
              <th class="text-end">{{ 'media.arr_admin.import_lists.col_actions'|trans }}</th>
            </tr>
          </thead>
          <tbody>
            {% for list in lists %}
            <tr data-list="{{ list|json_encode|e('html_attr') }}">
              <td class="fw-medium">{{ list.name ?? '—' }}</td>
              <td><span class="badge bg-secondary-lt">{{ list.implementationName ?? list.implementation ?? '—' }}</span></td>
              <td>
                {% if list.enable ?? list.enabled ?? false %}
                  <span class="badge bg-success-lt text-success">{{ 'media.arr_admin.import_lists.yes'|trans }}</span>
                {% else %}
                  <span class="badge bg-secondary-lt">{{ 'media.arr_admin.import_lists.no'|trans }}</span>
                {% endif %}
              </td>
              <td class="text-muted small">{{ list.qualityProfileId ?? '—' }}</td>
              <td class="text-muted small">{{ list.rootFolderPath ?? '—' }}</td>
              <td class="text-end d-flex gap-2 justify-content-end">
                <button class="btn btn-ghost-secondary btn-icon" data-bs-toggle="modal" data-bs-target="#modal-il" data-edit-item="{{ list|json_encode|e('html_attr') }}" title="{{ 'media.arr_admin.import_lists.edit'|trans }}">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                </button>
                <button class="btn btn-ghost-danger btn-icon btn-il-delete" data-id="{{ list.id }}" data-name="{{ list.name ?? '' }}" title="{{ 'media.arr_admin.import_lists.delete'|trans }}">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                </button>
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endif %}
  </div>
</div>

</div>
</div>

{% include 'radarr/_schema_modal.html.twig' with {
  modal_id: 'modal-il',
  modal_title_add: 'media.arr_admin.import_lists.modal_title_add'|trans,
  modal_title_edit: 'media.arr_admin.import_lists.modal_title_edit'|trans,
  schema_url: instance_path('radarr_import_list_schema'),
  save_url_add: instance_path('radarr_import_list_add'),
  save_url_edit: app.request.getBasePath() ~ '/medias/' ~ current_slug('radarr') ~ '/radarr/listes-import/__ID__/modifier'
} %}
{% endblock %}

{% block javascripts %}
<script>
(function() {
  var I18N = {
    error_delete: {{ 'media.arr_admin.import_lists.error_delete'|trans|json_encode|raw }},
    confirm_delete_tpl: {{ 'media.arr_admin.import_lists.confirm_delete_tpl'|trans({name: '__NAME__'})|json_encode|raw }}
  };

  var feedback = document.getElementById('il-feedback');
  function showFeedback(msg, type) {
    type = type || 'success';
    feedback.className = 'alert alert-' + type + ' mb-3';
    feedback.textContent = msg;
    feedback.classList.remove('d-none');
    setTimeout(function() { feedback.classList.add('d-none'); }, 4000);
  }

  document.querySelectorAll('.btn-il-delete').forEach(function(btn) {
    btn.addEventListener('click', function() {
      if (!confirm(I18N.confirm_delete_tpl.replace('__NAME__', btn.dataset.name))) return;
      fetch('{{ app.request.getBasePath() }}/medias/' + INSTANCE_SLUG + '/radarr/listes-import/' + btn.dataset.id + '/supprimer', {
        method: 'POST', headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'}, body: '{}',
      }).then(function(r) { return r.json(); }).then(function(data) {
        if (data.ok) location.reload();
        else showFeedback(data.error || I18N.error_delete, 'danger');
      });
    });
  });
})();
</script>
{% endblock %}
