{% extends 'base.html.twig' %}

{% block title %}{{ 'media.arr_admin.backups.title_radarr'|trans }}{% endblock %}

{% block body %}
<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <h2 class="page-title">{{ 'media.arr_admin.backups.page_title'|trans }}</h2>
      </div>
      <div class="col-auto ms-auto d-flex gap-2 align-items-center">
        <button id="btn-create-backup" class="btn btn-primary btn-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><path d="M12 5v14m-7-7l7 7l7-7"/></svg>
          {{ 'media.arr_admin.backups.create'|trans }}
        </button>
        {% include 'media/_radarr_nav.html.twig' %}
      </div>
    </div>
  </div>
</div>

<div class="page-body">
<div class="container-xl">

{% if error %}
<div class="alert alert-danger">{{ 'media.arr_admin.backups.error_unreachable_radarr'|trans }}</div>
{% endif %}

<div id="backup-progress" class="alert alert-info d-none mb-3">
  <div class="d-flex align-items-center gap-2">
    <div class="spinner-border spinner-border-sm"></div>
    <span id="backup-msg">{{ 'media.arr_admin.backups.backup_in_progress'|trans }}</span>
  </div>
</div>

<div class="alert alert-warning d-none" id="restore-alert">
  <span id="restore-msg"></span>
</div>

<div class="card">
  <div class="card-header">
    <h3 class="card-title">{{ 'media.arr_admin.backups.card_title'|trans }}</h3>
    <div class="card-options">
      <span class="badge bg-secondary-lt">{{ 'media.arr_admin.backups.count_tpl'|trans({count: backups|length}) }}</span>
    </div>
  </div>
  <div class="card-body p-0">
    {% if backups is empty %}
      <div class="text-muted text-center py-5">{{ 'media.arr_admin.backups.empty'|trans }}</div>
    {% else %}
      <div class="table-responsive">
        <table class="table table-vcenter table-hover mb-0">
          <thead>
            <tr>
              <th>{{ 'media.arr_admin.backups.col_name'|trans }}</th>
              <th>{{ 'media.arr_admin.backups.col_type'|trans }}</th>
              <th>{{ 'media.arr_admin.backups.col_size'|trans }}</th>
              <th>{{ 'media.arr_admin.backups.col_date'|trans }}</th>
              <th class="text-end">{{ 'media.arr_admin.backups.col_actions'|trans }}</th>
            </tr>
          </thead>
          <tbody>
            {% for backup in backups %}
            <tr>
              <td class="fw-medium small">{{ backup.name ?? '—' }}</td>
              <td>
                {% if (backup.type ?? '') == 'scheduled' %}
                  <span class="badge bg-blue-lt">{{ 'media.arr_admin.backups.type_scheduled'|trans }}</span>
                {% else %}
                  <span class="badge bg-secondary-lt">{{ 'media.arr_admin.backups.type_manual'|trans }}</span>
                {% endif %}
              </td>
              <td class="text-muted small">
                {{ backup.size is defined ? backup.size|prismarr_bytes : '—' }}
              </td>
              <td class="text-muted small">
                {{ backup.time is defined ? backup.time|date('d/m/Y H:i') : '—' }}
              </td>
              <td class="text-end">
                <button class="btn btn-ghost-primary btn-sm btn-restore"
                        data-bs-toggle="modal" data-bs-target="#modal-restore"
                        data-id="{{ backup.id }}"
                        data-name="{{ backup.name ?? '' }}">
                  {{ 'media.arr_admin.backups.restore'|trans }}
                </button>
                <button class="btn btn-ghost-danger btn-sm btn-backup-delete"
                        data-id="{{ backup.id }}">
                  {{ 'media.arr_admin.backups.delete'|trans }}
                </button>
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endif %}
  </div>
</div>

{# Restore confirmation modal #}
<div class="modal modal-blur fade" id="modal-restore" tabindex="-1">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">{{ 'media.arr_admin.backups.modal_title'|trans }}</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p>{{ 'media.arr_admin.backups.modal_question_prefix'|trans }}<strong id="restore-name"></strong>{{ 'media.arr_admin.backups.modal_question_suffix'|trans }}</p>
        <p class="text-muted small">{{ 'media.arr_admin.backups.restart_warning_radarr'|trans }}</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-ghost-secondary" data-bs-dismiss="modal">{{ 'media.arr_admin.backups.cancel'|trans }}</button>
        <button type="button" class="btn btn-warning" id="confirm-restore">{{ 'media.arr_admin.backups.restore'|trans }}</button>
      </div>
    </div>
  </div>
</div>

</div>
</div>
{% endblock %}

{% block javascripts %}
<script>
(function(){
var I18N = {
  starting: {{ 'media.arr_admin.backups.backup_starting'|trans|json_encode|raw }},
  statusTpl: {{ 'media.arr_admin.backups.backup_status_tpl'|trans({status: '__STATUS__'})|json_encode|raw }},
  done: {{ 'media.arr_admin.backups.backup_done'|trans|json_encode|raw }},
  failed: {{ 'media.arr_admin.backups.backup_failed'|trans|json_encode|raw }},
  errorGeneric: {{ 'media.arr_admin.backups.backup_error'|trans|json_encode|raw }},
  errorNetwork: {{ 'media.arr_admin.backups.error_network'|trans|json_encode|raw }},
  confirmDelete: {{ 'media.arr_admin.backups.confirm_delete'|trans|json_encode|raw }},
  errorDelete: {{ 'media.arr_admin.backups.error_delete'|trans|json_encode|raw }},
  restoreInProgress: {{ 'media.arr_admin.backups.restore_in_progress'|trans|json_encode|raw }},
  restoreStarted: {{ 'media.arr_admin.backups.restore_started_radarr'|trans|json_encode|raw }},
  restoreError: {{ 'media.arr_admin.backups.restore_error'|trans|json_encode|raw }}
};
var pendingRestoreId = null;

// Create a backup
var btnCreate = document.getElementById('btn-create-backup');
if (btnCreate) {
  btnCreate.onclick = function() {
    var progress = document.getElementById('backup-progress');
    var msg = document.getElementById('backup-msg');
    btnCreate.disabled = true;
    progress.classList.remove('d-none');
    msg.textContent = I18N.starting;

    fetch('{{ instance_path('radarr_backup_create') }}', {
      method: 'POST',
      headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
      body: '{}'
    }).then(function(r){ return r.json(); }).then(function(data){
      if (!data.ok) { msg.textContent = I18N.errorGeneric; return; }

      var cmdId = data.cmdId;
      var poll = setInterval(function() {
        fetch('{{ instance_path('radarr_command_status', {cmdId: '__ID__'}) }}'.replace('__ID__', cmdId)).then(function(sr){ return sr.json(); }).then(function(s){
          msg.textContent = I18N.statusTpl.replace('__STATUS__', (s.status != null ? s.status : '?'));
          if (s.status === 'completed' || s.status === 'failed') {
            clearInterval(poll);
            if (window._prismarrRadarrBackupsTimer === poll) window._prismarrRadarrBackupsTimer = null;
            if (s.status === 'completed') {
              msg.textContent = I18N.done;
              setTimeout(function(){ location.reload(); }, 2000);
            } else {
              msg.textContent = I18N.failed;
            }
          }
        }).catch(function(){ /* silencieux */ });
      }, 3000);
      window._prismarrRadarrBackupsTimer = poll;
    }).catch(function(){
      msg.textContent = I18N.errorNetwork;
    });
  };
}

// Supprimer
document.querySelectorAll('.btn-backup-delete').forEach(function(btn) {
  btn.onclick = function() {
    if (!confirm(I18N.confirmDelete)) return;
    var id = btn.dataset.id;
    fetch('{{ app.request.getBasePath() }}/medias/' + INSTANCE_SLUG + '/radarr/sauvegardes/' + id + '/supprimer', {
      method: 'POST',
      headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
      body: '{}'
    }).then(function(r){ return r.json(); }).then(function(data){
      if (data.ok) location.reload();
      else alert(I18N.errorDelete);
    }).catch(function(){
      alert(I18N.errorDelete);
    });
  };
});

// Restore — listen to show.bs.modal to retrieve the data
var modalRestore = document.getElementById('modal-restore');
function onRestoreModalShow(e) {
  var btn = e.relatedTarget;
  if (btn) {
    pendingRestoreId = btn.dataset.id;
    document.getElementById('restore-name').textContent = btn.dataset.name;
  }
}
if (modalRestore) {
  modalRestore.addEventListener('show.bs.modal', onRestoreModalShow);
}

var btnConfirmRestore = document.getElementById('confirm-restore');
if (btnConfirmRestore) {
  btnConfirmRestore.onclick = function() {
    var alertEl = document.getElementById('restore-alert');
    var msg = document.getElementById('restore-msg');
    alertEl.classList.remove('d-none');
    msg.textContent = I18N.restoreInProgress;

    fetch('{{ app.request.getBasePath() }}/medias/' + INSTANCE_SLUG + '/radarr/sauvegardes/' + pendingRestoreId + '/restaurer', {
      method: 'POST',
      headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
      body: '{}'
    }).then(function(r){ return r.json(); }).then(function(data){
      if (data.ok) {
        msg.textContent = I18N.restoreStarted;
        alertEl.classList.remove('alert-warning');
        alertEl.classList.add('alert-success');
      } else {
        msg.textContent = I18N.restoreError;
        alertEl.classList.remove('alert-warning');
        alertEl.classList.add('alert-danger');
      }
    }).catch(function(){
      msg.textContent = I18N.restoreError;
      alertEl.classList.remove('alert-warning');
      alertEl.classList.add('alert-danger');
    });
  };
}

document.addEventListener('turbo:before-render', function cleanup() {
  if (window._prismarrRadarrBackupsTimer) {
    clearInterval(window._prismarrRadarrBackupsTimer);
    window._prismarrRadarrBackupsTimer = null;
  }
  if (modalRestore) {
    modalRestore.removeEventListener('show.bs.modal', onRestoreModalShow);
  }
  document.removeEventListener('turbo:before-render', cleanup);
});
})();
</script>
{% endblock %}
