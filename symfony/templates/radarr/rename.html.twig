{% extends 'base.html.twig' %}

{% block title %}{{ 'media.arr_admin.rename.title_radarr'|trans }}{% endblock %}

{% block body %}
<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <h2 class="page-title">{{ 'media.arr_admin.rename.page_title'|trans }}</h2>
      </div>
      <div class="col-auto ms-auto">
        {% include 'media/_radarr_nav.html.twig' %}
      </div>
    </div>
  </div>
</div>

<div class="page-body">
<div class="container-xl">

{% if error %}
<div class="alert alert-danger">{{ 'media.arr_admin.rename.error_unreachable_radarr'|trans }}</div>
{% endif %}

<div class="row g-3">
  <div class="col-12 col-md-4">
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">{{ 'media.arr_admin.rename.choose_movie_card_title'|trans }}</h3>
      </div>
      <div class="card-body">
        <select class="form-select" id="movie-select">
          <option value="">{{ 'media.arr_admin.rename.select_placeholder'|trans }}</option>
          {% for movie in movies %}
          <option value="{{ movie.id }}">{{ movie.title }}{% if movie.year %} ({{ movie.year }}){% endif %}</option>
          {% endfor %}
        </select>
        <div id="proposals-loading" class="text-center mt-3 d-none">
          <div class="spinner-border spinner-border-sm"></div>
          <span class="ms-2 text-muted small">{{ 'media.arr_admin.rename.loading'|trans }}</span>
        </div>
      </div>
    </div>
  </div>

  <div class="col-12 col-md-8">
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">{{ 'media.arr_admin.rename.proposals_card_title'|trans }}</h3>
        <div class="card-options">
          <button id="btn-rename-all" class="btn btn-warning btn-sm d-none">
            {{ 'media.arr_admin.rename.btn_rename_all'|trans }}
          </button>
        </div>
      </div>
      <div class="card-body" id="proposals-container">
        <div class="text-muted text-center py-5">{{ 'media.arr_admin.rename.select_movie_hint'|trans }}</div>
      </div>
    </div>
  </div>
</div>

<div id="rename-progress" class="alert alert-info d-none mt-3">
  <div class="d-flex align-items-center gap-2">
    <div class="spinner-border spinner-border-sm"></div>
    <span id="rename-msg">{{ 'media.arr_admin.rename.progress_starting'|trans }}</span>
  </div>
</div>

</div>
</div>
{% endblock %}

{% block javascripts %}
<script>
(function(){
var _I18N = {
  select_movie_hint: {{ 'media.arr_admin.rename.select_movie_hint'|trans|json_encode|raw }},
  no_rename_needed: {{ 'media.arr_admin.rename.no_rename_needed'|trans|json_encode|raw }},
  col_current_path: {{ 'media.arr_admin.rename.col_current_path'|trans|json_encode|raw }},
  col_new_path: {{ 'media.arr_admin.rename.col_new_path'|trans|json_encode|raw }},
  load_error: {{ 'media.arr_admin.rename.load_error'|trans|json_encode|raw }},
  progress_starting: {{ 'media.arr_admin.rename.progress_starting'|trans|json_encode|raw }},
  progress_status_tpl: {{ 'media.arr_admin.rename.progress_status_tpl'|trans({status: '__STATUS__'})|json_encode|raw }},
  progress_done: {{ 'media.arr_admin.rename.progress_done'|trans|json_encode|raw }},
  generic_error: {{ 'media.arr_admin.rename.generic_error'|trans|json_encode|raw }},
  network_error: {{ 'media.arr_admin.rename.network_error'|trans|json_encode|raw }}
};
var currentMovieId = null;

function escapeHtml(str) {
  return String(str).replace(/[&<>"']/g, function(c){
    return c === '&' ? '&amp;' : c === '<' ? '&lt;' : c === '>' ? '&gt;' : c === '"' ? '&quot;' : '&#39;';
  });
}

var movieSelect = document.getElementById('movie-select');
if (movieSelect) {
  movieSelect.onchange = function(e) {
    var id = e.target.value;
    if (!id) {
      document.getElementById('proposals-container').innerHTML = '<div class="text-muted text-center py-5">' + _I18N.select_movie_hint + '</div>';
      document.getElementById('btn-rename-all').classList.add('d-none');
      currentMovieId = null;
      return;
    }
    currentMovieId = parseInt(id);
    document.getElementById('proposals-loading').classList.remove('d-none');
    document.getElementById('btn-rename-all').classList.add('d-none');

    fetch('{{ app.request.getBasePath() }}/medias/' + INSTANCE_SLUG + '/radarr/renommer/' + id + '/propositions', {
      headers: {'X-Requested-With': 'XMLHttpRequest'}
    }).then(function(r){ return r.json(); }).then(function(proposals){
      document.getElementById('proposals-loading').classList.add('d-none');

      if (!proposals || proposals.length === 0) {
        document.getElementById('proposals-container').innerHTML = '<div class="text-muted text-center py-5">' + _I18N.no_rename_needed + '</div>';
        return;
      }

      document.getElementById('btn-rename-all').classList.remove('d-none');
      var html = '<div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>' + _I18N.col_current_path + '</th><th>' + _I18N.col_new_path + '</th></tr></thead><tbody>';
      proposals.forEach(function(p) {
        var current = p.existingPath != null ? p.existingPath : '—';
        var newPath = p.newPath != null ? p.newPath : '—';
        var changed = current !== newPath;
        html += '<tr class="' + (changed ? '' : 'text-muted') + '">'
          + '<td class="small text-muted" style="word-break:break-all;max-width:300px">' + escapeHtml(current) + '</td>'
          + '<td class="small fw-medium" style="word-break:break-all;max-width:300px">' + escapeHtml(newPath) + '</td>'
          + '</tr>';
      });
      html += '</tbody></table></div>';
      document.getElementById('proposals-container').innerHTML = html;
    }).catch(function(){
      document.getElementById('proposals-loading').classList.add('d-none');
      document.getElementById('proposals-container').innerHTML = '<div class="alert alert-danger">' + _I18N.load_error + '</div>';
    });
  };
}

var btnRenameAll = document.getElementById('btn-rename-all');
if (btnRenameAll) {
  btnRenameAll.onclick = function() {
    if (!currentMovieId) return;
    btnRenameAll.disabled = true;
    var progress = document.getElementById('rename-progress');
    var msg = document.getElementById('rename-msg');
    progress.classList.remove('d-none');
    msg.textContent = _I18N.progress_starting;

    fetch('{{ app.request.getBasePath() }}/medias/' + INSTANCE_SLUG + '/radarr/renommer/' + currentMovieId + '/executer', {
      method: 'POST',
      headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
      body: '{}'
    }).then(function(r){ return r.json(); }).then(function(data){
      if (!data.ok || !data.cmdId) { msg.textContent = _I18N.generic_error; return; }

      var poll = setInterval(function() {
        fetch('{{ instance_path('radarr_command_status', {cmdId: '__ID__'}) }}'.replace('__ID__', data.cmdId)).then(function(sr){ return sr.json(); }).then(function(s){
          msg.textContent = _I18N.progress_status_tpl.replace('__STATUS__', (s.status != null ? s.status : '?'));
          if (s.status === 'completed' || s.status === 'failed') {
            clearInterval(poll);
            if (window._prismarrRadarrRenameTimer === poll) window._prismarrRadarrRenameTimer = null;
            btnRenameAll.disabled = false;
            if (s.status === 'completed') msg.textContent = _I18N.progress_done;
          }
        }).catch(function(){ /* silencieux */ });
      }, 3000);
      window._prismarrRadarrRenameTimer = poll;
    }).catch(function(){
      msg.textContent = _I18N.network_error;
    });
  };
}

document.addEventListener('turbo:before-render', function cleanup() {
  if (window._prismarrRadarrRenameTimer) {
    clearInterval(window._prismarrRadarrRenameTimer);
    window._prismarrRadarrRenameTimer = null;
  }
  document.removeEventListener('turbo:before-render', cleanup);
});
})();
</script>
{% endblock %}
