{% extends 'base.html.twig' %}

{% block title %}{{ 'media.arr_admin.download_clients.title_radarr'|trans }}{% endblock %}

{% block body %}
<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <h2 class="page-title">{{ 'media.arr_admin.download_clients.page_title'|trans }}</h2>
      </div>
      <div class="col-auto ms-auto d-flex gap-2 align-items-center">
        <button class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#modal-dc">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14m-7-7h14"/></svg>
          {{ 'media.arr_admin.download_clients.add'|trans }}
        </button>
        {% include 'media/_radarr_nav.html.twig' %}
      </div>
    </div>
  </div>
</div>

<div class="page-body">
<div class="container-xl">

{% if error %}
<div class="alert alert-danger">{{ 'media.arr_admin.download_clients.error_unreachable_radarr'|trans }}</div>
{% endif %}

<div id="dc-feedback" class="alert d-none mb-3"></div>

<div class="card">
  <div class="card-header">
    <h3 class="card-title">{{ 'media.arr_admin.download_clients.card_title'|trans }}</h3>
    <div class="card-options">
      <span class="badge bg-secondary-lt">{{ clients|length }}</span>
    </div>
  </div>
  <div class="card-body p-0">
    {% if clients is empty %}
      <div class="text-muted text-center py-5">{{ 'media.arr_admin.download_clients.empty'|trans }}</div>
    {% else %}
      <div class="table-responsive">
        <table class="table table-vcenter mb-0">
          <thead>
            <tr>
              <th>{{ 'media.arr_admin.download_clients.col_name'|trans }}</th>
              <th>{{ 'media.arr_admin.download_clients.col_type'|trans }}</th>
              <th>{{ 'media.arr_admin.download_clients.col_host'|trans }}</th>
              <th>{{ 'media.arr_admin.download_clients.col_port'|trans }}</th>
              <th>{{ 'media.arr_admin.download_clients.col_enabled'|trans }}</th>
              <th>{{ 'media.arr_admin.download_clients.col_priority'|trans }}</th>
              <th class="text-end">{{ 'media.arr_admin.download_clients.col_actions'|trans }}</th>
            </tr>
          </thead>
          <tbody>
            {% for client in clients %}
            <tr data-client="{{ client|json_encode|e('html_attr') }}">
              <td class="fw-medium">{{ client.name ?? '—' }}</td>
              <td><span class="badge bg-secondary-lt">{{ client.implementation ?? client.implementationName ?? '—' }}</span></td>
              <td class="text-muted small">
                {% set host = null %}
                {% for field in (client.fields ?? []) %}
                  {% if field.name == 'host' %}{% set host = field.value %}{% endif %}
                {% endfor %}
                {{ host ?? '—' }}
              </td>
              <td class="text-muted small">
                {% set port = null %}
                {% for field in (client.fields ?? []) %}
                  {% if field.name == 'port' %}{% set port = field.value %}{% endif %}
                {% endfor %}
                {{ port ?? '—' }}
              </td>
              <td>
                {% if client.enable ?? client.enabled ?? false %}
                  <span class="badge bg-success-lt text-success">{{ 'media.arr_admin.download_clients.yes'|trans }}</span>
                {% else %}
                  <span class="badge bg-secondary-lt">{{ 'media.arr_admin.download_clients.no'|trans }}</span>
                {% endif %}
              </td>
              <td class="text-muted">{{ client.priority ?? '—' }}</td>
              <td class="text-end d-flex gap-2 justify-content-end">
                <button class="btn btn-ghost-secondary btn-icon" data-bs-toggle="modal" data-bs-target="#modal-dc" data-edit-item="{{ client|json_encode|e('html_attr') }}" title="{{ 'media.arr_admin.download_clients.edit'|trans }}">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                </button>
                <button class="btn btn-ghost-primary btn-icon btn-dc-test" data-id="{{ client.id }}" title="{{ 'media.arr_admin.download_clients.test'|trans }}">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                </button>
                <button class="btn btn-ghost-danger btn-icon btn-dc-delete" data-id="{{ client.id }}" data-name="{{ client.name ?? '' }}" title="{{ 'media.arr_admin.download_clients.delete'|trans }}">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                </button>
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endif %}
  </div>
</div>

</div>
</div>

{% include 'radarr/_schema_modal.html.twig' with {
  modal_id: 'modal-dc',
  modal_title_add: 'media.arr_admin.download_clients.modal_title_add'|trans,
  modal_title_edit: 'media.arr_admin.download_clients.modal_title_edit'|trans,
  schema_url: instance_path('radarr_download_client_schema'),
  save_url_add: instance_path('radarr_download_client_add'),
  save_url_edit: app.request.getBasePath() ~ '/medias/' ~ current_slug('radarr') ~ '/radarr/clients-telechargement/__ID__/modifier',
  test_url: instance_path('radarr_download_client_test')
} %}
{% endblock %}

{% block javascripts %}
<script>
(function() {
  var I18N = {
    fallback_name: {{ 'media.arr_admin.download_clients.fallback_name'|trans|json_encode|raw }},
    test_success_title: {{ 'media.arr_admin.download_clients.test_success_title'|trans|json_encode|raw }},
    test_failure: {{ 'media.arr_admin.download_clients.test_failure'|trans|json_encode|raw }},
    test_label: {{ 'media.arr_admin.download_clients.test'|trans|json_encode|raw }},
    test_success_feedback_tpl: {{ 'media.arr_admin.download_clients.test_success_feedback_tpl'|trans({name: '__NAME__'})|json_encode|raw }},
    test_failure_feedback_tpl: {{ 'media.arr_admin.download_clients.test_failure_feedback_tpl'|trans({name: '__NAME__', error: '__ERR__'})|json_encode|raw }},
    error_network_title: {{ 'media.arr_admin.download_clients.error_network_title'|trans|json_encode|raw }},
    error_network: {{ 'media.arr_admin.download_clients.error_network'|trans|json_encode|raw }},
    error_delete: {{ 'media.arr_admin.download_clients.error_delete'|trans|json_encode|raw }},
    confirm_delete_tpl: {{ 'media.arr_admin.download_clients.confirm_delete_tpl'|trans({name: '__NAME__'})|json_encode|raw }}
  };

  var feedback = document.getElementById('dc-feedback');
  function showFeedback(msg, type) {
    type = type || 'success';
    feedback.className = 'alert alert-' + type + ' mb-3';
    feedback.textContent = msg;
    feedback.classList.remove('d-none');
    setTimeout(function() { feedback.classList.add('d-none'); }, type === 'danger' ? 10000 : 4000);
  }

  var SVG_CHECK = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>';
  var SVG_OK = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>';
  var SVG_FAIL = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>';
  var SVG_SPIN = '<span class="spinner-border spinner-border-sm" style="width:14px;height:14px;"></span>';

  document.querySelectorAll('.btn-dc-test').forEach(function(btn) {
    btn.addEventListener('click', function() {
      btn.disabled = true;
      btn.innerHTML = SVG_SPIN;
      var client, name;
      try {
        client = JSON.parse(btn.closest('tr').dataset.client);
        name = client.name || I18N.fallback_name;
      } catch (e) {
        btn.innerHTML = SVG_FAIL; btn.title = I18N.error_network_title;
        showFeedback(I18N.error_network, 'danger');
        btn.disabled = false;
        setTimeout(function() { btn.innerHTML = SVG_CHECK; btn.title = I18N.test_label; }, 3000);
        return;
      }
      fetch('{{ instance_path('radarr_download_client_test') }}', {
        method: 'POST', headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
        body: JSON.stringify(client),
      }).then(function(r) { return r.json(); }).then(function(data) {
        btn.innerHTML = data.ok ? SVG_OK : SVG_FAIL;
        btn.title = data.ok ? I18N.test_success_title : (data.error || I18N.test_failure);
        if (data.ok) {
          showFeedback(I18N.test_success_feedback_tpl.replace('__NAME__', name), 'success');
        } else {
          showFeedback(I18N.test_failure_feedback_tpl.replace('__NAME__', name).replace('__ERR__', (data.error || I18N.test_failure)), 'danger');
        }
      }).catch(function() {
        btn.innerHTML = SVG_FAIL; btn.title = I18N.error_network_title;
        showFeedback(I18N.error_network, 'danger');
      }).then(function() {
        btn.disabled = false;
        setTimeout(function() { btn.innerHTML = SVG_CHECK; btn.title = I18N.test_label; }, 3000);
      });
    });
  });

  document.querySelectorAll('.btn-dc-delete').forEach(function(btn) {
    btn.addEventListener('click', function() {
      if (!confirm(I18N.confirm_delete_tpl.replace('__NAME__', btn.dataset.name))) return;
      fetch('{{ app.request.getBasePath() }}/medias/' + INSTANCE_SLUG + '/radarr/clients-telechargement/' + btn.dataset.id + '/supprimer', {
        method: 'POST', headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'}, body: '{}',
      }).then(function(r) { return r.json(); }).then(function(data) {
        if (data.ok) location.reload();
        else showFeedback(data.error || I18N.error_delete, 'danger');
      });
    });
  });
})();
</script>
{% endblock %}
