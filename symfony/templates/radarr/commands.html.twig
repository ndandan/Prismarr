{% extends 'base.html.twig' %}

{% block title %}{{ 'media.arr_admin.commands.title_radarr'|trans }}{% endblock %}

{% block body %}
<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <h2 class="page-title">{{ 'media.arr_admin.commands.page_title'|trans }}</h2>
      </div>
      <div class="col-auto ms-auto">
        {% include 'media/_radarr_nav.html.twig' %}
      </div>
    </div>
  </div>
</div>

<div class="page-body">
<div class="container-xl">

{% if error %}
<div class="alert alert-danger">{{ 'media.arr_admin.commands.error_unreachable_radarr'|trans }}</div>
{% endif %}

<div id="cmd-feedback" class="alert d-none mb-3"></div>

<div class="card">
  <div class="card-header">
    <h3 class="card-title">{{ 'media.arr_admin.commands.card_title'|trans }}</h3>
    <div class="card-options">
      <span class="badge bg-secondary-lt" id="cmd-count">{{ commands|length }}</span>
      <span class="text-muted small ms-2">{{ 'media.arr_admin.commands.refresh_hint'|trans }}</span>
    </div>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-vcenter mb-0" id="commands-table">
        <thead>
          <tr>
            <th>{{ 'media.arr_admin.commands.col_id'|trans }}</th>
            <th>{{ 'media.arr_admin.commands.col_command'|trans }}</th>
            <th>{{ 'media.arr_admin.commands.col_status'|trans }}</th>
            <th>{{ 'media.arr_admin.commands.col_started'|trans }}</th>
            <th>{{ 'media.arr_admin.commands.col_ended'|trans }}</th>
            <th>{{ 'media.arr_admin.commands.col_duration'|trans }}</th>
            <th>{{ 'media.arr_admin.commands.col_message'|trans }}</th>
            <th class="w-1"></th>
          </tr>
        </thead>
        <tbody id="commands-tbody">
          {% if commands is empty %}
          <tr><td colspan="8" class="text-center text-muted py-4">{{ 'media.arr_admin.commands.empty'|trans }}</td></tr>
          {% else %}
          {% for cmd in commands %}
          <tr>
            <td class="text-muted small">{{ cmd.id }}</td>
            <td class="fw-medium">{{ cmd.name ?? '—' }}</td>
            <td>
              {% set status = cmd.status ?? 'unknown' %}
              {% if status == 'queued' %}
                <span class="badge bg-secondary-lt">{{ 'media.arr_admin.commands.status_queued'|trans }}</span>
              {% elseif status == 'started' %}
                <span class="badge bg-primary-lt text-primary">{{ 'media.arr_admin.commands.status_started'|trans }}</span>
              {% elseif status == 'completed' %}
                <span class="badge bg-success-lt text-success">{{ 'media.arr_admin.commands.status_completed'|trans }}</span>
              {% elseif status == 'failed' %}
                <span class="badge bg-danger-lt text-danger">{{ 'media.arr_admin.commands.status_failed'|trans }}</span>
              {% else %}
                <span class="badge bg-secondary-lt">{{ status }}</span>
              {% endif %}
            </td>
            <td class="text-muted small">
              {{ cmd.started is defined ? cmd.started|date('H:i:ss') : '—' }}
            </td>
            <td class="text-muted small">
              {{ cmd.ended is defined ? cmd.ended|date('H:i:ss') : '—' }}
            </td>
            <td class="text-muted small">
              {% if cmd.duration is defined %}
                {{ cmd.duration }}
              {% else %}—{% endif %}
            </td>
            <td class="small text-muted" style="max-width:300px;word-break:break-word">
              {{ cmd.message ?? '' }}
              {% if (cmd.status ?? '') == 'failed' and cmd.exception is defined %}
                <span class="text-danger">{{ cmd.exception|slice(0, 150) }}</span>
              {% endif %}
            </td>
            <td>
              {% if status in ['queued', 'started'] %}
              <button class="btn btn-ghost-danger btn-icon btn-sm btn-cmd-cancel"
                      data-id="{{ cmd.id }}"
                      title="{{ 'media.arr_admin.commands.cancel_title'|trans }}">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6l-12 12m0 -12l12 12"/></svg>
              </button>
              {% endif %}
            </td>
          </tr>
          {% endfor %}
          {% endif %}
        </tbody>
      </table>
    </div>
  </div>
</div>

</div>
</div>
{% endblock %}

{% block javascripts %}
<script>
(function(){
var I18N = {
  confirmCancelTpl: {{ 'media.arr_admin.commands.confirm_cancel_tpl'|trans({id: '__ID__'})|json_encode|raw }},
  cancelledTpl: {{ 'media.arr_admin.commands.cancelled_tpl'|trans({id: '__ID__'})|json_encode|raw }},
  errorCancel: {{ 'media.arr_admin.commands.error_cancel'|trans|json_encode|raw }},
  errorNetwork: {{ 'media.arr_admin.commands.error_network'|trans|json_encode|raw }}
};
var feedback = document.getElementById('cmd-feedback');
function showFeedback(msg, type) {
  feedback.className = 'alert alert-' + (type || 'success') + ' mb-3';
  feedback.textContent = msg;
  feedback.classList.remove('d-none');
  setTimeout(function(){ feedback.classList.add('d-none'); }, 4000);
}

function bindCancelButtons() {
  document.querySelectorAll('.btn-cmd-cancel').forEach(function(btn) {
    btn.onclick = function() {
      var cmdId = btn.dataset.id;
      if (!confirm(I18N.confirmCancelTpl.replace('__ID__', cmdId))) return;
      btn.disabled = true;
      fetch('{{ app.request.getBasePath() }}/medias/' + INSTANCE_SLUG + '/radarr/command/' + cmdId + '/annuler', {
        method: 'POST',
        headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
        body: '{}'
      }).then(function(r){ return r.json(); }).then(function(data){
        if (data.ok) {
          showFeedback(I18N.cancelledTpl.replace('__ID__', cmdId));
          setTimeout(function(){ location.reload(); }, 800);
        } else {
          showFeedback(data.error || I18N.errorCancel, 'danger');
          btn.disabled = false;
        }
      }).catch(function(){
        showFeedback(I18N.errorNetwork, 'danger');
        btn.disabled = false;
      });
    };
  });
}
bindCancelButtons();

// Auto-refresh toutes les 5s
var refreshTimer = setInterval(function() {
  fetch(window.location.href, {headers: {'X-Requested-With': 'XMLHttpRequest'}}).then(function(r){
    if (!r.ok) return null;
    return r.text();
  }).then(function(html){
    if (!html) return;
    var parser = new DOMParser();
    var doc = parser.parseFromString(html, 'text/html');
    var newTbody = doc.getElementById('commands-tbody');
    var newCount = doc.getElementById('cmd-count');
    if (newTbody) {
      document.getElementById('commands-tbody').innerHTML = newTbody.innerHTML;
      bindCancelButtons();
    }
    if (newCount) {
      document.getElementById('cmd-count').textContent = newCount.textContent;
    }
  }).catch(function(){ /* silencieux */ });
}, 5000);
window._prismarrRadarrCmdTimer = refreshTimer;

document.addEventListener('turbo:before-render', function cleanup() {
  if (window._prismarrRadarrCmdTimer) {
    clearInterval(window._prismarrRadarrCmdTimer);
    window._prismarrRadarrCmdTimer = null;
  }
  document.removeEventListener('turbo:before-render', cleanup);
});
})();
</script>
{% endblock %}
