{% extends 'base.html.twig' %}

{% block title %}{{ 'media.arr_admin.notifications.title_radarr'|trans }}{% endblock %}

{% block body %}
<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <h2 class="page-title">{{ 'media.arr_admin.notifications.page_title'|trans }}</h2>
      </div>
      <div class="col-auto ms-auto d-flex gap-2 align-items-center">
        <button class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#modal-notif">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14m-7-7h14"/></svg>
          {{ 'media.arr_admin.notifications.add'|trans }}
        </button>
        {% include 'media/_radarr_nav.html.twig' %}
      </div>
    </div>
  </div>
</div>

<div class="page-body">
<div class="container-xl">

{% if error %}
<div class="alert alert-danger">{{ 'media.arr_admin.notifications.error_unreachable_radarr'|trans }}</div>
{% endif %}

<div id="notif-feedback" class="alert d-none mb-3"></div>

<div class="card">
  <div class="card-header">
    <h3 class="card-title">{{ 'media.arr_admin.notifications.card_title'|trans }}</h3>
    <div class="card-options">
      <span class="badge bg-secondary-lt">{{ notifications|length }}</span>
    </div>
  </div>
  <div class="card-body p-0">
    {% if notifications is empty %}
      <div class="text-muted text-center py-5">{{ 'media.arr_admin.notifications.empty'|trans }}</div>
    {% else %}
      <div class="table-responsive">
        <table class="table table-vcenter table-hover mb-0">
          <thead>
            <tr>
              <th>{{ 'media.arr_admin.notifications.col_name'|trans }}</th>
              <th>{{ 'media.arr_admin.notifications.col_type'|trans }}</th>
              <th>{{ 'media.arr_admin.notifications.col_triggers'|trans }}</th>
              <th class="text-end">{{ 'media.arr_admin.notifications.col_actions'|trans }}</th>
            </tr>
          </thead>
          <tbody>
            {% for notif in notifications %}
            <tr>
              <td class="fw-medium">{{ notif.name ?? '—' }}</td>
              <td>
                <span class="badge bg-blue-lt">{{ notif.implementationName ?? notif.implementation ?? '—' }}</span>
              </td>
              <td class="small">
                <div class="d-flex flex-wrap gap-1">
                  {% if notif.onGrab ?? false %}<span class="badge bg-secondary-lt">{{ 'media.arr_admin.notifications.trigger_grab'|trans }}</span>{% endif %}
                  {% if notif.onDownload ?? false %}<span class="badge bg-secondary-lt">{{ 'media.arr_admin.notifications.trigger_download'|trans }}</span>{% endif %}
                  {% if notif.onUpgrade ?? false %}<span class="badge bg-secondary-lt">{{ 'media.arr_admin.notifications.trigger_upgrade'|trans }}</span>{% endif %}
                  {% if notif.onRename ?? false %}<span class="badge bg-secondary-lt">{{ 'media.arr_admin.notifications.trigger_rename'|trans }}</span>{% endif %}
                  {% if notif.onMovieAdded ?? false %}<span class="badge bg-secondary-lt">{{ 'media.arr_admin.notifications.trigger_movie_added'|trans }}</span>{% endif %}
                  {% if notif.onMovieDelete ?? false %}<span class="badge bg-secondary-lt">{{ 'media.arr_admin.notifications.trigger_delete'|trans }}</span>{% endif %}
                  {% if notif.onHealthIssue ?? false %}<span class="badge bg-secondary-lt">{{ 'media.arr_admin.notifications.trigger_health'|trans }}</span>{% endif %}
                  {% if notif.onApplicationUpdate ?? false %}<span class="badge bg-secondary-lt">{{ 'media.arr_admin.notifications.trigger_update'|trans }}</span>{% endif %}
                  {% if notif.onManualInteractionRequired ?? false %}<span class="badge bg-secondary-lt">{{ 'media.arr_admin.notifications.trigger_interaction'|trans }}</span>{% endif %}
                </div>
              </td>
              <td class="text-end">
                <div class="d-flex gap-2 justify-content-end">
                  <button class="btn btn-ghost-secondary btn-icon btn-notif-edit"
                          data-bs-toggle="modal" data-bs-target="#modal-notif"
                          data-edit-item="{{ notif|json_encode|e('html_attr') }}" title="{{ 'media.arr_admin.notifications.edit'|trans }}">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                  </button>
                  <button class="btn btn-ghost-primary btn-icon btn-notif-test"
                          data-id="{{ notif.id }}" title="{{ 'media.arr_admin.notifications.test'|trans }}">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                  </button>
                  <button class="btn btn-ghost-danger btn-icon btn-notif-delete"
                          data-id="{{ notif.id }}" data-name="{{ notif.name ?? '' }}" title="{{ 'media.arr_admin.notifications.delete'|trans }}">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                  </button>
                </div>
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endif %}
  </div>
</div>

</div>
</div>

{% include 'radarr/_schema_modal.html.twig' with {
  modal_id: 'modal-notif',
  modal_title_add: 'media.arr_admin.notifications.modal_title_add'|trans,
  modal_title_edit: 'media.arr_admin.notifications.modal_title_edit'|trans,
  schema_url: instance_path('radarr_notifications_schema'),
  save_url_add: instance_path('radarr_notification_add'),
  save_url_edit: app.request.getBasePath() ~ '/medias/' ~ current_slug('radarr') ~ '/radarr/notifications/__ID__/modifier',
  test_url: instance_path('radarr_notification_test_payload'),
  mode: 'notification'
} %}
{% endblock %}

{% block javascripts %}
<script>
(function(){
  var I18N = {
    error_test: {{ 'media.arr_admin.notifications.error_test'|trans|json_encode|raw }},
    error_network: {{ 'media.arr_admin.notifications.error_network'|trans|json_encode|raw }},
    error_delete: {{ 'media.arr_admin.notifications.error_delete'|trans|json_encode|raw }},
    confirm_delete_tpl: {{ 'media.arr_admin.notifications.confirm_delete_tpl'|trans({name: '__NAME__'})|json_encode|raw }}
  };

  var feedback = document.getElementById('notif-feedback');
  function showFeedback(msg, type) {
    type = type || 'success';
    feedback.className = 'alert alert-' + type + ' mb-3';
    feedback.textContent = msg;
    feedback.classList.remove('d-none');
    setTimeout(function() { feedback.classList.add('d-none'); }, type === 'danger' ? 10000 : 4000);
  }

  var SVG_OK = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>';
  var SVG_FAIL = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>';
  var SVG_SPIN = '<span class="spinner-border spinner-border-sm" style="width:14px;height:14px;"></span>';

  document.querySelectorAll('.btn-notif-test').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var origHTML = btn.innerHTML;
      btn.disabled = true;
      btn.innerHTML = SVG_SPIN;
      fetch('{{ app.request.getBasePath() }}/medias/' + INSTANCE_SLUG + '/radarr/notifications/' + btn.dataset.id + '/tester', {
        method: 'POST',
        headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
        body: '{}',
      }).then(function(r) { return r.json(); }).then(function(data) {
        btn.innerHTML = data.ok ? SVG_OK : SVG_FAIL;
        if (!data.ok) showFeedback(data.error || I18N.error_test, 'danger');
      }).catch(function() {
        btn.innerHTML = SVG_FAIL;
        showFeedback(I18N.error_network, 'danger');
      }).then(function() {
        btn.disabled = false;
        setTimeout(function() { btn.innerHTML = origHTML; }, 3000);
      });
    });
  });

  document.querySelectorAll('.btn-notif-delete').forEach(function(btn) {
    btn.addEventListener('click', function() {
      if (!confirm(I18N.confirm_delete_tpl.replace('__NAME__', btn.dataset.name))) return;
      fetch('{{ app.request.getBasePath() }}/medias/' + INSTANCE_SLUG + '/radarr/notifications/' + btn.dataset.id + '/supprimer', {
        method: 'POST',
        headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
        body: '{}',
      }).then(function(r) { return r.json(); }).then(function(data) {
        if (data.ok) location.reload();
        else showFeedback(data.error || I18N.error_delete, 'danger');
      });
    });
  });
})();
</script>
{% endblock %}
