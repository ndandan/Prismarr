{% extends 'base.html.twig' %}
{% import '_icons.html.twig' as ico %}

{% block title %}{{ 'decouverte.title'|trans }}{% endblock %}
{% block page_title %}<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="#6366f1" stroke="#6366f1" stroke-width="1.5" stroke-linejoin="round"><path d="M12 2l2.4 7.4h7.6l-6.2 4.5l2.4 7.4l-6.2 -4.6l-6.2 4.6l2.4 -7.4l-6.2 -4.5h7.6z"/></svg> {{ 'decouverte.title'|trans }}{% endblock %}

{% block body %}
<style>
  /* ── Structure de page : sections scrollables horizontales ── */
  .tmdb-section { margin-bottom: 1.75rem; }
  .tmdb-section-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 0.5rem; padding: 0 0.25rem;
  }
  .tmdb-section-header h3 {
    margin: 0; font-size: 1rem; font-weight: 600;
    color: var(--tblr-body-color);
  }
  .tmdb-section-header h3 .count {
    font-size: 0.75rem; color: var(--tblr-secondary); font-weight: 400;
    margin-left: 0.4rem;
  }
  .tmdb-section-actions { display: flex; gap: 0.25rem; }
  .tmdb-scroll-btn {
    width: 28px; height: 28px; border-radius: 50%;
    border: 1px solid var(--tblr-border-color);
    background: var(--tblr-bg-surface); color: var(--tblr-body-color);
    display: inline-flex; align-items: center; justify-content: center;
    cursor: pointer; transition: all 0.15s;
  }
  .tmdb-scroll-btn:hover { background: var(--tblr-primary); color: #fff; border-color: var(--tblr-primary); }

  .tmdb-row {
    display: flex; gap: 0.75rem; overflow-x: auto; scroll-behavior: smooth;
    padding: 0.25rem 0.25rem 0.75rem; scrollbar-width: thin;
  }
  .tmdb-row::-webkit-scrollbar { height: 6px; }
  .tmdb-row::-webkit-scrollbar-thumb { background: var(--tblr-border-color); border-radius: 3px; }

  /* ── media-card (mimique de templates/media/films.html.twig) ── */
  .media-card[data-tmdb-id] {
    flex: 0 0 150px; width: 150px;
    position: relative; border-radius: .5rem; overflow: hidden;
    background: var(--tblr-bg-surface);
    border: 1px solid var(--tblr-border-color);
    cursor: pointer; transition: transform .15s, box-shadow .15s;
  }
  .media-card[data-tmdb-id]:hover {
    transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,.3);
    z-index: 2;
  }
  .media-card[data-tmdb-id] img {
    width: 100%; aspect-ratio: 2/3; object-fit: cover; display: block;
  }
  .media-card[data-tmdb-id] .no-poster {
    width: 100%; aspect-ratio: 2/3;
    display: flex; align-items: center; justify-content: center;
    background: var(--tblr-bg-surface-secondary);
    color: var(--tblr-muted); font-size: 1.5rem;
  }
  .media-card[data-tmdb-id] .card-overlay {
    position: absolute; bottom: 0; left: 0; right: 0;
    background: linear-gradient(transparent, rgba(0,0,0,.85));
    padding: .5rem .4rem .4rem;
  }
  .media-card[data-tmdb-id] .card-title-text {
    font-size: .72rem; font-weight: 600; color: #fff;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    line-height: 1.2;
  }
  .media-card[data-tmdb-id] .card-year { font-size: .62rem; color: rgba(255,255,255,.6); }
  .media-card[data-tmdb-id] .quality-badge {
    position: absolute; top: .4rem; left: .4rem;
    font-size: .6rem; font-weight: 700; padding: .1rem .35rem;
    border-radius: .25rem; background: rgba(0,0,0,.65); color: #fff;
    backdrop-filter: blur(4px);
  }
  .media-card[data-tmdb-id] .quality-badge.movie { background: rgba(255,194,48,.92); color: #1a1a1a; }
  .media-card[data-tmdb-id] .quality-badge.tv    { background: rgba(0,204,255,.92);  color: #1a1a1a; }
  .media-card[data-tmdb-id] .lib-badge {
    position: absolute; top: .4rem; left: calc(.4rem + 2.2rem + .25rem);
    font-size: .6rem; font-weight: 700; padding: .1rem .35rem;
    border-radius: .25rem; color: #fff;
    backdrop-filter: blur(4px);
  }
  .media-card[data-tmdb-id] .vote-badge {
    position: absolute; bottom: 0; right: 0;
    font-size: .62rem; font-weight: 700; padding: .1rem .35rem;
    border-top-left-radius: .3rem;
    color: #fff; z-index: 2;
  }
  .media-card[data-tmdb-id] .vote-badge.good { background: rgba(34,197,94,.9); }
  .media-card[data-tmdb-id] .vote-badge.mid  { background: rgba(245,158,11,.9); }
  .media-card[data-tmdb-id] .vote-badge.bad  { background: rgba(239,68,68,.9); }

  /* Hover info (style Radarr/Sonarr) */
  .media-card[data-tmdb-id] .hover-info {
    position: absolute; inset: 0; background: rgba(0,0,0,.8);
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: .55rem; opacity: 0; transition: opacity .2s;
    pointer-events: none; z-index: 5;
  }
  .media-card[data-tmdb-id]:hover .hover-info { opacity: 1; pointer-events: auto; }
  .media-card[data-tmdb-id]:hover .card-overlay,
  .media-card[data-tmdb-id]:hover .quality-badge,
  .media-card[data-tmdb-id]:hover .lib-badge,
  .media-card[data-tmdb-id]:hover .vote-badge { opacity: 0; pointer-events: none; transition: opacity .2s; }
  .media-card[data-tmdb-id]:hover .wl-star { z-index: 8; }

  /* Countdown badge J-X */
  .media-card[data-tmdb-id] .countdown-badge {
    position: absolute; top: .4rem; right: .4rem;
    font-size: .55rem; font-weight: 700; padding: .1rem .35rem;
    border-radius: .25rem; background: rgba(245,158,11,.9); color: #fff;
    backdrop-filter: blur(4px); z-index: 3;
  }
  .media-card[data-tmdb-id]:hover .countdown-badge { opacity: 0; pointer-events: none; transition: opacity .2s; }

  /* Vu récemment — cards compactes */
  #tmdb-recent-row .media-card[data-tmdb-id] { flex: 0 0 100px; width: 100px; }
  #tmdb-recent-row .media-card[data-tmdb-id] .quality-badge,
  #tmdb-recent-row .media-card[data-tmdb-id] .lib-badge,
  #tmdb-recent-row .media-card[data-tmdb-id] .countdown-badge,
  #tmdb-recent-row .media-card[data-tmdb-id] .vote-badge { display: none; }
  #tmdb-recent-row .media-card[data-tmdb-id] .card-title-text { font-size: .6rem; }
  #tmdb-recent-row .media-card[data-tmdb-id] .card-year { font-size: .5rem; }
  .media-card[data-tmdb-id] .hover-info .h-title {
    font-size: .75rem; font-weight: 700; color: #fff; line-height: 1.2;
    margin-bottom: .15rem;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .media-card[data-tmdb-id] .hover-info .h-year { font-size: .65rem; color: rgba(255,255,255,.65); margin-bottom: .35rem; }
  .media-card[data-tmdb-id] .hover-info .h-actions { display: flex; gap: .25rem; flex-direction: column; }
  .media-card[data-tmdb-id] .hover-info .h-actions .btn { font-size: .65rem; padding: .2rem .4rem; }

  /* Watchlist star button */
  .media-card[data-tmdb-id] .wl-star {
    position: absolute; top: .3rem; right: .3rem;
    width: 24px; height: 24px; border-radius: 50%;
    background: rgba(0,0,0,.5); border: none;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; opacity: 0; transition: opacity .15s;
    z-index: 6; padding: 0;
  }
  .media-card[data-tmdb-id]:hover .wl-star { opacity: 1; }
  .media-card[data-tmdb-id] .wl-star svg { width: 14px; height: 14px; }
  .media-card[data-tmdb-id] .wl-star.in-wl { opacity: 1; background: rgba(245,158,11,.85); }
  .media-card[data-tmdb-id] .wl-star.in-wl:hover { background: rgba(245,158,11,1); }
  .media-card[data-tmdb-id] .wl-star:not(.in-wl):hover { background: rgba(245,158,11,.6); }

  /* ── Touch devices: hover-only actions made reachable (audit 2026-06-29)
     Details/Add and the watchlist star only appear via :hover, which never
     fires on touch. On hover-less devices the hover-info becomes a compact
     persistent bottom bar (not the full-cover overlay) carrying title/year
     + actions, replacing the plain card-overlay, and the star stays
     visible. CSS-only; desktop hover behaviour unchanged. */
  @media (hover: none) {
    .media-card[data-tmdb-id] .hover-info {
      opacity: 1; pointer-events: auto;
      top: auto; /* bottom bar instead of inset:0 full cover */
      background: linear-gradient(transparent, rgba(0,0,0,.88) 35%);
      padding-top: 1.4rem;
    }
    .media-card[data-tmdb-id] .hover-info .h-overview { display: none; }
    .media-card[data-tmdb-id] .card-overlay { display: none; } /* title/year now in hover-info */
    .media-card[data-tmdb-id] .wl-star { opacity: 1; }
    /* Tap targets: the 24px star and the tiny action buttons get a larger
       hit area on coarse pointers. */
    .media-card[data-tmdb-id] .wl-star { width: 32px; height: 32px; }
    .media-card[data-tmdb-id] .wl-star svg { width: 16px; height: 16px; }
    .media-card[data-tmdb-id] .hover-info .h-actions .btn { min-height: 32px; }
    /* The compact "Vu récemment" strip (100px tiles) has no room for the
       persistent bar — keep its plain overlay there. */
    #tmdb-recent-row .media-card[data-tmdb-id] .hover-info { display: none; }
    #tmdb-recent-row .media-card[data-tmdb-id] .card-overlay { display: block; }
  }

  /* Overrides contextuels */
  .tmdb-results-grid .media-card[data-tmdb-id] { flex: none; width: auto; }
  .td-similar-row .media-card[data-tmdb-id] { flex: 0 0 110px; width: 110px; }

  /* ── Barre de recherche + actions ── */
  .tmdb-searchbar {
    display: flex; gap: .5rem; align-items: center;
    margin-bottom: 1.25rem; flex-wrap: wrap;
  }
  .tmdb-search-wrap {
    flex: 1; min-width: 200px; display: flex; align-items: center; gap: .5rem;
    background: var(--tblr-bg-surface);
    border: 1px solid var(--tblr-border-color);
    border-radius: .5rem;
    padding: .45rem .75rem;
    transition: border-color .15s, box-shadow .15s;
  }
  .tmdb-search-wrap:focus-within {
    border-color: var(--tblr-primary);
    box-shadow: 0 0 0 3px rgba(var(--tblr-primary-rgb),.12);
  }
  .tmdb-search-ico { color: var(--tblr-muted); flex-shrink: 0; }
  .tmdb-search-wrap:focus-within .tmdb-search-ico { color: var(--tblr-primary); }
  .tmdb-search-input {
    flex: 1; background: transparent; border: 0; outline: 0;
    color: var(--tblr-body-color); font-size: .85rem;
    min-width: 0;
  }
  .tmdb-search-input::placeholder { color: var(--tblr-muted); }
  .tmdb-search-kbd {
    background: var(--tblr-bg-surface-secondary);
    color: var(--tblr-muted);
    border: 1px solid var(--tblr-border-color);
    border-radius: .25rem; font-size: .6rem;
    padding: .1rem .35rem; font-weight: 600;
    letter-spacing: .5px;
  }
  .tmdb-action-btns { display: flex; gap: .35rem; align-items: center; }
  .tmdb-action-btn {
    display: inline-flex; align-items: center; gap: .35rem;
    padding: .4rem .7rem;
    background: var(--tblr-bg-surface);
    border: 1px solid var(--tblr-border-color);
    border-radius: .5rem;
    color: var(--tblr-body-color); font-weight: 500; font-size: .78rem;
    cursor: pointer; transition: all .15s; text-decoration: none;
    white-space: nowrap;
  }
  .tmdb-action-btn:hover { background: rgba(var(--tblr-primary-rgb),.08); border-color: var(--tblr-primary); color: var(--tblr-primary); }
  .tmdb-action-btn.active { background: var(--tblr-primary); color: #fff; border-color: var(--tblr-primary); }
  .tmdb-action-btn svg { flex-shrink: 0; }
  .tmdb-filter-badge {
    display: inline-flex; align-items: center; justify-content: center;
    background: #ef4444; color: #fff;
    width: 16px; height: 16px; border-radius: 50%;
    font-size: .6rem; font-weight: 700;
    margin-left: .15rem;
  }

  .tmdb-search-bar { margin-bottom: 1rem; }
  .tmdb-results-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 0.75rem;
  }
  .tmdb-results-grid .media-card {
    position: relative; border-radius: .5rem; overflow: hidden;
    background: var(--tblr-bg-surface); border: 1px solid var(--tblr-border-color);
    cursor: pointer; transition: transform .15s, box-shadow .15s;
  }
  .tmdb-results-grid .media-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,.3); }
  .tmdb-results-grid .media-card img { width: 100%; aspect-ratio: 2/3; object-fit: cover; display: block; }
  .tmdb-results-grid .media-card .no-poster {
    width: 100%; aspect-ratio: 2/3; display: flex; align-items: center; justify-content: center;
    background: var(--tblr-bg-surface-secondary); color: var(--tblr-muted); font-size: 1.5rem;
  }
  .tmdb-results-grid .media-card .card-overlay {
    position: absolute; bottom: 0; left: 0; right: 0;
    background: linear-gradient(transparent, rgba(0,0,0,.85)); padding: .5rem .4rem .4rem;
  }
  .tmdb-results-grid .media-card .card-title-text { font-size: .72rem; font-weight: 600; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; line-height: 1.2; }
  .tmdb-results-grid .media-card .card-year { font-size: .62rem; color: rgba(255,255,255,.6); }

  /* ── Hero trending (header immersif, format 2-col) ── */
  .tmdb-hero-row .tmdb-hero { margin-bottom: 0; height: 100%; }
  .tmdb-hero {
    position: relative; border-radius: .5rem; overflow: hidden;
    min-height: 220px;
    border: 1px solid var(--tblr-border-color);
    background: #18181b;
    color: #fff; cursor: pointer;
    transition: transform .15s, box-shadow .15s;
  }
  .tmdb-hero:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,.4); }
  .tmdb-hero-bg {
    position: absolute; inset: 0;
    background-size: cover; background-position: center 20%;
    filter: brightness(0.45);
  }
  .tmdb-hero-bg::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(24,24,27,.95) 0%, rgba(24,24,27,.6) 50%, rgba(24,24,27,.2) 100%);
  }
  .tmdb-hero-content {
    position: relative; z-index: 1; padding: 1.25rem 1.5rem;
    display: flex; flex-direction: column; justify-content: flex-end;
    min-height: 220px;
  }
  .tmdb-hero-label {
    text-transform: uppercase; letter-spacing: 1.5px; font-size: 0.65rem;
    color: var(--tblr-primary); font-weight: 700; margin-bottom: 0.35rem;
  }
  .tmdb-hero-title { font-size: 1.4rem; font-weight: 700; margin: 0 0 0.3rem; line-height: 1.15; }
  .tmdb-hero-meta { display: flex; flex-wrap: wrap; gap: 0.4rem 0.6rem; align-items: center; margin-bottom: 0.5rem; font-size: 0.75rem; opacity: 0.9; }
  .tmdb-hero-overview {
    font-size: 0.8rem; line-height: 1.4; opacity: 0.9;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden; margin-bottom: 0.7rem;
  }
  .tmdb-hero-actions { display: flex; gap: 0.4rem; flex-wrap: wrap; }

  /* TMDb detail modal — calqué sur le modal Films */
  #tmdb-detail-modal .modal-content { background: var(--tblr-bg-surface); }

  .td-backdrop {
    position: relative; min-height: 200px;
    background-size: cover; background-position: center top;
    background-repeat: no-repeat;
  }
  .td-backdrop::after {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(24,24,27,1) 0%, rgba(24,24,27,.85) 40%, rgba(24,24,27,.4) 100%);
  }
  .td-backdrop-content {
    position: relative; z-index: 1;
    padding: 2.5rem 1.5rem 1rem;
  }
  .td-rating-badge {
    display: inline-flex; align-items: center; gap: .3rem;
    font-size: .78rem; font-weight: 600;
    padding: .2rem .5rem; border-radius: .3rem;
    background: rgba(255,255,255,.12); color: #fff;
  }
  .td-genre-badge {
    font-size: .68rem; padding: .15rem .45rem;
    border-radius: 1rem; background: rgba(255,255,255,.1);
    color: rgba(255,255,255,.75); border: 1px solid rgba(255,255,255,.15);
  }
  .td-poster-col img {
    width: 100%; border-radius: .5rem;
    box-shadow: 0 4px 20px rgba(0,0,0,.4);
  }

  .td-cast-scroll {
    display: flex; gap: .75rem; overflow-x: auto;
    padding-bottom: .5rem; scrollbar-width: thin;
  }
  .td-cast-card { flex-shrink: 0; width: 90px; text-align: center; }
  .td-cast-card img {
    width: 64px; height: 64px; border-radius: 50%;
    object-fit: cover; background: var(--tblr-bg-surface-secondary);
  }
  .td-cast-card .cast-name { font-size: .7rem; font-weight: 600; line-height: 1.2; margin-top: .3rem; }
  .td-cast-card .cast-role { font-size: .62rem; color: var(--tblr-muted); line-height: 1.2; display: block; }

  .td-trailer {
    position: relative; aspect-ratio: 16/9;
    border-radius: .5rem; overflow: hidden; background: #000;
  }
  .td-trailer iframe { width: 100%; height: 100%; border: 0; }

  .td-similar-row {
    display: flex; gap: .5rem; overflow-x: auto;
    padding-bottom: .4rem; scrollbar-width: thin;
  }

  /* Saisons : carousel horizontal de cards avec poster + méta */
  .td-seasons-scroll {
    display: flex; gap: .6rem; overflow-x: auto;
    padding: .2rem .2rem .6rem; scrollbar-width: thin;
  }
  .td-seasons-scroll::-webkit-scrollbar { height: 6px; }
  .td-seasons-scroll::-webkit-scrollbar-thumb { background: var(--tblr-border-color); border-radius: 3px; }
  .td-season-card {
    flex: 0 0 120px; width: 120px;
    background: var(--tblr-bg-surface-secondary);
    border: 1px solid var(--tblr-border-color);
    border-radius: .4rem; overflow: hidden;
    transition: transform .15s, box-shadow .15s;
  }
  .td-season-card:hover { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(0,0,0,.3); }
  .td-season-card img {
    width: 100%; aspect-ratio: 2/3; object-fit: cover;
    background: var(--tblr-bg-surface); display: block;
  }
  .td-season-card .no-poster {
    width: 100%; aspect-ratio: 2/3; background: var(--tblr-bg-surface);
    display: flex; align-items: center; justify-content: center;
    color: var(--tblr-muted);
  }
  .td-season-card .season-body { padding: .4rem; }
  .td-season-card .season-name {
    font-weight: 600; font-size: .75rem; line-height: 1.2;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    margin-bottom: .15rem;
  }
  .td-season-card .season-meta {
    font-size: .65rem; color: var(--tblr-muted); line-height: 1.3;
  }
  .td-season-card .season-vote { color: #f5c518; font-weight: 700; }

  /* Infos rapides clé-valeur dans la colonne gauche */
  .td-quickinfo {
    display: flex; flex-direction: column; gap: .25rem;
    font-size: .75rem;
  }
  .td-quickinfo .qi-row {
    display: flex; align-items: center; gap: .5rem;
    padding: .3rem .4rem; border-radius: .3rem;
    background: var(--tblr-bg-surface-secondary);
  }
  .td-quickinfo .qi-icon {
    width: 20px; text-align: center; color: var(--tblr-muted); flex-shrink: 0;
  }
  .td-quickinfo .qi-label {
    color: var(--tblr-muted); flex-shrink: 0; min-width: 65px; font-size: .7rem;
  }
  .td-quickinfo .qi-value {
    color: var(--tblr-body-color); font-weight: 500;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    flex: 1; text-align: right;
  }

  /* Providers compacts (logos plus petits) */
  #td-providers .provider-group {
    margin-bottom: .3rem; font-size: .72rem;
  }
  #td-providers .provider-group-label {
    color: var(--tblr-muted); margin-bottom: .2rem; font-size: .7rem;
  }
  #td-providers .provider-logos { display: flex; flex-wrap: wrap; gap: .2rem; }
  #td-providers .provider-logos img {
    width: 28px; height: 28px; border-radius: 5px; object-fit: cover;
  }

  /* Galerie backdrops (horizontal scroll, 16:9 thumbs) */
  .td-backdrops-scroll {
    display: flex; gap: .5rem; overflow-x: auto;
    padding: .2rem .2rem .6rem; scrollbar-width: thin;
  }
  .td-backdrops-scroll::-webkit-scrollbar { height: 6px; }
  .td-backdrops-scroll::-webkit-scrollbar-thumb { background: var(--tblr-border-color); border-radius: 3px; }
  .td-backdrop-thumb {
    flex: 0 0 240px; width: 240px; aspect-ratio: 16/9;
    border-radius: .4rem; overflow: hidden; cursor: pointer;
    border: 1px solid var(--tblr-border-color);
    transition: transform .15s, box-shadow .15s;
  }
  .td-backdrop-thumb:hover { transform: scale(1.03); box-shadow: 0 4px 16px rgba(0,0,0,.4); }
  .td-backdrop-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* Lightbox plein écran pour backdrops */
  .td-lightbox {
    position: fixed; inset: 0; z-index: 1080;
    background: rgba(0,0,0,.95);
    display: none; align-items: center; justify-content: center;
    cursor: zoom-out;
  }
  .td-lightbox.show { display: flex; }
  .td-lightbox img { max-width: 96vw; max-height: 96vh; object-fit: contain; }
  .td-lightbox .close-x {
    position: absolute; top: 20px; right: 20px;
    background: rgba(255,255,255,.2); color: #fff;
    width: 40px; height: 40px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 24px; cursor: pointer;
  }

  .td-video-btn {
    border: 1px solid var(--tblr-border-color);
    background: var(--tblr-bg-surface-secondary);
    padding: .2rem .5rem; font-size: .72rem;
    border-radius: .25rem; cursor: pointer;
    transition: all .15s;
  }
  .td-video-btn:hover { background: var(--tblr-primary); color: white; border-color: var(--tblr-primary); }
  .td-video-btn.active { background: var(--tblr-primary); color: white; border-color: var(--tblr-primary); }

  /* ── Mobile/tablet readability floor (responsive audit 2026-06-29) ──
     Floor sub-11px text at 11px (.6875rem) below the lg breakpoint. Kept
     last in this block so it wins the cascade at equal specificity;
     desktop (≥992px) keeps the original sizes. */
  @media (max-width: 991.98px) {
    .media-card[data-tmdb-id] .card-year,
    .media-card[data-tmdb-id] .quality-badge,
    .media-card[data-tmdb-id] .lib-badge,
    .media-card[data-tmdb-id] .vote-badge,
    .media-card[data-tmdb-id] .countdown-badge,
    #tmdb-recent-row .media-card[data-tmdb-id] .card-title-text,
    #tmdb-recent-row .media-card[data-tmdb-id] .card-year,
    .media-card[data-tmdb-id] .hover-info .h-year,
    .media-card[data-tmdb-id] .hover-info .h-actions .btn,
    .tmdb-search-kbd,
    .tmdb-filter-badge,
    .tmdb-results-grid .media-card .card-year,
    .tmdb-hero-label,
    .td-cast-card .cast-role,
    .td-season-card .season-meta,
    .td-genre-badge { font-size: .6875rem; }
  }
</style>

<div class="page-body">
  <div class="container-xl">

    {% if error %}
      {% include 'error/_service_banner.html.twig' with {
        service: 'TMDb',
        wizard_route: 'app_setup_tmdb',
        configured_url: service_url,
        reason: 'unreachable'
      } %}
    {% endif %}

    {% if not error %}

    {# Search bar + filter button — refined version #}
    <div class="tmdb-searchbar">
      <div class="tmdb-search-wrap">
        <svg class="tmdb-search-ico" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10 10m-7 0a7 7 0 1 0 14 0a7 7 0 1 0 -14 0"/>
          <path d="M21 21l-6 -6"/>
        </svg>
        <input id="tmdb-search" type="search"
               class="tmdb-search-input"
               placeholder="{{ 'decouverte.search_placeholder'|trans }}"
               autocomplete="off">
        <kbd class="tmdb-search-kbd d-none d-md-inline">TMDb</kbd>
      </div>
      <div class="tmdb-action-btns">
        <button type="button" class="tmdb-action-btn" id="tmdb-filters-toggle">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 4h18M7 12h10M11 20h2"/>
          </svg>
          {{ 'decouverte.actions.filters'|trans }}
          <span class="tmdb-filter-badge" id="tmdb-filter-active-count" style="display:none;">0</span>
        </button>
        <a href="{{ path('tmdb_watchlist') }}" class="tmdb-action-btn" id="tmdb-watchlist-link">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="#f59e0b" stroke="#f59e0b" stroke-width="1.5" stroke-linejoin="round">
            <path d="M12 2l2.4 7.4h7.6l-6.2 4.5 2.4 7.4-6.2-4.6-6.2 4.6 2.4-7.4-6.2-4.5h7.6z"/>
          </svg>
          {{ 'decouverte.actions.watchlist'|trans }}
          <span class="tmdb-filter-badge" id="tmdb-wl-count" style="display:none;">0</span>
        </a>
        <a href="{{ path('tmdb_explorer') }}" class="tmdb-action-btn">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2">
            <circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 000 20 14.5 14.5 0 000-20"/><path d="M2 12h20"/>
          </svg>
          {{ 'decouverte.actions.explorer'|trans }}
        </a>
      </div>
    </div>

    {# Filter drawer (offcanvas at all widths) #}
    <div id="tmdb-filters" class="offcanvas offcanvas-start" tabindex="-1" aria-labelledby="tmdb-filters-label">
      <div class="offcanvas-header">
        <h5 class="offcanvas-title" id="tmdb-filters-label">{{ 'decouverte.filters.drawer_title'|trans }}</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" data-bs-target="#tmdb-filters" aria-label="Close"></button>
      </div>
      <div class="offcanvas-body">
        <div class="d-flex flex-column gap-3">
          <div>
            <label class="form-label small mb-1">{{ 'decouverte.filters.type'|trans }}</label>
            <div class="btn-group d-flex" role="group">
              <input type="radio" class="btn-check" name="filter-type" id="filter-type-movie" value="movie" checked>
              <label class="btn btn-outline-primary btn-sm" for="filter-type-movie">{{ 'decouverte.filters.movies'|trans }}</label>
              <input type="radio" class="btn-check" name="filter-type" id="filter-type-tv" value="tv">
              <label class="btn btn-outline-primary btn-sm" for="filter-type-tv">{{ 'decouverte.filters.series'|trans }}</label>
            </div>
          </div>
          <div>
            <label class="form-label small mb-1">{{ 'decouverte.filters.genre'|trans }}</label>
            <select class="form-select form-select-sm" id="filter-genre">
              <option value="">{{ 'decouverte.filters.all'|trans }}</option>
            </select>
          </div>
          <div class="d-flex gap-2">
            <div class="flex-fill">
              <label class="form-label small mb-1">{{ 'decouverte.filters.year_from'|trans }}</label>
              <input type="number" class="form-control form-control-sm" id="filter-year-min" placeholder="1970" min="1900" max="2030">
            </div>
            <div class="flex-fill">
              <label class="form-label small mb-1">{{ 'decouverte.filters.year_to'|trans }}</label>
              <input type="number" class="form-control form-control-sm" id="filter-year-max" placeholder="2030" min="1900" max="2030">
            </div>
          </div>
          <div>
            <label class="form-label small mb-1">{{ 'decouverte.filters.vote_min'|trans({value: '__VAL__'})|replace({'__VAL__': '<span id="filter-vote-val" class="fw-medium">0</span>'})|raw }}</label>
            <input type="range" class="form-range" id="filter-vote-min" min="0" max="10" step="0.5" value="0">
          </div>
          <div>
            <label class="form-label small mb-1">{{ 'decouverte.filters.sort'|trans }}</label>
            <select class="form-select form-select-sm" id="filter-sort">
              <option value="popularity.desc">{{ 'decouverte.filters.sort_options.popularity'|trans }}</option>
              <option value="vote_average.desc">{{ 'decouverte.filters.sort_options.vote_avg'|trans }}</option>
              <option value="vote_count.desc">{{ 'decouverte.filters.sort_options.vote_count'|trans }}</option>
              <option value="primary_release_date.desc">{{ 'decouverte.filters.sort_options.release'|trans }}</option>
              <option value="revenue.desc">{{ 'decouverte.filters.sort_options.revenue'|trans }}</option>
            </select>
          </div>
          <div class="d-flex gap-2 justify-content-end mt-2 pt-2 border-top">
            <button type="button" class="btn btn-ghost-secondary btn-sm" id="filter-reset">{{ 'decouverte.filters.reset'|trans }}</button>
            <button type="button" class="btn btn-primary btn-sm" id="filter-apply">{{ 'decouverte.filters.apply'|trans }}</button>
          </div>
        </div>
      </div>
    </div>

    {# Search OR filter results #}
    <div id="tmdb-search-results" class="mb-3" style="display:none;">
      <div class="d-flex align-items-center justify-content-between mb-2">
        <h3 class="mb-0" style="font-size:1rem;">
          <span id="tmdb-search-title">{{ 'decouverte.search.results'|trans }}</span>
          <span id="tmdb-search-count" class="text-secondary small ms-1"></span>
        </h3>
        <button type="button" class="btn btn-sm btn-ghost-secondary" id="tmdb-search-close">{{ 'decouverte.search.close'|trans }}</button>
      </div>
      <div class="tmdb-results-grid" id="tmdb-search-grid"></div>
    </div>

    {% if heroMovie or heroTv %}
      <div class="row g-3 mb-3 tmdb-hero-row">
        {% if heroMovie %}
          <div class="col-lg-6">
            {{ _self.hero(heroMovie, 'decouverte.hero.movie'|trans) }}
          </div>
        {% endif %}
        {% if heroTv %}
          <div class="col-lg-6">
            {{ _self.hero(heroTv, 'decouverte.hero.tv'|trans) }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    {# Recommendations section based on library (loaded via AJAX) — All/Movies/TV Shows filter #}
    <div class="tmdb-section" data-section="my-recs" id="tmdb-my-recs" style="display:none;">
      <div class="tmdb-section-header">
        <h3>
          {{ 'decouverte.section.my_recs.title'|trans }}
          <span class="count">· {{ 'decouverte.section.my_recs.subtitle'|trans }} <span id="tmdb-my-recs-count"></span></span>
        </h3>
        <div class="d-flex align-items-center gap-2">
          <div class="btn-group btn-group-sm" role="group">
            <input type="radio" class="btn-check" name="myrecs-filter" id="myrecs-all" value="all" checked>
            <label class="btn btn-outline-secondary py-0 px-2" for="myrecs-all" style="font-size:.7rem;">{{ 'decouverte.filters.all'|trans }}</label>
            <input type="radio" class="btn-check" name="myrecs-filter" id="myrecs-movies" value="movie">
            <label class="btn btn-outline-secondary py-0 px-2" for="myrecs-movies" style="font-size:.7rem;">{{ 'decouverte.filters.movies'|trans }}</label>
            <input type="radio" class="btn-check" name="myrecs-filter" id="myrecs-tv" value="tv">
            <label class="btn btn-outline-secondary py-0 px-2" for="myrecs-tv" style="font-size:.7rem;">{{ 'decouverte.filters.series'|trans }}</label>
          </div>
          <div class="tmdb-section-actions">
            <button type="button" class="tmdb-scroll-btn" data-scroll="left" aria-label="{{ 'decouverte.scroll.prev'|trans }}">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6l-6 6l6 6"/></svg>
            </button>
            <button type="button" class="tmdb-scroll-btn" data-scroll="right" aria-label="{{ 'decouverte.scroll.next'|trans }}">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6l-6 6"/></svg>
            </button>
          </div>
        </div>
      </div>
      <div class="tmdb-row" id="tmdb-my-recs-row">
        <div class="text-secondary py-3 px-2">
          <span class="spinner-border spinner-border-sm me-2"></span>{{ 'decouverte.section.my_recs.loading'|trans }}
        </div>
      </div>
    </div>

    {{ _self.section('decouverte.section.trending'|trans, trending, 'trending') }}
    {{ _self.section('decouverte.section.popular_movies'|trans, popMovies, 'popular-movies') }}
    {{ _self.section('decouverte.section.popular_tv'|trans, popTv, 'popular-tv') }}
    {{ _self.section('decouverte.section.upcoming'|trans, upcoming, 'upcoming') }}
    {{ _self.section('decouverte.section.on_air'|trans, onAir, 'on-air') }}
    {{ _self.section('decouverte.section.top_movies'|trans, topMovies, 'top-movies') }}
    {{ _self.section('decouverte.section.top_tv'|trans, topTv, 'top-tv') }}
    {# Recently viewed — discreet, at the bottom of the page #}
    <div id="tmdb-recent" style="display:none; margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid var(--tblr-border-color);">
      <div class="d-flex align-items-center justify-content-between mb-2">
        <span style="font-size:.8rem; color:var(--tblr-muted); font-weight:500;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px; margin-right:4px;"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          {{ 'decouverte.recent.title'|trans }}
        </span>
        <button type="button" class="btn btn-ghost-secondary btn-sm py-0 px-1" id="tmdb-recent-clear" style="font-size:.65rem;" title="{{ 'decouverte.recent.clear_title'|trans }}">{{ 'decouverte.recent.clear'|trans }}</button>
      </div>
      <div class="tmdb-row" id="tmdb-recent-row" style="gap:.5rem;"></div>
    </div>

  </div>
</div>

{# ── Full-screen lightbox for backdrop gallery ─────────────────────────── #}
<div class="td-lightbox" id="td-lightbox">
  <div class="close-x" data-td-lb-close>×</div>
  <img id="td-lightbox-img" src="" alt="">
</div>

{# ── TMDb detail modal ─────────────────────────────────────────────────────── #}
<div class="modal modal-blur fade" id="tmdb-detail-modal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-fullscreen-lg-down modal-xl" role="document" style="margin-top:1rem;">
    <div class="modal-content" style="background:var(--tblr-bg-surface)">
      <div id="tmdb-detail-loading" style="padding:4rem; text-align:center;">
        <div class="spinner-border text-primary" role="status"></div>
      </div>
      <div id="tmdb-detail-content" style="display:none;">

        {# ── Header backdrop ── #}
        <div class="td-backdrop" id="td-backdrop">
          <div class="td-backdrop-content">
            <div class="d-flex justify-content-between align-items-start">
              <div style="max-width:85%">
                <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                  <span id="td-type-badge" class="badge"></span>
                  <h2 class="text-white mb-0" id="td-title" style="text-shadow:0 2px 8px rgba(0,0,0,.6)"></h2>
                </div>
                <div id="td-original" class="text-white-50 small mb-1" style="display:none"></div>
                <div id="td-tagline" class="text-white-50 fst-italic small mb-2" style="display:none"></div>
                <div class="d-flex flex-wrap align-items-center gap-2 mt-2">
                  <span id="td-year" class="text-white-50 fw-medium"></span>
                  <span id="td-runtime" class="text-white-50 small" style="display:none"></span>
                  <span id="td-meta-seasons" class="text-white-50 small" style="display:none"></span>
                  <span id="td-status-info" class="text-white-50 small" style="display:none"></span>
                  <span id="td-rating-tmdb" class="td-rating-badge" style="display:none">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="#01d277" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14l-5-4.87 6.91-1.01z"/></svg>
                    <span id="td-rating-tmdb-val"></span>
                  </span>
                </div>
                <div id="td-genres" class="d-flex flex-wrap gap-1 mt-2"></div>
              </div>
              <button type="button" class="btn-close btn-close-white ms-2 mt-1" data-bs-dismiss="modal" aria-label="{{ 'decouverte.action.close'|trans }}" style="filter:drop-shadow(0 0 2px rgba(0,0,0,.8))"></button>
            </div>
          </div>
        </div>

        {# ── Body 2 colonnes ── #}
        <div class="modal-body pt-3">
          <div class="row g-4">

            {# Left column: poster + status + actions + providers #}
            <div class="col-md-5 col-lg-4">
              <div class="td-poster-col mb-3">
                <img id="td-poster" src="" alt="" loading="lazy" style="display:none">
              </div>

              <div class="d-flex flex-wrap gap-2 mb-3" id="td-status-badges"></div>

              <div class="d-grid gap-2 mb-3" id="td-actions"></div>

              <div class="d-flex gap-2 mb-3 flex-wrap" id="td-external-links"></div>

              {# Quick info (compact key-value) #}
              <div id="td-quickinfo-block" style="display:none" class="mb-3">
                <h5 class="mb-2" style="font-size:.85rem; font-weight:600;">{{ 'decouverte.modal.quick_info'|trans }}</h5>
                <div id="td-quickinfo" class="td-quickinfo"></div>
              </div>

              {# Collection (movies) — moved left #}
              <div id="td-collection-block" style="display:none" class="mb-3">
                <div class="card">
                  <div class="card-body py-2">
                    <div class="d-flex align-items-center gap-2">
                      <img id="td-collection-poster" src="" alt="" style="width:40px; border-radius:.25rem;">
                      <div class="min-w-0">
                        <div class="text-muted" style="font-size:.7rem;">{{ 'decouverte.modal.part_of'|trans }}</div>
                        <div class="fw-medium" style="font-size:.8rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;" id="td-collection-name"></div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              {# Next/Last episode (series) — moved left #}
              <div id="td-next-ep-block" style="display:none" class="mb-2">
                <div class="card border-primary">
                  <div class="card-body py-2">
                    <div class="text-muted" style="font-size:.7rem;">{{ 'decouverte.modal.next_episode'|trans }}</div>
                    <div class="fw-medium" style="font-size:.8rem;" id="td-next-ep-label"></div>
                    <div class="text-muted" style="font-size:.7rem;" id="td-next-ep-date"></div>
                  </div>
                </div>
              </div>
              <div id="td-last-ep-block" style="display:none" class="mb-3">
                <div class="card">
                  <div class="card-body py-2">
                    <div class="text-muted" style="font-size:.7rem;">{{ 'decouverte.modal.last_episode'|trans }}</div>
                    <div class="fw-medium" style="font-size:.8rem;" id="td-last-ep-label"></div>
                    <div class="text-muted" style="font-size:.7rem;" id="td-last-ep-date"></div>
                  </div>
                </div>
              </div>

              {# Providers streaming (compact) #}
              <div id="td-providers-block" style="display:none" class="mb-3">
                <h5 class="mb-2" style="font-size:.85rem; font-weight:600;">
                  {{ 'decouverte.modal.available_on'|trans }} <span id="td-providers-country" class="text-muted" style="font-size:.7rem;"></span>
                </h5>
                <div id="td-providers"></div>
              </div>
            </div>

            {# Right column #}
            <div class="col-md-7 col-lg-8">

              {# Synopsis pleine largeur #}
              <div class="mb-3" id="td-overview-block" style="display:none">
                <h4 class="mb-2">{{ 'decouverte.modal.synopsis'|trans }}</h4>
                <p id="td-overview" class="text-muted mb-0" style="line-height:1.65; font-size:.9rem;"></p>
              </div>

              {# Trailer : card autonome #}
              <div class="card mb-3" id="td-trailer-block" style="display:none;">
                <div class="card-header py-1 px-2 d-flex align-items-center justify-content-between" style="min-height:34px;">
                  <h3 class="card-title mb-0" style="font-size:.78rem;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#ff0000" stroke="none" style="vertical-align:-2px;"><path d="M10 15l5.19-3L10 9v6m11.56-7.83c.13.47.22 1.1.28 1.9.07.8.1 1.49.1 2.09L22 12c0 2.19-.16 3.8-.44 4.83-.25.9-.83 1.48-1.73 1.73-.47.13-1.33.22-2.65.28-1.3.07-2.49.1-3.59.1L12 19c-4.19 0-6.8-.16-7.83-.44-.9-.25-1.48-.83-1.73-1.73-.13-.47-.22-1.1-.28-1.9-.07-.8-.1-1.49-.1-2.09L2 12c0-2.19.16-3.8.44-4.83.25-.9.83-1.48 1.73-1.73.47-.13 1.33-.22 2.65-.28 1.3-.07 2.49-.1 3.59-.1L12 5c4.19 0 6.8.16 7.83.44.9.25 1.48.83 1.73 1.73z"/></svg>
                    {{ 'decouverte.modal.trailer'|trans }} <span id="td-trailer-name" class="text-muted ms-1" style="font-size:.7rem;"></span>
                  </h3>
                  <a id="td-trailer-yt-link" href="#" target="_blank" rel="noopener" class="btn btn-sm btn-ghost-secondary p-1" title="{{ 'decouverte.modal.trailer_youtube_link'|trans }}">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 7h-5a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2-2v-5"/><path d="M10 14l10-10"/><path d="M15 4l5 0l0 5"/></svg>
                  </a>
                </div>
                <div class="card-body p-2">
                  <div class="td-trailer" id="td-trailer"></div>
                  <div id="td-video-gallery" class="d-flex flex-wrap gap-1 mt-2" style="display:none"></div>
                </div>
              </div>

              {# Casting #}
              <div class="card mb-3" id="td-cast-block" style="display:none">
                <div class="card-header py-2">
                  <h3 class="card-title mb-0">{{ 'decouverte.modal.cast'|trans }}</h3>
                </div>
                <div class="card-body py-2">
                  <div class="td-cast-scroll" id="td-cast"></div>
                </div>
              </div>

              {# Production + crew info #}
              <div class="card mb-3" id="td-info-block" style="display:none">
                <div class="card-header py-2">
                  <h3 class="card-title mb-0">{{ 'decouverte.modal.info'|trans }}</h3>
                </div>
                <div class="card-body py-2">
                  <div class="table-responsive">
                    <table class="table table-sm table-vcenter mb-0" style="font-size:.82rem">
                      <tbody id="td-info-rows"></tbody>
                    </table>
                  </div>
                </div>
              </div>

              {# Seasons (series) — horizontal carousel with properly-sized posters #}
              <div class="card mb-3" id="td-seasons-block" style="display:none">
                <div class="card-header py-2 d-flex align-items-center justify-content-between">
                  <h3 class="card-title mb-0">{{ 'decouverte.modal.seasons'|trans }}</h3>
                  <div class="tmdb-section-actions">
                    <button type="button" class="tmdb-scroll-btn" data-seasons-scroll="left" aria-label="{{ 'decouverte.scroll.prev'|trans }}">
