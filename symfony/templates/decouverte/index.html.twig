</div>

{% endif %} {# /if not error #}

{# ── Hero macro (movie or series) ─────────────────────────────────────────────── #}
{% macro hero(item, label) %}
  <div class="tmdb-hero" data-tmdb-id="{{ item.id }}" data-tmdb-type="{{ item.type }}">
    {% if item.backdrop %}
      <div class="tmdb-hero-bg" style="background-image:url('{{ item.backdrop }}');"></div>
    {% endif %}
    <div class="tmdb-hero-content">
      <div class="tmdb-hero-label">{{ label }}</div>
      <h2 class="tmdb-hero-title">{{ item.title }}</h2>
      <div class="tmdb-hero-meta">
        {% if item.year %}<span>{{ item.year }}</span>{% endif %}
        {% if item.vote %}<span>{{ ico.icon('star-filled', '', 14) }} {{ item.vote }}/10</span>{% endif %}
        {% if item.in_library %}
          {# v1.1.0 — match the badge colour + label to the actual
             library status (downloaded / missing / announced / inCinemas
             / unmonitored), same scheme as the trending cards below.
             Falls back to a plain green "in library" when no status is
             attached (defensive — shouldn't happen post-refactor). #}
          {% set _heroStatusColors = {'downloaded':'#22c55e','missing':'#f59e0b','announced':'#6366f1','inCinemas':'#6366f1','partial':'#3b82f6','unmonitored':'#6b7280'} %}
          {% set _heroStatusKey = item.lib_status ? 'decouverte.modal.status.' ~ item.lib_status : null %}
          <span class="badge" style="background:{{ _heroStatusColors[item.lib_status] ?? '#22c55e' }}; color:#fff;">
            {{ _heroStatusKey ? _heroStatusKey|trans : 'decouverte.badge.in_library'|trans }}
          </span>
        {% endif %}
      </div>
      {% if item.overview %}
        <div class="tmdb-hero-overview">{{ item.overview }}</div>
      {% endif %}
      <div class="tmdb-hero-actions">
        {% if not item.in_library %}
          <button class="btn btn-primary btn-sm tmdb-add-btn"
                  data-tmdb-id="{{ item.id }}"
                  data-tmdb-type="{{ item.type }}"
                  data-tmdb-title="{{ item.title }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1"><path d="M12 5l0 14"/><path d="M5 12l14 0"/></svg>
            {{ 'decouverte.action.add'|trans }}
          </button>
        {% endif %}
        <button type="button" class="btn btn-outline-light btn-sm tmdb-hero-details-btn"
                data-tmdb-id="{{ item.id }}" data-tmdb-type="{{ item.type }}">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
          {{ 'decouverte.action.details'|trans }}
        </button>
      </div>
    </div>
  </div>
{% endmacro %}

{# ── Macro for a horizontally-scrollable section ────────────────────────────── #}
{% macro section(title, items, slug) %}
  <div class="tmdb-section" data-section="{{ slug }}">
    <div class="tmdb-section-header">
      <h3>
        {{ title }}
        <span class="count">· {{ items|length }}</span>
      </h3>
      <div class="tmdb-section-actions">
        <button type="button" class="tmdb-scroll-btn" data-scroll="left" aria-label="{{ 'decouverte.scroll.prev'|trans }}">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M15 6l-6 6l6 6"/></svg>
        </button>
        <button type="button" class="tmdb-scroll-btn" data-scroll="right" aria-label="{{ 'decouverte.scroll.next'|trans }}">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M9 6l6 6l-6 6"/></svg>
        </button>
      </div>
    </div>
    <div class="tmdb-row">
      {% for item in items %}
        {{ _self.card(item) }}
      {% else %}
        <div class="text-secondary py-4 px-2">{{ 'decouverte.search.no_results'|trans }}</div>
      {% endfor %}
    </div>
  </div>
{% endmacro %}

{# ── Macro for a TMDb card (mimics .media-card layout from Movies) ────────── #}
{% macro card(item) %}
  {% set voteClass = 'bad' %}
  {% if item.vote >= 7 %}{% set voteClass = 'good' %}
  {% elseif item.vote >= 5 %}{% set voteClass = 'mid' %}
  {% endif %}
  <div class="media-card"
       data-tmdb-id="{{ item.id }}"
       data-tmdb-type="{{ item.type }}"
       data-tmdb-title="{{ item.title }}"
       data-tmdb-vote="{{ item.vote }}"
       data-tmdb-year="{{ item.year }}"
       data-release="{{ item.release }}"
       >
    {% if item.poster %}
      <img src="{{ item.poster }}" alt="{{ item.title }}" loading="lazy">
    {% else %}
      <div class="no-poster">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M7 4v16l13 -8z"/></svg>
      </div>
    {% endif %}
    <span class="quality-badge {{ item.type }}">{{ item.type == 'movie' ? 'decouverte.modal.type_film'|trans : 'decouverte.modal.type_series'|trans }}</span>
    {% if item.in_library %}
      {% set statusColors = {'downloaded':'#22c55e','missing':'#f59e0b','announced':'#6366f1','inCinemas':'#6366f1','partial':'#3b82f6','unmonitored':'#6b7280'} %}
      {% set statusShortKey = 'decouverte.card.status_short.' ~ (item.lib_status ?: 'default') %}
      <span class="lib-badge" style="background:{{ statusColors[item.lib_status] ?? '#22c55e' }};">{{ statusShortKey|trans }}</span>
    {% endif %}
    <button type="button" class="wl-star" data-tmdb-id="{{ item.id }}" data-tmdb-type="{{ item.type }}" title="{{ 'decouverte.modal.watchlist'|trans }}">
      <svg viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2"><path d="M12 2l2.4 7.4h7.6l-6.2 4.5 2.4 7.4-6.2-4.6-6.2 4.6 2.4-7.4-6.2-4.5h7.6z"/></svg>
    </button>
    {% if item.vote %}
      <span class="vote-badge {{ voteClass }}">{{ ico.icon('star-filled', '', 14) }} {{ item.vote }}</span>
    {% endif %}
    <div class="card-overlay">
      <div class="card-title-text" title="{{ item.title }}">{{ item.title }}</div>
      <div class="card-year">{{ item.year ?: '' }}</div>
    </div>
    <div class="hover-info">
      <div class="h-title">{{ item.title }}</div>
      <div class="h-year">{{ item.year ?: '' }}{% if item.vote %} · {{ ico.icon('star-filled', '', 14) }} {{ item.vote }}{% endif %}</div>
      <div class="h-actions">
        {% if not item.in_library %}
          <button type="button" class="btn btn-primary btn-sm tmdb-add-btn"
                  data-tmdb-id="{{ item.id }}"
                  data-tmdb-type="{{ item.type }}"
                  data-tmdb-title="{{ item.title }}">{{ 'decouverte.action.add'|trans }}</button>
        {% else %}
          {% set statusColors = {'downloaded':'#22c55e','missing':'#f59e0b','announced':'#6366f1','inCinemas':'#6366f1','partial':'#3b82f6','unmonitored':'#6b7280'} %}
          {% set statusKey = 'decouverte.modal.status.' ~ (item.lib_status ?: 'downloaded') %}
          {% set statusLabel = item.lib_status ? statusKey|trans : 'decouverte.card.in_library_short'|trans %}
          <a href="{{ (item.type == 'movie' ? '/medias/' ~ current_slug('radarr') ~ '/films' : '/medias/' ~ current_slug('sonarr') ~ '/series') ~ '?open=' ~ item.lib_id }}" class="btn btn-sm" style="background:{{ statusColors[item.lib_status] ?? '#22c55e' }};color:#fff;">{{ statusLabel }}</a>
        {% endif %}
      </div>
    </div>
  </div>
{% endmacro %}

<script>
(function() {
  function escHtml(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

  // Localized strings used by the detail modal + toasts. Built server-side
  // so every label stays in sync with the current request locale.
  var TMDB_I18N = {
    type_film:    {{ 'decouverte.modal.type_film'|trans|json_encode|raw }},
    type_series:  {{ 'decouverte.modal.type_series'|trans|json_encode|raw }},
    watchlist:    {{ 'decouverte.modal.watchlist'|trans|json_encode|raw }},
    in_watchlist: {{ 'decouverte.modal.in_watchlist'|trans|json_encode|raw }},
    in_library:   {{ 'decouverte.modal.in_library'|trans|json_encode|raw }},
    not_monitored:{{ 'decouverte.modal.not_monitored'|trans|json_encode|raw }},
    coming_soon:  {{ 'decouverte.modal.coming_soon'|trans|json_encode|raw }},
    in_production:{{ 'decouverte.modal.in_production'|trans|json_encode|raw }},
    ended:        {{ 'decouverte.modal.ended_series'|trans|json_encode|raw }},
    canceled:     {{ 'decouverte.modal.canceled_series'|trans|json_encode|raw }},
    network_error:{{ 'decouverte.modal.network_error'|trans|json_encode|raw }},
    wl_added:     {{ 'decouverte.watchlist.added_toast'|trans|json_encode|raw }},
    wl_removed:   {{ 'decouverte.watchlist.removed_toast'|trans|json_encode|raw }},
    season_tpl:   {{ 'decouverte.modal.season_label'|trans({n: '__N__'})|json_encode|raw }},
    episode_short:{{ 'decouverte.modal.episode_short'|trans|json_encode|raw }},
    impossible:   {{ 'decouverte.modal.impossible'|trans({reason: '__REASON__'})|json_encode|raw }},
    generic_err:  {{ 'decouverte.modal.generic_error'|trans|json_encode|raw }},
    add_to_radarr:{{ 'decouverte.modal.add_to'|trans({service: 'Radarr'})|json_encode|raw }},
    add_to_sonarr:{{ 'decouverte.modal.add_to'|trans({service: 'Sonarr'})|json_encode|raw }},
    view_movies:  {{ 'decouverte.modal.view_in'|trans({section: 'decouverte.modal.view_movies'|trans})|json_encode|raw }},
    view_series:  {{ 'decouverte.modal.view_in'|trans({section: 'decouverte.modal.view_series'|trans})|json_encode|raw }},
    lib_status: {
      downloaded:  {{ 'decouverte.modal.status.downloaded'|trans|json_encode|raw }},
      missing:     {{ 'decouverte.modal.status.missing'|trans|json_encode|raw }},
      announced:   {{ 'decouverte.modal.status.announced'|trans|json_encode|raw }},
      inCinemas:   {{ 'decouverte.modal.status.inCinemas'|trans|json_encode|raw }},
      partial:     {{ 'decouverte.modal.status.partial'|trans|json_encode|raw }},
      unmonitored: {{ 'decouverte.modal.status.unmonitored'|trans|json_encode|raw }},
    },
    tmdb_status: {
      'Released':         {{ 'decouverte.modal.tmdb_status.released'|trans|json_encode|raw }},
      'Post Production':  {{ 'decouverte.modal.tmdb_status.post_production'|trans|json_encode|raw }},
      'In Production':    {{ 'decouverte.modal.tmdb_status.in_production'|trans|json_encode|raw }},
      'Planned':          {{ 'decouverte.modal.tmdb_status.planned'|trans|json_encode|raw }},
      'Rumored':          {{ 'decouverte.modal.tmdb_status.rumored'|trans|json_encode|raw }},
      'Canceled':         {{ 'decouverte.modal.tmdb_status.canceled'|trans|json_encode|raw }},
      'Ended':            {{ 'decouverte.modal.tmdb_status.ended'|trans|json_encode|raw }},
      'Returning Series': {{ 'decouverte.modal.tmdb_status.returning_series'|trans|json_encode|raw }},
      'Pilot':            {{ 'decouverte.modal.tmdb_status.pilot'|trans|json_encode|raw }},
    },
    qi: {
      release:         {{ 'decouverte.modal.qi.release'|trans|json_encode|raw }},
      runtime:         {{ 'decouverte.modal.qi.runtime'|trans|json_encode|raw }},
      episode_runtime: {{ 'decouverte.modal.qi.episode_runtime'|trans|json_encode|raw }},
      status:          {{ 'decouverte.modal.qi.status'|trans|json_encode|raw }},
      certification:   {{ 'decouverte.modal.qi.certification'|trans|json_encode|raw }},
      orig_language:   {{ 'decouverte.modal.qi.orig_language'|trans|json_encode|raw }},
      country:         {{ 'decouverte.modal.qi.country'|trans|json_encode|raw }},
      budget:          {{ 'decouverte.modal.qi.budget'|trans|json_encode|raw }},
      box_office:      {{ 'decouverte.modal.qi.box_office'|trans|json_encode|raw }},
      votes:           {{ 'decouverte.modal.qi.votes'|trans|json_encode|raw }},
      popularity:      {{ 'decouverte.modal.qi.popularity'|trans|json_encode|raw }},
    },
    provider: {
      flatrate: {{ 'decouverte.modal.provider.flatrate'|trans|json_encode|raw }},
      rent:     {{ 'decouverte.modal.provider.rent'|trans|json_encode|raw }},
      buy:      {{ 'decouverte.modal.provider.buy'|trans|json_encode|raw }},
    },
    info_row: {
      director:       {{ 'decouverte.modal.info_row.director'|trans|json_encode|raw }},
      writers:        {{ 'decouverte.modal.info_row.writers'|trans|json_encode|raw }},
      composers:      {{ 'decouverte.modal.info_row.composers'|trans|json_encode|raw }},
      cinematography: {{ 'decouverte.modal.info_row.cinematography'|trans|json_encode|raw }},
      creators:       {{ 'decouverte.modal.info_row.creators'|trans|json_encode|raw }},
      production:     {{ 'decouverte.modal.info_row.production'|trans|json_encode|raw }},
      network:        {{ 'decouverte.modal.info_row.network'|trans|json_encode|raw }},
      country:        {{ 'decouverte.modal.info_row.country'|trans|json_encode|raw }},
      orig_language:  {{ 'decouverte.modal.info_row.orig_language'|trans|json_encode|raw }},
      languages:      {{ 'decouverte.modal.info_row.languages'|trans|json_encode|raw }},
      classification: {{ 'decouverte.modal.info_row.classification'|trans|json_encode|raw }},
      budget:         {{ 'decouverte.modal.info_row.budget'|trans|json_encode|raw }},
      revenue:        {{ 'decouverte.modal.info_row.revenue'|trans|json_encode|raw }},
      episode_runtime:{{ 'decouverte.modal.info_row.episode_runtime'|trans|json_encode|raw }},
      tags:           {{ 'decouverte.modal.info_row.tags'|trans|json_encode|raw }},
      popularity:     {{ 'decouverte.modal.info_row.popularity_tmdb'|trans|json_encode|raw }},
    },
    // ICU template for "N seasons · M episodes"
    seasons_tpl: {
      one_one:     {{ 'decouverte.modal.seasons_episodes'|trans({seasons: 1, episodes: 1})|json_encode|raw }},
      one_many:    {{ 'decouverte.modal.seasons_episodes'|trans({seasons: 1, episodes: 9})|json_encode|raw }},
      many_one:    {{ 'decouverte.modal.seasons_episodes'|trans({seasons: 9, episodes: 1})|json_encode|raw }},
      many_many:   {{ 'decouverte.modal.seasons_episodes'|trans({seasons: 9, episodes: 9})|json_encode|raw }},
    },
  };
  function seasonsEpisodes(s, e) {
    var key = (s === 1 ? 'one' : 'many') + '_' + (e === 1 ? 'one' : 'many');
    var tpl = TMDB_I18N.seasons_tpl[key] || '';
    var idx = 0;
    return tpl.replace(/\b\d+\b/g, function() {
      return String(idx++ === 0 ? s : e);
    });
  }

  // ── Scroll horizontal par boutons
  document.querySelectorAll('[data-section]').forEach(function(section) {
    var row = section.querySelector('.tmdb-row');
    if (!row) return;
    section.querySelectorAll('.tmdb-scroll-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var dir = btn.dataset.scroll === 'right' ? 1 : -1;
        row.scrollBy({ left: dir * (row.clientWidth * 0.75), behavior: 'smooth' });
      });
    });
  });

  // ── Recently viewed (localStorage) ────────────────────────
  var RECENT_KEY = 'prismarr_tmdb_recent';
  var RECENT_MAX = 10;
  var recentBlock = document.getElementById('tmdb-recent');
  var recentRow   = document.getElementById('tmdb-recent-row');

  function getRecent() {
    try { return JSON.parse(localStorage.getItem(RECENT_KEY)) || []; } catch(e) { return []; }
  }

  function saveRecent(list) {
    localStorage.setItem(RECENT_KEY, JSON.stringify(list));
  }

  function pushRecent(item) {
    var list = getRecent().filter(function(r) { return !(r.id === item.id && r.type === item.type); });
    list.unshift(item);
    if (list.length > RECENT_MAX) list = list.slice(0, RECENT_MAX);
    saveRecent(list);
    renderRecent();
  }

  function renderRecent() {
    var list = getRecent();
    if (!list.length) { recentBlock.style.display = 'none'; return; }
    recentBlock.style.display = '';
    recentRow.innerHTML = list.map(renderCardHTML).join('');
    if (window._prismarrWatchlistSync) window._prismarrWatchlistSync();
  }

  renderRecent();

  var clearBtn = document.getElementById('tmdb-recent-clear');
  if (clearBtn) {
    clearBtn.addEventListener('click', function() {
      localStorage.removeItem(RECENT_KEY);
      renderRecent();
    });
  }

  // ── J-X countdown on Twig cards (client-side)
  function applyCountdowns() {
    document.querySelectorAll('.media-card[data-release]').forEach(function(card) {
      var rel = card.dataset.release;
      if (!rel) return;
      if (card.querySelector('.countdown-badge')) return; // already added
      var diff = Math.ceil((new Date(rel) - new Date()) / 86400000);
      if (diff > 0 && diff <= 365) {
        var badge = document.createElement('span');
        badge.className = 'countdown-badge';
        badge.textContent = 'J-' + diff;
        card.appendChild(badge);
      }
    });
  }
  applyCountdowns();

  // ── Add button → resolve + open existing quick-add modal (base.html.twig)
  function triggerQuickAdd(item) {
    // Create an ephemeral element with data-quick-add to trigger the global listener
    var trigger = document.createElement('button');
    trigger.setAttribute('data-quick-add', JSON.stringify(item));
    trigger.style.display = 'none';
    document.body.appendChild(trigger);
    trigger.click();
    setTimeout(function() { trigger.remove(); }, 100);
  }

  function handleAddClick(btn) {
    var type = btn.dataset.tmdbType;  // 'movie' | 'tv'
    var id   = btn.dataset.tmdbId;
    var orig = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

    fetch('/decouverte/resolve/' + type + '/' + id, { credentials: 'same-origin' })
      .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, body: d }; }); })
      .then(function(res) {
        btn.disabled = false;
        btn.innerHTML = orig;
        if (!res.ok) {
          if (window._prismarrToast) {
            window._prismarrToast(TMDB_I18N.impossible.replace('__REASON__', res.body.error || TMDB_I18N.generic_err), 'danger');
          }
          return;
        }
        triggerQuickAdd(res.body);
      })
      .catch(function() {
        btn.disabled = false;
        btn.innerHTML = orig;
        if (window._prismarrToast) window._prismarrToast(TMDB_I18N.network_error, 'danger');
      });
  }

  document.addEventListener('click', function(e) {
    var addBtn = e.target.closest('.tmdb-add-btn');
    if (addBtn) {
      e.preventDefault();
      e.stopPropagation();
      handleAddClick(addBtn);
      return;
    }
  });

  // ── Click on card → Prismarr detail modal (Turbo-safe manual open)
  var detailModal    = document.getElementById('tmdb-detail-modal');
  var detailLoading  = document.getElementById('tmdb-detail-loading');
  var detailContent  = document.getElementById('tmdb-detail-content');

  function openDetailModal() {
    detailLoading.style.display = '';
    detailContent.style.display = 'none';
    detailModal.classList.add('show');
    detailModal.style.display = 'block';
    detailModal.setAttribute('aria-modal', 'true');
    detailModal.removeAttribute('aria-hidden');
    document.body.classList.add('modal-open');
    if (!document.querySelector('.modal-backdrop.tmdb-detail-backdrop')) {
      var bd = document.createElement('div');
      bd.className = 'modal-backdrop fade show tmdb-detail-backdrop';
      document.body.appendChild(bd);
    }
  }

  function closeDetailModal() {
    detailModal.classList.remove('show');
    detailModal.style.display = 'none';
    detailModal.setAttribute('aria-hidden', 'true');
    detailModal.removeAttribute('aria-modal');
    var bd = document.querySelector('.modal-backdrop.tmdb-detail-backdrop');
    if (bd) bd.remove();
    if (!document.querySelector('.modal.show')) {
      document.body.classList.remove('modal-open');
    }
    var trWrap = document.getElementById('td-trailer');
    if (trWrap) trWrap.innerHTML = '';
  }

  // Close on X, backdrop, ESC
  detailModal.addEventListener('click', function(e) {
    if (e.target.closest('[data-bs-dismiss="modal"]')) {
      e.preventDefault();
      closeDetailModal();
      return;
    }
    if (e.target === detailModal) {
      closeDetailModal();
    }
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && detailModal.classList.contains('show')) {
      closeDetailModal();
    }
  });

  function voteClass(v) {
    if (v >= 7) return 'good';
    if (v >= 5) return 'mid';
    return 'bad';
  }

  function renderDetail(d) {
    detailLoading.style.display = 'none';
    detailContent.style.display = '';

    // Save to "Recently viewed"
    pushRecent({
      id: d.id, type: d.type, title: d.title, year: d.year,
      poster: d.poster, vote: d.vote, vote_count: d.vote_count,
      in_library: d.in_library, lib_status: d.lib_status, lib_id: d.lib_id
    });

    var safeTitle = escHtml(d.title || '—');

    // Backdrop
    var bg = document.getElementById('td-backdrop');
    if (d.backdrop) {
      bg.style.backgroundImage = 'url("' + d.backdrop + '")';
    } else {
      bg.style.backgroundImage = 'none';
      bg.style.background = '#1a1a1f';
    }

    // Header : badge type + titre + original + tagline
    var typeBadge = document.getElementById('td-type-badge');
    typeBadge.textContent = d.type === 'movie' ? TMDB_I18N.type_film : TMDB_I18N.type_series;
    typeBadge.className = 'badge ' + (d.type === 'movie' ? 'bg-warning text-dark' : 'bg-info text-dark');
    document.getElementById('td-title').textContent = d.title || '—';
    var orig = document.getElementById('td-original');
    if (d.original && d.original !== d.title) { orig.textContent = d.original; orig.style.display = ''; }
    else { orig.style.display = 'none'; }
    var tg = document.getElementById('td-tagline');
    if (d.tagline) { tg.textContent = '« ' + d.tagline + ' »'; tg.style.display = ''; }
    else { tg.style.display = 'none'; }

    // Meta header: year, runtime, seasons, status, TMDb rating
    document.getElementById('td-year').textContent = d.year || '';
    var rt = document.getElementById('td-runtime');
    if (d.runtime) { rt.textContent = d.runtime + ' min'; rt.style.display = ''; } else { rt.style.display = 'none'; }
    var se = document.getElementById('td-meta-seasons');
    if (d.seasons) { se.textContent = seasonsEpisodes(d.seasons, d.episodes || 0); se.style.display = ''; } else { se.style.display = 'none'; }
    var st = document.getElementById('td-status-info');
    if (d.status) { st.textContent = d.status; st.style.display = ''; } else { st.style.display = 'none'; }
    if (d.vote) {
      document.getElementById('td-rating-tmdb').style.display = '';
      document.getElementById('td-rating-tmdb-val').textContent = d.vote + ' / 10';
    } else {
      document.getElementById('td-rating-tmdb').style.display = 'none';
    }

    // Genres
    var genresEl = document.getElementById('td-genres');
    genresEl.innerHTML = (d.genres || []).map(function(g) {
      return '<span class="td-genre-badge">' + escHtml(g) + '</span>';
    }).join('');

    // Poster
    var poster = document.getElementById('td-poster');
    if (d.poster) { poster.src = d.poster; poster.alt = d.title || ''; poster.style.display = ''; }
    else { poster.style.display = 'none'; }

    // Status badges (left column) — white text forced on colored background
    var badges = [];
    function mkBadge(bg, text, icon) {
      var i = icon ? '<svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="margin-right:3px; vertical-align:-1px;">' + icon + '</svg>' : '';
      return '<span class="badge" style="background:' + bg + '; color:#fff; font-weight:600;">' + i + text + '</span>';
    }
    if (d.in_library && d.lib_status) {
      var statusMap = {
        'downloaded':  { bg: '#22c55e', label: TMDB_I18N.lib_status.downloaded,  icon: '<path d="M5 12l5 5l10-10"/>' },
        'missing':     { bg: '#f59e0b', label: TMDB_I18N.lib_status.missing,     icon: null },
        'announced':   { bg: '#6366f1', label: TMDB_I18N.lib_status.announced,   icon: null },
        'inCinemas':   { bg: '#6366f1', label: TMDB_I18N.lib_status.inCinemas,   icon: null },
        'partial':     { bg: '#3b82f6', label: TMDB_I18N.lib_status.partial,     icon: null },
        'unmonitored': { bg: '#6b7280', label: TMDB_I18N.lib_status.unmonitored, icon: null }
      };
      var libSt = statusMap[d.lib_status] || { bg: '#22c55e', label: TMDB_I18N.in_library, icon: '<path d="M5 12l5 5l10-10"/>' };
      badges.push(mkBadge(libSt.bg, libSt.label, libSt.icon));
    } else if (d.in_library) {
      badges.push(mkBadge('#22c55e', TMDB_I18N.in_library, '<path d="M5 12l5 5l10-10"/>'));
    } else {
      badges.push(mkBadge('#64748b', TMDB_I18N.not_monitored, null));
    }
    if (!d.in_library && d.release) {
      var now = new Date();
      var rel = new Date(d.release);
      if (rel > now) badges.push(mkBadge('#6366f1', TMDB_I18N.coming_soon, null));
    }
    if (d.status === 'In Production' || d.status === 'Returning Series') {
      badges.push(mkBadge('#3b82f6', TMDB_I18N.in_production, null));
    } else if (d.status === 'Ended') {
      badges.push(mkBadge('#f59e0b', TMDB_I18N.ended, null));
    } else if (d.status === 'Canceled') {
      badges.push(mkBadge('#ef4444', TMDB_I18N.canceled, null));
    }
    document.getElementById('td-status-badges').innerHTML = badges.join(' ');

    // Actions (colonne gauche, verticales comme films modal)
    var actions = [];
    if (!d.in_library) {
      actions.push('<button class="btn btn-primary tmdb-add-btn" data-tmdb-id="' + d.id + '" data-tmdb-type="' + d.type + '" data-tmdb-title="' + safeTitle + '">'
        + '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><path d="M12 5v14"/><path d="M5 12h14"/></svg>' + (d.type === 'movie' ? TMDB_I18N.add_to_radarr : TMDB_I18N.add_to_sonarr) + '</button>');
    } else {
      var libUrl = d.type === 'movie' ? '/medias/' + DEFAULT_RADARR_SLUG + '/films' : '/medias/' + DEFAULT_SONARR_SLUG + '/series';
      if (d.lib_id) libUrl += '?open=' + d.lib_id;
      var btnClass = d.lib_status === 'downloaded' ? 'btn-success' : (d.lib_status === 'missing' || d.lib_status === 'partial' ? 'btn-warning' : 'btn-outline-primary');
      actions.push('<a href="' + libUrl + '" class="btn ' + btnClass + '">'
        + '<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><path d="M5 12l5 5l10-10"/></svg>' + (d.type === 'movie' ? TMDB_I18N.view_movies : TMDB_I18N.view_series) + '</a>');
    }
    // Bouton watchlist dans la modal
    var wlKey = d.type + '_' + d.id;
    var isInWl = window._prismarrWatchlist && window._prismarrWatchlist[wlKey];
    actions.push('<button class="btn ' + (isInWl ? 'btn-warning' : 'btn-outline-warning') + ' tmdb-wl-modal-btn" data-tmdb-id="' + d.id + '" data-tmdb-type="' + d.type + '" data-tmdb-title="' + safeTitle + '" data-poster-path="' + (d.poster_path || '') + '" data-vote="' + (d.vote || '') + '" data-year="' + (d.year || '') + '">'
      + '<svg width="15" height="15" viewBox="0 0 24 24" fill="' + (isInWl ? '#fff' : 'none') + '" stroke="currentColor" stroke-width="2" class="me-1"><path d="M12 2l2.4 7.4h7.6l-6.2 4.5 2.4 7.4-6.2-4.6-6.2 4.6 2.4-7.4-6.2-4.5h7.6z"/></svg>'
      + (isInWl ? TMDB_I18N.in_watchlist : TMDB_I18N.watchlist) + '</button>');

    document.getElementById('td-actions').innerHTML = actions.join('');

    // External links
    var ext = [];
    ext.push('<a href="https://www.themoviedb.org/' + d.type + '/' + d.id + '" target="_blank" rel="noopener" class="btn btn-sm btn-outline-secondary">TMDb ↗</a>');
    if (d.imdb_id) ext.push('<a href="https://www.imdb.com/title/' + d.imdb_id + '" target="_blank" rel="noopener" class="btn btn-sm btn-outline-secondary">IMDb ↗</a>');
    if (d.homepage && /^https?:\/\//.test(d.homepage)) ext.push('<a href="' + d.homepage + '" target="_blank" rel="noopener" class="btn btn-sm btn-outline-secondary">Site ↗</a>');
    document.getElementById('td-external-links').innerHTML = ext.join('');

    // Synopsis
    var ovBlock = document.getElementById('td-overview-block');
    if (d.overview) {
      document.getElementById('td-overview').textContent = d.overview;
      ovBlock.style.display = '';
    } else {
      ovBlock.style.display = 'none';
    }

    // Trailer + galerie alternatives
    var trBlock   = document.getElementById('td-trailer-block');
    var trWrap    = document.getElementById('td-trailer');
    var trName    = document.getElementById('td-trailer-name');
    var trYtLink  = document.getElementById('td-trailer-yt-link');
    var galWrap   = document.getElementById('td-video-gallery');

    function playVideo(key, name) {
      trWrap.innerHTML = '<iframe src="https://www.youtube.com/embed/' + key + '?rel=0&cc_lang_pref=fr&hl=fr" allowfullscreen allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"></iframe>';
      trName.textContent = name ? '— ' + name : '';
      trYtLink.href = 'https://www.youtube.com/watch?v=' + key;
      // Marquer le bouton actif
      galWrap.querySelectorAll('.td-video-btn').forEach(function(b) {
        b.classList.toggle('active', b.dataset.ytKey === key);
      });
    }

    if (d.trailer && d.trailer.key) {
      playVideo(d.trailer.key, d.trailer.name);
      // Galerie : trailer principal + alternatives
      var videos = [d.trailer].concat(d.video_gallery || []);
      if (videos.length > 1) {
        galWrap.innerHTML = videos.map(function(v, i) {
          return '<button type="button" class="td-video-btn" data-yt-key="' + v.key + '" data-yt-name="' + (v.name||'').replace(/"/g,'&quot;') + '">' + (v.type || 'Trailer') + (i === 0 ? ' ' + {{ ico.icon('star-filled', '', 12)|json_encode|raw }} : '') + '</button>';
        }).join('');
        galWrap.style.display = '';
        // Re-activate the current button
        var firstBtn = galWrap.querySelector('[data-yt-key="' + d.trailer.key + '"]');
        if (firstBtn) firstBtn.classList.add('active');
      } else {
        galWrap.style.display = 'none';
        galWrap.innerHTML = '';
      }
      trBlock.style.display = '';
    } else {
      trWrap.innerHTML = '';
      galWrap.innerHTML = '';
      galWrap.style.display = 'none';
      trBlock.style.display = 'none';
    }

    // Cast (style cast-scroll avec avatars 64px ronds comme modal Films)
    var castBlock = document.getElementById('td-cast-block');
    if (d.cast && d.cast.length) {
      document.getElementById('td-cast').innerHTML = d.cast.map(function(c) {
        var photo = c.profile
          ? '<img src="' + c.profile + '" alt="" loading="lazy">'
          : '<img src="data:image/svg+xml;utf8,%3Csvg xmlns=\'http://www.w3.org/2000/svg\' width=\'64\' height=\'64\' viewBox=\'0 0 24 24\' fill=\'%23888\'%3E%3Cpath d=\'M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z\'/%3E%3C/svg%3E">';
        return '<div class="td-cast-card">' + photo
          + '<div class="cast-name">' + escHtml(c.name || '—') + '</div>'
          + '<span class="cast-role">' + escHtml(c.character || '') + '</span></div>';
      }).join('');
      castBlock.style.display = '';
    } else {
      castBlock.style.display = 'none';
    }

    // Quick info (left column) — date, runtime, status, language, classification, vote count
    var qiBlock = document.getElementById('td-quickinfo-block');
    var qiRows = [];
    function qi(icon, label, value) {
      if (!value) return;
      var safe = escHtml(String(value));
      qiRows.push('<div class="qi-row"><span class="qi-icon">' + icon + '</span><span class="qi-label">' + escHtml(label) + '</span><span class="qi-value" title="' + safe + '">' + safe + '</span></div>');
    }
    qi({{ ico.icon('calendar', '', 16)|json_encode|raw }}, TMDB_I18N.qi.release, d.release || null);
    if (d.type === 'movie' && d.runtime) {
      var h = Math.floor(d.runtime / 60);
      var m = d.runtime % 60;
      qi({{ ico.icon('clock', '', 16)|json_encode|raw }}, TMDB_I18N.qi.runtime, (h > 0 ? h + 'h' + (m > 0 ? String(m).padStart(2, '0') : '') : m + ' min'));
    } else if (d.type === 'tv' && d.episode_runtime) {
      qi({{ ico.icon('clock', '', 16)|json_encode|raw }}, TMDB_I18N.qi.episode_runtime, d.episode_runtime + ' min');
    }
    qi({{ ico.icon('movie', '', 16)|json_encode|raw }}, TMDB_I18N.qi.status, d.status ? (TMDB_I18N.tmdb_status[d.status] || d.status) : null);
    qi({{ ico.icon('masks-theater', '', 16)|json_encode|raw }}, TMDB_I18N.qi.certification, d.certification);
    qi({{ ico.icon('language', '', 16)|json_encode|raw }}, TMDB_I18N.qi.orig_language, d.original_language ? d.original_language.toUpperCase() : null);
    qi({{ ico.icon('world', '', 16)|json_encode|raw }}, TMDB_I18N.qi.country, (d.countries && d.countries.length) ? d.countries[0] : null);
    if (d.type === 'movie' && d.budget && d.budget > 0) {
      qi({{ ico.icon('coin', '', 16)|json_encode|raw }}, TMDB_I18N.qi.budget, '$' + (d.budget / 1e6).toFixed(1) + 'M');
    }
    if (d.type === 'movie' && d.revenue && d.revenue > 0) {
      qi({{ ico.icon('cash', '', 16)|json_encode|raw }}, TMDB_I18N.qi.box_office, '$' + (d.revenue / 1e6).toFixed(1) + 'M');
    }
    if (d.vote_count) qi({{ ico.icon('star-filled', '', 16)|json_encode|raw }}, TMDB_I18N.qi.votes, d.vote_count.toLocaleString());
    if (d.popularity) qi({{ ico.icon('flame', '', 16)|json_encode|raw }}, TMDB_I18N.qi.popularity, d.popularity);
    if (qiRows.length) {
      document.getElementById('td-quickinfo').innerHTML = qiRows.join('');
      qiBlock.style.display = '';
    } else {
      qiBlock.style.display = 'none';
    }

    // Providers streaming (version compacte colonne gauche)
    var provBlock = document.getElementById('td-providers-block');
    var totalProv = 0;
    if (d.providers) {
      totalProv = (d.providers.flatrate || []).length + (d.providers.rent || []).length + (d.providers.buy || []).length;
    }
    if (totalProv > 0) {
      document.getElementById('td-providers-country').textContent = '(' + d.providers.country + ')';
      var provHtml = '';
      function renderProviderGroup(label, list) {
        if (!list || !list.length) return '';
        var items = list.map(function(p) {
          return p.logo
            ? '<img src="' + p.logo + '" alt="' + (p.name||'') + '" title="' + (p.name||'').replace(/"/g,'&quot;') + '">'
            : '<span class="badge bg-secondary-lt">' + (p.name||'') + '</span>';
        }).join('');
        return '<div class="provider-group"><div class="provider-group-label">' + label + '</div><div class="provider-logos">' + items + '</div></div>';
      }
      provHtml += renderProviderGroup(TMDB_I18N.provider.flatrate, d.providers.flatrate);
      provHtml += renderProviderGroup(TMDB_I18N.provider.rent, d.providers.rent);
      provHtml += renderProviderGroup(TMDB_I18N.provider.buy, d.providers.buy);
      if (d.providers.link) provHtml += '<a href="' + d.providers.link + '" target="_blank" rel="noopener" class="small d-block mt-1">JustWatch ↗</a>';
      document.getElementById('td-providers').innerHTML = provHtml;
      provBlock.style.display = '';
    } else {
      provBlock.style.display = 'none';
    }

    // Collection (films uniquement)
    var colBlock = document.getElementById('td-collection-block');
    if (d.collection && d.collection.name) {
      var cp = document.getElementById('td-collection-poster');
      if (d.collection.poster) { cp.src = d.collection.poster; cp.style.display = ''; }
      else { cp.style.display = 'none'; }
      document.getElementById('td-collection-name').textContent = d.collection.name;
      colBlock.style.display = '';
    } else {
      colBlock.style.display = 'none';
    }

    // Next/Last episode (TV series)
    function fmtEp(ep) {
      var code = 'S' + String(ep.season).padStart(2, '0') + 'E' + String(ep.episode).padStart(2, '0');
      return code + (ep.name ? ' — ' + ep.name : '');
    }
    var nextBlock = document.getElementById('td-next-ep-block');
    if (d.next_episode) {
      document.getElementById('td-next-ep-label').textContent = fmtEp(d.next_episode);
      document.getElementById('td-next-ep-date').textContent = d.next_episode.air_date || '';
      nextBlock.style.display = '';
    } else {
      nextBlock.style.display = 'none';
    }
    var lastBlock = document.getElementById('td-last-ep-block');
    if (d.last_episode) {
      document.getElementById('td-last-ep-label').textContent = fmtEp(d.last_episode);
      document.getElementById('td-last-ep-date').textContent = d.last_episode.air_date || '';
      lastBlock.style.display = '';
    } else {
      lastBlock.style.display = 'none';
    }

    // Info table: director, writers, composer, studio, country, language, budget, revenue, certification, keywords
    var infoRows = [];
    function addRow(label, value) {
      if (value === null || value === undefined || value === '' || (Array.isArray(value) && !value.length)) return;
      var displayed = Array.isArray(value) ? value.join(', ') : value;
      infoRows.push('<tr><td class="text-muted" style="width:30%">' + label + '</td><td>' + displayed + '</td></tr>');
    }
    if (d.crew) {
      addRow(TMDB_I18N.info_row.director, d.crew.directors);
      addRow(TMDB_I18N.info_row.writers, d.crew.writers);
      addRow(TMDB_I18N.info_row.composers, d.crew.composers);
      if (d.crew.cinematographers) addRow(TMDB_I18N.info_row.cinematography, d.crew.cinematographers);
    }
    if (d.creators && d.creators.length) addRow(TMDB_I18N.info_row.creators, d.creators);
    if (d.companies && d.companies.length) {
      var compHtml = d.companies.map(function(c) {
        return c.logo
          ? '<img src="' + c.logo + '" alt="" title="' + (c.name||'').replace(/"/g,'&quot;') + '" style="height:20px; object-fit:contain; background:white; padding:2px 4px; border-radius:3px; margin-right:4px;">'
          : '<span class="badge bg-secondary-lt me-1">' + c.name + '</span>';
      }).join('');
      infoRows.push('<tr><td class="text-muted">' + TMDB_I18N.info_row.production + '</td><td>' + compHtml + '</td></tr>');
    }
    if (d.networks && d.networks.length) {
      var netHtml = d.networks.map(function(n) {
        return n.logo
          ? '<img src="' + n.logo + '" alt="" title="' + (n.name||'').replace(/"/g,'&quot;') + '" style="height:20px; object-fit:contain; background:white; padding:2px 4px; border-radius:3px; margin-right:4px;">'
          : '<span class="badge bg-secondary-lt me-1">' + n.name + '</span>';
      }).join('');
      infoRows.push('<tr><td class="text-muted">' + TMDB_I18N.info_row.network + '</td><td>' + netHtml + '</td></tr>');
    }
    addRow(TMDB_I18N.info_row.country, d.countries);
    addRow(TMDB_I18N.info_row.orig_language, d.original_language ? d.original_language.toUpperCase() : null);
    addRow(TMDB_I18N.info_row.languages, d.spoken_languages);
    addRow(TMDB_I18N.info_row.classification, d.certification);
    if (d.budget && d.budget > 0) addRow(TMDB_I18N.info_row.budget, '$' + d.budget.toLocaleString());
    if (d.revenue && d.revenue > 0) addRow(TMDB_I18N.info_row.revenue, '$' + d.revenue.toLocaleString());
    if (d.episode_runtime) addRow(TMDB_I18N.info_row.episode_runtime, d.episode_runtime + ' min');
    if (d.keywords && d.keywords.length) {
      addRow(TMDB_I18N.info_row.tags, d.keywords.map(function(k) { return '<span class="td-genre-badge me-1" style="color:var(--tblr-secondary); background:var(--tblr-bg-surface-secondary); border-color:var(--tblr-border-color);">' + escHtml(k) + '</span>'; }).join(''));
    }
    if (d.popularity) addRow(TMDB_I18N.info_row.popularity, d.popularity);
    var infoBlock = document.getElementById('td-info-block');
    if (infoRows.length) {
      document.getElementById('td-info-rows').innerHTML = infoRows.join('');
      infoBlock.style.display = '';
    } else {
      infoBlock.style.display = 'none';
    }

    // Seasons (TV series)
    var seasonsBlock = document.getElementById('td-seasons-block');
    if (d.seasons_list && d.seasons_list.length) {
      // Sort: season 0 (specials) last
      var sorted = d.seasons_list.slice().sort(function(a, b) {
        if (a.number === 0) return 1;
        if (b.number === 0) return -1;
        return a.number - b.number;
      });
      document.getElementById('td-seasons').innerHTML = sorted.map(function(s) {
        var poster = s.poster
          ? '<img src="' + s.poster + '" alt="" loading="lazy">'
          : '<div class="no-poster"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 4v16l13 -8z"/></svg></div>';
        var year = s.air_date ? s.air_date.substring(0, 4) : '—';
        var vote = s.vote ? '<span class="season-vote">' + {{ ico.icon('star-filled', '', 12)|json_encode|raw }} + ' ' + s.vote + '</span>' : '';
        return '<div class="td-season-card" title="' + (s.overview||'').replace(/"/g,'&quot;') + '">' + poster
          + '<div class="season-body">'
          + '<div class="season-name">' + (s.name || TMDB_I18N.season_tpl.replace('__N__', s.number)) + '</div>'
          + '<div class="season-meta">' + s.episode_count + ' ' + TMDB_I18N.episode_short + ' · ' + year + ' ' + vote + '</div>'
          + '</div></div>';
      }).join('');
      seasonsBlock.style.display = '';
    } else {
      seasonsBlock.style.display = 'none';
    }

    // Titres alternatifs
    var altBlock = document.getElementById('td-alt-titles-block');
    if (d.alt_titles && d.alt_titles.length) {
      document.getElementById('td-alt-titles').innerHTML = d.alt_titles.map(function(t) {
        return '<span class="badge bg-secondary-lt"><span class="text-muted me-1">' + t.country + '</span>' + t.title + '</span>';
      }).join('');
      altBlock.style.display = '';
    } else {
      altBlock.style.display = 'none';
    }

    // Reviews
    var revBlock = document.getElementById('td-reviews-block');
    if (d.reviews && d.reviews.length) {
      document.getElementById('td-reviews').innerHTML = d.reviews.map(function(r) {
        var excerpt = (r.content || '').substring(0, 300);
        if (r.content && r.content.length > 300) excerpt += '…';
        var rating = r.rating ? ' <span class="badge bg-warning ms-2">' + {{ ico.icon('star-filled', '', 12)|json_encode|raw }} + ' ' + r.rating + '/10</span>' : '';
        var link = r.url ? ' <a href="' + r.url + '" target="_blank" rel="noopener" class="small">Lire ↗</a>' : '';
        return '<div class="mb-2 pb-2 border-bottom">'
          + '<div class="d-flex align-items-center gap-2 mb-1"><strong class="small">' + escHtml(r.author) + '</strong>' + rating + link + '</div>'
          + '<div class="small text-muted" style="white-space:pre-wrap;">' + excerpt + '</div></div>';
      }).join('');
      revBlock.style.display = '';
    } else {
      revBlock.style.display = 'none';
    }

    // Galerie backdrops (carousel horizontal + lightbox)
    var backdropsBlock = document.getElementById('td-backdrops-block');
    if (d.backdrops && d.backdrops.length) {
      document.getElementById('td-backdrops').innerHTML = d.backdrops.map(function(b) {
        return '<div class="td-backdrop-thumb" data-td-lb-open="' + b.full + '"><img src="' + b.thumb + '" alt="" loading="lazy"></div>';
      }).join('');
      backdropsBlock.style.display = '';
    } else {
      backdropsBlock.style.display = 'none';
    }

    // Similar (cards plus petites)
    var simBlock = document.getElementById('td-similar-block');
    if (d.similar && d.similar.length) {
      document.getElementById('td-similar').innerHTML = d.similar.map(renderCardHTML).join('');
      simBlock.style.display = '';
    } else {
      simBlock.style.display = 'none';
    }
  }

  // Switch video in the gallery
  document.addEventListener('click', function(e) {
    var vbtn = e.target.closest('.td-video-btn');
    if (!vbtn) return;
    var key = vbtn.dataset.ytKey;
    var name = vbtn.dataset.ytName;
    var trWrap = document.getElementById('td-trailer');
    var trName = document.getElementById('td-trailer-name');
    var trYtLink = document.getElementById('td-trailer-yt-link');
    trWrap.innerHTML = '<iframe src="https://www.youtube.com/embed/' + key + '?rel=0&cc_lang_pref=fr&hl=fr" allowfullscreen allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"></iframe>';
    trName.textContent = name ? '— ' + name : '';
    trYtLink.href = 'https://www.youtube.com/watch?v=' + key;
    vbtn.parentNode.querySelectorAll('.td-video-btn').forEach(function(b) {
      b.classList.toggle('active', b === vbtn);
    });
  });

  // Scroll arrows for similar + seasons + backdrops (in the modal)
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('[data-td-scroll], [data-seasons-scroll], [data-backdrops-scroll]');
    if (!btn) return;
    var rowId, dirAttr;
    if (btn.hasAttribute('data-seasons-scroll'))   { rowId = 'td-seasons';   dirAttr = btn.dataset.seasonsScroll; }
    else if (btn.hasAttribute('data-backdrops-scroll')) { rowId = 'td-backdrops'; dirAttr = btn.dataset.backdropsScroll; }
    else                                           { rowId = 'td-similar';  dirAttr = btn.dataset.tdScroll; }
    var row = document.getElementById(rowId);
    if (!row) return;
    var dir = dirAttr === 'right' ? 1 : -1;
    row.scrollBy({ left: dir * (row.clientWidth * 0.75), behavior: 'smooth' });
  });

  // Lightbox backdrops
  var lb = document.getElementById('td-lightbox');
  var lbImg = document.getElementById('td-lightbox-img');
  document.addEventListener('click', function(e) {
    var open = e.target.closest('[data-td-lb-open]');
    if (open) {
      lbImg.src = open.dataset.tdLbOpen;
      lb.classList.add('show');
      return;
    }
    if (e.target.closest('[data-td-lb-close]') || e.target === lb) {
      lb.classList.remove('show');
      lbImg.src = '';
    }
  });
  document.addEventListener('keydown', function(e) {
    if (!document.getElementById('td-lightbox')) return;
    if (e.key === 'Escape' && lb.classList.contains('show')) {
      lb.classList.remove('show');
      lbImg.src = '';
    }
  });

  function renderCardHTML(item) {
    var vc = item.vote >= 7 ? 'good' : (item.vote >= 5 ? 'mid' : 'bad');
    var safeTitle = escHtml(item.title || '');
    var poster = item.poster
      ? '<img src="' + item.poster + '" alt="" loading="lazy">'
      : '<div class="no-poster">' + {{ ico.icon('movie', '', 32)|json_encode|raw }} + '</div>';
    var statusColors = { downloaded: '#22c55e', missing: '#f59e0b', announced: '#6366f1', inCinemas: '#6366f1', partial: '#3b82f6', unmonitored: '#6b7280' };
    // Short labels (for card badges) — reuse the card.status_short keys
    // from _i18n, with a sensible fallback if a lib_status is unknown.
    var cardShort = {
      downloaded:  {{ 'decouverte.card.status_short.downloaded'|trans|json_encode|raw }},
      missing:     {{ 'decouverte.card.status_short.missing'|trans|json_encode|raw }},
      announced:   {{ 'decouverte.card.status_short.announced'|trans|json_encode|raw }},
      inCinemas:   {{ 'decouverte.card.status_short.inCinemas'|trans|json_encode|raw }},
      partial:     {{ 'decouverte.card.status_short.partial'|trans|json_encode|raw }},
      unmonitored: {{ 'decouverte.card.status_short.unmonitored'|trans|json_encode|raw }},
      _default:    {{ 'decouverte.card.status_short.default'|trans|json_encode|raw }},
    };
    var inLibraryShort = {{ 'decouverte.card.in_library_short'|trans|json_encode|raw }};
    var libBadge = item.in_library ? '<span class="lib-badge" style="background:' + (statusColors[item.lib_status] || '#22c55e') + ';">' + (cardShort[item.lib_status] || cardShort._default) + '</span>' : '';
    var voteBadge = item.vote ? '<span class="vote-badge ' + vc + '">' + {{ ico.icon('star-filled', '', 12)|json_encode|raw }} + ' ' + item.vote + '</span>' : '';
    var hoverBtn  = item.in_library
      ? '<a href="' + (item.type === 'movie' ? '/medias/' + DEFAULT_RADARR_SLUG + '/films' : '/medias/' + DEFAULT_SONARR_SLUG + '/series') + '?open=' + (item.lib_id||'') + '" class="btn btn-sm" style="background:' + ({downloaded:'#22c55e',missing:'#f59e0b',announced:'#6366f1',inCinemas:'#6366f1',partial:'#3b82f6',unmonitored:'#6b7280'}[item.lib_status]||'#22c55e') + ';color:#fff;">' + (cardShort[item.lib_status] || inLibraryShort) + '</a>'
      : '<button type="button" class="btn btn-primary btn-sm tmdb-add-btn" data-tmdb-id="' + item.id + '" data-tmdb-type="' + item.type + '" data-tmdb-title="' + safeTitle + '">' + {{ 'decouverte.action.add'|trans|json_encode|raw }} + '</button>';

    var wlClass = (window._prismarrWatchlist && window._prismarrWatchlist[item.type + '_' + item.id]) ? ' in-wl' : '';
    var wlStar = '<button type="button" class="wl-star' + wlClass + '" data-tmdb-id="' + item.id + '" data-tmdb-type="' + item.type + '" title="Watchlist"><svg viewBox="0 0 24 24" fill="' + (wlClass ? '#f59e0b' : 'none') + '" stroke="#f59e0b" stroke-width="2"><path d="M12 2l2.4 7.4h7.6l-6.2 4.5 2.4 7.4-6.2-4.6-6.2 4.6 2.4-7.4-6.2-4.5h7.6z"/></svg></button>';

    // Countdown J-X
    var countdown = '';
    if (item.release) {
      var diff = Math.ceil((new Date(item.release) - new Date()) / 86400000);
      if (diff > 0 && diff <= 365) countdown = '<span class="countdown-badge">J-' + diff + '</span>';
    }

    // safeTitle is already escHtml'd above; also escape the textual fields
    // (title fallback "—" already safe, but item.title was untrusted and
    // splat raw into innerHTML before this pass). item.year is server-side
    // numeric but defense-in-depth costs nothing.
    var titleOrDash = item.title ? safeTitle : '—';
    var safeYear    = escHtml(item.year || '');
    return '<div class="media-card" data-tmdb-id="' + item.id + '" data-tmdb-type="' + item.type + '" data-tmdb-title="' + safeTitle + '" data-tmdb-vote="' + (item.vote||'') + '" data-tmdb-year="' + safeYear + '" data-release="' + escHtml(item.release||'') + '">'
      + poster
      + '<span class="quality-badge ' + item.type + '">' + (item.type === 'movie' ? TMDB_I18N.type_film : TMDB_I18N.type_series) + '</span>'
      + libBadge + countdown + wlStar + voteBadge
      + '<div class="card-overlay"><div class="card-title-text" title="' + safeTitle + '">' + titleOrDash + '</div>'
      + '<div class="card-year">' + safeYear + '</div></div>'
      + '<div class="hover-info"><div class="h-title">' + titleOrDash + '</div>'
      + '<div class="h-year">' + safeYear + (item.vote ? ' · ' + {{ ico.icon('star-filled', '', 12)|json_encode|raw }} + ' ' + item.vote : '') + '</div>'
      + '<div class="h-actions">' + hoverBtn + '</div></div></div>';
  }

  function loadDetail(type, id) {
    openDetailModal();
    fetch('/decouverte/detail/' + type + '/' + id, { credentials: 'same-origin' })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (d.error) {
          detailLoading.innerHTML = '<div class="alert alert-danger m-4">' + {{ 'decouverte.search.error_prefix'|trans({message: '__MSG__'})|json_encode|raw }}.replace('__MSG__', d.error) + '</div>';
          return;
        }
        renderDetail(d);
      })
      .catch(function() {
        detailLoading.innerHTML = '<div class="alert alert-danger m-4">' + TMDB_I18N.network_error + '</div>';
      });
  }

  document.addEventListener('click', function(e) {
    if (e.target.closest('.tmdb-add-btn') || e.target.closest('.h-actions') || e.target.closest('a') || e.target.closest('.wl-star')) return;
    var card = e.target.closest('.media-card[data-tmdb-id]');
    if (!card) return;
    e.preventDefault();
    loadDetail(card.dataset.tmdbType, card.dataset.tmdbId);
  });


  // Recherche TMDb avec debounce
  var searchInput = document.getElementById('tmdb-search');
  var searchBlock = document.getElementById('tmdb-search-results');
  var searchGrid  = document.getElementById('tmdb-search-grid');
  var searchCount = document.getElementById('tmdb-search-count');
  var searchAbort = null;
  var searchTimer = null;

  var SEARCH_NO_RESULTS_HTML = '<div class="text-secondary py-4 px-2" style="grid-column: 1 / -1;">' + {{ 'decouverte.search.no_results'|trans|json_encode|raw }} + '</div>';

  function runSearch(q) {
    if (searchAbort) { try { searchAbort.abort(); } catch (e) {} }
    if (!q || q.length < 2) {
      searchBlock.style.display = 'none';
      return;
    }
    searchAbort = new AbortController();
    fetch('/decouverte/search?q=' + encodeURIComponent(q), { signal: searchAbort.signal, credentials: 'same-origin' })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        var results = d.results || [];
        searchCount.textContent = '(' + results.length + ')';
        searchBlock.style.display = '';
        if (results.length === 0) {
          searchGrid.innerHTML = SEARCH_NO_RESULTS_HTML;
        } else {
          searchGrid.innerHTML = results.map(renderCardHTML).join('');
          if (window._prismarrWatchlistSync) window._prismarrWatchlistSync();
        }
      })
      .catch(function() {});
  }

  if (searchInput) {
    searchInput.addEventListener('input', function() {
      clearTimeout(searchTimer);
      var v = searchInput.value.trim();
      searchTimer = setTimeout(function() { runSearch(v); }, 300);
    });
  }

  // Hero "View details" button → opens Prismarr modal (not external TMDb)
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('.tmdb-hero-details-btn');
    if (!btn) return;
    e.preventDefault();
    e.stopPropagation();
    loadDetail(btn.dataset.tmdbType, btn.dataset.tmdbId);
  });

  // "For you" filter: All / Movies / TV (3 distinct lists returned by the backend)
  var myRecsSets = { all: [], movie: [], tv: [] };
  var myRecsCountEl = document.getElementById('tmdb-my-recs-count');
  function renderMyRecs(typeFilter) {
    var list = myRecsSets[typeFilter] || [];
    myRecsRow.innerHTML = list.map(renderCardHTML).join('')
      || '<div class="text-secondary py-4 px-2">' + {{ 'decouverte.search.no_filter_item'|trans|json_encode|raw }} + '</div>';
    if (myRecsCountEl) myRecsCountEl.textContent = '(' + list.length + ')';
    if (window._prismarrWatchlistSync) window._prismarrWatchlistSync();
  }
  document.querySelectorAll('input[name="myrecs-filter"]').forEach(function(r) {
    r.addEventListener('change', function() { renderMyRecs(r.value); });
  });

  // Close results (search / filters)
  var searchClose = document.getElementById('tmdb-search-close');
  if (searchClose) {
    searchClose.addEventListener('click', function() {
      searchBlock.style.display = 'none';
      searchInput.value = '';
    });
  }

  // ── Recommendations based on the library (AJAX load on page load)
  var myRecsBlock = document.getElementById('tmdb-my-recs');
  var myRecsRow = document.getElementById('tmdb-my-recs-row');
  fetch('/decouverte/mes-recommandations', { credentials: 'same-origin' })
    .then(function(r) { return r.json(); })
    .then(function(d) {
      if (d.seeds === 0 || !d.results || !d.results.length) {
        myRecsBlock.style.display = 'none';
        return;
      }
      myRecsSets.all   = d.results || [];
      myRecsSets.movie = d.movies  || [];
      myRecsSets.tv    = d.tv      || [];
      renderMyRecs('all');
      myRecsBlock.style.display = '';
      if (window._prismarrWatchlistSync) window._prismarrWatchlistSync();
    })
    .catch(function() { myRecsBlock.style.display = 'none'; });

  // ── Page filters
  var filtersPanel = document.getElementById('tmdb-filters');
  var filtersToggle = document.getElementById('tmdb-filters-toggle');
  var filterGenre   = document.getElementById('filter-genre');
  var filterYearMin = document.getElementById('filter-year-min');
  var filterYearMax = document.getElementById('filter-year-max');
  var filterVoteMin = document.getElementById('filter-vote-min');
  var filterVoteVal = document.getElementById('filter-vote-val');
  var filterSort    = document.getElementById('filter-sort');
  var filterApply   = document.getElementById('filter-apply');
  var filterReset   = document.getElementById('filter-reset');
  var genresCache   = { movie: null, tv: null };

  // This build ships Bootstrap under window.tabler (no window.bootstrap global),
  // so resolve the Offcanvas class defensively rather than assuming `bootstrap`.
  function offcanvasFor(el) {
    var C = (window.bootstrap && window.bootstrap.Offcanvas)
         || (window.tabler && (window.tabler.Offcanvas
              || (window.tabler.bootstrap && window.tabler.bootstrap.Offcanvas)));
    return C ? C.getOrCreateInstance(el) : null;
  }

  filtersToggle.addEventListener('click', function() {
    var oc = offcanvasFor(filtersPanel);
    if (oc) oc.toggle();
    if (!genresCache.movie) loadGenres('movie');
  });

  function currentType() {
    var radio = document.querySelector('input[name="filter-type"]:checked');
    return radio ? radio.value : 'movie';
  }

  function loadGenres(type) {
    fetch('/decouverte/genres/' + type, { credentials: 'same-origin' })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        genresCache[type] = d.genres || [];
        populateGenreSelect();
      });
  }

  function populateGenreSelect() {
    var t = currentType();
    var list = genresCache[t] || [];
    var current = filterGenre.value;
    filterGenre.innerHTML = '<option value="">Tous</option>' + list.map(function(g) {
      return '<option value="' + g.id + '">' + g.name + '</option>';
    }).join('');
    if (list.some(function(g) { return String(g.id) === current; })) filterGenre.value = current;
  }

  // Type change → reload genres + adjust sort (primary_release_date is movie-only)
  document.querySelectorAll('input[name="filter-type"]').forEach(function(r) {
    r.addEventListener('change', function() {
      var t = currentType();
      if (!genresCache[t]) loadGenres(t);
      else populateGenreSelect();
      // For TV series, "primary_release_date" → "first_air_date"
      Array.from(filterSort.options).forEach(function(o) {
        if (t === 'tv' && o.value === 'primary_release_date.desc') { o.value = 'first_air_date.desc'; o.textContent = 'Date diffusion ↓'; }
        if (t === 'movie' && o.value === 'first_air_date.desc')    { o.value = 'primary_release_date.desc'; o.textContent = 'Date sortie ↓'; }
      });
    });
  });

  filterVoteMin.addEventListener('input', function() {
    filterVoteVal.textContent = filterVoteMin.value;
  });

  function updateFilterCount() {
    var n = 0;
    if (filterGenre.value) n++;
    if (filterYearMin.value) n++;
    if (filterYearMax.value) n++;
    if (parseFloat(filterVoteMin.value) > 0) n++;
    var badge = document.getElementById('tmdb-filter-active-count');
    if (n > 0) {
      badge.textContent = n;
      badge.style.display = '';
      filtersToggle.classList.add('active');
    } else {
      badge.style.display = 'none';
      filtersToggle.classList.remove('active');
    }
  }

  function applyFilters() {
    var type = currentType();
    updateFilterCount();
    var params = new URLSearchParams({ type: type });
    if (filterGenre.value)   params.set('genres', filterGenre.value);
    if (filterYearMin.value) params.set('year_min', filterYearMin.value);
    if (filterYearMax.value) params.set('year_max', filterYearMax.value);
    if (parseFloat(filterVoteMin.value) > 0) {
      params.set('vote_min', filterVoteMin.value);
      params.set('vote_count_min', '100'); // évite les films avec 2 votes à 10
    }
    if (filterSort.value)    params.set('sort', filterSort.value);

    var typeLabel = type === 'movie'
      ? {{ 'decouverte.filters.movies'|trans|json_encode|raw }}
      : {{ 'decouverte.filters.series'|trans|json_encode|raw }};
    document.getElementById('tmdb-search-title').textContent = {{ 'decouverte.search.results_filtered'|trans({label: '__LABEL__'})|json_encode|raw }}.replace('__LABEL__', typeLabel);
    searchGrid.innerHTML = '<div class="text-secondary p-3"><span class="spinner-border spinner-border-sm me-2"></span>' + {{ 'decouverte.search.searching'|trans|json_encode|raw }} + '</div>';
    searchBlock.style.display = '';

    fetch('/decouverte/filter?' + params.toString(), { credentials: 'same-origin' })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        searchGrid.innerHTML = (d.results || []).map(renderCardHTML).join('')
          || '<div class="text-secondary p-3">' + {{ 'decouverte.search.no_filter_results'|trans|json_encode|raw }} + '</div>';
        searchCount.textContent = {{ 'decouverte.search.count'|trans({count: '__N__'})|json_encode|raw }}.replace('__N__', d.total_results || (d.results||[]).length);
        if (window._prismarrWatchlistSync) window._prismarrWatchlistSync();
      })
      .catch(function() {
        searchGrid.innerHTML = '<div class="alert alert-danger">' + {{ 'decouverte.search.search_error'|trans|json_encode|raw }} + '</div>';
      });
  }
  filterApply.addEventListener('click', function() {
    applyFilters();
    var oc = offcanvasFor(filtersPanel);
    if (oc) oc.hide();
  });
  filterReset.addEventListener('click', function() {
    filterGenre.value = '';
    filterYearMin.value = '';
    filterYearMax.value = '';
    filterVoteMin.value = 0;
    filterVoteVal.textContent = '0';
    filterSort.value = 'popularity.desc';
    searchBlock.style.display = 'none';
    updateFilterCount();
  });

  // Reset the title on a new text search
  if (searchInput) {
    searchInput.addEventListener('focus', function() {
      document.getElementById('tmdb-search-title').textContent = {{ 'decouverte.search.results'|trans|json_encode|raw }};
    });
  }

  // ── Watchlist ───────────────────────────────────────────
  window._prismarrWatchlist = {};

  // Load the watchlist index on startup
  function syncAllWlStars() {
    document.querySelectorAll('.wl-star[data-tmdb-id]').forEach(function(btn) {
      var key = btn.dataset.tmdbType + '_' + btn.dataset.tmdbId;
      var inWl = !!window._prismarrWatchlist[key];
      btn.classList.toggle('in-wl', inWl);
      btn.querySelector('svg').setAttribute('fill', inWl ? '#f59e0b' : 'none');
    });
    // Counter badge
    var count = Object.keys(window._prismarrWatchlist).length;
    var badge = document.getElementById('tmdb-wl-count');
    if (badge) {
      badge.textContent = count;
      badge.style.display = count > 0 ? '' : 'none';
    }
  }
  window._prismarrWatchlistSync = syncAllWlStars;

  fetch('/decouverte/watchlist/status', { credentials: 'same-origin' })
    .then(function(r) { return r.json(); })
    .then(function(d) {
      window._prismarrWatchlist = d.index || {};
      syncAllWlStars();
    });

  // Toggle watchlist (click on card star or modal button)
  function syncWlUI(tmdbId, type, added) {
    document.querySelectorAll('.wl-star[data-tmdb-id="' + tmdbId + '"][data-tmdb-type="' + type + '"]').forEach(function(s) {
      s.classList.toggle('in-wl', added);
      s.querySelector('svg').setAttribute('fill', added ? '#f59e0b' : 'none');
    });
    var modalBtn = document.querySelector('.tmdb-wl-modal-btn[data-tmdb-id="' + tmdbId + '"]');
    if (modalBtn) {
      modalBtn.className = 'btn ' + (added ? 'btn-warning' : 'btn-outline-warning') + ' tmdb-wl-modal-btn';
      modalBtn.querySelector('svg').setAttribute('fill', added ? '#fff' : 'none');
      var textNode = modalBtn.childNodes[modalBtn.childNodes.length - 1];
      textNode.textContent = added ? 'Dans la watchlist' : 'Watchlist';
    }
    if (window._prismarrWatchlistSync) window._prismarrWatchlistSync();
  }

  function toggleWatchlist(tmdbId, type, title, posterPath, vote, year, btn) {
    var key = type + '_' + tmdbId;
    var wasIn = !!window._prismarrWatchlist[key];
    var willAdd = !wasIn;

    // Optimistic: immediate UI update
    if (willAdd) window._prismarrWatchlist[key] = true;
    else delete window._prismarrWatchlist[key];
    syncWlUI(tmdbId, type, willAdd);

    fetch('/decouverte/watchlist/toggle', {
      method: 'POST',
      credentials: 'same-origin',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        tmdb_id: parseInt(tmdbId),
        type: type,
        title: title,
        poster_path: posterPath || null,
        vote: vote ? parseFloat(vote) : null,
        year: year ? parseInt(year) : null
      })
    })
    .then(function(r) { return r.json(); })
    .then(function(d) {
      // Confirm or correct the state
      var added = d.action === 'added';
      if (added) window._prismarrWatchlist[key] = true;
      else delete window._prismarrWatchlist[key];
      if (added !== willAdd) syncWlUI(tmdbId, type, added);
      if (window._prismarrToast) window._prismarrToast(added ? TMDB_I18N.wl_added : TMDB_I18N.wl_removed, added ? 'success' : 'info');
    })
    .catch(function() {
      // Rollback on network error
      if (wasIn) window._prismarrWatchlist[key] = true;
      else delete window._prismarrWatchlist[key];
      syncWlUI(tmdbId, type, wasIn);
      if (window._prismarrToast) window._prismarrToast(TMDB_I18N.network_error, 'danger');
    });
  }

  // Star click on cards (only .media-card, not .ex-card)
  document.addEventListener('click', function(e) {
    var star = e.target.closest('.wl-star');
    if (!star) return;
    if (!star.closest('.media-card[data-tmdb-id]')) return;
    e.stopPropagation();
    e.preventDefault();
    var card = star.closest('.media-card[data-tmdb-id]');
    var posterImg = card ? card.querySelector('img') : null;
    var posterPath = '';
    if (posterImg && posterImg.src) {
      var match = posterImg.src.match(/\/t\/p\/\w+(\/.+)$/);
      if (match) posterPath = match[1];
    }
    toggleWatchlist(
      star.dataset.tmdbId,
      star.dataset.tmdbType,
      card ? card.dataset.tmdbTitle : '',
      posterPath,
      card ? (card.dataset.tmdbVote || '') : '',
      card ? (card.dataset.tmdbYear || '') : '',
      star
    );
  });

  // Clic bouton watchlist dans la modal
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('.tmdb-wl-modal-btn');
    if (!btn) return;
    e.stopPropagation();
    toggleWatchlist(
      btn.dataset.tmdbId,
      btn.dataset.tmdbType,
      btn.dataset.tmdbTitle,
      btn.dataset.posterPath,
      btn.dataset.vote,
      btn.dataset.year,
      btn
    );
  });

  // Si URL a ?detail=type/id, ouvrir la modal au chargement
  if (document.getElementById('tmdb-detail-modal')) {
    var urlParams = new URLSearchParams(window.location.search);
    var detailParam = urlParams.get('detail');
    if (detailParam) {
      var parts = detailParam.split('/');
      if (parts.length === 2) {
        setTimeout(function() { loadDetail(parts[0], parts[1]); }, 300);
      }
      // Nettoyer l'URL
      history.replaceState(null, '', window.location.pathname);
    }
  }
})();
</script>
{% endblock %}
