{% extends 'base.html.twig' %}
{% import '_icons.html.twig' as ico %}

{% block title %}{{ 'decouverte.watchlist.title'|trans }}{% endblock %}
{% block page_title %}Watchlist{% endblock %}

{% block body %}
<style>
  .wl-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 1rem;
  }
  .wl-card {
    position: relative; border-radius: .5rem; overflow: hidden;
    background: var(--tblr-bg-surface); border: 1px solid var(--tblr-border-color);
    transition: transform .15s, box-shadow .15s; cursor: pointer;
  }
  .wl-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,.3); }
  .wl-card img { width: 100%; aspect-ratio: 2/3; object-fit: cover; display: block; }
  .wl-card .no-poster {
    width: 100%; aspect-ratio: 2/3; display: flex; align-items: center; justify-content: center;
    background: var(--tblr-bg-surface-secondary); color: var(--tblr-muted); font-size: 2rem;
  }
  .wl-card .card-overlay {
    position: absolute; bottom: 0; left: 0; right: 0;
    background: linear-gradient(transparent, rgba(0,0,0,.85));
    padding: .5rem .5rem .4rem;
  }
  .wl-card .card-title { font-size: .78rem; font-weight: 600; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .wl-card .card-sub { font-size: .65rem; color: rgba(255,255,255,.6); }
  .wl-card .type-badge {
    position: absolute; top: .4rem; left: .4rem;
    font-size: .6rem; font-weight: 700; padding: .1rem .35rem;
    border-radius: .25rem; color: #1a1a1a;
  }
  .wl-card .type-badge.movie { background: rgba(255,194,48,.92); }
  .wl-card .type-badge.tv { background: rgba(0,204,255,.92); }
  .wl-card .lib-dot {
    position: absolute; top: .4rem; right: .4rem;
    width: 12px; height: 12px; border-radius: 50%;
    border: 2px solid rgba(0,0,0,.4);
    background: #22c55e; box-shadow: 0 0 6px #22c55e;
  }
  .wl-card .vote-badge {
    position: absolute; bottom: 0; right: 0;
    font-size: .62rem; font-weight: 700; padding: .1rem .35rem;
    border-top-left-radius: .3rem; color: #fff;
  }
  .wl-card .vote-badge.good { background: rgba(34,197,94,.9); }
  .wl-card .vote-badge.mid { background: rgba(245,158,11,.9); }
  .wl-card .vote-badge.bad { background: rgba(239,68,68,.9); }
  .wl-card .wl-remove {
    position: absolute; top: .35rem; right: .35rem;
    width: 24px; height: 24px; border-radius: 50%;
    background: rgba(239,68,68,.85); color: #fff;
    border: none; display: flex; align-items: center; justify-content: center;
    cursor: pointer; opacity: 0; transition: opacity .15s;
    z-index: 5;
  }
  .wl-card:hover .wl-remove { opacity: 1; }
  .wl-card .wl-remove:hover { background: #ef4444; }
  .wl-card .wl-notes-ico {
    position: absolute; top: .35rem; right: 2.2rem;
    width: 24px; height: 24px; border-radius: 50%;
    background: rgba(var(--tblr-primary-rgb),.85); color: #fff;
    border: none; display: flex; align-items: center; justify-content: center;
    cursor: pointer; opacity: 0; transition: opacity .15s;
    z-index: 5;
  }
  .wl-card:hover .wl-notes-ico { opacity: 1; }
  .wl-card .wl-notes-ico:hover { background: var(--tblr-primary); }
  .wl-card .wl-notes-preview {
    position: absolute; bottom: 3.8rem; left: .4rem; right: .4rem;
    font-size: .6rem; color: rgba(255,255,255,.9);
    background: rgba(var(--tblr-primary-rgb),.8); border-radius: .3rem; padding: .15rem .35rem;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    pointer-events: none; z-index: 3;
  }

  .wl-empty {
    text-align: center; padding: 4rem 1rem; color: var(--tblr-muted);
  }
  .wl-empty svg { opacity: .4; margin-bottom: 1rem; }

  .wl-filters { display: flex; gap: .5rem; align-items: center; flex-wrap: wrap; margin-bottom: 1rem; }
  .wl-filter-btn {
    padding: .3rem .7rem; border-radius: .4rem; border: 1px solid var(--tblr-border-color);
    background: var(--tblr-bg-surface); color: var(--tblr-body-color);
    cursor: pointer; font-size: .8rem; font-weight: 500; transition: all .15s;
  }
  .wl-filter-btn:hover, .wl-filter-btn.active { background: var(--tblr-primary); color: #fff; border-color: var(--tblr-primary); }
  .wl-sort-select {
    padding: .3rem .6rem; border-radius: .4rem; border: 1px solid var(--tblr-border-color);
    background: var(--tblr-bg-surface); color: var(--tblr-body-color);
    font-size: .8rem; cursor: pointer;
  }
  .wl-search {
    padding: .3rem .7rem; border-radius: .4rem; border: 1px solid var(--tblr-border-color);
    background: var(--tblr-bg-surface); color: var(--tblr-body-color);
    font-size: .8rem; flex: 1; min-width: 120px; max-width: 250px;
  }
  .wl-search:focus { border-color: var(--tblr-primary); outline: none; box-shadow: 0 0 0 3px rgba(var(--tblr-primary-rgb),.18); }
  .wl-count { font-size: .8rem; color: var(--tblr-muted); }

  /* ── Touch devices: remove/notes buttons are hover-only and unreachable
     on touch (responsive audit 2026-06-29) — keep them always visible with
     a bigger hit area. Desktop hover behaviour unchanged. */
  @media (hover: none) {
    .wl-card .wl-remove,
    .wl-card .wl-notes-ico { opacity: 1; width: 32px; height: 32px; }
    .wl-card .wl-notes-ico { right: 2.6rem; }
  }

  /* ── Mobile/tablet readability floor (responsive audit 2026-06-29) ──
     Floor sub-11px text at 11px (.6875rem) below the lg breakpoint;
     desktop (≥992px) keeps the original sizes. */
  @media (max-width: 991.98px) {
    .wl-card .card-sub,
    .wl-card .type-badge,
    .wl-card .vote-badge,
    .wl-card .wl-notes-preview { font-size: .6875rem; }
  }
</style>

<div class="container-xl">
  <!-- Back to Discover -->
  <div class="mb-3">
    <a href="{{ path('tmdb_index') }}" class="btn btn-outline-secondary btn-sm">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
      {{ 'watchlist_page.back_to_discover'|trans }}
    </a>
  </div>

  <!-- Stats -->
  <div class="row g-3 mb-3">
    <div class="col-auto">
      <div class="card card-sm">
        <div class="card-body d-flex align-items-center gap-2 py-2 px-3">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2"><path d="M12 2l2.4 7.4h7.6l-6.2 4.5 2.4 7.4-6.2-4.6-6.2 4.6 2.4-7.4-6.2-4.5h7.6z"/></svg>
          <span class="fw-bold" id="wl-total">{{ items|length }}</span>
          <span class="text-secondary">{{ 'watchlist_page.count_titles'|trans({count: items|length}) }}</span>
        </div>
      </div>
    </div>
    <div class="col-auto">
      <div class="card card-sm">
        <div class="card-body d-flex align-items-center gap-2 py-2 px-3">
          <span style="color:#ffc230;">{{ ico.icon('movie', '', 16) }}</span>
          <span class="fw-bold" id="wl-movies">{{ items|filter(i => i.type == 'movie')|length }}</span>
          <span class="text-secondary">{{ 'watchlist_page.films_suffix'|trans }}</span>
        </div>
      </div>
    </div>
    <div class="col-auto">
      <div class="card card-sm">
        <div class="card-body d-flex align-items-center gap-2 py-2 px-3">
          <span style="color:#0cf;">{{ ico.icon('device-tv', '', 16) }}</span>
          <span class="fw-bold" id="wl-series">{{ items|filter(i => i.type == 'tv')|length }}</span>
          <span class="text-secondary">{{ 'watchlist_page.series_suffix'|trans }}</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Filtres -->
  <div class="wl-filters">
    <button class="wl-filter-btn active" data-filter="all">{{ 'decouverte.watchlist.filter_all'|trans }}</button>
    <button class="wl-filter-btn" data-filter="movie">{{ 'decouverte.watchlist.filter_movies'|trans }}</button>
    <button class="wl-filter-btn" data-filter="tv">{{ 'decouverte.watchlist.filter_tv'|trans }}</button>
    <select class="wl-sort-select" id="wl-sort">
      <option value="added_desc">{{ 'decouverte.watchlist.sort.added_desc'|trans }}</option>
      <option value="added_asc">{{ 'decouverte.watchlist.sort.added_asc'|trans }}</option>
      <option value="title_asc">{{ 'decouverte.watchlist.sort.title_asc'|trans }}</option>
      <option value="title_desc">{{ 'decouverte.watchlist.sort.title_desc'|trans }}</option>
      <option value="vote_desc">{{ 'decouverte.watchlist.sort.vote_desc'|trans }}</option>
      <option value="year_desc">{{ 'decouverte.watchlist.sort.year_desc'|trans }}</option>
    </select>
    <input type="text" class="wl-search" id="wl-search" placeholder="{{ 'decouverte.watchlist.search_placeholder'|trans }}">
    <span class="wl-count" id="wl-visible-count"></span>
  </div>

  <!-- Grille -->
  <div class="wl-grid" id="wl-grid">
    {% for item in items %}
    <div class="wl-card"
         tabindex="0" role="button" data-kb-activate
         aria-label="{{ item.title }}"
         data-wl-id="{{ item.id }}"
         data-tmdb-id="{{ item.tmdbId }}"
         data-type="{{ item.type }}"
         data-title="{{ item.title }}"
         data-vote="{{ item.vote }}"
         data-year="{{ item.year }}"
         data-added="{{ item.addedAt }}"
         data-notes="{{ item.notes|default('')|e('html_attr') }}">
      {% if item.poster %}
        <img src="{{ item.poster }}" alt="{{ item.title }}" loading="lazy">
      {% else %}
        <div class="no-poster">{{ ico.icon('movie', '', 32) }}</div>
      {% endif %}
      <span class="type-badge {{ item.type }}">{{ item.type == 'movie' ? 'decouverte.watchlist.type_film'|trans : 'decouverte.watchlist.type_tv'|trans }}</span>
      {% if item.in_library %}
        <span class="lib-dot" title="{{ 'decouverte.badge.in_library'|trans }}"></span>
      {% endif %}
      {% if item.vote %}
        {% set vc = item.vote >= 7 ? 'good' : (item.vote >= 5 ? 'mid' : 'bad') %}
        <span class="vote-badge {{ vc }}">{{ ico.icon('star-filled', '', 14) }} {{ item.vote }}</span>
      {% endif %}
      {% if item.notes %}
        <div class="wl-notes-preview">{{ ico.icon('note', '', 14) }} {{ item.notes }}</div>
      {% endif %}
      <button class="wl-notes-ico" title="{{ 'decouverte.watchlist.notes_title'|trans }}" data-wl-id="{{ item.id }}">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 013.002 3.002L7.368 18.635a2 2 0 01-.855.506l-2.872.838.838-2.872a2 2 0 01.506-.855z"/></svg>
      </button>
      <button class="wl-remove" title="{{ 'common.action.delete'|trans }}" data-wl-id="{{ item.id }}">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6L6 18"/><path d="M6 6l12 12"/></svg>
      </button>
      <div class="card-overlay">
        <div class="card-title" title="{{ item.title }}">{{ item.title }}</div>
        <div class="card-sub">{{ item.year ?: '' }} · {{ 'watchlist_page.added_on'|trans({date: item.addedAt|slice(0, 10)}) }}</div>
      </div>
    </div>
    {% endfor %}
  </div>

  {% if items is empty %}
  <div class="wl-empty">
    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2l2.4 7.4h7.6l-6.2 4.5 2.4 7.4-6.2-4.6-6.2 4.6 2.4-7.4-6.2-4.5h7.6z"/></svg>
    <h3>{{ 'decouverte.watchlist.empty_title'|trans }}</h3>
    <p>{{ 'decouverte.watchlist.empty_message'|trans({path: path('tmdb_index')})|raw }}</p>
  </div>
  {% endif %}
</div>

<!-- Modal notes -->
<div class="modal modal-blur fade" id="wl-notes-modal" tabindex="-1">
  <div class="modal-dialog modal-sm modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">{{ 'decouverte.watchlist.notes_title'|trans }}</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <textarea class="form-control" id="wl-notes-text" rows="4" placeholder="{{ 'decouverte.watchlist.notes_placeholder'|trans }}"></textarea>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'decouverte.watchlist.notes_cancel'|trans }}</button>
        <button type="button" class="btn btn-primary" id="wl-notes-save">{{ 'decouverte.watchlist.notes_save'|trans }}</button>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  var grid = document.getElementById('wl-grid');
  var cards = grid ? Array.from(grid.querySelectorAll('.wl-card')) : [];
  var currentFilter = 'all';
  var currentSearch = '';

  // Filtres type
  document.querySelectorAll('.wl-filter-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.wl-filter-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      currentFilter = btn.dataset.filter;
      applyFilters();
    });
  });

  // Recherche
  var searchInput = document.getElementById('wl-search');
  if (searchInput) {
    searchInput.addEventListener('input', function() {
      currentSearch = searchInput.value.toLowerCase().trim();
      applyFilters();
    });
  }

  // Tri
  var sortSelect = document.getElementById('wl-sort');
  if (sortSelect) {
    sortSelect.addEventListener('change', function() {
      sortCards(sortSelect.value);
      applyFilters();
    });
  }

  function applyFilters() {
    var visible = 0;
    cards.forEach(function(card) {
      var typeMatch = currentFilter === 'all' || card.dataset.type === currentFilter;
      var searchMatch = !currentSearch || card.dataset.title.toLowerCase().indexOf(currentSearch) !== -1;
      var show = typeMatch && searchMatch;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    var countEl = document.getElementById('wl-visible-count');
    if (countEl) countEl.textContent = visible + ' / ' + cards.length;
  }

  function sortCards(mode) {
    cards.sort(function(a, b) {
      switch (mode) {
        case 'added_desc': return (b.dataset.added || '').localeCompare(a.dataset.added || '');
        case 'added_asc': return (a.dataset.added || '').localeCompare(b.dataset.added || '');
        case 'title_asc': return (a.dataset.title || '').localeCompare(b.dataset.title || '');
        case 'title_desc': return (b.dataset.title || '').localeCompare(a.dataset.title || '');
        case 'vote_desc': return (parseFloat(b.dataset.vote) || 0) - (parseFloat(a.dataset.vote) || 0);
        case 'year_desc': return (parseInt(b.dataset.year) || 0) - (parseInt(a.dataset.year) || 0);
        default: return 0;
      }
    });
    cards.forEach(function(card) { grid.appendChild(card); });
  }

  applyFilters();

  // Supprimer
  grid && grid.addEventListener('click', function(e) {
    var rmBtn = e.target.closest('.wl-remove');
    if (!rmBtn) return;
    e.stopPropagation();
    var card = rmBtn.closest('.wl-card');
    var wlId = rmBtn.dataset.wlId;
    if (!confirm({{ 'decouverte.watchlist.remove_confirm'|trans({title: '__TITLE__'})|json_encode|raw }}.replace('__TITLE__', card.dataset.title))) return;

    fetch('{{ app.request.getBasePath() }}/decouverte/watchlist/remove/' + wlId, { method: 'POST', credentials: 'same-origin' })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (d.ok) {
          card.style.transition = 'opacity .3s, transform .3s';
          card.style.opacity = '0';
          card.style.transform = 'scale(.9)';
          setTimeout(function() {
            card.remove();
            cards = Array.from(grid.querySelectorAll('.wl-card'));
            applyFilters();
            updateStats();
          }, 300);
          if (window._prismarrToast) window._prismarrToast({{ 'decouverte.watchlist.removed_toast'|trans|json_encode|raw }}, 'success');
        }
      });
  });

  // Notes modal
  var notesModal = document.getElementById('wl-notes-modal');
  var notesText = document.getElementById('wl-notes-text');
  var notesSave = document.getElementById('wl-notes-save');
  var currentNotesId = null;
  var currentNotesCard = null;

  grid && grid.addEventListener('click', function(e) {
    var noteBtn = e.target.closest('.wl-notes-ico');
    if (!noteBtn) return;
    e.stopPropagation();
    currentNotesCard = noteBtn.closest('.wl-card');
    currentNotesId = noteBtn.dataset.wlId;
    notesText.value = currentNotesCard.dataset.notes || '';
    notesModal.classList.add('show');
    notesModal.style.display = 'block';
    notesModal.setAttribute('aria-modal', 'true');
    document.body.classList.add('modal-open');
    var backdrop = document.createElement('div');
    backdrop.className = 'modal-backdrop fade show';
    backdrop.id = 'wl-notes-backdrop';
    document.body.appendChild(backdrop);
    notesText.focus();
  });

  function closeNotesModal() {
    notesModal.classList.remove('show');
    notesModal.style.display = 'none';
    document.body.classList.remove('modal-open');
    var bd = document.getElementById('wl-notes-backdrop');
    if (bd) bd.remove();
  }

  notesModal.querySelector('.btn-close').addEventListener('click', closeNotesModal);
  notesModal.querySelector('.btn-secondary').addEventListener('click', closeNotesModal);
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && notesModal.classList.contains('show')) closeNotesModal();
  });

  notesSave.addEventListener('click', function() {
    if (!currentNotesId) return;
    var notes = notesText.value.trim();
    fetch('{{ app.request.getBasePath() }}/decouverte/watchlist/notes/' + currentNotesId, {
      method: 'POST',
      credentials: 'same-origin',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ notes: notes || null })
    })
    .then(function(r) { return r.json(); })
    .then(function(d) {
      if (d.ok) {
        currentNotesCard.dataset.notes = notes;
        var preview = currentNotesCard.querySelector('.wl-notes-preview');
        if (notes) {
          if (!preview) {
            preview = document.createElement('div');
            preview.className = 'wl-notes-preview';
            currentNotesCard.appendChild(preview);
          }
          preview.innerHTML = {{ ico.icon('note', '', 14)|json_encode|raw }} + ' ' + escHtml(notes);
        } else if (preview) {
          preview.remove();
        }
        closeNotesModal();
        if (window._prismarrToast) window._prismarrToast({{ 'decouverte.watchlist.notes_saved_toast'|trans|json_encode|raw }}, 'success');
      }
    });
  });

  // Click on card → redirect to discover with modal open
  grid && grid.addEventListener('click', function(e) {
    if (e.target.closest('.wl-remove') || e.target.closest('.wl-notes-ico')) return;
    var card = e.target.closest('.wl-card');
    if (!card) return;
    window.location.href = '{{ app.request.getBasePath() }}/decouverte?detail=' + card.dataset.type + '/' + card.dataset.tmdbId;
  });

  function updateStats() {
    var all = grid ? Array.from(grid.querySelectorAll('.wl-card')) : [];
    var total = all.length;
    var movies = all.filter(function(c) { return c.dataset.type === 'movie'; }).length;
    var series = total - movies;
    var el = document.getElementById('wl-total'); if (el) el.textContent = total;
    el = document.getElementById('wl-movies'); if (el) el.textContent = movies;
    el = document.getElementById('wl-series'); if (el) el.textContent = series;
  }
})();
</script>
{% endblock %}
