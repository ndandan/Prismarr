      qualityDefsCache = quals;

      allFiles.sort(function(a, b) {
        var snA = a.seasonNumber || 0, snB = b.seasonNumber || 0;
        if (snA !== snB) return snA - snB;
        var epA = 9999, epB = 9999;
        episodes.forEach(function(ep) {
          if (ep.episodeFileId === a.id) epA = ep.episodeNumber || 0;
          if (ep.episodeFileId === b.id) epB = ep.episodeNumber || 0;
        });
        return epA - epB;
      });
      fileManagerFiles = allFiles;

