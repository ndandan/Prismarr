        <div class="alert alert-warning py-2 small mb-3">{{ 'media.series.bulk.delete_warning'|trans|raw }}</div>
        <div class="form-check mb-2"><input type="checkbox" class="form-check-input" id="bulk-s-delete-files"><label class="form-check-label" for="bulk-s-delete-files">{{ 'media.series.bulk.delete_files'|trans }}</label></div>
