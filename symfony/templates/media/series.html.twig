        <div id="bulk-s-rename-changes" style="max-height:350px;overflow-y:auto;"></div>
      </div>
      <div class="modal-footer"><button class="btn btn-secondary" data-bs-dismiss="modal">{{ 'media.series.bulk.cancel'|trans }}</button><button class="btn btn-primary" id="bulk-s-rename-go" disabled>{{ 'media.series.bulk.rename_go'|trans }}</button></div>
    </div>
  </div>
</div>

<div id="bulk-bar-series">
