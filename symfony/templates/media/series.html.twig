        <div class="row g-3">
          <div class="col-md-6"><label class="form-label small">{{ 'media.series.bulk.edit_monitored'|trans }}</label><select class="form-select form-select-sm" id="bulk-s-monitored"><option value="">{{ 'media.series.bulk.edit_keep'|trans }}</option><option value="true">{{ 'media.series.bulk.edit_follow'|trans }}</option><option value="false">{{ 'media.series.bulk.edit_unfollow'|trans }}</option></select></div>
          <div class="col-md-6"><label class="form-label small">{{ 'media.series.bulk.edit_quality'|trans }}</label><select class="form-select form-select-sm" id="bulk-s-quality"><option value="">{{ 'media.series.bulk.edit_keep'|trans }}</option></select></div>
          <div class="col-md-6"><label class="form-label small">{{ 'media.series.bulk.edit_type'|trans }}</label><select class="form-select form-select-sm" id="bulk-s-type"><option value="">{{ 'media.series.bulk.edit_keep'|trans }}</option><option value="standard">{{ 'media.series.bulk.type_standard'|trans }}</option><option value="daily">{{ 'media.series.bulk.type_daily'|trans }}</option><option value="anime">{{ 'media.series.bulk.type_anime'|trans }}</option></select></div>
          <div class="col-md-6"><label class="form-label small">{{ 'media.series.bulk.edit_root'|trans }}</label><select class="form-select form-select-sm" id="bulk-s-root"><option value="">{{ 'media.series.bulk.edit_keep'|trans }}</option></select></div>
          <div class="col-md-6"><label class="form-label small">{{ 'media.series.bulk.edit_season_folder'|trans }}</label><select class="form-select form-select-sm" id="bulk-s-season-folder"><option value="">{{ 'media.series.bulk.edit_keep'|trans }}</option><option value="true">{{ 'media.series.bulk.yes'|trans }}</option><option value="false">{{ 'media.series.bulk.no'|trans }}</option></select></div>
