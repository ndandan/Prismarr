        <div class="text-muted small mt-3" id="bulk-s-edit-info"></div>
      </div>
      <div class="modal-footer"><button class="btn btn-secondary" data-bs-dismiss="modal">{{ 'media.series.bulk.cancel'|trans }}</button><button class="btn btn-primary" id="bulk-s-edit-save">{{ 'media.series.bulk.save'|trans }}</button></div>
    </div>
  </div>
</div>

