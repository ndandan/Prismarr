    var pEpisodes = ajaxGet('{{ app.request.getBasePath() }}/medias/' + (INSTANCE_SLUG || DEFAULT_SONARR_SLUG) + '/series/' + currentId + '/episodes');

    Promise.all([pFiles, pQuals, pEpisodes]).then(function(results) {
