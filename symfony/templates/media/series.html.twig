        if (checkedEps.length > rows.length) {
          showFmFeedback(tpl(SERIES_I18N.fm_save_bulk_too_many_tpl, { PICKED: checkedEps.length, SEL: rows.length }), 'warning');
          return;
        }
        rows.forEach(function(tr, i) {
          if (i < checkedEps.length) {
            var epSelect = tr.querySelector('.fm-episode-select');
            if (epSelect) epSelect.value = checkedEps[i];
          }
        });
        bulkEpDd.querySelectorAll('.fm-bulk-ep-cb').forEach(function(cb) { cb.checked = false; });
        bulkEpDd.style.display = 'none';
        markDirty();
      });
