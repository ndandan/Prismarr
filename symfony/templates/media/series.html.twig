        // Determine season from first selected row
        var rows = getCheckedRows();
        var sn = 1;
        if (rows.length) {
          var seasonSel = rows[0].querySelector('.fm-season-select');
          if (seasonSel) sn = parseInt(seasonSel.value) || 0;
        }
        // Rebuild checkboxes for that season only
        var html = '';
        (fmSeasonsMap[sn] || []).forEach(function(ep) {
          html += '<label class="dropdown-item d-flex align-items-center gap-2 py-1" style="font-size:.75rem;cursor:pointer;">' +
            '<input class="form-check-input fm-bulk-ep-cb m-0" type="checkbox" value="' + (ep.episodeNumber || 0) + '" style="width:14px;height:14px;">' +
            'E' + String(ep.episodeNumber || 0).padStart(2, '0') + ' — ' + esc(ep.title || '') +
            '</label>';
        });
        bulkEpDd.innerHTML = html || '<div class="p-2 text-muted small">' + esc(SERIES_I18N.fm_bulk_no_episode) + '</div>';
        bulkEpDd.style.display = '';
      });
      bulkEpDd.addEventListener('click', function(e) { e.stopPropagation(); });
