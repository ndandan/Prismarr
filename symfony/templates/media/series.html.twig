  function fmtSize(bytes) {
    if (!bytes) return '0';
    var gb = bytes / 1073741824;
    if (gb >= 1) return gb.toFixed(1) + ' ' + SERIES_I18N.gb_suffix;
    return (bytes / 1048576).toFixed(0) + ' ' + SERIES_I18N.mo_suffix;
  }

  // Group skip reasons returned by SonarrClient::manualImportFromFolders into
  // a compact summary like "5× Invalid season or episode, 2× Existing file".
  // Strips the "<filename>: " prefix so identical Sonarr rejections collapse
  // to one entry. Top 3 only — anything beyond gets "+N more".
  function formatImportReasons(reasons) {
    if (!reasons || !reasons.length) return '';
    var counts = {};
    reasons.forEach(function(r) {
      var clean = String(r);
      var idx = clean.indexOf(': ');
      if (idx >= 0 && idx < clean.length - 2) clean = clean.substring(idx + 2);
      counts[clean] = (counts[clean] || 0) + 1;
    });
    var ordered = Object.keys(counts).map(function(k) { return { text: k, count: counts[k] }; });
    ordered.sort(function(a, b) { return b.count - a.count; });
    var top = ordered.slice(0, 3).map(function(g) {
      return g.count > 1 ? (g.count + '× ' + g.text) : g.text;
    });
    if (ordered.length > 3) top.push('+' + (ordered.length - 3) + ' more');
    return top.join(', ');
  }

  var prevQueueSeriesIds = {};
  function renderQueue(items) {
    // Detect series whose items disappeared (download completed) → refresh their card
    var currIds = {};
    items.forEach(function(item) { if (item.seriesId) currIds[item.seriesId] = true; });
    Object.keys(prevQueueSeriesIds).forEach(function(sid) {
      if (!currIds[sid] && typeof refreshSeriesCard === 'function') {
        refreshSeriesCard(sid);
      }
    });
    prevQueueSeriesIds = currIds;

    if (!items.length) {
      queueCard.style.display = 'none';
      return;
    }
    queueCard.style.display = '';
    queueCount.textContent = items.length;

    var html = '';
    items.forEach(function(item) {
      var pct = item.size > 0 ? Math.round((item.size - item.sizeleft) / item.size * 100) : 0;
      var statusClass = item.trackedState === 'importing' ? 'bg-purple-lt text-purple'
                      : item.trackedStatus === 'warning' ? 'bg-warning-lt text-warning'
                      : item.trackedStatus === 'error' ? 'bg-danger-lt text-danger'
                      : 'bg-success-lt text-success';
      var statusLabel = item.trackedState === 'importing' ? SERIES_I18N.queue_status_import : (item.status || '—');

      html += '<tr>';
      html += '<td><div class="fw-medium" style="font-size:.82rem;">' + (item.seriesTitle || '—') + '</div>';
      html += '<div class="text-muted" style="font-size:.75rem;">' + (item.episode || '—') + '</div></td>';
      html += '<td><span class="badge bg-blue-lt" style="font-size:.7rem;">' + (item.quality || '—') + '</span></td>';
      html += '<td style="min-width:120px"><div class="d-flex align-items-center gap-2">';
      html += '<div class="queue-progress flex-grow-1"><div class="queue-progress-bar" style="width:' + pct + '%"></div></div>';
      html += '<span class="text-muted" style="font-size:.75rem;">' + pct + '%</span></div>';
      html += '<div class="text-muted" style="font-size:.7rem;">' + fmtSize(item.size - item.sizeleft) + ' / ' + fmtSize(item.size) + '</div></td>';
      // Status + messages
      html += '<td>';
      html += '<span class="badge ' + statusClass + '" style="font-size:.7rem;">' + statusLabel + '</span>';
      if (item.statusMessages && item.statusMessages.length > 0) {
        var firstMsg = item.statusMessages[0].title || '';
        var allMsgs = item.statusMessages.map(function(m) {
          return (m.title || '') + (m.messages && m.messages.length ? ': ' + m.messages.join(', ') : '');
        }).join('\n');
        html += '<div class="text-danger" style="font-size:.7rem;max-width:250px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="' + allMsgs.replace(/"/g, '&quot;') + '">' + firstMsg + '</div>';
      }
      html += '</td>';

      // Actions
      html += '<td><div class="d-flex gap-1 justify-content-end">';
      if (item.status === 'delay' || item.status === 'queued') {
        html += '<button class="btn btn-ghost-success btn-icon btn-sm btn-queue-grab" data-id="' + item.id + '" title="' + esc(SERIES_I18N.queue_force_download) + '">';
        html += '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>';
        html += '</button>';
      }
      html += '<button class="btn btn-ghost-danger btn-icon btn-sm btn-queue-del" data-id="' + item.id + '" title="' + esc(SERIES_I18N.queue_delete_from_queue) + '">';
      html += '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>';
      html += '</button></div></td>';
      html += '</tr>';
    });
    queueTbody.innerHTML = html;

    // Bind delete buttons
    queueTbody.querySelectorAll('.btn-queue-del').forEach(function(btn) {
      btn.addEventListener('click', function() {
        if (!confirm(SERIES_I18N.queue_confirm_delete)) return;
        btn.disabled = true;
        fetch('{{ app.request.getBasePath() }}/medias/' + (INSTANCE_SLUG || DEFAULT_SONARR_SLUG) + '/series/queue/' + btn.dataset.id + '/delete', {
          method: 'POST',
          headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
          body: JSON.stringify({ removeFromClient: true, blocklist: false }),
        }).then(function(r) { return r.json(); }).then(function(data) {
          if (data.ok) refreshQueue();
          else btn.disabled = false;
        });
      });
    });

    // Bind grab buttons
    queueTbody.querySelectorAll('.btn-queue-grab').forEach(function(btn) {
      btn.addEventListener('click', function() {
        btn.disabled = true;
        fetch('{{ app.request.getBasePath() }}/medias/' + (INSTANCE_SLUG || DEFAULT_SONARR_SLUG) + '/series/queue/' + btn.dataset.id + '/grab', {
          method: 'POST',
          headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
          body: '{}'
        }).then(function(r) { return r.json(); }).then(function(data) {
          if (data.ok) refreshQueue();
          else btn.disabled = false;
        });
      });
    });

    // Classify blocked items
    var warnings = items.filter(function(i) { return i.trackedStatus === 'warning' || i.trackedStatus === 'error'; });
    // "Stale" = all sub-messages say "already imported" → safe to clean
    // "Real" = has files that genuinely need manual import
    var staleItems = [];
    var realBlocked = [];
    warnings.forEach(function(w) {
      var msgs = w.statusMessages || [];
      var allImported = msgs.length > 0 && msgs.every(function(m) {
        return !m.messages || !m.messages.length || m.messages.every(function(msg) {
          return msg.toLowerCase().indexOf('already imported') !== -1;
        });
      });
      if (allImported) staleItems.push(w);
      else realBlocked.push(w);
    });

    var bannerEl = document.getElementById('queue-warning-banner');
    if (warnings.length > 0) {
      if (!bannerEl) {
        bannerEl = document.createElement('div');
        bannerEl.id = 'queue-warning-banner';
        bannerEl.className = 'alert alert-warning mb-0 py-2';
        bannerEl.style.cssText = 'font-size:.82rem;border-radius:0;';
        queueCard.querySelector('#queue-body').insertBefore(bannerEl, queueCard.querySelector('.table-responsive'));
      }

      var html = '<div class="d-flex align-items-center justify-content-between flex-wrap gap-2">';
      html += '<span>';
      if (staleItems.length > 0) {
        html += '<strong>' + tpl(SERIES_I18N.queue_warning_already_imported_tpl, { COUNT: staleItems.length }) + '</strong>';
      }
      if (realBlocked.length > 0) {
        if (staleItems.length > 0) html += ' + ';
        html += '<strong class="text-danger">' + tpl(SERIES_I18N.queue_warning_imports_pending_tpl, { COUNT: realBlocked.length }) + '</strong>';
      }
      html += '</span><div class="d-flex gap-2">';
      if (staleItems.length > 0) {
        html += '<button class="btn btn-sm btn-warning" id="btn-clean-queue">' + esc(tpl(SERIES_I18N.queue_clean_duplicates_tpl, { COUNT: staleItems.length })) + '</button>';
      }
      if (realBlocked.length > 0) {
        html += '<button class="btn btn-sm btn-primary" id="btn-import-blocked">' + esc(tpl(SERIES_I18N.queue_import_files_tpl, { COUNT: realBlocked.length })) + '</button>';
      }
      html += '</div></div>';
      bannerEl.innerHTML = html;
      bannerEl.style.display = '';

      // Clean stale items
      var cleanBtn = document.getElementById('btn-clean-queue');
      if (cleanBtn) {
        cleanBtn.addEventListener('click', function() {
          if (!confirm(tpl(SERIES_I18N.queue_confirm_clean_tpl, { COUNT: staleItems.length }))) return;
          cleanBtn.disabled = true;
          cleanBtn.innerHTML = '<span class="spinner-border spinner-border-sm" style="width:12px;height:12px;"></span> ' + SERIES_I18N.queue_cleaning;
          var done = 0;
          staleItems.forEach(function(w) {
            fetch('{{ app.request.getBasePath() }}/medias/' + (INSTANCE_SLUG || DEFAULT_SONARR_SLUG) + '/series/queue/' + w.id + '/delete', {
              method: 'POST',
              headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
              body: JSON.stringify({ removeFromClient: true, blocklist: false }),
            }).then(function() {
              done++;
              if (done >= staleItems.length) refreshQueue();
            });
          });
        });
      }

      // Import real blocked items.
      // v1.1.0: backend now receives { paths: [...] } only — Sonarr's manual
      // import preview enriches each path with episodeIds/releaseGroup/quality
      // server-side, so the frontend doesn't try to forge a payload by hand.
      var importBtn = document.getElementById('btn-import-blocked');
      if (importBtn) {
        importBtn.addEventListener('click', function() {
          importBtn.disabled = true;
          importBtn.innerHTML = '<span class="spinner-border spinner-border-sm" style="width:12px;height:12px;"></span> ' + SERIES_I18N.queue_importing;
          var items = realBlocked.map(function(w) {
            return { path: w.outputPath || '', downloadId: w.downloadId || '' };
          }).filter(function(it) { return it.path !== '' || it.downloadId !== ''; });
          fetch('{{ app.request.getBasePath() }}/medias/' + (INSTANCE_SLUG || DEFAULT_SONARR_SLUG) + '/series/queue/import', {
            method: 'POST',
            headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
            body: JSON.stringify({ items: items }),
          }).then(function(r) { return r.json(); }).then(function(data) {
            var imported = data.imported || 0;
            var skipped  = data.skipped  || 0;
            var total    = imported + skipped;
            // Group raw reasons returned by Sonarr (one per skipped file) by
            // their core message — typically the part after the colon, since
            // Sonarr prefixes with the filename. Top 3 are summarised so the
            // banner stays readable when 30 files share the same rejection.
            var reasonsLine = formatImportReasons(data.reasons || []);
            if (data.ok && imported > 0 && skipped === 0) {
              showPageBanner(tpl(SERIES_I18N.queue_import_done_tpl, { IMPORTED: imported }), 'success');
              setTimeout(refreshQueue, 3000);
            } else if (imported > 0) {
              // Partial success — keep the success colour, append the
              // skipped count and the reasons so the user knows what to fix.
              showPageBanner(tpl(SERIES_I18N.queue_import_partial_tpl, {
                IMPORTED: imported, TOTAL: total, SKIPPED: skipped, REASONS: reasonsLine,
              }), 'warning');
              setTimeout(refreshQueue, 3000);
            } else {
              // Nothing got through — e.g. files don't carry a season/episode
              // marker that Sonarr can match. The button stays clickable so
              // the user can retry after renaming.
              importBtn.disabled = false;
              importBtn.textContent = SERIES_I18N.queue_error;
              var msg = total > 0
                ? tpl(SERIES_I18N.queue_import_none_tpl, { TOTAL: total, REASONS: reasonsLine })
                : SERIES_I18N.queue_error;
              showPageBanner(msg, 'danger');
            }
          });
        });
      }
    } else if (bannerEl) {
      bannerEl.style.display = 'none';
    }
  }

  function refreshQueue() {
    fetch('{{ app.request.getBasePath() }}/medias/' + (INSTANCE_SLUG || DEFAULT_SONARR_SLUG) + '/series/queue', { headers: {'X-Requested-With': 'XMLHttpRequest'} })
    .then(function(r) { return r.json(); })
    .then(function(items) { renderQueue(items); });
  }

  // Initial render from server data
  renderQueue({{ queue|json_encode|raw }});
  // Auto-refresh queue every 3s
  setInterval(refreshQueue, 2000);
  // RefreshMonitoredDownloads every 8s (tells Sonarr to check qBittorrent)
  setInterval(function() {
    fetch('{{ app.request.getBasePath() }}/medias/' + (INSTANCE_SLUG || DEFAULT_SONARR_SLUG) + '/series/queue/refresh', {
      method: 'POST',
      headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
      body: '{}',
    });
  }, 6000);

  // ── Modal ──────────────────────────────────────────────────────────────────
  var currentId        = null;
  var currentMonitored = false;
  var searchInProgress = false;
  var modalEl          = document.getElementById('modal-serie');
  var SVG_SEARCH_SM = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>';
  var SVG_SPIN_SM = '<span class="spinner-border spinner-border-sm" style="width:12px;height:12px;"></span>';
  var SVG_OK_SM = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5"><path d="M20 6 9 17l-5-5"/></svg>';
  var SVG_MONITOR_ON = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#6366f1" stroke="#6366f1" stroke-width="2"><path d="M6 5h12l1 14H5z"/><path d="M9 5V3h6v2"/></svg>';
  var SVG_MONITOR_OFF = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" opacity=".4"><path d="M6 5h12l1 14H5z"/><path d="M9 5V3h6v2"/></svg>';
  var SVG_FILES = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>';
  var SVG_HISTORY = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>';
  var SVG_INTERACTIVE = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>';

  modalEl.addEventListener('show.bs.modal', function (event) {
    var card         = event.relatedTarget;
    if (!card || !card.dataset.id) return;
    currentId        = card.dataset.id;
    currentMonitored = card.dataset.monitored === '1';
    hideBanner();
    var status       = card.dataset.status;
    var type         = card.dataset.type;
    var percent      = parseInt(card.dataset.percent) || 0;
    var epCount      = parseInt(card.dataset.episodeCount) || 0;
    var epFiles      = parseInt(card.dataset.episodeFileCount) || 0;

    // Fanart
    var fanartEl = document.getElementById('modal-serie-fanart');
    var fanart = card.dataset.fanart || '';
    fanartEl.style.backgroundImage = fanart ? 'url(' + fanart + ')' : 'none';

    // Poster
    var poster = document.getElementById('modal-serie-poster');
    poster.src = card.dataset.poster || '';
    poster.style.display = card.dataset.poster ? '' : 'none';

    // Title
    document.getElementById('modal-serie-title').textContent = card.dataset.displayTitle + (card.dataset.year ? ' (' + card.dataset.year + ')' : '');

    // Meta line (in header, like Radarr)
    var meta = '';
    if (card.dataset.year) meta += '<span class="text-white-50 fw-medium">' + card.dataset.year + '</span>';
    if (card.dataset.runtime) meta += '<span class="text-white-50">' + card.dataset.runtime + ' min</span>';
    if (card.dataset.certification) meta += '<span class="badge bg-dark text-white-50">' + card.dataset.certification + '</span>';
    if (card.dataset.ratings && parseFloat(card.dataset.ratings) > 0) {
      meta += '<span style="display:inline-flex;align-items:center;gap:3px;color:#f5c518;font-size:.85rem;">';
      meta += '<svg width="14" height="14" viewBox="0 0 24 24" fill="#f5c518" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14l-5-4.87 6.91-1.01z"/></svg>';
      meta += parseFloat(card.dataset.ratings).toFixed(1) + '</span>';
    }
    if (card.dataset.network) meta += '<span class="text-white-50">' + card.dataset.network + '</span>';
    document.getElementById('modal-serie-meta').innerHTML = meta;

    // Genres (in header)
    var genres = '';
    (card.dataset.genres || '').split(', ').forEach(function(g) {
      if (g) genres += '<span class="badge bg-dark text-white-50" style="font-size:.65rem;">' + g + '</span>';
    });
    document.getElementById('modal-serie-genres').innerHTML = genres;

    // Left column badges
    var badges = '';
    if (status === 'continuing') badges += '<span class="badge" style="background:rgba(34,197,94,.15);color:#4ade80;">' + esc(SERIES_I18N.continuing) + '</span>';
    else if (status === 'ended') badges += '<span class="badge" style="background:rgba(107,114,128,.15);color:#9ca3af;">' + esc(SERIES_I18N.ended) + '</span>';
    if (currentMonitored) badges += '<span class="badge" style="background:rgba(var(--tblr-primary-rgb),.15);color:var(--tblr-primary);">' + esc(SERIES_I18N.followed) + '</span>';
    else badges += '<span class="badge" style="background:rgba(107,114,128,.15);color:#9ca3af;">' + esc(SERIES_I18N.unfollowed) + '</span>';
    if (type === 'anime') badges += '<span class="badge bg-purple-lt">' + esc(SERIES_I18N.anime) + '</span>';
    if (card.dataset.size && parseFloat(card.dataset.size) > 0) badges += '<span class="badge bg-secondary-lt">' + card.dataset.size + ' ' + esc(SERIES_I18N.gb_suffix) + '</span>';
    badges += '<span class="badge bg-secondary-lt">' + esc(tpl(SERIES_I18N.season_tpl, { COUNT: card.dataset.seasonCount })) + '</span>';
    document.getElementById('modal-serie-badges').innerHTML = badges;

    // Progress
    document.getElementById('modal-serie-progress-bar').style.width = percent + '%';
    document.getElementById('modal-serie-progress-bar').style.background = percent === 100 ? '#22c55e' : '#6366f1';
    document.getElementById('modal-serie-progress-label').textContent = epFiles + '/' + epCount + ' ' + SERIES_I18N.episodes_suffix + ' (' + percent + '%)';

    // Overview
    document.getElementById('modal-serie-overview').textContent = card.dataset.overview || SERIES_I18N.d_no_synopsis;

    // Monitor button
    refreshSerieMonitorBtn();

    // Load episodes
    loadEpisodes();
  });

  function loadEpisodes() {
    var epContainer = document.getElementById('modal-serie-episodes');
    epContainer.innerHTML = '<div class="text-center text-muted py-4"><span class="spinner-border spinner-border-sm me-1"></span> ' + esc(SERIES_I18N.d_loading_episodes) + '</div>';

    Promise.all([
      ajaxGet('{{ app.request.getBasePath() }}/medias/' + (INSTANCE_SLUG || DEFAULT_SONARR_SLUG) + '/series/' + currentId + '/episodes'),
      ajaxGet('{{ app.request.getBasePath() }}/medias/' + (INSTANCE_SLUG || DEFAULT_SONARR_SLUG) + '/series/' + currentId + '/files')
    ]).then(function(results) {
      var episodes = results[0] || [];
      var allFiles = results[1] || [];
      // Index files by id for quick lookup
      var filesById = {};
      allFiles.forEach(function(f) { filesById[f.id] = f; });

      var seasons = {};
      episodes.forEach(function(ep) {
        var sn = ep.seasonNumber || 0;
        if (!seasons[sn]) seasons[sn] = [];
        seasons[sn].push(ep);
      });
      var seasonNums = Object.keys(seasons).map(Number).sort(function(a,b) { return b - a; });

      function fmtSizeEp(bytes) {
        if (!bytes) return '';
        var gb = bytes / 1073741824;
        return gb >= 1 ? gb.toFixed(1) + ' ' + SERIES_I18N.gb_suffix : Math.round(bytes / 1048576) + ' ' + SERIES_I18N.mo_suffix;
      }

      var html = '';
      seasonNums.forEach(function(sn, idx) {
        var eps = seasons[sn];
        var total = eps.length;
        var files = eps.filter(function(e) { return e.hasFile; }).length;
        var sPct = total > 0 ? Math.round(files / total * 100) : 0;
        var isFirst = idx === 0 && sn > 0;

        // Determine if season is monitored (from episode data)
        var seasonMonitored = eps.some(function(e) { return e.monitored; });

        html += '<div class="card mb-2" style="background:rgba(0,0,0,.2);border:1px solid var(--tblr-border-color);">';
        // Season header
        html += '<div class="card-header d-flex align-items-center gap-2 px-3 py-2 season-toggle" data-sn="' + sn + '" style="cursor:pointer;background:rgba(0,0,0,.15);border-bottom:1px solid var(--tblr-border-color);' + (sn === 0 ? 'opacity:.6;' : '') + '">';
        // Monitor toggle
        var monDisabled = !currentMonitored ? ' disabled style="flex-shrink:0;opacity:.3;pointer-events:none;"' : ' style="flex-shrink:0;"';
        html += '<button class="btn btn-ghost-secondary btn-icon btn-sm btn-season-monitor" data-series-id="' + currentId + '" data-season="' + sn + '" data-monitored="' + (seasonMonitored ? '1' : '0') + '" onclick="event.stopPropagation();" title="' + esc(seasonMonitored ? SERIES_I18N.d_unmonitor : SERIES_I18N.d_monitor) + '"' + monDisabled + '>' + (seasonMonitored ? SVG_MONITOR_ON : SVG_MONITOR_OFF) + '</button>';
        html += '<svg class="s-chev' + (isFirst ? ' open' : '') + '" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="transition:transform .2s;flex-shrink:0;' + (isFirst ? 'transform:rotate(90deg);' : '') + '"><path d="m9 18 6-6-6-6"/></svg>';
        html += '<span class="fw-medium" style="min-width:90px;">' + (sn === 0 ? esc(SERIES_I18N.d_season_specials) : esc(tpl(SERIES_I18N.d_season_tpl, { N: sn }))) + '</span>';
        html += '<div style="flex:1;max-width:200px;height:5px;border-radius:3px;background:rgba(255,255,255,.1);overflow:hidden;"><div style="height:100%;width:' + sPct + '%;background:' + (sPct === 100 ? '#22c55e' : '#6366f1') + ';border-radius:3px;"></div></div>';
        html += '<span class="text-muted" style="font-size:.78rem;min-width:60px;">' + files + '/' + total + '</span>';
        // Season actions
        html += '<div class="ms-auto d-flex gap-1" onclick="event.stopPropagation();">';
        html += '<button class="btn btn-ghost-primary btn-icon btn-sm btn-search-season-modal" data-series-id="' + currentId + '" data-season="' + sn + '" title="' + esc(SERIES_I18N.d_search_season_title) + '">' + SVG_SEARCH_SM + '</button>';
        html += '<button class="btn btn-ghost-secondary btn-icon btn-sm btn-season-interactive" data-series-id="' + currentId + '" data-season="' + sn + '" title="' + esc(SERIES_I18N.d_season_interactive_search) + '">' + SVG_INTERACTIVE + '</button>';
        html += '<button class="btn btn-ghost-secondary btn-icon btn-sm btn-season-files" data-series-id="' + currentId + '" data-season="' + sn + '" title="' + esc(SERIES_I18N.d_manage_files) + '">' + SVG_FILES + '</button>';
        html += '<button class="btn btn-ghost-secondary btn-icon btn-sm btn-season-rename" data-series-id="' + currentId + '" data-season="' + sn + '" title="' + esc(SERIES_I18N.d_rename_files) + '">' + RENAME_ICON + '</button>';
        html += '<button class="btn btn-ghost-secondary btn-icon btn-sm btn-season-history" data-series-id="' + currentId + '" data-season="' + sn + '" title="' + esc(SERIES_I18N.d_history) + '">' + SVG_HISTORY + '</button>';
        html += '</div>';
        html += '</div>';

        // Episodes
        html += '<div class="s-body" id="s-' + sn + '" style="' + (isFirst ? '' : 'display:none;') + '">';
        eps.forEach(function(ep) {
          var hasFile = ep.hasFile || false;
          var epMon = ep.monitored || false;
          var dotColor = hasFile ? '#22c55e' : (epMon ? '#f59e0b' : '#6b7280');
          var dotGlow = hasFile ? 'box-shadow:0 0 4px #22c55e;' : (epMon ? 'box-shadow:0 0 4px #f59e0b;' : '');
          html += '<div class="d-flex align-items-center gap-2 px-3" style="padding:.4rem 0;border-top:1px solid rgba(255,255,255,.05);font-size:.82rem;">';
          // Episode monitor toggle
          var epMonStyle = !currentMonitored ? 'flex-shrink:0;padding:0;width:20px;height:20px;opacity:.3;pointer-events:none;' : 'flex-shrink:0;padding:0;width:20px;height:20px;';
          html += '<button class="btn btn-ghost-secondary btn-icon btn-sm btn-ep-monitor" data-ep-id="' + (ep.id || '') + '" data-monitored="' + (epMon ? '1' : '0') + '" title="' + esc(epMon ? SERIES_I18N.d_unmonitor : SERIES_I18N.d_monitor) + '" style="' + epMonStyle + '"' + (!currentMonitored ? ' disabled' : '') + '>' + (epMon ? SVG_MONITOR_ON : SVG_MONITOR_OFF) + '</button>';
          html += '<span style="width:10px;height:10px;border-radius:50%;background:' + dotColor + ';' + dotGlow + 'flex-shrink:0;"></span>';
          html += '<span style="min-width:40px;color:var(--tblr-secondary);font-weight:600;font-size:.78rem;">E' + String(ep.episodeNumber || 0).padStart(2, '0') + '</span>';
          html += '<span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' + (ep.title || '—') + '</span>';
          html += '<span style="min-width:80px;color:var(--tblr-secondary);font-size:.72rem;text-align:right;">' + (ep.airDate || '—') + '</span>';
          if (hasFile) {
            // Media info tooltip
            var epFile = filesById[ep.episodeFileId] || null;
            var miLines = [];
            if (epFile) {
              var emi = epFile.mediaInfo || {};
              var eqn = (epFile.quality && epFile.quality.quality) ? epFile.quality.quality.name : '';
              if (eqn) miLines.push(SERIES_I18N.d_ei_path + eqn);
              if (emi.videoCodec) miLines.push(SERIES_I18N.d_ei_video + emi.videoCodec + (emi.videoBitDepth ? ' ' + emi.videoBitDepth + 'bit' : '') + (emi.videoDynamicRange ? ' ' + emi.videoDynamicRange : ''));
              if (emi.resolution) miLines.push(SERIES_I18N.d_ei_resolution + emi.resolution);
              if (emi.audioCodec) miLines.push(SERIES_I18N.d_ei_audio + emi.audioCodec + (emi.audioChannels ? ' ' + emi.audioChannels + 'ch' : ''));
              if (emi.audioLanguages) miLines.push(SERIES_I18N.d_ei_tracks + emi.audioLanguages);
              if (emi.subtitles) miLines.push(SERIES_I18N.d_ei_subs + emi.subtitles);
              if (epFile.size) miLines.push(SERIES_I18N.d_ei_size + fmtSizeEp(epFile.size));
              if (epFile.releaseGroup) miLines.push(SERIES_I18N.d_ei_group + epFile.releaseGroup);
            }
            var epInfoTip = miLines.length ? miLines.join('\n') : SERIES_I18N.d_ei_none;
            html += '<button class="btn btn-ghost-secondary btn-icon btn-sm" title="' + epInfoTip.replace(/"/g,'&quot;') + '" style="flex-shrink:0;width:20px;height:20px;cursor:help;">' +
              '<svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg></button>';
          }
          // Search buttons on ALL episodes (downloaded ones can be upgraded)
          if (ep.id) {
            var epLabel = 'S' + String(ep.seasonNumber || 0).padStart(2,'0') + 'E' + String(ep.episodeNumber || 0).padStart(2,'0');
            html += '<button class="btn btn-ghost-primary btn-icon btn-sm btn-ep-search" data-ep-id="' + ep.id + '" title="' + esc(SERIES_I18N.d_search_bookmark) + '" style="flex-shrink:0;">' + SVG_SEARCH_SM + '</button>';
            html += '<button class="btn btn-ghost-secondary btn-icon btn-sm btn-ep-interactive" data-ep-id="' + ep.id + '" data-ep-label="' + epLabel + '" title="' + esc(SERIES_I18N.d_interactive_search) + '" style="flex-shrink:0;">' + SVG_INTERACTIVE + '</button>';
          }
          if (hasFile) {
            html += '<button class="btn btn-ghost-danger btn-icon btn-sm btn-ep-file-del" data-file-id="' + (ep.episodeFileId || '') + '" title="' + esc(SERIES_I18N.d_delete_file) + '" style="flex-shrink:0;width:20px;height:20px;">' +
              '<svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg></button>';
          }
          html += '</div>';
        });
        html += '</div></div>';
      });

      epContainer.innerHTML = html || '<div class="text-muted text-center py-4">' + esc(SERIES_I18N.d_no_episodes) + '</div>';

      // Bind accordion
      epContainer.querySelectorAll('.season-toggle').forEach(function(h) {
        h.addEventListener('click', function() {
          var sn = h.dataset.sn;
          var body = document.getElementById('s-' + sn);
          var chev = h.querySelector('.s-chev');
          var isOpen = body.style.display !== 'none';
          epContainer.querySelectorAll('.s-body').forEach(function(b) { b.style.display = 'none'; });
          epContainer.querySelectorAll('.s-chev').forEach(function(c) { c.style.transform = ''; c.classList.remove('open'); });
          if (!isOpen) {
            body.style.display = '';
            chev.style.transform = 'rotate(90deg)';
            chev.classList.add('open');
          }
        });
      });

      // Bind episode search
      epContainer.querySelectorAll('.btn-ep-search').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
          e.stopPropagation();
          var epId = parseInt(btn.dataset.epId);
          btn.disabled = true;
          btn.innerHTML = SVG_SPIN_SM;
          postAction('{{ app.request.getBasePath() }}/medias/' + (INSTANCE_SLUG || DEFAULT_SONARR_SLUG) + '/series/episode/search', { episodeIds: [epId] }, function(data) {
            if (data.cmdId) {
              pollCmd(data.cmdId, SERIES_I18N.d_search_cmd_episode, function(success) {
                btn.innerHTML = success ? SVG_OK_SM : SVG_SEARCH_SM;
                btn.disabled = false;
              });
            } else {
              btn.innerHTML = SVG_OK_SM;
              btn.disabled = false;
            }
          });
        });
      });

      // Bind season monitor
      epContainer.querySelectorAll('.btn-season-monitor').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
          e.stopPropagation();
          var mon = btn.dataset.monitored !== '1';
          btn.disabled = true;
          postAction('{{ app.request.getBasePath() }}/medias/' + (INSTANCE_SLUG || DEFAULT_SONARR_SLUG) + '/series/season/monitor', {
            seriesId: parseInt(btn.dataset.seriesId),
            seasonNumber: parseInt(btn.dataset.season),
            monitored: mon,
          }, function() {
            btn.dataset.monitored = mon ? '1' : '0';
            btn.innerHTML = mon ? SVG_MONITOR_ON : SVG_MONITOR_OFF;
            btn.title = mon ? SERIES_I18N.d_unmonitor : SERIES_I18N.d_monitor;
            btn.disabled = false;
