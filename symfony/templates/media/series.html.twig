            var eventColors = {1:'success',2:'primary',3:'secondary',4:'danger',6:'warning',7:'danger',8:'success',9:'warning'};
            var html = '<div class="table-responsive" style="max-height:calc(100% - 1rem);overflow-y:auto"><table class="table table-sm table-vcenter table-hover mb-0" style="font-size:.78rem"><thead class="sticky-top" style="background:var(--tblr-bg-surface)"><tr><th>' + esc(SERIES_I18N.d_col_episode) + '</th><th>' + esc(SERIES_I18N.d_col_action) + '</th><th>' + esc(SERIES_I18N.d_col_source) + '</th><th>' + esc(SERIES_I18N.d_col_quality) + '</th><th>' + esc(SERIES_I18N.d_col_date) + '</th></tr></thead><tbody>';
