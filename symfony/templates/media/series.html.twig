      bulkIfVal.addEventListener('change', function() {
        var val = this.value;
        if (val === '') return;
        getCheckedRows().forEach(function(tr) {
          tr.querySelector('.fm-indexer-flags').value = val;
        });
        this.value = '';
        markDirty();
      });
    }

    // Close all menus on overlay click
    document.getElementById('ep-filemanager-overlay').addEventListener('click', function() {
      container.querySelectorAll('.fm-lang-dropdown').forEach(function(d) { d.style.display = 'none'; });
      if (bulkLangDd) bulkLangDd.style.display = 'none';
      if (bulkEpDd) bulkEpDd.style.display = 'none';
    });

    function getCheckedRows() {
      var rows = [];
      container.querySelectorAll('.fm-row-check:checked').forEach(function(cb) {
        rows.push(cb.closest('tr'));
      });
      return rows;
    }

    var saveAllBtn = container.querySelector('.fm-save-all-btn');

    function markDirty() {
      // Check if any row differs from original
      var dirty = false;
      container.querySelectorAll('tr[data-file-index]').forEach(function(tr) {
        if (isRowDirty(tr)) dirty = true;
      });
      saveAllBtn.disabled = !dirty;
    }

    function isRowDirty(tr) {
      var curQual = tr.querySelector('.fm-quality-select').value;
      var curRt   = tr.querySelector('.fm-release-type') ? tr.querySelector('.fm-release-type').value : '';
      var curIf   = tr.querySelector('.fm-indexer-flags') ? tr.querySelector('.fm-indexer-flags').value : '0';
      var curLangs = [];
      tr.querySelectorAll('.fm-lang-cb:checked').forEach(function(c) { curLangs.push(c.value); });
      curLangs.sort();
      var curSeason = tr.querySelector('.fm-season-select') ? tr.querySelector('.fm-season-select').value : '';
      var curEp = tr.querySelector('.fm-episode-select') ? tr.querySelector('.fm-episode-select').value : '';
      var dirty = curQual !== tr.dataset.origQuality
          || curLangs.join(',') !== tr.dataset.origLangs
          || curRt !== (tr.dataset.origReleaseType || '')
          || curIf !== (tr.dataset.origIndexerFlags || '0')
          || curSeason !== (tr.dataset.origSeason || '')
          || curEp !== (tr.dataset.origEpisode || '')
          || (tr.querySelector('.fm-release-group') ? tr.querySelector('.fm-release-group').value : '') !== (tr.dataset.initRelGroup || '');
      return dirty;
    }

    // Save all modified files
    saveAllBtn.addEventListener('click', function() {
      var dirtyRows = [];
      container.querySelectorAll('tr[data-file-index]').forEach(function(tr) {
        if (isRowDirty(tr)) dirtyRows.push(tr);
      });
      if (!dirtyRows.length) return;

      saveAllBtn.disabled = true;
      saveAllBtn.innerHTML = '<span class="spinner-border spinner-border-sm" style="width:12px;height:12px;"></span> ' + SERIES_I18N.fm_saving;

      // Use bulk editor endpoint (PUT /api/v3/episodefile/editor) — the only way that actually works
      var fileIds = dirtyRows.map(function(tr) { return parseInt(tr.dataset.fileId); });

      // Build common payload from first dirty row (bulk applies same values to all)
      // For individual changes, we send one bulk request per row
      var done = 0;
      var errors = 0;

      dirtyRows.forEach(function(tr) {
        var fileId = parseInt(tr.dataset.fileId);
        var idx = parseInt(tr.dataset.fileIndex);

        // Build payload — all fields sent to our route which does GET+modify+PUT /bulk
        var payload = { fileId: fileId };

        var curQual = tr.querySelector('.fm-quality-select').value;
        if (curQual !== tr.dataset.origQuality) {
          var selectedQualId = parseInt(curQual);
          var qualObj = null;
          if (qualityDefsCache) {
            for (var i = 0; i < qualityDefsCache.length; i++) {
              var qd = qualityDefsCache[i];
              var qdId = qd.quality ? qd.quality.id : (qd.id || 0);
              if (qdId === selectedQualId) { qualObj = qd.quality || { id: qdId }; break; }
            }
          }
          if (!qualObj) qualObj = { id: selectedQualId };
          var origFile = fileManagerFiles[idx];
          var revision = (origFile && origFile.quality && origFile.quality.revision)
            ? origFile.quality.revision : { version: 1, real: 0, isRepack: false };
          payload.quality = { quality: qualObj, revision: revision };
        }

        var checkedLangs = [];
        tr.querySelectorAll('.fm-lang-cb:checked').forEach(function(cb) {
          checkedLangs.push({ id: parseInt(cb.value), name: cb.dataset.name });
        });
        var curLangIds = checkedLangs.map(function(l) { return String(l.id); }).sort().join(',');
        if (curLangIds !== (tr.dataset.origLangs || '')) {
          payload.languages = checkedLangs;
        }

        var relGroup = tr.querySelector('.fm-release-group') ? tr.querySelector('.fm-release-group').value : '';
        if (relGroup !== (tr.dataset.initRelGroup || '')) {
          payload.releaseGroup = relGroup;
        }

        var curRt = tr.querySelector('.fm-release-type') ? tr.querySelector('.fm-release-type').value : '';
        if (curRt !== (tr.dataset.origReleaseType || '')) {
          payload.releaseType = curRt;
        }

        var curIf = tr.querySelector('.fm-indexer-flags') ? tr.querySelector('.fm-indexer-flags').value : '0';
        if (curIf !== (tr.dataset.origIndexerFlags || '0')) {
          payload.indexerFlags = parseInt(curIf);
        }

        // Check if episode changed → needs reassign
        var curEpVal = tr.querySelector('.fm-episode-select') ? tr.querySelector('.fm-episode-select').value : '';
        var curSeasonVal = tr.querySelector('.fm-season-select') ? tr.querySelector('.fm-season-select').value : '';
        var seasonChanged = curSeasonVal !== (tr.dataset.origSeason || '');
        var epChanged = curEpVal !== (tr.dataset.origEpisode || '') || seasonChanged;

        // Validate: if season changed, episode must be selected
        if (seasonChanged && !curEpVal) {
          errors++;
          done++;
          var path = tr.querySelector('td:nth-child(2)');
          showFmFeedback(tpl(SERIES_I18N.fm_no_ep_for_file_tpl, { NAME: (path ? path.textContent.trim().substring(0, 40) : '') }), 'warning');
          if (done >= dirtyRows.length) {
            saveAllBtn.innerHTML = SERIES_I18N.fm_save_all;
            markDirty();
          }
          return;
        }

        // Build promises
        var promises = [];
        // Only send bulk-update if non-episode fields changed
        var hasNonEpChanges = Object.keys(payload).length > 1; // more than just fileId
        if (hasNonEpChanges) {
          promises.push(ajaxPost('{{ app.request.getBasePath() }}/medias/' + (INSTANCE_SLUG || DEFAULT_SONARR_SLUG) + '/series/files/bulk-update', payload));
        }
        // Send reassign if episode changed
        if (epChanged && curEpVal) {
          // Find the episode ID from the episode number
          var targetSn = parseInt(curSeasonVal) || 0;
          var targetEpNum = parseInt(curEpVal) || 0;
          var targetEpId = null;
          (fmSeasonsMap[targetSn] || []).forEach(function(ep) {
            if ((ep.episodeNumber || 0) === targetEpNum) targetEpId = ep.id;
          });
          if (targetEpId) {
            promises.push(ajaxPost('{{ app.request.getBasePath() }}/medias/' + (INSTANCE_SLUG || DEFAULT_SONARR_SLUG) + '/series/file/' + fileId + '/reassign', {
              seriesId: parseInt(currentId),
              episodeIds: [targetEpId]
            }));
          }
        }

        if (!promises.length) {
          done++;
          if (done >= dirtyRows.length) {
            saveAllBtn.innerHTML = SERIES_I18N.fm_save_all;
            markDirty();
          }
          return;
        }

        Promise.all(promises)
        .then(function(results) {
          done++;
          var allOk = results.every(function(d) { return d && d.ok; });
          if (!allOk) errors++;
          else {
            tr.dataset.origQuality = tr.querySelector('.fm-quality-select').value;
            tr.dataset.initRelGroup = tr.querySelector('.fm-release-group') ? tr.querySelector('.fm-release-group').value : '';
            var lIds = [];
            tr.querySelectorAll('.fm-lang-cb:checked').forEach(function(c) { lIds.push(c.value); });
            lIds.sort();
            if (lIds.length) tr.dataset.origLangs = lIds.join(',');
            if (tr.querySelector('.fm-season-select')) tr.dataset.origSeason = tr.querySelector('.fm-season-select').value;
            if (tr.querySelector('.fm-episode-select')) tr.dataset.origEpisode = tr.querySelector('.fm-episode-select').value;
            if (tr.querySelector('.fm-release-type')) tr.dataset.origReleaseType = tr.querySelector('.fm-release-type').value;
            if (tr.querySelector('.fm-indexer-flags')) tr.dataset.origIndexerFlags = tr.querySelector('.fm-indexer-flags').value;
          }
          if (done >= dirtyRows.length) {
            saveAllBtn.innerHTML = SERIES_I18N.fm_save_all;
            markDirty();
            showFmFeedback(errors ? tpl(SERIES_I18N.fm_save_partial_tpl, { OK: (done - errors), ERR: errors }) : tpl(SERIES_I18N.fm_save_success_tpl, { COUNT: done }), errors ? 'warning' : 'success');
            // Refresh episodes in modal after save
            if (!errors) {
              setTimeout(function() {
                document.getElementById('ep-filemanager-overlay').style.display = 'none';
                loadEpisodes();
              }, 1500);
            }
          }
        }).catch(function() {
          done++; errors++;
          if (done >= dirtyRows.length) {
            saveAllBtn.innerHTML = SERIES_I18N.fm_save_all;
            markDirty();
            showFmFeedback(SERIES_I18N.fm_save_network_error, 'danger');
          }
        });
      });
    });

    // Delete buttons
    container.querySelectorAll('.fm-delete-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        if (!confirm(SERIES_I18N.d_confirm_delete_file)) return;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm" style="width:12px;height:12px;"></span>';
        ajaxPost('{{ app.request.getBasePath() }}/medias/' + (INSTANCE_SLUG || DEFAULT_SONARR_SLUG) + '/series/file/' + btn.dataset.fileId + '/delete')
        .then(function(data) {
          if (data && data.ok) {
            showFmFeedback(SERIES_I18N.d_file_deleted, 'success');
            btn.closest('tr').remove();
          } else {
            showFmFeedback(SERIES_I18N.d_file_delete_error, 'danger');
            btn.disabled = false;
          }
        }).catch(function() {
          showFmFeedback(SERIES_I18N.d_network_error, 'danger');
          btn.disabled = false;
        });
      });
    });
  }


  function showFmFeedback(text, type) {
    var el  = document.getElementById('ep-filemanager-feedback');
    var txt = document.getElementById('ep-filemanager-feedback-text');
    el.style.display = '';
    el.className = 'alert alert-' + (type || 'info') + ' m-3 py-2 small';
    txt.textContent = text;
    if (type === 'success') setTimeout(function() { el.style.display = 'none'; }, 4000);
  }

  var fileOverlayOpen = false;
  function openFileOverlay() {
    fileOverlayOpen = true;
    document.getElementById('ep-filemanager-backdrop').style.display = '';
    document.getElementById('ep-filemanager-overlay').style.display = '';
    modalEl.style.visibility = 'hidden';
    modalEl.style.pointerEvents = 'none';
    var bsBackdrop = document.querySelector('.modal-backdrop');
    if (bsBackdrop) bsBackdrop.style.display = 'none';
  }
  function closeFileOverlay() {
    fileOverlayOpen = false;
    document.getElementById('ep-filemanager-overlay').style.display = 'none';
    document.getElementById('ep-filemanager-backdrop').style.display = 'none';
    modalEl.style.visibility = '';
    modalEl.style.pointerEvents = '';
    var bsBackdrop = document.querySelector('.modal-backdrop');
    if (bsBackdrop) bsBackdrop.style.display = '';
  }
  document.getElementById('ep-filemanager-close').addEventListener('click', closeFileOverlay);
  document.getElementById('ep-filemanager-back').addEventListener('click', closeFileOverlay);
  document.getElementById('ep-filemanager-backdrop').addEventListener('click', closeFileOverlay);

  /* ══════════════════════════════════════════════════════════════════════════
     Modal ajout série
     ══════════════════════════════════════════════════════════════════════════ */
  var addConfigLoaded = false;
  var addSelectedSerie = null;
  var addSearchTimer = null;

  document.getElementById('modal-add-serie').addEventListener('show.bs.modal', function() {
    document.getElementById('add-serie-search').value = '';
    document.getElementById('add-serie-results').innerHTML = '';
    document.getElementById('add-serie-form').style.display = 'none';
    addSelectedSerie = null;

    if (!addConfigLoaded) {
      addConfigLoaded = true;
      Promise.all([
        ajaxGet('{{ app.request.getBasePath() }}/medias/' + (INSTANCE_SLUG || DEFAULT_SONARR_SLUG) + '/sonarr/quality-profiles'),
        ajaxGet('{{ app.request.getBasePath() }}/medias/' + (INSTANCE_SLUG || DEFAULT_SONARR_SLUG) + '/sonarr/root-folders'),
        ajaxGet('{{ app.request.getBasePath() }}/medias/' + (INSTANCE_SLUG || DEFAULT_SONARR_SLUG) + '/sonarr/tags-json')
      ]).then(function(results) {
        var profiles = results[0] || [];
        var roots = results[1] || [];
        var tags = results[2] || [];
        var qSel = document.getElementById('add-serie-quality');
        qSel.innerHTML = '';
        profiles.forEach(function(p) {
          var o = document.createElement('option'); o.value = p.id; o.textContent = p.name; qSel.appendChild(o);
        });
        var rSel = document.getElementById('add-serie-root');
        rSel.innerHTML = '';
        roots.forEach(function(r) {
          var o = document.createElement('option'); o.value = r.path; o.textContent = r.path; rSel.appendChild(o);
        });
        var tContainer = document.getElementById('add-serie-tags');
        tContainer.innerHTML = '';
        tags.forEach(function(t) {
          var lbl = document.createElement('label');
          lbl.className = 'badge bg-secondary-lt';
          lbl.style.cursor = 'pointer';
          lbl.innerHTML = '<input type="checkbox" class="d-none add-tag-cb" value="' + t.id + '"> ' + t.label;
          lbl.addEventListener('click', function() {
            var cb = lbl.querySelector('input');
            cb.checked = !cb.checked;
            lbl.className = 'badge ' + (cb.checked ? 'bg-primary' : 'bg-secondary-lt');
            lbl.style.cursor = 'pointer';
          });
          tContainer.appendChild(lbl);
        });
      });
    }
  });

  // Recherche debounce
  document.getElementById('add-serie-search').addEventListener('input', function() {
    var q = this.value.trim();
    if (addSearchTimer) clearTimeout(addSearchTimer);
    if (q.length < 2) { document.getElementById('add-serie-results').innerHTML = ''; document.getElementById('add-serie-loading').style.display = 'none'; return; }
    addSearchTimer = setTimeout(function() {
      document.getElementById('add-serie-loading').style.display = '';
      document.getElementById('add-serie-results').innerHTML = '';
      ajaxGet('{{ app.request.getBasePath() }}/medias/' + (INSTANCE_SLUG || DEFAULT_SONARR_SLUG) + '/series/lookup?term=' + encodeURIComponent(q)).then(function(results) {
        document.getElementById('add-serie-loading').style.display = 'none';
        var container = document.getElementById('add-serie-results');
        container.innerHTML = '';
        if (!results || !results.length) {
          container.innerHTML = '<div class="col-12 text-muted text-center py-3">' + esc(SERIES_I18N.modal_no_results) + '</div>';
          return;
        }
        results.slice(0, 20).forEach(function(s) {
          var existing = !!s.id;
          var col = document.createElement('div');
          col.className = 'col-12 col-md-6';
          var genres = (s.genres || []).slice(0, 4).map(function(g) { return '<span class="badge bg-secondary-lt me-1" style="font-size:.55rem;">' + esc(g) + '</span>'; }).join('');
          var statusBadge = '';
          if (existing) statusBadge = '<span class="badge bg-success ms-1" style="font-size:.55rem;">' + esc(SERIES_I18N.modal_already_added) + '</span>';
          else if (s.status === 'ended') statusBadge = '<span class="badge bg-secondary-lt ms-1" style="font-size:.55rem;">' + esc(SERIES_I18N.ended) + '</span>';
          else if (s.status === 'continuing') statusBadge = '<span class="badge bg-success-lt ms-1" style="font-size:.55rem;">' + esc(SERIES_I18N.continuing) + '</span>';

          col.innerHTML =
            '<div class="add-serie-result d-flex gap-2 p-2 rounded" data-tvdbid="' + (s.tvdbId || '') + '" style="cursor:pointer;border:1px solid var(--tblr-border-color);' + (existing ? 'opacity:.5;' : '') + '" data-serie=\'' + JSON.stringify(s).replace(/'/g, '&#39;') + '\'>' +
            (s.poster ? '<img src="' + esc(s.poster) + '" style="width:60px;height:90px;object-fit:cover;border-radius:.4rem;flex-shrink:0;" loading="lazy">' : '<div style="width:60px;height:90px;background:var(--tblr-bg-surface-secondary);border-radius:.4rem;flex-shrink:0;"></div>') +
            '<div class="flex-grow-1 min-width-0">' +
            '<div class="fw-bold" style="font-size:.82rem;">' + esc(s.title) + (s.year ? ' <span class="text-muted fw-normal">(' + s.year + ')</span>' : '') + statusBadge + '</div>' +
            '<div class="text-muted small">' + (s.network || '') + (s.seasonCount ? ' · ' + tpl(SERIES_I18N.season_tpl, { COUNT: s.seasonCount }) : '') + '</div>' +
            (genres ? '<div class="mt-1">' + genres + '</div>' : '') +
            (s.overview ? '<div class="text-muted mt-1" style="font-size:.7rem;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;">' + esc(s.overview) + '</div>' : '') +
            '</div></div>';
          container.appendChild(col);
        });

        // Bind click
        container.querySelectorAll('.add-serie-result').forEach(function(el) {
          el.addEventListener('click', function() {
            var s = JSON.parse(el.dataset.serie);
            if (s.id) return;
            addSelectedSerie = s;
            document.getElementById('add-serie-tvdbid').value = s.tvdbId || '';
            document.getElementById('add-serie-title').textContent = s.title + (s.year ? ' (' + s.year + ')' : '');
            if (s.seriesType === 'anime') document.getElementById('add-serie-type').value = 'anime';
            else document.getElementById('add-serie-type').value = 'standard';
            document.getElementById('add-serie-form').style.display = '';
            // Highlight selected
            container.querySelectorAll('.add-serie-result').forEach(function(r) { r.style.borderColor = 'var(--tblr-border-color)'; });
            el.style.borderColor = '#6366f1';
          });
        });
      });
    }, 400);
  });

  // Confirmer ajout
  document.getElementById('add-serie-confirm').addEventListener('click', function() {
    if (!addSelectedSerie) return;
    var btn = this;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> ' + SERIES_I18N.modal_adding;

    var selectedTags = [];
    document.querySelectorAll('.add-tag-cb:checked').forEach(function(cb) {
      selectedTags.push(parseInt(cb.value));
    });
    ajaxPost('{{ app.request.getBasePath() }}/medias/' + (INSTANCE_SLUG || DEFAULT_SONARR_SLUG) + '/series/add', {
      tvdbId: parseInt(document.getElementById('add-serie-tvdbid').value),
      rootFolderPath: document.getElementById('add-serie-root').value,
      qualityProfileId: parseInt(document.getElementById('add-serie-quality').value),
      seriesType: document.getElementById('add-serie-type').value,
      monitor: document.getElementById('add-serie-monitor').value,
      monitored: true,
      seasonFolder: document.getElementById('add-serie-season-folder').checked,
      searchForMissing: document.getElementById('add-serie-search-missing').checked,
      tags: selectedTags
    }).then(function(data) {
      btn.disabled = false;
      btn.innerHTML = SERIES_I18N.modal_add_button;
      if (data.ok) {
        var resultEl = document.getElementById('add-serie-result');
        resultEl.className = 'mt-2 alert alert-success';
        resultEl.textContent = SERIES_I18N.modal_added_success;
        resultEl.classList.remove('d-none');
        btn.style.display = 'none';
        setTimeout(function() { location.reload(); }, 2000);
      } else {
        var resultEl = document.getElementById('add-serie-result');
        resultEl.className = 'mt-2 alert alert-danger';
        resultEl.textContent = tpl(SERIES_I18N.modal_add_error_tpl, { ERR: (data.error || SERIES_I18N.modal_error_unknown) });
        resultEl.classList.remove('d-none');
        btn.disabled = false;
        btn.innerHTML = SERIES_I18N.modal_add_button;
      }
    }).catch(function() {
      btn.disabled = false;
      btn.innerHTML = SERIES_I18N.modal_add_button;
      var resultEl = document.getElementById('add-serie-result');
      resultEl.className = 'mt-2 alert alert-danger';
      resultEl.textContent = SERIES_I18N.modal_network_error;
      resultEl.classList.remove('d-none');
    });
  });

  // Deep-link: ?open={sonarrId} opens the matching series modal once the
  // page has rendered. The controller has already switched to the page that
  // holds this id, so the card is guaranteed to be in the DOM. Only the
  // `open` param is stripped afterwards so a refresh re-renders the same
  // filter view without re-triggering the modal.
  var openParam = new URLSearchParams(window.location.search).get('open');
  if (openParam) {
    var target = document.querySelector('.media-card[data-id="' + openParam + '"]') || document.querySelector('.series-table-row[data-id="' + openParam + '"]');
    if (target) setTimeout(function() { target.click(); }, 300);
    var cleanUrl = new URL(window.location.href);
    cleanUrl.searchParams.delete('open');
    history.replaceState(null, '', cleanUrl.pathname + (cleanUrl.search ? cleanUrl.search : '') + cleanUrl.hash);
  }

})();
</script>
{% endblock %}
