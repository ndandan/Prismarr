  function postAction(url, body, successCb, errorCb) {
    fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify(body),
    })
    .then(function (r) { return r.json(); })
    .then(function (data) {
      if (data.ok) { if (successCb) successCb(data); }
      else { if (errorCb) errorCb(data); else showBanner(data.error || SERIES_I18N.d_error, 'danger'); }
    })
    .catch(function () { showBanner(SERIES_I18N.d_network_error, 'danger'); });
  }

  var bannerEl = document.getElementById('modal-serie-banner');
  function showBanner(html, type) {
    bannerEl.className = 'alert alert-' + (type || 'info') + ' mb-2 py-2';
    bannerEl.style.fontSize = '.82rem';
    bannerEl.innerHTML = html;
    bannerEl.classList.remove('d-none');
  }
  function hideBanner() { bannerEl.classList.add('d-none'); }

  var bannerLocked = false;
  var pageBannerSeriesId = null;

  // Defense-in-depth: showPageBanner is the safe form — `msg` is treated as
  // plain text via textContent. showPageBannerHtml is the explicit-HTML form
  // for the few call sites that inject a spinner SVG alongside an i18n
  // template. Same split as films.html.twig.
  function showPageBanner(msg, type, seriesId) {
    showPageBannerInternal(String(msg ?? ''), type, seriesId, false);
  }
  function showPageBannerHtml(msg, type, seriesId) {
    showPageBannerInternal(String(msg ?? ''), type, seriesId, true);
  }
  function showPageBannerInternal(msg, type, seriesId, allowHtml) {
    bannerLocked = true;
    if (seriesId) pageBannerSeriesId = seriesId;
    var el = document.getElementById('sonarr-warnings-banner');
    // Type icon for the auto-dismissing states; 'info' banners carry their own spinner.
    var ico = (type !== 'info' && window._prismarrTypeIcon) ? window._prismarrTypeIcon(type) : '';
    // openBtn HTML is built from i18n strings only (esc() on the title) — the
    // outer msg is the part that may carry untrusted content, so we build the
    // alert differently depending on allowHtml: textContent for the msg in
    // safe mode, then append the openBtn HTML via insertAdjacentHTML.
    var openBtnHtml = pageBannerSeriesId ? ' <button class="btn btn-sm py-0 px-1 ms-auto page-banner-open" style="opacity:.7" title="' + esc(SERIES_I18N.w_open_series_title) + '"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg></button>' : '';
    var existing = el.querySelector('.alert');
    var target = (existing && existing.classList.contains('alert-' + type)) ? existing : null;
    if (!target) {
      el.innerHTML = '';
      target = document.createElement('div');
      target.className = 'alert alert-' + (type || 'info') + ' mb-3 d-flex align-items-center gap-2';
      target.style.fontSize = '.82rem';
      el.appendChild(target);
    }
    if (allowHtml) {
      target.innerHTML = ico + msg + openBtnHtml;
    } else {
      target.innerHTML = ico + '<span></span>';
      target.querySelector('span').textContent = msg;
      if (openBtnHtml) target.insertAdjacentHTML('beforeend', openBtnHtml);
    }
    var openEl = el.querySelector('.page-banner-open');
    if (openEl) {
      openEl.onclick = function() {
        if (!pageBannerSeriesId) return;
        var card = grid.querySelector('[data-id="' + pageBannerSeriesId + '"]');
        if (card) card.click();
      };
    }
    if (type === 'success' || type === 'warning' || type === 'danger') {
      setTimeout(function() { bannerLocked = false; el.innerHTML = ''; pageBannerSeriesId = null; }, 6000);
    }
  }
  function hidePageBanner() {
    bannerLocked = false;
    document.getElementById('sonarr-warnings-banner').innerHTML = '';
    pageBannerSeriesId = null;
  }

  // Tout analyser + RSS Sync
  document.getElementById('btn-refresh-all-series').addEventListener('click', function() {
    var btn = this; btn.disabled = true;
    ajaxPost('{{ app.request.getBasePath() }}/medias/' + (INSTANCE_SLUG || DEFAULT_SONARR_SLUG) + '/series/command/refresh-all', {}).then(function(d) {
      btn.disabled = false;
      if (d.ok && d.cmdId) {
        pollCmd(d.cmdId, SERIES_I18N.w_refresh_label, function() {});
      } else {
        showPageBanner(SERIES_I18N.w_generic_error, 'danger');
      }
    }).catch(function() { btn.disabled = false; });
  });

  document.getElementById('btn-rss-sync-series').addEventListener('click', function() {
    var btn = this; btn.disabled = true;
    ajaxPost('{{ app.request.getBasePath() }}/medias/' + (INSTANCE_SLUG || DEFAULT_SONARR_SLUG) + '/series/command/rss-sync', {}).then(function(d) {
      btn.disabled = false;
      if (d.ok && d.cmdId) {
        pollCmd(d.cmdId, SERIES_I18N.w_rss_label, function() {});
      } else {
        showPageBanner(SERIES_I18N.w_generic_error, 'danger');
      }
    }).catch(function() { btn.disabled = false; });
  });

  // Warnings auto-refresh (10s)
  function refreshSeriesWarnings() {
    if (bannerLocked) return;
    var el = document.getElementById('sonarr-warnings-banner');
    if (!el) return;
    ajaxGet('{{ app.request.getBasePath() }}/medias/' + (INSTANCE_SLUG || DEFAULT_SONARR_SLUG) + '/series/warnings').then(function(warnings) {
      if (!warnings || !warnings.length) { el.innerHTML = ''; return; }
      el.innerHTML = '<div class="alert alert-warning mb-3"><div class="d-flex align-items-center"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-2 flex-shrink-0"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg><div>' + warnings.map(function(w) { return '<div>' + w + '</div>'; }).join('') + '</div></div></div>';
    }).catch(function(){});
  }
  refreshSeriesWarnings();
  setInterval(refreshSeriesWarnings, 10000);

  // Check for active commands on page load (only user-initiated ones)
  var POLL_COMMANDS = {'SeriesSearch':1,'SeasonSearch':1,'EpisodeSearch':1,'RenameFiles':1,'MissingEpisodeSearch':1};
  ajaxGet('{{ app.request.getBasePath() }}/medias/' + (INSTANCE_SLUG || DEFAULT_SONARR_SLUG) + '/series/commands/active').then(function(cmds) {
    if (!cmds || !cmds.length) return;
    cmds.forEach(function(cmd) {
      var name = cmd.name || '';
      if (!POLL_COMMANDS[name]) return;
      var cmdId = cmd.id;
      if (!cmdId) return;
      var seriesId = (cmd.body && cmd.body.seriesId) ? String(cmd.body.seriesId) : null;
      var label = name;
      if (name === 'SeriesSearch') label = SERIES_I18N.d_search_series;
      else if (name === 'SeasonSearch') label = SERIES_I18N.d_search_cmd_season;
      else if (name === 'EpisodeSearch') label = SERIES_I18N.d_search_cmd_episode;
      else if (name === 'RenameFiles') label = SERIES_I18N.d_search_cmd_rename;
      else if (name === 'MissingEpisodeSearch') label = SERIES_I18N.d_search_missing_short;
      pollCmd(cmdId, label, function() {}, seriesId);
    });
  });

  function pollCmd(cmdId, label, onDone, seriesId) {
    var pollSeriesId = seriesId || currentId;
    var pollCount = 0;
    showPageBannerHtml('<span class="spinner-border spinner-border-sm me-2"></span> ' + tpl(SERIES_I18N.w_cmd_in_progress_tpl, { LBL: label }), 'info', pollSeriesId);
    if (pollSeriesId && pollSeriesId == currentId) {
      showBanner('<span class="spinner-border spinner-border-sm me-2"></span> ' + tpl(SERIES_I18N.w_cmd_in_progress_tpl, { LBL: label }), 'info');
    }
    var timer = setInterval(function() {
      pollCount++;
      var elapsed = pollCount * 2;
      fetch('{{ app.request.getBasePath() }}/medias/' + (INSTANCE_SLUG || DEFAULT_SONARR_SLUG) + '/series/command/' + cmdId, { headers: {'X-Requested-With':'XMLHttpRequest'} })
      .then(function(r) { return r.json(); })
      .then(function(cmd) {
        var st = (cmd.status || '').toLowerCase();
        var msg = cmd.message || '';
        var isCurrentModal = pollSeriesId && pollSeriesId == currentId;
        if (st === 'completed') {
          clearInterval(timer);
          // Sonarr's command message sometimes carries "(\d+) report(s) downloaded"
          // or "grabbed" (older versions, singular vs plural varies), often just
          // "Completed" on v4+. Treat a no-match as "unknown count" rather than
          // "zero" so we stop falsely claiming "no result found" when Sonarr did
          // grab something but doesn't tell us how many.
          var dl = msg.match(/(\d+)\s+reports?\s+(?:downloaded|grabbed)/i);
          var dlCount = dl ? parseInt(dl[1], 10) : null;
          var searchKw = SERIES_I18N.d_search_bookmark.toLowerCase();
          var isSearch = label.toLowerCase().indexOf(searchKw) !== -1 || label.toLowerCase().indexOf('recherche') !== -1 || label.toLowerCase().indexOf('search') !== -1;
          if (dlCount !== null && dlCount > 0) {
            if (isCurrentModal) showBanner(tpl(SERIES_I18N.w_cmd_dl_ok_tpl, { LBL: label, COUNT: dlCount }), 'success');
            showPageBanner(tpl(SERIES_I18N.w_cmd_dl_ok_tpl, { LBL: label, COUNT: dlCount }), 'success', pollSeriesId);
          } else if (dlCount === 0 && isSearch) {
            if (isCurrentModal) showBanner(tpl(SERIES_I18N.w_cmd_nothing_tpl, { LBL: label }), 'warning');
            showPageBanner(tpl(SERIES_I18N.w_cmd_nothing_tpl, { LBL: label }), 'warning', pollSeriesId);
          } else {
            if (isCurrentModal) showBanner(tpl(SERIES_I18N.w_cmd_done_tpl, { LBL: label }), 'success');
            showPageBanner(tpl(SERIES_I18N.w_cmd_done_tpl, { LBL: label }), 'success', pollSeriesId);
          }
          if (isCurrentModal) setTimeout(hideBanner, 5000);
          if (onDone) onDone(true, msg);
        } else if (st === 'failed') {
          clearInterval(timer);
          var errMsg = msg || SERIES_I18N.d_unknown_error;
          if (isCurrentModal) showBanner(tpl(SERIES_I18N.w_cmd_failed_tpl, { LBL: label, ERR: errMsg }), 'danger');
          showPageBanner(tpl(SERIES_I18N.w_cmd_failed_tpl, { LBL: label, ERR: errMsg }), 'danger', pollSeriesId);
          if (onDone) onDone(false, msg);
        } else {
          var display = msg || tpl(SERIES_I18N.d_search_in_progress_generic_tpl, { SEC: elapsed });
          if (isCurrentModal) showBanner('<span class="spinner-border spinner-border-sm me-2"></span> ' + tpl(SERIES_I18N.w_cmd_elapsed_tpl, { LBL: label, MSG: display }), 'info');
          showPageBannerHtml('<span class="spinner-border spinner-border-sm me-2"></span> ' + tpl(SERIES_I18N.w_cmd_elapsed_tpl, { LBL: label, MSG: display }), 'info', pollSeriesId);
        }
      });
    }, 2000);
    return timer;
  }

