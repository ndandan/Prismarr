            setTimeout(loadEpisodes, 500);
          });
        });
      });

      // Bind episode monitor
      var allEpMonBtns = Array.from(epContainer.querySelectorAll('.btn-ep-monitor'));
      var lastMonClickIdx = -1;

      allEpMonBtns.forEach(function(btn, idx) {
        btn.addEventListener('click', function(e) {
          e.stopPropagation();
          var mon = btn.dataset.monitored !== '1';

          // Shift+click → select range
          if (e.shiftKey && lastMonClickIdx >= 0 && lastMonClickIdx !== idx) {
            var start = Math.min(lastMonClickIdx, idx);
            var end = Math.max(lastMonClickIdx, idx);
            var rangeBtns = allEpMonBtns.slice(start, end + 1);
            var epIds = rangeBtns.map(function(b) { return parseInt(b.dataset.epId); });

            // Update UI immediately
            rangeBtns.forEach(function(b) {
              b.dataset.monitored = mon ? '1' : '0';
              b.innerHTML = mon ? SVG_MONITOR_ON : SVG_MONITOR_OFF;
              b.title = mon ? SERIES_I18N.d_unmonitor : SERIES_I18N.d_monitor;
              // Update dot color
              var dot = b.parentNode.querySelector('span[style*="border-radius:50%"]');
              if (dot) {
                var hasFile = dot.style.background === 'rgb(34, 197, 94)';
