    fm_bulk_pick_eps: {{ 'media.series.filemanager.bulk_pick_eps'|trans|json_encode|raw }},
    fm_bulk_apply: {{ 'media.series.filemanager.bulk_apply'|trans|json_encode|raw }},
    fm_bulk_no_episode: {{ 'media.series.filemanager.bulk_no_episode'|trans|json_encode|raw }},
    fm_bulk_group_placeholder: {{ 'media.series.filemanager.bulk_group_placeholder'|trans|json_encode|raw }},
    fm_bulk_group_ok: {{ 'media.series.filemanager.bulk_group_ok'|trans|json_encode|raw }},
    fm_save_all: {{ 'media.series.filemanager.save_all'|trans|json_encode|raw }},
    fm_saving: {{ 'media.series.filemanager.saving'|trans|json_encode|raw }},
    fm_season_option_special: {{ 'media.series.filemanager.season_option_special'|trans|json_encode|raw }},
    fm_no_ep_for_file_tpl: {{ 'media.series.filemanager.no_ep_for_file_tpl'|trans({name: '__NAME__'})|json_encode|raw }},
    fm_save_success_tpl: {{ 'media.series.filemanager.save_success_tpl'|trans({count: '__COUNT__'})|json_encode|raw }},
    fm_save_partial_tpl: {{ 'media.series.filemanager.save_partial_tpl'|trans({ok: '__OK__', errors: '__ERR__'})|json_encode|raw }},
    fm_save_network_error: {{ 'media.series.filemanager.save_network_error'|trans|json_encode|raw }},
    fm_save_bulk_too_many_tpl: {{ 'media.series.filemanager.save_bulk_too_many_tpl'|trans({picked: '__PICKED__', selected: '__SEL__'})|json_encode|raw }},
    fm_save_bulk_none_selected: {{ 'media.series.filemanager.save_bulk_none_selected'|trans|json_encode|raw }},
    fm_release_type_single: {{ 'media.series.filemanager.release_type_single'|trans|json_encode|raw }},
    fm_release_type_multi: {{ 'media.series.filemanager.release_type_multi'|trans|json_encode|raw }},
    fm_release_type_pack: {{ 'media.series.filemanager.release_type_pack'|trans|json_encode|raw }},
    fm_indexer_flag_none: {{ 'media.series.filemanager.indexer_flag_none'|trans|json_encode|raw }}
  };
  function tpl(s, map) {
    if (!s) return '';
    Object.keys(map || {}).forEach(function(k){
      s = s.split('__' + k + '__').join(String(map[k]));
    });
    return s;
  }

  /* ══════════════════════════════════════════════════════════════════════════
     Grid + filters — issue #19 made everything server-side.
     #series-filter-form re-navigates with the new query params on every
     change; the grid rendered by Twig is already filtered, sorted, paginated.
     applyFilters() is kept as a thin no-op shim for legacy callers (shelf
     rebuild after bulk delete), it only triggers a shelf re-render when that
     view is active.
     ══════════════════════════════════════════════════════════════════════════ */
  var grid    = document.getElementById('series-grid');
  var visibleCards = function() { return Array.from(grid.querySelectorAll('.media-card')).filter(function(c) { return getComputedStyle(c).display !== 'none'; }); };
  var search  = document.getElementById('search-input');
  var btnAll  = document.querySelectorAll('#series-filter-form .filter-pill');
  var shelfView = document.getElementById('series-shelf-view');
  var filterForm   = document.getElementById('series-filter-form');
  var statusInput  = document.getElementById('series-filter-status');
  var shelfBuilt = false;

  // Below lg the filters live in an offcanvas drawer: auto-submit-on-change is
  // suppressed (it would navigate and destroy the open drawer). The Apply
  // button flips _applyingFilters and calls submitFiltersForm() once.
  var _filtersMobile = window.matchMedia('(max-width: 991.98px)');
  var _applyingFilters = false;

  function submitFiltersForm() {
    if (_filtersMobile.matches && !_applyingFilters) return;
    if (!filterForm) return;
    if (typeof filterForm.requestSubmit === 'function') {
      filterForm.requestSubmit();
    } else {
      filterForm.submit();
    }
  }

  function applyFilters() {
    // Server-side filtering already drove the current DOM; only the shelf
    // rebuild needs to be re-triggered when it's the active view.
    if (shelfView && shelfView.style.display === 'block' && typeof buildShelfView === 'function') {
      shelfBuilt = false; buildShelfView();
    }
  }

  // Auto-submit on filter change.
  ['filter-genre', 'filter-network', 'sort-select'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el) el.addEventListener('change', submitFiltersForm);
  });

  // Drawer Apply (mobile only): defer the single navigation to here.
  var _seriesApplyBtn = document.getElementById('series-filters-apply');
  if (_seriesApplyBtn) _seriesApplyBtn.addEventListener('click', function() {
    _applyingFilters = true;
    submitFiltersForm();
  });

  // Debounced text search: submit after 300ms of inactivity so typing
  // a 5-letter word doesn't trigger 5 navigations.
  var _seriesSearchTimer;
  if (search) {
    search.addEventListener('input', function() {
      clearTimeout(_seriesSearchTimer);
      _seriesSearchTimer = setTimeout(submitFiltersForm, 300);
    });
  }

  // Loading state visuel : grille/table/shelf passent en opacity 0.5 dès qu'un
  // filter submit ou un click pagination part. Le full reload remplace ensuite
  // toute la page, donc pas besoin de retirer la classe (la nouvelle page la
  // recrée sans). Donne un feedback "ça réagit" même quand le reload prend
  // 200-500 ms. (Turbo Frame swap envisagé puis abandonné : nécessite une
  // refonte JS Turbo-safe, cf card kanban + extraction ES modules.)
  function markLibraryLoading() {
    if (grid) grid.classList.add('library-loading');
    var tableViewEl = document.getElementById('series-table-view');
    if (tableViewEl) tableViewEl.classList.add('library-loading');
    if (shelfView) shelfView.classList.add('library-loading');
  }
  if (filterForm) filterForm.addEventListener('submit', markLibraryLoading);
  document.addEventListener('click', function(e) {
    if (e.target.closest('.library-pagination-card a.page-link')) markLibraryLoading();
  }, true);
  document.addEventListener('submit', function(e) {
    if (e.target.closest('.library-pagination-card')) markLibraryLoading();
  }, true);

  // Build a query string from the form so the bulk-filtered endpoints can
  // re-apply the same filter server-side.
  function currentFilterParams(extra) {
    var params = new URLSearchParams(new FormData(filterForm));
    Object.keys(extra || {}).forEach(function(k) { params.set(k, extra[k]); });
    return params.toString();
  }

  // Resolve the current filter to the full list of matching series IDs via
  // the server (so bulk-filtered actions hit the whole filtered scope, not
  // just the items rendered on the current page).
  function fetchFilteredSeriesIds(extra) {
    var url = '{{ app.request.getBasePath() }}/medias/' + (INSTANCE_SLUG || DEFAULT_SONARR_SLUG) + '/series/filter/ids?' + currentFilterParams(extra || {});
    return ajaxGet(url).then(function(data) {
      return (data && Array.isArray(data.ids)) ? data.ids : [];
    });
  }

  // Status buttons → set the hidden input and submit (the form's GET
  // submission becomes the new ?status= in the URL).
  btnAll.forEach(function (btn) {
    btn.addEventListener('click', function () {
      btnAll.forEach(function (b) { b.classList.remove('active'); });
      btn.classList.add('active');
      statusInput.value = btn.dataset.filter || 'all';
      submitFiltersForm();
    });
  });

  // View mode switch + persist.
  // shelfView and shelfBuilt are already declared alongside the filter
  // helpers above (issue #19 needed them earlier in the file).
  var tableView = document.getElementById('series-table-view');
  var shelfExpanded = {};

  // Issue #19 — cards in the DOM are already filtered/sorted server-side,
  // so the shelves operate on whatever the user is currently looking at.
  // Caveat: with pagination active the shelves only see the current page.
  // The unlimited-fetch variant ships in 1.1.1+.
  function buildShelfView() {
    if (shelfBuilt) return;
    shelfBuilt = true;
    var cards = Array.from(grid.querySelectorAll('.media-card'));
    var groups = {
      'continuing': { label: {{ ico.icon('device-tv', '', 14)|json_encode|raw }} + ' ' + SERIES_I18N.continuing, items: [] },
      'ended': { label: {{ ico.icon('check', '', 14)|json_encode|raw }} + ' ' + SERIES_I18N.ended, items: [] },
      'upcoming': { label: {{ ico.icon('crystal-ball', '', 14)|json_encode|raw }} + ' ' + SERIES_I18N.upcoming, items: [] },
      'anime': { label: {{ ico.icon('flower', '', 14)|json_encode|raw }} + ' ' + SERIES_I18N.anime, items: [] },
      'unmonitored': { label: {{ ico.icon('eye', '', 14)|json_encode|raw }} + ' ' + SERIES_I18N.unfollowed, items: [] }
    };
    cards.forEach(function(c) {
      var s = c.dataset;
      var item = { id: s.id, title: s.displayTitle || '', poster: s.poster || '', percent: parseInt(s.percent) || 0, status: s.status, type: s.type, monitored: s.monitored };
      if (s.type === 'anime') groups.anime.items.push(item);
      if (s.monitored === '0') { groups.unmonitored.items.push(item); return; }
      if (s.status === 'continuing') groups.continuing.items.push(item);
      else if (s.status === 'ended') groups.ended.items.push(item);
      else if (s.status === 'upcoming') groups.upcoming.items.push(item);
    });
    var html = '';
    ['continuing','anime','ended','upcoming','unmonitored'].forEach(function(key) {
      var g = groups[key];
      if (!g.items.length) return;
      var isExpanded = !!shelfExpanded[key];
      html += '<div class="shelf-section' + (isExpanded ? ' is-expanded' : '') + '" data-shelf="' + key + '">';
      html += '<div class="shelf-header"><button type="button" class="shelf-toggle" data-shelf-toggle="' + key + '" aria-label="Toggle shelf" aria-expanded="' + (isExpanded ? 'true' : 'false') + '"><span class="shelf-chevron">›</span></button>';
      html += '<h4>' + g.label + ' <span class="text-muted fw-normal" style="font-size:.75rem;">(' + g.items.length + ')</span></h4></div>';
      html += '<div class="shelf-scroll">';
      g.items.forEach(function(item) {
        var barColor = item.percent === 100 ? '#22c55e' : (item.percent > 0 ? '#ef4444' : '#6b7280');
        if (item.status === 'continuing' && item.percent === 100) barColor = '#38bdf8';
        html += '<div class="shelf-card" data-id="' + item.id + '">';
        html += item.poster ? '<img src="' + item.poster + '" alt="" loading="lazy">' : '<div style="width:100%;aspect-ratio:2/3;background:var(--tblr-bg-surface-secondary);"></div>';
        html += '<div class="shelf-title">' + item.title + '</div>';
        html += '<div class="shelf-bar" style="background:' + barColor + ';"></div>';
        html += '</div>';
      });
      html += '</div></div>';
    });
    shelfView.innerHTML = html;
    // Click handler
    shelfView.onclick = function(e) {
      var toggle = e.target.closest('[data-shelf-toggle]');
      if (toggle) {
        var shelfKey = toggle.dataset.shelfToggle;
        shelfExpanded[shelfKey] = !shelfExpanded[shelfKey];
        shelfBuilt = false;
        buildShelfView();
        return;
      }
      var sc = e.target.closest('.shelf-card');
      if (!sc) return;
      var id = sc.dataset.id;
      if (selectMode) {
        var card = grid.querySelector('.media-card[data-id="' + id + '"]');
        if (card) toggleSelect(card);
        sc.style.outline = selectedSeriesIds.has(id) ? '2px solid var(--tblr-primary)' : 'none';
        return;
      }
      var card = grid.querySelector('.media-card[data-id="' + id + '"]');
      if (card) card.click();
    };
  }

  function setViewMode(mode) {
    grid.classList.remove('view-table', 'view-extended', 'view-compact', 'view-wall');
    grid.style.display = '';
    tableView.classList.remove('active');
    shelfView.style.display = 'none';
    if (mode === 'table') {
      grid.style.display = 'none';
      tableView.classList.add('active');
    } else if (mode === 'shelf') {
      grid.style.display = 'none';
      buildShelfView();
      shelfView.style.display = 'block';
    } else if (mode !== 'grid') {
      grid.classList.add('view-' + mode);
    }
    document.querySelectorAll('.view-btn').forEach(function(b) {
      b.classList.remove('active', 'btn-secondary');
      b.classList.add('btn-ghost-secondary');
      if (b.dataset.view === mode) { b.classList.add('active', 'btn-secondary'); b.classList.remove('btn-ghost-secondary'); }
    });
    try { localStorage.setItem('prismarr_series_view', mode); } catch(e) {}
    applyFilters();
  }
  // Restore saved view
  var savedView = 'grid';
  try { savedView = localStorage.getItem('prismarr_series_view') || 'grid'; } catch(e) {}
  if (savedView !== 'grid') setViewMode(savedView);

  document.querySelectorAll('.view-btn').forEach(function(btn) {
    btn.addEventListener('click', function() { setViewMode(btn.dataset.view); });
  });

  // Clic signet hover → toggle suivi rapidement
  grid.addEventListener('mousedown', function(e) {
    if (e.target.closest('.hover-monitor-btn')) { blockModal = true; }
  }, true);
  grid.addEventListener('click', function(e) {
    var btn = e.target.closest('.hover-monitor-btn');
    if (!btn) return;
    e.preventDefault();
    e.stopImmediatePropagation();
    blockModal = true;
    var id = btn.dataset.id;
    var mon = btn.dataset.monitored === '1';
    var newMon = !mon;
    ajaxPost('{{ app.request.getBasePath() }}/medias/' + (INSTANCE_SLUG || DEFAULT_SONARR_SLUG) + '/series/' + id + '/monitor', { monitored: newMon }).then(function(data) {
      if (data.ok) {
        btn.dataset.monitored = newMon ? '1' : '0';
        var svg = btn.querySelector('svg');
        svg.setAttribute('fill', newMon ? '#6366f1' : 'none');
        svg.setAttribute('stroke', newMon ? '#6366f1' : 'rgba(255,255,255,.5)');
        btn.title = newMon ? SERIES_I18N.d_unmonitor : SERIES_I18N.d_monitor;
        var card = grid.querySelector('.media-card[data-id="' + id + '"]');
        if (card) card.dataset.monitored = newMon ? '1' : '0';
        refreshSeriesCard(id);
      }
    });
  }, true);

  // Clic sur une ligne du tableau → ouvrir la modal via la card correspondante
  document.getElementById('series-table-tbody').addEventListener('click', function(e) {
    var row = e.target.closest('.series-table-row');
    if (!row) return;
    var id = row.dataset.id;
    if (selectMode) {
      var card = grid.querySelector('.media-card[data-id="' + id + '"]');
      if (card) toggleSelect(card);
      syncSeriesTableSelection();
      return;
    }
    var card = grid.querySelector('.media-card[data-id="' + id + '"]');
    if (card) card.click();
  });

  function syncSeriesTableSelection() {
    document.querySelectorAll('.select-cb-table-s').forEach(function(cb) {
      var id = cb.dataset.id;
      var isSelected = selectedSeriesIds.has(id);
      cb.style.background = isSelected ? '#6366f1' : 'rgba(0,0,0,.3)';
      cb.style.borderColor = isSelected ? '#6366f1' : 'rgba(255,255,255,.4)';
      cb.closest('tr').style.background = isSelected ? 'rgba(var(--tblr-primary-rgb),.1)' : '';
    });
  }

  // Refresh the currently filtered series. The wrapping conditional in the
  // template only emits these handlers when a filter is active, but we still
  // guard with a null check: a missing node would crash with
  // "addEventListener of null".
  var btnUpdateFilteredSeries = document.getElementById('btn-update-filtered-series');
  if (btnUpdateFilteredSeries) btnUpdateFilteredSeries.addEventListener('click', function() {
    var btn = this;
    btn.disabled = true;
    showPageBannerHtml('<span class="spinner-border spinner-border-sm me-2"></span> ' + SERIES_I18N.w_resolving_filter, 'info');

    fetchFilteredSeriesIds().then(function(ids) {
      // Capture the initial count locally so the final banner doesn't read
      // a mutated `.length` (the async callbacks fire after we've already
      // moved on, and other UI handlers may touch `ids` in unexpected ways).
      var total = ids.length;
      if (total === 0) {
        btn.disabled = false;
        showPageBanner(SERIES_I18N.w_no_filter_match, 'warning');
        return;
      }
      showPageBannerHtml('<span class="spinner-border spinner-border-sm me-2"></span> ' + tpl(SERIES_I18N.w_refreshing_tpl, { COUNT: total }), 'info');
      var done = 0;
      var finish = function() {
        done++;
        if (done >= total) {
          btn.disabled = false;
          showPageBanner(tpl(SERIES_I18N.w_refresh_tpl, { COUNT: total }), 'success');
        }
      };
      ids.forEach(function(sid) {
        ajaxPost('{{ app.request.getBasePath() }}/medias/' + (INSTANCE_SLUG || DEFAULT_SONARR_SLUG) + '/series/' + sid + '/refresh', {})
          .then(finish, finish);
      });
    }).catch(function() {
      btn.disabled = false;
      showPageBanner(SERIES_I18N.w_network_error || 'Network error', 'danger');
    });
  });

  // Search for missing episodes across the filtered series. searchable_only=1
  // narrows the server-side resolver to monitored series with at least one
  // missing episode, sparing the user a confirm dialog on irrelevant items.
  var btnSearchFilteredSeries = document.getElementById('btn-search-filtered-series');
  if (btnSearchFilteredSeries) btnSearchFilteredSeries.addEventListener('click', function() {
    var btn = this;
    btn.disabled = true;
    showPageBannerHtml('<span class="spinner-border spinner-border-sm me-2"></span> ' + SERIES_I18N.w_resolving_filter, 'info');

    fetchFilteredSeriesIds({ searchable_only: '1' }).then(function(ids) {
      var total = ids.length;
      if (total === 0) {
        btn.disabled = false;
        showPageBanner(SERIES_I18N.w_no_monitored_filtered, 'warning');
        return;
      }
      if (!confirm(tpl(SERIES_I18N.w_confirm_search_filtered_tpl, { COUNT: total }))) {
        btn.disabled = false;
        return;
      }
      showPageBannerHtml('<span class="spinner-border spinner-border-sm me-2"></span> ' + tpl(SERIES_I18N.w_searching_tpl, { COUNT: total }), 'info');
      var done = 0;
      var finish = function() {
        done++;
        if (done >= total) {
          btn.disabled = false;
          showPageBanner(tpl(SERIES_I18N.w_search_launched_tpl, { COUNT: total }), 'success');
        }
      };
      ids.forEach(function(sid) {
        ajaxPost('{{ app.request.getBasePath() }}/medias/' + (INSTANCE_SLUG || DEFAULT_SONARR_SLUG) + '/series/' + sid + '/search', {})
          .then(finish, finish);
      });
    }).catch(function() {
      btn.disabled = false;
      showPageBanner(SERIES_I18N.w_network_error || 'Network error', 'danger');
    });
  });

  /* ══════════════════════════════════════════════════════════════════════════
     Mode sélection + actions bulk séries
     ══════════════════════════════════════════════════════════════════════════ */
  var selectMode = false;
  var selectedSeriesIds = new Set();
  var lastSelectedIdx = -1;
  var bulkBar = document.getElementById('bulk-bar-series');
  var bulkCount = document.getElementById('bulk-count-series');

  function updateBulkBar() {
    bulkCount.textContent = selectedSeriesIds.size;
    bulkBar.style.display = selectMode ? 'block' : 'none';
  }

  function toggleSelect(card, force) {
    var id = card.dataset.id;
    var cb = card.querySelector('.select-cb');
    var selected = force !== undefined ? force : !selectedSeriesIds.has(id);
    if (selected) { selectedSeriesIds.add(id); card.classList.add('selected'); cb.classList.add('checked'); }
    else { selectedSeriesIds.delete(id); card.classList.remove('selected'); cb.classList.remove('checked'); }
    updateBulkBar();
    if (typeof syncSeriesTableSelection === 'function') syncSeriesTableSelection();
  }

  function clearSelection() {
    selectedSeriesIds.clear(); lastSelectedIdx = -1;
    grid.querySelectorAll('.media-card').forEach(function(c) { c.classList.remove('selected'); c.querySelector('.select-cb').classList.remove('checked'); });
    // Clear tableau
