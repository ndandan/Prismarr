            document.getElementById('season-rename-go').addEventListener('click', function() {
              var goBtn = this;
              goBtn.disabled = true;
              goBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> ' + SERIES_I18N.d_rename_in_progress;
              ajaxPost('{{ app.request.getBasePath() }}/medias/' + (INSTANCE_SLUG || DEFAULT_SONARR_SLUG) + '/series/' + seriesId + '/rename', { fileIds: fileIds }).then(function(data) {
                if (data.ok && data.cmdId) {
                  var pollRename = setInterval(function() {
                    ajaxGet('{{ app.request.getBasePath() }}/medias/' + (INSTANCE_SLUG || DEFAULT_SONARR_SLUG) + '/series/command/' + data.cmdId).then(function(cmd) {
