                <option value="all">{{ 'media.series.modal.monitor_all'|trans }}</option>
                <option value="future">{{ 'media.series.modal.monitor_future'|trans }}</option>
                <option value="missing">{{ 'media.series.modal.monitor_missing'|trans }}</option>
                <option value="firstSeason">{{ 'media.series.modal.monitor_first_season'|trans }}</option>
                <option value="lastSeason">{{ 'media.series.modal.monitor_last_season'|trans }}</option>
                <option value="none">{{ 'media.series.modal.monitor_none'|trans }}</option>
              </select>
            </div>
          </div>
          <div class="d-flex align-items-center gap-3 mt-2 flex-wrap">
            <label class="form-check mb-0"><input type="checkbox" class="form-check-input" id="add-serie-season-folder" checked><span class="form-check-label small">{{ 'media.series.modal.season_folders'|trans }}</span></label>
            <label class="form-check mb-0"><input type="checkbox" class="form-check-input" id="add-serie-search-missing"><span class="form-check-label small">{{ 'media.series.modal.search_missing'|trans }}</span></label>
            <div class="d-flex align-items-center gap-1 ms-auto">
              <span class="small text-muted">{{ 'media.series.modal.tags_label'|trans }}</span>
              <div class="d-flex gap-1 flex-wrap" id="add-serie-tags"></div>
            </div>
          </div>
          <div id="add-serie-result" class="mt-2 alert d-none" style="font-size:.9rem;"></div>
          <input type="hidden" id="add-serie-tvdbid">
        </div>

        <div id="add-serie-loading" class="text-muted small text-center py-2" style="display:none"><span class="spinner-border spinner-border-sm me-1"></span> {{ 'media.series.modal.searching'|trans }}</div>
        <div id="add-serie-results" class="row g-3"></div>
      </div>
    </div>
  </div>
</div>

