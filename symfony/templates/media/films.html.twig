{% extends 'base.html.twig' %}
{% import '_icons.html.twig' as ico %}

{# v1.1.0 — page_title is rendered automatically by base.html.twig
   (icon + instance name on instance-aware routes). The browser tab
   title still uses the legacy "Radarr" brand for single-instance
   installs and the instance name otherwise. #}
{% set _radarr_label = (instance_count|default(1) > 1 and current_instance) ? current_instance.name : 'Radarr' %}
{% block title %}{{ _radarr_label }}{% endblock %}
{% block head_meta %}<meta name="turbo-visit-control" content="reload">{% endblock %}

{% block stylesheets %}
<style>
.media-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: .75rem;
}
.media-card {
    position: relative;
    border-radius: .5rem;
    overflow: hidden;
    background: var(--tblr-bg-surface);
    border: 1px solid var(--tblr-border-color);
    cursor: pointer;
    transition: transform .15s, box-shadow .15s;
}
.media-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,.3); }
.media-card img { width: 100%; aspect-ratio: 2/3; object-fit: cover; display: block; }
.media-card .no-poster {
    width: 100%; aspect-ratio: 2/3;
    display: flex; align-items: center; justify-content: center;
    background: var(--tblr-bg-surface-secondary);
    color: var(--tblr-muted); font-size: .7rem; text-align: center; padding: .5rem;
}
.media-card .card-overlay {
    position: absolute; bottom: 0; left: 0; right: 0;
    background: linear-gradient(transparent, rgba(0,0,0,.85));
    padding: .5rem .4rem .4rem;
}
.media-card .card-title-text {
    font-size: .72rem; font-weight: 600; color: #fff;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    line-height: 1.2;
}
.media-card .card-year { font-size: .62rem; color: rgba(255,255,255,.55); }
.media-card .status-dot {
    position: absolute; top: .4rem; right: .4rem;
    width: 12px; height: 12px; border-radius: 50%;
    border: 2px solid rgba(0,0,0,.4);
    box-shadow: 0 0 6px currentColor;
}
.media-card .quality-badge {
    position: absolute; top: .4rem; left: .4rem;
    font-size: .6rem; font-weight: 700; padding: .1rem .3rem;
    border-radius: .25rem; background: rgba(0,0,0,.65); color: #fff;
    backdrop-filter: blur(4px);
}
.queue-progress { height: 4px; border-radius: 2px; background: var(--tblr-bg-surface-secondary); overflow: hidden; margin-top: .25rem; }
.queue-progress-bar { height: 100%; border-radius: 2px; background: var(--tblr-primary); transition: width .3s; }
@keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: .5; } }
/* Issue #19 — status filter buttons: outlined variants with a tinted active state */
.filter-btn { font-weight: 500; }
.filter-btn.active { color: #fff !important; }
.filter-btn[data-filter="all"].active,
.filter-btn[data-filter="unmonitored"].active { background-color: var(--tblr-secondary) !important; border-color: var(--tblr-secondary) !important; }
.filter-btn[data-filter="monitored"].active { background-color: var(--tblr-info) !important; border-color: var(--tblr-info) !important; }
.filter-btn[data-filter="downloaded"].active { background-color: var(--tblr-success) !important; border-color: var(--tblr-success) !important; }
.filter-btn[data-filter="missing"].active { background-color: var(--tblr-warning) !important; border-color: var(--tblr-warning) !important; }

/* ── Modal film detail ── */
.film-header-backdrop {
    position: relative;
    min-height: 200px;
    background-size: cover;
    background-position: center top;
    background-repeat: no-repeat;
}
.film-header-backdrop.has-fanart { min-height: 200px; }
.film-header-backdrop::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(24,24,27,1) 0%, rgba(24,24,27,.85) 40%, rgba(24,24,27,.4) 100%);
}
.film-header-content {
    position: relative;
    z-index: 1;
    padding: 2.5rem 1.5rem 1rem;
}
.film-rating-badge {
    display: inline-flex; align-items: center; gap: .3rem;
    font-size: .78rem; font-weight: 600;
    padding: .2rem .5rem; border-radius: .3rem;
    background: rgba(255,255,255,.12);
    color: #fff;
}
.film-genre-badge {
    font-size: .68rem; padding: .15rem .45rem;
    border-radius: 1rem; background: rgba(255,255,255,.1);
    color: rgba(255,255,255,.75); border: 1px solid rgba(255,255,255,.15);
}
.film-poster-col img {
    width: 100%; border-radius: .5rem;
    box-shadow: 0 4px 20px rgba(0,0,0,.4);
}
.film-action-btn {
    width: 100%; text-align: left;
    font-size: .8rem;
}
/* Mode sélection */
.select-mode .media-card { cursor: pointer; }
.select-mode .media-card .select-cb { display: flex !important; z-index: 10; }
.media-card .select-cb {
    display: none; position: absolute; top: .4rem; left: .4rem; z-index: 3;
    width: 22px; height: 22px; border-radius: 50%;
    border: 2px solid rgba(255,255,255,.6); background: rgba(0,0,0,.4);
    align-items: center; justify-content: center;
    transition: all .15s;
}
.media-card .select-cb.checked {
    background: var(--tblr-primary); border-color: var(--tblr-primary);
}
.media-card.selected { outline: 2px solid var(--tblr-primary); outline-offset: -2px; }
/* Vue mur */
.media-grid.view-wall { grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 2px; }
.media-grid.view-wall .media-card { border-radius: 0; border: none; }
.media-grid.view-wall .media-card .status-dot,
.media-grid.view-wall .media-card .quality-badge,
.media-grid.view-wall .media-card .card-overlay { display: none !important; }
.media-grid.view-wall .media-card:hover { transform: none; box-shadow: none; }
.media-grid.view-wall.select-mode .media-card .select-cb { display: flex !important; z-index: 10; }
/* Vue étendue */
.media-grid.view-extended { display: flex; flex-direction: column; gap: .5rem; }
.media-grid.view-extended .media-card { display: flex !important; flex-direction: row; border-radius: .5rem; overflow: hidden; height: auto; }
.media-grid.view-extended .media-card img { width: 80px; height: 120px; aspect-ratio: auto; object-fit: cover; flex-shrink: 0; }
.media-grid.view-extended .media-card .no-poster { width: 80px; height: 120px; aspect-ratio: auto; font-size: .55rem; flex-shrink: 0; }
.media-grid.view-extended .media-card .status-dot,
.media-grid.view-extended .media-card .quality-badge,
.media-grid.view-extended .media-card .card-overlay,
.media-grid.view-extended .media-card .hover-info { display: none !important; }
.media-grid.view-extended .media-card .extended-info { display: flex; flex-direction: column; justify-content: center; padding: .5rem .75rem; flex: 1; min-width: 0; }
.media-card .extended-info { display: none; }
/* Hover Seerr */
.media-card .hover-info {
    position: absolute; inset: 0; background: rgba(0,0,0,.75);
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: .6rem; opacity: 0; transition: opacity .2s;
    pointer-events: none; overflow: hidden; z-index: 5; border-radius: .5rem;
}
.media-card:hover .hover-info { opacity: 1; }
.media-card:hover .status-dot,
.media-card:hover .quality-badge,
.media-card:hover .card-overlay { opacity: 0; transition: opacity .2s; }
.media-card .hover-info .h-title { font-size: .78rem; font-weight: 700; color: #fff; line-height: 1.2; margin-bottom: .2rem; }
.media-card .hover-info .h-year { font-size: .65rem; color: rgba(255,255,255,.6); margin-bottom: .3rem; }
.media-card .hover-info .h-overview { font-size: .62rem; color: rgba(255,255,255,.5); line-height: 1.3; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; }
.media-card .hover-info .h-badges { display: flex; gap: .25rem; flex-wrap: wrap; margin-bottom: .3rem; }
.media-card .hover-info .h-badges .badge { font-size: .55rem; }
.media-grid.view-extended .media-card .hover-info { display: none !important; }
/* Table view (movies) */
#films-table-view { display: none; }
#films-table-view.active { display: block; }
/* Shelves view (movies) */
#films-shelf-view { display: none; }
.shelf-section { margin-bottom: 1.5rem; }
.shelf-header { display: flex; align-items: center; gap: .35rem; margin-bottom: .5rem; padding-left: .2rem; }
.shelf-section h4 { font-size: .85rem; margin: 0; }
.shelf-toggle { border: 0; background: transparent; color: var(--tblr-muted); padding: .1rem .25rem; line-height: 1; border-radius: .25rem; transition: color .15s, background-color .15s, transform .15s; }
.shelf-toggle:hover { color: var(--tblr-body-color); background: var(--tblr-bg-surface-secondary); }
.shelf-toggle .shelf-chevron { display: inline-block; transition: transform .15s; }
.shelf-section.is-expanded .shelf-toggle .shelf-chevron { transform: rotate(90deg); }
.shelf-scroll { display: flex; gap: .5rem; overflow-x: auto; padding-bottom: .5rem; scrollbar-width: thin; }
.shelf-section.is-expanded .shelf-scroll { flex-wrap: wrap; overflow-x: visible; }
.shelf-scroll .shelf-card { flex-shrink: 0; width: 110px; cursor: pointer; position: relative; border-radius: .4rem; overflow: hidden; transition: transform .15s; }
.shelf-scroll .shelf-card:hover { transform: scale(1.05); z-index: 2; }
.shelf-scroll .shelf-card img { width: 100%; aspect-ratio: 2/3; object-fit: cover; display: block; }
.shelf-scroll .shelf-card .shelf-bar { position: absolute; bottom: 0; left: 0; right: 0; height: 3px; }
.shelf-scroll .shelf-card .shelf-title { position: absolute; bottom: 3px; left: 0; right: 0; background: linear-gradient(transparent, rgba(0,0,0,.8)); padding: 1rem .3rem .2rem; font-size: .6rem; font-weight: 600; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
#bulk-bar {
    display: none; position: fixed; bottom: 0; left: 0; right: 0; z-index: 1050;
    background: var(--tblr-bg-surface); border-top: 2px solid var(--tblr-border-color);
    padding: .5rem 1.2rem; box-shadow: 0 -4px 12px rgba(0,0,0,.3);
}
@media (min-width: 992px) { #bulk-bar { left: 15rem; } }
.cast-scroll {
    display: flex; gap: .75rem;
    overflow-x: auto; padding-bottom: .5rem;
    scrollbar-width: thin;
}
.cast-card {
    flex-shrink: 0; width: 90px; text-align: center;
}
.cast-card img {
    width: 64px; height: 64px; border-radius: 50%;
    object-fit: cover; background: var(--tblr-bg-surface-secondary);
}
.cast-card { position: relative; }
.cast-card .cast-name { font-size: .7rem; font-weight: 600; line-height: 1.2; margin-top: .3rem; }
.cast-card .cast-role { font-size: .62rem; color: var(--tblr-muted); line-height: 1.2; }
.cast-card .cast-bookmark {
    position: absolute; top: -2px; right: 4px;
    cursor: pointer; opacity: .5; transition: opacity .15s;
    background: none; border: none; padding: 0; line-height: 1;
}
.cast-card .cast-bookmark:hover { opacity: 1; }
.cast-card .cast-bookmark.active { opacity: 1; }
.timeline-event {
    position: relative; padding-left: 1.2rem; padding-bottom: .75rem;
    border-left: 2px solid var(--tblr-border-color);
}
.timeline-event::before {
    content: ''; position: absolute; left: -5px; top: .35rem;
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--tblr-border-color);
}
.timeline-event.ev-grabbed::before { background: var(--tblr-primary); }
.timeline-event.ev-imported::before,
.timeline-event.ev-downloadFolderImported::before { background: var(--tblr-success); }
.timeline-event.ev-failed::before,
.timeline-event.ev-downloadFailed::before { background: var(--tblr-danger); }
.timeline-event.ev-deleted::before,
.timeline-event.ev-movieFileDeleted::before { background: var(--tblr-secondary); }

/* Feedback visuel pendant un filter/pagination submit : la library passe en
   opacity réduite + pointer-events off jusqu'à ce que le browser ait remplacé
   la page. Donne l'impression que ça réagit instantanément même sur un full
   reload de 200-500ms. */
.library-loading { opacity: 0.5; transition: opacity 120ms ease-out; pointer-events: none; }
</style>
{% endblock %}

{% block body %}
{% if not error %}
<div class="container-xl py-2">
  <div class="d-flex align-items-center justify-content-end">
    {% include 'media/_radarr_nav.html.twig' %}
  </div>
</div>
{% endif %}

<div class="page-body">
<div class="container-xl">

{% if error %}
  {% include 'error/_service_banner.html.twig' with {
    service: 'Radarr',
    wizard_route: 'app_setup_managers',
    configured_url: service_url,
    reason: 'unreachable'
  } %}
{% endif %}

{% if not error %}
<div id="warnings-banner"></div>

{# ── Stats (compact strip — #7) ── #}
<div class="card card-sm mb-3">
  <div class="card-body py-2 d-flex flex-wrap align-items-baseline justify-content-around gap-2 gap-sm-3">
    <div><span class="h3 mb-0">{{ stats.total }}</span> <span class="text-muted small">{{ 'media.films.stats.total'|trans }}</span></div>
    <div><span class="h3 mb-0 text-success">{{ stats.downloaded }}</span> <span class="text-muted small">{{ 'media.films.stats.downloaded'|trans }}</span></div>
    <div><span class="h3 mb-0 text-warning">{{ stats.monitored }}</span> <span class="text-muted small">{{ 'media.films.stats.waiting'|trans }}</span></div>
    <div><span class="h3 mb-0">{{ stats.totalGb }} <span class="text-muted fs-5">{{ 'media.films.stats.gb_suffix'|trans }}</span></span> <span class="text-muted small">{{ 'media.films.stats.total_size'|trans }}</span></div>
  </div>
</div>

{# ── Download queue (auto-refresh) ── #}
<div id="queue-card" class="card mb-3" style="{{ queue is empty ? 'display:none' : '' }}">
  <div class="card-header" style="cursor:pointer;" id="queue-toggle">
    <h3 class="card-title d-flex align-items-center gap-2">
      <svg id="queue-chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="transition:transform .2s; transform: rotate(90deg);"><path d="m9 18 6-6-6-6"/></svg>
      {{ ico.icon('download', '', 18) }} {{ 'media.films.queue.title'|trans }} <span class="badge bg-primary text-white ms-1" id="queue-count">{{ queue|length }}</span>
    </h3>
    <div class="card-actions">
      <span class="text-muted small" id="queue-refresh-label"></span>
    </div>
  </div>
  <div id="queue-body"></div>
</div>

{# ── Filters (issue #19 — server-side pagination + filters) ──
   Layout: two side-by-side cards.
     - Left card: filters (row 1 search + status buttons,
                           row 2 dropdowns quality / genre / language / sort)
     - Right card: view modes (row 1) + actions refresh / RSS / select / + Add (row 2)
   The right card sizes to its content, the left one stretches to fill the rest.
   On mobile (<1200px) they stack vertically via the xl breakpoint. #}
<div class="row g-2 mb-3 align-items-stretch films-toolbar">
  <div class="col-12 col-xl-9">
    <div class="card h-100 films-toolbar-filters">
      <div class="card-body py-2">
      <form method="get" id="films-filter-form" action="{{ path('app_media_films', { slug: current_instance.slug }) }}" class="d-flex flex-column gap-2">
        <input type="hidden" name="status" id="films-filter-status" value="{{ query.status }}">
        {# Row 1: search input (fixed width) + 5 status buttons sharing the remaining width via flex-fill. #}
        <div class="d-flex align-items-center gap-2 flex-wrap flex-md-nowrap">
          <input type="text" name="q" id="search-input" class="form-control form-control-sm" placeholder="{{ 'media.films.filters.search_placeholder'|trans }}" style="max-width:220px" value="{{ query.q }}" autocomplete="off">
          <div class="d-flex gap-1 flex-wrap flex-md-nowrap films-status-group flex-fill">
            <button type="button" class="btn btn-sm btn-outline-secondary filter-btn flex-fill{% if query.status == 'all' %} active{% endif %}" data-filter="all">{{ 'media.films.filters.status.all'|trans }}</button>
            <button type="button" class="btn btn-sm btn-outline-success filter-btn flex-fill{% if query.status == 'downloaded' %} active{% endif %}" data-filter="downloaded">{{ 'media.films.filters.status.downloaded'|trans }}</button>
            <button type="button" class="btn btn-sm btn-outline-warning filter-btn flex-fill{% if query.status == 'missing' %} active{% endif %}" data-filter="missing">{{ 'media.films.filters.status.missing'|trans }}</button>
            <button type="button" class="btn btn-sm btn-outline-secondary filter-btn flex-fill{% if query.status == 'unmonitored' %} active{% endif %}" data-filter="unmonitored">{{ 'media.films.filters.status.unmonitored'|trans }}</button>
            <button type="button" class="btn btn-sm btn-outline-info filter-btn flex-fill{% if query.status == 'monitored' %} active{% endif %}" data-filter="monitored">{{ 'media.films.filters.status.monitored'|trans }}</button>
          </div>
        </div>
        {# Row 2: 4 dropdowns sharing the available width via flex-fill. #}
        <div class="d-flex align-items-center gap-2 flex-wrap flex-md-nowrap">
          <select name="quality" id="filter-quality" class="form-select form-select-sm flex-fill" style="min-width:120px">
            <option value="">{{ 'media.films.filters.quality'|trans }}</option>
            {% for q in library.qualities %}
              <option value="{{ q }}"{% if query.quality == q %} selected{% endif %}>{{ q }}</option>
            {% endfor %}
          </select>
          <select name="genre" id="filter-genre" class="form-select form-select-sm flex-fill" style="min-width:120px">
            <option value="">{{ 'media.films.filters.genre'|trans }}</option>
            {% for g in library.genres %}
              <option value="{{ g }}"{% if query.genre == g %} selected{% endif %}>{{ g }}</option>
            {% endfor %}
          </select>
          <select name="language" id="filter-language" class="form-select form-select-sm flex-fill" style="min-width:120px">
            <option value="">{{ 'media.films.filters.language'|trans }}</option>
            {% for l in library.languages %}
              <option value="{{ l }}"{% if query.language == l %} selected{% endif %}>{{ l }}</option>
            {% endfor %}
          </select>
          <select name="sort" id="sort-select" class="form-select form-select-sm flex-fill" style="min-width:140px">
            <option value="title-asc"{% if query.sort == 'title-asc' %} selected{% endif %}>{{ 'media.films.filters.sort.title_asc'|trans }}</option>
            <option value="title-desc"{% if query.sort == 'title-desc' %} selected{% endif %}>{{ 'media.films.filters.sort.title_desc'|trans }}</option>
            <option value="year-desc"{% if query.sort == 'year-desc' %} selected{% endif %}>{{ 'media.films.filters.sort.year_desc'|trans }}</option>
            <option value="year-asc"{% if query.sort == 'year-asc' %} selected{% endif %}>{{ 'media.films.filters.sort.year_asc'|trans }}</option>
            <option value="added-desc"{% if query.sort == 'added-desc' %} selected{% endif %}>{{ 'media.films.filters.sort.added_desc'|trans }}</option>
            <option value="size-desc"{% if query.sort == 'size-desc' %} selected{% endif %}>{{ 'media.films.filters.sort.size_desc'|trans }}</option>
            <option value="size-asc"{% if query.sort == 'size-asc' %} selected{% endif %}>{{ 'media.films.filters.sort.size_asc'|trans }}</option>
          </select>
        </div>
        <noscript><button type="submit" class="btn btn-sm btn-primary align-self-start">{{ 'media.films.filters.apply'|trans }}</button></noscript>
      </form>
      {% if query.hasActiveFilter or query.q != '' %}
        <div class="d-flex align-items-center gap-1 mt-2 pt-2 border-top films-bulk-row">
          <button type="button" class="btn btn-primary btn-sm" id="btn-update-filtered" style="display:{% if query.hasActiveFilter %}inline-flex{% else %}none{% endif %}" title="{{ 'media.films.actions.refresh_filtered_title'|trans }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg>
            {{ 'media.films.actions.refresh_filtered'|trans }}
          </button>
          <button type="button" class="btn btn-warning btn-sm" id="btn-search-filtered" style="display:{% if query.hasActiveFilter %}inline-flex{% else %}none{% endif %}" title="{{ 'media.films.actions.search_filtered_title'|trans }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            {{ 'media.films.actions.search_filtered'|trans }}
          </button>
          <a href="{{ path('app_media_films', { slug: current_instance.slug }) }}" class="btn btn-sm btn-ghost-secondary ms-auto">{{ 'media.films.pagination.reset_filters'|trans }}</a>
        </div>
      {% endif %}
      </div>
    </div>
  </div>
  <div class="col-12 col-xl-3">
    <div class="card h-100 films-toolbar-actions">
      <div class="card-body py-2">
      <div class="d-flex flex-column gap-2 align-items-stretch">
        <div class="d-flex gap-1" id="view-mode-btns">
          <button type="button" class="btn btn-sm btn-secondary view-btn flex-fill active" data-view="grid" title="{{ 'media.films.view.grid'|trans }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
          </button>
          <button type="button" class="btn btn-sm btn-ghost-secondary view-btn flex-fill" data-view="wall" title="{{ 'media.films.view.wall'|trans }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="6" height="9"/><rect x="10" y="2" width="6" height="9"/><rect x="18" y="2" width="4" height="9"/><rect x="2" y="13" width="6" height="9"/><rect x="10" y="13" width="6" height="9"/><rect x="18" y="13" width="4" height="9"/></svg>
          </button>
          <button type="button" class="btn btn-sm btn-ghost-secondary view-btn flex-fill" data-view="extended" title="{{ 'media.films.view.extended'|trans }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="7" rx="1"/><rect x="3" y="14" width="18" height="7" rx="1"/></svg>
          </button>
