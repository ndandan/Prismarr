              <option value="">{{ 'media.films.bulk.edit_keep'|trans }}</option>
              <option value="true">{{ 'media.films.bulk.edit_follow'|trans }}</option>
              <option value="false">{{ 'media.films.bulk.edit_unfollow'|trans }}</option>
            </select>
          </div>
          <div class="col-md-6">
            <label class="form-label small">{{ 'media.films.bulk.edit_quality'|trans }}</label>
            <select class="form-select form-select-sm" id="bulk-edit-quality">
              <option value="">{{ 'media.films.bulk.edit_keep'|trans }}</option>
            </select>
          </div>
          <div class="col-md-6">
            <label class="form-label small">{{ 'media.films.bulk.edit_availability'|trans }}</label>
            <select class="form-select form-select-sm" id="bulk-edit-avail">
              <option value="">{{ 'media.films.bulk.edit_keep'|trans }}</option>
              <option value="announced">{{ 'media.films.bulk.availability_announced'|trans }}</option>
              <option value="inCinemas">{{ 'media.films.bulk.availability_in_cinemas'|trans }}</option>
              <option value="released">{{ 'media.films.bulk.availability_released'|trans }}</option>
            </select>
          </div>
          <div class="col-md-6">
            <label class="form-label small">{{ 'media.films.bulk.edit_root'|trans }}</label>
            <select class="form-select form-select-sm" id="bulk-edit-root">
              <option value="">{{ 'media.films.bulk.edit_keep'|trans }}</option>
            </select>
          </div>
        </div>
        <div class="text-muted small mt-3" id="bulk-edit-info"></div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary" data-bs-dismiss="modal">{{ 'media.films.bulk.cancel'|trans }}</button>
        <button class="btn btn-primary" id="bulk-edit-save">{{ 'media.films.bulk.save'|trans }}</button>
      </div>
    </div>
  </div>
</div>

{# ── Bulk tags modal ── #}
<div class="modal modal-blur fade" id="modal-bulk-tags" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">{{ 'media.films.bulk.tags_title'|trans }}</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label small">{{ 'media.films.bulk.tags_label'|trans }}</label>
          <div class="d-flex flex-column gap-1 mb-2" id="bulk-tags-list"></div>
        </div>
        <div class="mb-3">
          <label class="form-label small">{{ 'media.films.bulk.tags_action'|trans }}</label>
          <select class="form-select form-select-sm" id="bulk-tags-action">
            <option value="add">{{ 'media.films.bulk.tags_add'|trans }}</option>
            <option value="remove">{{ 'media.films.bulk.tags_remove'|trans }}</option>
            <option value="replace">{{ 'media.films.bulk.tags_replace'|trans }}</option>
          </select>
        </div>
        <div class="text-muted small" id="bulk-tags-info"></div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-secondary" data-bs-dismiss="modal">{{ 'media.films.bulk.cancel'|trans }}</button>
        <button class="btn btn-primary" id="bulk-tags-save">{{ 'media.films.bulk.apply'|trans }}</button>
      </div>
    </div>
  </div>
</div>

{# ── Bulk delete modal ── #}
<div class="modal modal-blur fade" id="modal-bulk-delete" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title text-danger">{{ 'media.films.bulk.delete_title'|trans }}</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="alert alert-warning py-2 small mb-3">{{ 'media.films.bulk.delete_warning'|trans|raw }}</div>
        <div class="form-check mb-2">
          <input type="checkbox" class="form-check-input" id="bulk-delete-files">
          <label class="form-check-label" for="bulk-delete-files">{{ 'media.films.bulk.delete_files'|trans }}</label>
