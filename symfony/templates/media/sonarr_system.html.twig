{% extends 'base.html.twig' %}

{% block title %}{{ 'media.arr_system.title_sonarr'|trans }}{% endblock %}

{% block body %}
<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col"><h2 class="page-title">{{ 'media.arr_system.title_sonarr'|trans }}</h2></div>
      <div class="col-auto ms-auto">{% include 'media/_sonarr_nav.html.twig' %}</div>
    </div>
  </div>
</div>

<div class="page-body">
<div class="container-xl">

<div class="row g-3">

{# ── Statut ── #}
<div class="col-12 col-lg-6">
  <div class="card h-100">
    <div class="card-header">
      <h3 class="card-title">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
        {{ 'media.arr_system.section.status'|trans }}
      </h3>
    </div>
    <div class="card-body">
      {% if status %}
        <div class="datagrid">
          <div class="datagrid-item">
            <div class="datagrid-title">{{ 'media.arr_system.status.version'|trans }}</div>
            <div class="datagrid-content fw-medium">{{ status.version ?? '—' }}</div>
          </div>
          <div class="datagrid-item">
            <div class="datagrid-title">{{ 'media.arr_system.status.os'|trans }}</div>
            <div class="datagrid-content">{{ status.osName ?? '—' }} {{ status.osVersion ?? '' }}</div>
          </div>
          <div class="datagrid-item">
            <div class="datagrid-title">{{ 'media.arr_system.status.net'|trans }}</div>
            <div class="datagrid-content">{{ status.runtimeVersion ?? '—' }}</div>
          </div>
          <div class="datagrid-item">
            <div class="datagrid-title">{{ 'media.arr_system.status.db'|trans }}</div>
            <div class="datagrid-content">{{ status.databaseVersion ?? '—' }}</div>
          </div>
          {% if status.startTime is defined %}
          <div class="datagrid-item">
            <div class="datagrid-title">{{ 'media.arr_system.status.started'|trans }}</div>
            <div class="datagrid-content">{{ status.startTime|date('d/m/Y H:i') }}</div>
          </div>
          {% endif %}
          <div class="datagrid-item">
            <div class="datagrid-title">{{ 'media.arr_system.status.url_base'|trans }}</div>
            <div class="datagrid-content">{{ status.urlBase ?? '/' }}</div>
          </div>
          {% if status.isDocker is defined %}
          <div class="datagrid-item">
            <div class="datagrid-title">{{ 'media.arr_system.status.docker'|trans }}</div>
            <div class="datagrid-content">
              {% if status.isDocker %}<span class="badge bg-blue-lt">{{ 'media.arr_system.status.yes'|trans }}</span>{% else %}<span class="badge bg-secondary-lt">{{ 'media.arr_system.status.no'|trans }}</span>{% endif %}
            </div>
          </div>
          {% endif %}
        </div>
      {% else %}
        <div class="text-muted small">{{ 'media.arr_system.status.unavailable'|trans }}</div>
      {% endif %}
    </div>
  </div>
</div>

{# ── Health ── #}
<div class="col-12 col-lg-6">
  <div class="card h-100">
    <div class="card-header">
      <h3 class="card-title">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        {{ 'media.arr_system.section.health'|trans }}
        {% if health|length > 0 %}
          <span class="badge bg-warning-lt text-warning ms-1">{{ 'media.arr_system.health.alerts_tpl'|trans({count: health|length}) }}</span>
        {% else %}
          <span class="badge bg-success-lt ms-1">{{ 'media.arr_system.health.ok'|trans }}</span>
        {% endif %}
      </h3>
    </div>
    <div class="card-body">
      {% if health is empty %}
        <div class="text-success small d-flex align-items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          {{ 'media.arr_system.health.empty'|trans }}
        </div>
      {% else %}
        <ul class="list-unstyled mb-0">
        {% for item in health %}
          <li class="d-flex gap-2 mb-2 pb-2 border-bottom">
            {% if item.type == 'error' %}<span class="badge bg-danger-lt flex-shrink-0">{{ 'media.arr_system.health.error'|trans }}</span>
            {% elseif item.type == 'warning' %}<span class="badge bg-warning-lt flex-shrink-0">{{ 'media.arr_system.health.warning'|trans }}</span>
            {% else %}<span class="badge bg-blue-lt flex-shrink-0">{{ 'media.arr_system.health.info'|trans }}</span>{% endif %}
            <span class="small">{{ item.message ?? '—' }}</span>
          </li>
        {% endfor %}
        </ul>
      {% endif %}
    </div>
  </div>
</div>

{# ── Espace disque ── #}
<div class="col-12">
  <div class="card">
    <div class="card-header">
      <h3 class="card-title">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
        {{ 'media.arr_system.section.disk'|trans }}
      </h3>
    </div>
    <div class="card-body">
      {% for disk in diskSpace %}
        {% set usedBytes = disk.totalSpace - disk.freeSpace %}
        {% set pct = disk.totalSpace > 0 ? (usedBytes / disk.totalSpace * 100)|round : 0 %}
        {% set freeGb = (disk.freeSpace / 1073741824)|round(1) %}
        {% set totalGb = (disk.totalSpace / 1073741824)|round(1) %}
        <div class="mb-3">
          <div class="d-flex justify-content-between mb-1">
            <span class="small fw-medium">{{ disk.path ?? '/' }}</span>
            <span class="small text-muted">{{ 'media.arr_system.disk.free_total_tpl'|trans({free: freeGb, total: totalGb}) }}</span>
          </div>
          <div class="progress progress-sm">
            <div class="progress-bar {% if pct > 90 %}bg-danger{% elseif pct > 75 %}bg-warning{% else %}bg-primary{% endif %}" style="width:{{ pct }}%"></div>
          </div>
          <div class="text-muted" style="font-size:.7rem;margin-top:.2rem">{{ 'media.arr_system.disk.used_pct_tpl'|trans({pct: pct}) }}</div>
        </div>
      {% else %}
        <div class="text-muted small">{{ 'media.arr_system.disk.empty'|trans }}</div>
      {% endfor %}
    </div>
  </div>
</div>

{# ── Download clients ── #}
<div class="col-12 col-lg-6">
  <div class="card h-100">
    <div class="card-header">
      <h3 class="card-title">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        {{ 'media.arr_system.section.download_clients'|trans }}
      </h3>
    </div>
    <div class="table-responsive">
      <table class="table table-vcenter table-sm card-table mb-0">
        <thead><tr><th>{{ 'media.arr_system.download_clients.name'|trans }}</th><th>{{ 'media.arr_system.download_clients.type'|trans }}</th><th>{{ 'media.arr_system.download_clients.enabled'|trans }}</th></tr></thead>
        <tbody>
        {% for client in downloadClients %}
          <tr>
            <td class="fw-medium">{{ client.name ?? '—' }}</td>
            <td class="text-muted small">{{ client.implementation ?? '—' }}</td>
            <td>{% if client.enable ?? false %}<span class="badge bg-success-lt">{{ 'media.arr_system.status.yes'|trans }}</span>{% else %}<span class="badge bg-secondary-lt">{{ 'media.arr_system.status.no'|trans }}</span>{% endif %}</td>
          </tr>
        {% else %}
          <tr><td colspan="3" class="text-center text-muted py-3">{{ 'media.arr_system.download_clients.empty'|trans }}</td></tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>

{# ── Indexeurs ── #}
<div class="col-12 col-lg-6">
  <div class="card h-100">
    <div class="card-header">
      <h3 class="card-title">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        {{ 'media.arr_system.section.indexers'|trans }}
      </h3>
    </div>
    <div class="table-responsive">
      <table class="table table-vcenter table-sm card-table mb-0">
        <thead><tr><th>{{ 'media.arr_system.indexers.name'|trans }}</th><th>{{ 'media.arr_system.indexers.enabled'|trans }}</th><th>{{ 'media.arr_system.indexers.rss'|trans }}</th><th>{{ 'media.arr_system.indexers.search'|trans }}</th></tr></thead>
        <tbody>
        {% for idx in indexers %}
          <tr>
            <td class="fw-medium">{{ idx.name ?? '—' }}</td>
            <td>{% if idx.enableRss ?? false %}<span class="badge bg-success-lt">{{ 'media.arr_system.status.yes'|trans }}</span>{% else %}<span class="badge bg-secondary-lt">{{ 'media.arr_system.status.no'|trans }}</span>{% endif %}</td>
            <td>{% if idx.enableRss ?? false %}<span class="text-success small">✓</span>{% else %}<span class="text-muted small">—</span>{% endif %}</td>
            <td>{% if idx.enableAutomaticSearch ?? false %}<span class="text-success small">✓</span>{% else %}<span class="text-muted small">—</span>{% endif %}</td>
          </tr>
        {% else %}
          <tr><td colspan="4" class="text-center text-muted py-3">{{ 'media.arr_system.indexers.empty'|trans }}</td></tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>

{# ── Recent logs ── #}
<div class="col-12">
  <div class="card">
    <div class="card-header">
      <h3 class="card-title">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        {{ 'media.arr_system.section.logs'|trans }}
      </h3>
    </div>
    <div class="table-responsive">
      <table class="table table-vcenter table-sm card-table mb-0">
        <thead><tr><th style="width:140px">{{ 'media.arr_system.logs.date'|trans }}</th><th style="width:90px">{{ 'media.arr_system.logs.level'|trans }}</th><th>{{ 'media.arr_system.logs.message'|trans }}</th></tr></thead>
        <tbody>
        {% for log in logs %}
          <tr>
            <td class="text-muted small text-nowrap">{{ log.time is defined ? log.time|date('d/m/Y H:i:s') : '—' }}</td>
            <td>
              {% if log.level == 'error' or log.level == 'fatal' %}<span class="badge bg-danger-lt">{{ log.level }}</span>
              {% elseif log.level == 'warn' %}<span class="badge bg-warning-lt">{{ log.level }}</span>
              {% else %}<span class="badge bg-secondary-lt">{{ log.level ?? '?' }}</span>{% endif %}
            </td>
            <td class="small text-truncate" style="max-width:500px;" title="{{ log.message ?? '' }}">{{ log.message ?? '—' }}</td>
          </tr>
        {% else %}
          <tr><td colspan="3" class="text-center text-muted py-3">{{ 'media.arr_system.logs.empty'|trans }}</td></tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>

</div>{# /row #}

</div>
</div>
{% endblock %}
