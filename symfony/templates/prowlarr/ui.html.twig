{% extends 'base.html.twig' %}
{% block title %}{{ 'prowlarr.ui.page_title_full'|trans }}{% endblock %}
{% block head_meta %}<meta name="turbo-visit-control" content="reload">{% endblock %}

{% block body %}
<div class="page-header d-print-none">
    <div class="container-xl">
        <div class="row g-2 align-items-center">
            <div class="col">
                <h2 class="page-title d-flex align-items-center gap-2">
                    <svg width="28" height="28" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg"><path d="M256 32C132.3 32 32 132.3 32 256s100.3 224 224 224 224-100.3 224-224S379.7 32 256 32zm0 400c-97 0-176-79-176-176S159 80 256 80s176 79 176 176-79 176-176 176z" fill="#E88D1A"/><path d="M256 120c-75 0-136 61-136 136s61 136 136 136 136-61 136-136-61-136-136-136zm0 224c-48.6 0-88-39.4-88-88s39.4-88 88-88 88 39.4 88 88-39.4 88-88 88z" fill="#E88D1A"/><circle cx="256" cy="256" r="48" fill="#E88D1A"/></svg>
                    {{ 'prowlarr.ui.title'|trans }}
                </h2>
            </div>
            <div class="col-auto ms-auto">{% include 'prowlarr/_prowlarr_nav.html.twig' %}</div>
        </div>
    </div>
</div>

<div class="page-body">
<div class="container-xl">

{% if error %}
    <div class="alert alert-danger">{{ 'prowlarr.common.error_unreachable'|trans }}</div>
{% endif %}

{% if config %}
<div class="row g-3">
    <div class="col-lg-8 mx-auto">

        {# ── Dates ── #}
        <div class="card mb-3">
            <div class="card-header"><h3 class="card-title" style="color:#E88D1A;">{{ 'prowlarr.ui.section_dates'|trans }}</h3></div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <label class="form-label small">{{ 'prowlarr.ui.short_date'|trans }}</label>
                        <select class="form-select form-select-sm pw-ui" data-key="shortDateFormat">
                            <option value="MMM D YYYY" {{ config.shortDateFormat == 'MMM D YYYY' ? 'selected' }}>Mar 25 2014</option>
                            <option value="DD/MM/YYYY" {{ config.shortDateFormat == 'DD/MM/YYYY' ? 'selected' }}>25/03/2014</option>
                            <option value="YYYY-MM-DD" {{ config.shortDateFormat == 'YYYY-MM-DD' ? 'selected' }}>2014-03-25</option>
                            <option value="DD MMM YYYY" {{ config.shortDateFormat == 'DD MMM YYYY' ? 'selected' }}>25 Mar 2014</option>
                        </select>
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label small">{{ 'prowlarr.ui.long_date'|trans }}</label>
                        <select class="form-select form-select-sm pw-ui" data-key="longDateFormat">
                            <option value="dddd, MMMM D YYYY" {{ config.longDateFormat == 'dddd, MMMM D YYYY' ? 'selected' }}>Tuesday, March 25, 2014</option>
                            <option value="dddd D MMMM YYYY" {{ config.longDateFormat == 'dddd D MMMM YYYY' ? 'selected' }}>Tuesday 25 March 2014</option>
                        </select>
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label small">{{ 'prowlarr.ui.time_format'|trans }}</label>
                        <select class="form-select form-select-sm pw-ui" data-key="timeFormat">
                            <option value="h(:mm)a" {{ config.timeFormat == 'h(:mm)a' ? 'selected' }}>5pm / 5:30pm</option>
                            <option value="HH:mm" {{ config.timeFormat == 'HH:mm' ? 'selected' }}>17:00 / 17:30</option>
                        </select>
                    </div>
                    <div class="col-sm-6 d-flex align-items-end">
                        <label class="form-check form-switch mb-1">
                            <input class="form-check-input pw-ui" data-key="showRelativeDates" type="checkbox" {{ config.showRelativeDates ? 'checked' }}>
                            <span class="form-check-label small">{{ 'prowlarr.ui.show_relative'|trans }}</span>
                        </label>
                    </div>
                </div>
            </div>
        </div>

        {# ── Style ── #}
        <div class="card mb-3">
            <div class="card-header"><h3 class="card-title" style="color:#E88D1A;">{{ 'prowlarr.ui.section_style'|trans }}</h3></div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <label class="form-label small">{{ 'prowlarr.ui.theme'|trans }}</label>
                        <select class="form-select form-select-sm pw-ui" data-key="theme">
                            <option value="auto" {{ config.theme == 'auto' ? 'selected' }}>{{ 'prowlarr.ui.theme_auto'|trans }}</option>
                            <option value="light" {{ config.theme == 'light' ? 'selected' }}>{{ 'prowlarr.ui.theme_light'|trans }}</option>
                            <option value="dark" {{ config.theme == 'dark' ? 'selected' }}>{{ 'prowlarr.ui.theme_dark'|trans }}</option>
                        </select>
                    </div>
                    <div class="col-sm-6 d-flex align-items-end">
                        <label class="form-check form-switch mb-1">
                            <input class="form-check-input pw-ui" data-key="enableColorImpairedMode" type="checkbox" {{ config.enableColorImpairedMode ? 'checked' }}>
                            <span class="form-check-label small">{{ 'prowlarr.ui.color_impaired'|trans }}</span>
                        </label>
                    </div>
                </div>
            </div>
        </div>

        {# ── Langue ── #}
        <div class="card mb-3">
            <div class="card-header"><h3 class="card-title" style="color:#E88D1A;">{{ 'prowlarr.ui.section_language'|trans }}</h3></div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <label class="form-label small">{{ 'prowlarr.ui.ui_language'|trans }}</label>
                        <select class="form-select form-select-sm pw-ui" data-key="uiLanguage">
                            <option value="en" {{ config.uiLanguage == 'en' ? 'selected' }}>English</option>
                            <option value="fr" {{ config.uiLanguage == 'fr' ? 'selected' }}>Français</option>
                            <option value="de" {{ config.uiLanguage == 'de' ? 'selected' }}>Deutsch</option>
                            <option value="es" {{ config.uiLanguage == 'es' ? 'selected' }}>Español</option>
                            <option value="it" {{ config.uiLanguage == 'it' ? 'selected' }}>Italiano</option>
                            <option value="pt" {{ config.uiLanguage == 'pt' ? 'selected' }}>Português</option>
                            <option value="nl" {{ config.uiLanguage == 'nl' ? 'selected' }}>Nederlands</option>
                            <option value="ja" {{ config.uiLanguage == 'ja' ? 'selected' }}>日本語</option>
                            <option value="zh" {{ config.uiLanguage == 'zh' ? 'selected' }}>中文</option>
                            <option value="ru" {{ config.uiLanguage == 'ru' ? 'selected' }}>Русский</option>
                        </select>
                        <div class="form-text" style="font-size:.6rem;color:#f59e0b;">{{ 'prowlarr.ui.reload_required'|trans }}</div>
                    </div>
                </div>
            </div>
        </div>

        {# ── Save ── #}
        <div class="d-flex align-items-center gap-3">
            <button class="btn btn-primary" id="btn-save-ui" style="background:#E88D1A;border-color:#E88D1A;">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                {{ 'prowlarr.ui.save_btn'|trans }}
            </button>
            <span id="save-result" style="display:none;font-size:.8rem;"></span>
        </div>

    </div>
</div>
{% endif %}

</div>
</div>
{% endblock %}

{% block javascripts %}
<script>
(function () {
    var _I18N = {
        saveBtn: {{ 'prowlarr.ui.save_btn'|trans|json_encode|raw }},
        saving: {{ 'prowlarr.common.saving'|trans|json_encode|raw }},
        saved: {{ 'prowlarr.ui.saved'|trans|json_encode|raw }},
        error: {{ 'prowlarr.ui.save_error'|trans|json_encode|raw }}
    };
    var configData = {{ config|json_encode|raw }};

    document.getElementById('btn-save-ui').addEventListener('click', function () {
        var btn = this;
        var result = document.getElementById('save-result');
        var payload = JSON.parse(JSON.stringify(configData));

        document.querySelectorAll('.pw-ui').forEach(function (el) {
            var key = el.dataset.key;
            if (el.type === 'checkbox') payload[key] = el.checked;
            else payload[key] = el.value;
        });

        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> ' + _I18N.saving;

        fetch('{{ app.request.getBasePath() }}/prowlarr/ui/save', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        })
        .then(function (r) { return r.json(); })
        .then(function (d) {
            btn.disabled = false;
            btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg> ' + _I18N.saveBtn;
            result.style.display = '';
            if (d.ok) {
                result.style.color = '#22c55e';
                result.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:4px;"><path d="M5 12l5 5l10-10"/></svg> ' + _I18N.saved;
            } else {
                result.style.color = '#ef4444';
                result.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:4px;"><path d="M18 6L6 18M6 6l12 12"/></svg> ' + _I18N.error;
            }
            setTimeout(function () { result.style.display = 'none'; }, 3000);
        });
    });
})();
</script>
{% endblock %}
