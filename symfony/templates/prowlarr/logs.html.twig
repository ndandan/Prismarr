{% extends 'base.html.twig' %}
{% block title %}{{ 'prowlarr.logs.page_title_full'|trans }}{% endblock %}
{% block head_meta %}<meta name="turbo-visit-control" content="reload">{% endblock %}

{% block body %}
<div class="page-header d-print-none">
    <div class="container-xl">
        <div class="row g-2 align-items-center">
            <div class="col">
                <h2 class="page-title d-flex align-items-center gap-2">
                    <svg width="28" height="28" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg"><path d="M256 32C132.3 32 32 132.3 32 256s100.3 224 224 224 224-100.3 224-224S379.7 32 256 32zm0 400c-97 0-176-79-176-176S159 80 256 80s176 79 176 176-79 176-176 176z" fill="#E88D1A"/><path d="M256 120c-75 0-136 61-136 136s61 136 136 136 136-61 136-136-61-136-136-136zm0 224c-48.6 0-88-39.4-88-88s39.4-88 88-88 88 39.4 88 88-39.4 88-88 88z" fill="#E88D1A"/><circle cx="256" cy="256" r="48" fill="#E88D1A"/></svg>
                    {{ 'prowlarr.logs.title'|trans }}
                </h2>
            </div>
            <div class="col-auto ms-auto">{% include 'prowlarr/_prowlarr_nav.html.twig' %}</div>
        </div>
    </div>
</div>

<div class="page-body">
<div class="container-xl">

{% if error %}
    <div class="alert alert-danger">{{ 'prowlarr.common.error_unreachable'|trans }}</div>
{% endif %}

<div class="card">
    <div class="card-header">
        <h3 class="card-title">{{ 'prowlarr.logs.card_title'|trans }}</h3>
        <div class="card-options d-flex gap-2 align-items-center">
            <input type="text" id="log-search" class="form-control form-control-sm" placeholder="{{ 'prowlarr.logs.search_placeholder'|trans }}" style="width:200px;">
            <select id="log-level-filter" class="form-select form-select-sm" style="width:120px;">
                <option value="">{{ 'prowlarr.logs.level_all'|trans }}</option>
                <option value="info">{{ 'prowlarr.logs.level_info'|trans }}</option>
                <option value="debug">{{ 'prowlarr.logs.level_debug'|trans }}</option>
                <option value="warn">{{ 'prowlarr.logs.level_warn'|trans }}</option>
                <option value="error">{{ 'prowlarr.logs.level_error'|trans }}</option>
                <option value="fatal">{{ 'prowlarr.logs.level_fatal'|trans }}</option>
            </select>
            <span class="badge bg-secondary-lt" id="log-count">{{ records|length }}</span>
        </div>
    </div>
    <div class="card-body p-0">
        {% if records is empty %}
            {% import '_icons.html.twig' as ico %}
            <div class="empty py-5">
                <div class="empty-icon">{{ ico.icon('file', '', 36) }}</div>
                <p class="empty-title mb-0">{{ 'prowlarr.logs.empty'|trans }}</p>
            </div>
        {% else %}
        <div class="table-responsive">
            <table class="table table-vcenter table-sm mb-0">
                <thead>
                    <tr>
                        <th style="width:140px;">{{ 'prowlarr.logs.col_date'|trans }}</th>
                        <th style="width:80px;">{{ 'prowlarr.logs.col_level'|trans }}</th>
                        <th>{{ 'prowlarr.logs.col_message'|trans }}</th>
                        <th>{{ 'prowlarr.logs.col_logger'|trans }}</th>
                    </tr>
                </thead>
                <tbody id="log-tbody">
                    {% for log in records %}
                    {% set lvl = log.level is defined ? log.level|lower : 'info' %}
                    <tr data-level="{{ lvl }}">
                        <td class="text-muted small">{{ log.time is defined ? log.time|date('d/m H:i:s') : '—' }}</td>
                        <td>
                            {% if lvl == 'error' or lvl == 'fatal' %}
                                <span class="badge bg-danger-lt text-danger">{{ lvl }}</span>
                            {% elseif lvl == 'warn' or lvl == 'warning' %}
                                <span class="badge bg-warning-lt text-warning">{{ lvl }}</span>
                            {% elseif lvl == 'debug' or lvl == 'trace' %}
                                <span class="badge bg-info-lt text-info">{{ lvl }}</span>
                            {% else %}
                                <span class="badge bg-success-lt text-success">{{ lvl }}</span>
                            {% endif %}
                        </td>
                        <td class="small" style="max-width:500px;word-break:break-word;">{{ log.message ?? '—' }}</td>
                        <td class="text-muted small">{{ log.logger ?? '—' }}</td>
                    </tr>
                    {% if log.exception is defined and log.exception %}
                    <tr data-level="{{ lvl }}">
                        <td colspan="4" style="padding:.3rem 1rem;background:rgba(239,68,68,.05);font-size:.7rem;color:#ef4444;word-break:break-all;">{{ log.exception }}</td>
                    </tr>
                    {% endif %}
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% endif %}
    </div>
</div>

{# ── Pagination ── #}
{% set pageSize = 100 %}
{% set totalPages = ((total / pageSize)|round(0, 'ceil'))|default(1) %}
{% if totalPages > 1 %}
<nav class="mt-3">
    <ul class="pagination justify-content-center">
        <li class="page-item {{ page <= 1 ? 'disabled' }}">
            <a class="page-link" href="{{ path('prowlarr_logs_page', {page: page - 1}) }}">{{ 'prowlarr.logs.page_prev'|trans }}</a>
        </li>
        {% for p in 1..totalPages %}
            {% if p >= page - 3 and p <= page + 3 %}
            <li class="page-item {{ p == page ? 'active' }}">
                <a class="page-link" href="{{ path('prowlarr_logs_page', {page: p}) }}">{{ p }}</a>
            </li>
            {% endif %}
        {% endfor %}
        <li class="page-item {{ page >= totalPages ? 'disabled' }}">
            <a class="page-link" href="{{ path('prowlarr_logs_page', {page: page + 1}) }}">{{ 'prowlarr.logs.page_next'|trans }}</a>
        </li>
    </ul>
</nav>
{% endif %}

</div>
</div>
{% endblock %}

{% block javascripts %}
<script>
(function () {
    var search = document.getElementById('log-search');
    var levelFilter = document.getElementById('log-level-filter');
    var tbody = document.getElementById('log-tbody');
    var countBadge = document.getElementById('log-count');
    if (!tbody) return;

    function filterLogs() {
        var query = (search.value || '').toLowerCase();
        var level = levelFilter.value;
        var rows = tbody.querySelectorAll('tr');
        var visible = 0;
        for (var i = 0; i < rows.length; i++) {
            var row = rows[i];
            var rowLevel = row.getAttribute('data-level') || '';
            var text = row.textContent.toLowerCase();
            var matchLevel = !level || rowLevel === level || (level === 'warn' && rowLevel === 'warning') || (level === 'error' && (rowLevel === 'error' || rowLevel === 'fatal'));
            var matchSearch = !query || text.indexOf(query) !== -1;
            if (matchLevel && matchSearch) {
                row.style.display = '';
                visible++;
            } else {
                row.style.display = 'none';
            }
        }
        countBadge.textContent = visible;
    }

    search.addEventListener('input', filterLogs);
    levelFilter.addEventListener('change', filterLogs);
})();
</script>
{% endblock %}
