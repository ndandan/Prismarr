    function renderSchemaList(filters) {
        var container = document.getElementById('add-idx-list');
        var q = typeof filters === 'string' ? filters : (filters.q || '');
        var fProto = (filters.protocol || '');
        var fPrivacy = (filters.privacy || '');
        var fLang = (filters.lang || '');
        var fCat = (filters.cat || '');
        var filtered = schemaCache.filter(function (s) {
            if (q) {
                var haystack = ((s.name || '') + ' ' + (s.definitionName || '') + ' ' + (s.implementationName || '') + ' ' + (s.description || '') + ' ' + (s.language || '')).toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
                var qNorm = q.normalize('NFD').replace(/[\u0300-\u036f]/g, '');
                var words = qNorm.split(/\s+/).filter(function(w) { return w.length > 0; });
                var allMatch = words.every(function (w) { return haystack.includes(w); });
                if (!allMatch) return false;
            }
            if (fProto && s.protocol !== fProto) return false;
            if (fPrivacy && s.privacy !== fPrivacy) return false;
            if (fLang && s.language !== fLang) return false;
            if (fCat) { var hasCat = false; (s.capabilities && s.capabilities.categories || []).forEach(function(c) { if (c.name === fCat) hasCat = true; }); if (!hasCat) return false; }
            return true;
        });

        // Trier par pertinence : match dans le nom > match dans definitionName > le reste
        if (q) {
            filtered.sort(function (a, b) {
                var aName = ((a.name || '') + ' ' + (a.definitionName || '')).toLowerCase();
                var bName = ((b.name || '') + ' ' + (b.definitionName || '')).toLowerCase();
                var qNorm2 = q.normalize('NFD').replace(/[\u0300-\u036f]/g, '');
                var aInName = aName.includes(qNorm2) ? 1 : 0;
                var bInName = bName.includes(qNorm2) ? 1 : 0;
                if (aInName !== bInName) return bInName - aInName;
                // Commence par le terme
                var aStarts = aName.indexOf(qNorm2) === 0 ? 1 : 0;
                var bStarts = bName.indexOf(qNorm2) === 0 ? 1 : 0;
                if (aStarts !== bStarts) return bStarts - aStarts;
                return (a.name || '').localeCompare(b.name || '');
            });
        }
        filtered = filtered.slice(0, 60);

        if (!filtered.length) { container.innerHTML = '<div class="col-12 text-center text-secondary small py-2">' + esc(_I18N.noIndexerFound) + '</div>'; return; }

        var h = '';
        filtered.forEach(function (s) {
            var proto = s.protocol === 'torrent' ? '<span class="badge" style="background:rgba(var(--tblr-primary-rgb),.15);color:#818cf8;font-size:.6rem;">Torrent</span>' : '<span class="badge" style="background:rgba(14,165,233,.15);color:#38bdf8;font-size:.6rem;">Usenet</span>';
            var privacy = s.privacy === 'private' ? '<span class="badge bg-danger-lt" style="font-size:.6rem;">' + esc(_I18N.infoPrivacyPrivate) + '</span>' : (s.privacy === 'semiPrivate' ? '<span class="badge bg-warning-lt" style="font-size:.6rem;">' + esc(_I18N.listPrivacySemi) + '</span>' : '<span class="badge bg-green-lt" style="font-size:.6rem;">' + esc(_I18N.infoPrivacyPublic) + '</span>');
            var displayName = esc(s.name || s.definitionName || s.implementationName || '—');
            var lang = s.language ? '<span class="badge bg-secondary-lt" style="font-size:.55rem;">' + esc(s.language) + '</span>' : '';
            h += '<div class="col-12 col-sm-6 col-md-4"><div class="card pw-schema-card" data-schema-idx="' + schemaCache.indexOf(s) + '" style="cursor:pointer;transition:border-color .15s,background .15s;">';
            h += '<div class="card-body py-3 px-3">';
            h += '<div class="fw-semibold mb-1">' + displayName + '</div>';
            h += '<div class="d-flex flex-wrap gap-1 mb-2">' + proto + ' ' + privacy + ' ' + lang + '</div>';
            if (s.description) h += '<div class="text-secondary small" style="font-size:.72rem;line-height:1.3;">' + esc(s.description).substring(0, 120) + (s.description.length > 120 ? '…' : '') + '</div>';
            h += '</div></div></div>';
        });
        container.innerHTML = h;

        container.querySelectorAll('.pw-schema-card').forEach(function (card) {
            card.addEventListener('click', function () {
                var idx = parseInt(card.dataset.schemaIdx);
                selectedSchema = JSON.parse(JSON.stringify(schemaCache[idx]));
                document.getElementById('add-idx-form-title').textContent = selectedSchema.name || selectedSchema.definitionName || selectedSchema.implementationName || '—';
                document.getElementById('add-idx-list').style.display = 'none';
                document.getElementById('add-idx-filters').style.display = 'none';
                document.getElementById('add-idx-form').style.display = '';
                document.getElementById('add-idx-result').className = 'mt-2 alert d-none';
                // Injecter indexerUrls comme selectOptions pour baseUrl
                (selectedSchema.fields || []).forEach(function(f) {
                    if (f.name === 'baseUrl' && (!f.selectOptions || !f.selectOptions.length) && (selectedSchema || raw || {}).indexerUrls && (selectedSchema || raw || {}).indexerUrls.length) {
                        var urls = (selectedSchema || raw).indexerUrls;
                        f.selectOptions = urls.map(function(u) { return { value: u, name: u }; });
                        f._injectedOptions = true;
                        if (!f.value) f.value = urls[0];
                    }
                });
                renderFields(selectedSchema.fields || [], document.getElementById('add-idx-fields'), selectedSchema);
                loadAndRenderTags(selectedSchema.tags || []);
            });
        });
    }

