{% extends 'base.html.twig' %}
{% block title %}{{ 'prowlarr.index.title'|trans }}{% endblock %}
{% block page_title %}<svg width="24" height="24" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg"><path d="M256 32C132.3 32 32 132.3 32 256s100.3 224 224 224 224-100.3 224-224S379.7 32 256 32zm0 400c-97 0-176-79-176-176S159 80 256 80s176 79 176 176-79 176-176 176z" fill="#E88D1A"/><path d="M256 120c-75 0-136 61-136 136s61 136 136 136 136-61 136-136-61-136-136-136zm0 224c-48.6 0-88-39.4-88-88s39.4-88 88-88 88 39.4 88 88-39.4 88-88 88z" fill="#E88D1A"/><circle cx="256" cy="256" r="48" fill="#E88D1A"/></svg> {{ 'prowlarr.index.title'|trans }}{% endblock %}
{% block head_meta %}<meta name="turbo-visit-control" content="reload">{% endblock %}

{% block stylesheets %}
<style>
.pw-stat { font-size:1.5rem; font-weight:700; line-height:1; }
.pw-indexer-row { transition:background .1s; }
.pw-indexer-row:hover { background:rgba(255,255,255,.02); }
.pw-health-item { display:flex; align-items:flex-start; gap:.5rem; padding:.5rem .75rem; border-radius:.4rem; margin-bottom:.35rem; }
.pw-health-warning { background:rgba(245,158,11,.08); border-left:3px solid #f59e0b; }
.pw-health-error { background:rgba(239,68,68,.08); border-left:3px solid #ef4444; }
.pw-app-card { display:flex; align-items:center; gap:.75rem; padding:.6rem .85rem; background:var(--tblr-bg-surface); border:1px solid var(--tblr-border-color); border-radius:.5rem; }
.pw-search-results { max-height:500px; overflow-y:auto; }
.pw-result-row { font-size:.8rem; }
.pw-result-row td { padding:.35rem .5rem !important; }
.pw-toggle-btn { cursor:pointer; padding:2px 6px; border-radius:.25rem; border:1px solid var(--tblr-border-color); background:none; transition:all .15s; font-size:.7rem; }
.pw-toggle-btn:hover { border-color:var(--tblr-primary); }
.pw-toggle-btn.is-on { background:rgba(34,197,94,.15); border-color:#22c55e; color:#22c55e; }
.pw-toggle-btn.is-off { background:rgba(239,68,68,.1); border-color:#ef4444; color:#ef4444; }
#modal-add-indexer, #modal-edit-indexer, #modal-info-indexer { overscroll-behavior: contain; }
#modal-add-indexer .modal-dialog, #modal-edit-indexer .modal-dialog, #modal-info-indexer .modal-dialog { overscroll-behavior: contain; }
.pw-schema-card:hover { border-color:#E88D1A !important; background:rgba(232,141,26,.05) !important; }
</style>
{% endblock %}

{% block body %}
{% if not error %}
<div class="container-xl py-2">
    <div class="d-flex align-items-center justify-content-end">
        {% include 'prowlarr/_prowlarr_nav.html.twig' %}
    </div>
</div>
{% endif %}

<div class="page-body">
<div class="container-xl">

{% if error %}
  {% include 'error/_service_banner.html.twig' with {
    service: 'Prowlarr',
    wizard_route: 'app_setup_indexers',
    configured_url: service_url,
    reason: 'unreachable'
  } %}
{% endif %}

{% if not error %}

{# ── Stats ── #}
<div class="row g-3 mb-3">
    <div class="col-6 col-lg-2">
        <div class="card card-sm"><div class="card-body text-center">
            <div class="pw-stat" style="color:#E88D1A;">{{ stats.total ?? 0 }}</div>
            <div class="text-secondary small">{{ 'prowlarr.index.stats_indexers'|trans }}</div>
        </div></div>
    </div>
    <div class="col-6 col-lg-2">
        <div class="card card-sm"><div class="card-body text-center">
            <div class="pw-stat text-success">{{ stats.enabled ?? 0 }}</div>
            <div class="text-secondary small">{{ 'prowlarr.index.stats_active'|trans }}</div>
        </div></div>
    </div>
    <div class="col-6 col-lg-2">
        <div class="card card-sm"><div class="card-body text-center">
            <div class="pw-stat {{ (stats.failing ?? 0) > 0 ? 'text-danger' : 'text-secondary' }}">{{ stats.failing ?? 0 }}</div>
            <div class="text-secondary small">{{ 'prowlarr.index.stats_failing'|trans }}</div>
        </div></div>
    </div>
    <div class="col-6 col-lg-2">
        <div class="card card-sm"><div class="card-body text-center">
            <div class="pw-stat" style="color:var(--tblr-primary);">{{ stats.torrent ?? 0 }}</div>
            <div class="text-secondary small">{{ 'prowlarr.index.stats_torrent'|trans }}</div>
        </div></div>
    </div>
    <div class="col-6 col-lg-2">
        <div class="card card-sm"><div class="card-body text-center">
            <div class="pw-stat" style="color:#0ea5e9;">{{ stats.usenet ?? 0 }}</div>
            <div class="text-secondary small">{{ 'prowlarr.index.stats_usenet'|trans }}</div>
        </div></div>
    </div>
    <div class="col-6 col-lg-2">
        <div class="card card-sm"><div class="card-body text-center">
            <div class="pw-stat" style="color:#22c55e;">{{ apps|length }}</div>
            <div class="text-secondary small">{{ 'prowlarr.index.stats_apps'|trans }}</div>
        </div></div>
    </div>
</div>

{# ── Health ── #}
{% if health is not empty %}
<div class="card mb-3">
    <div class="card-header">
        <h3 class="card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1 text-warning"><path d="M12 9v4"/><path d="M10.363 3.591l-8.106 13.534a1.914 1.914 0 0 0 1.636 2.871h16.214a1.914 1.914 0 0 0 1.636 -2.871l-8.106 -13.534a1.914 1.914 0 0 0 -3.274 0z"/><path d="M12 16h.01"/></svg>
            {{ 'prowlarr.index.health_title'|trans }} <span class="badge bg-warning-lt ms-1">{{ health|length }}</span>
        </h3>
    </div>
    <div class="card-body p-2">
        {% for h in health %}
        <div class="pw-health-item {{ h.type == 'error' ? 'pw-health-error' : 'pw-health-warning' }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="{{ h.type == 'error' ? '#ef4444' : '#f59e0b' }}" stroke-width="2" class="flex-shrink-0" style="margin-top:2px;"><path d="M12 9v4"/><path d="M10.363 3.591l-8.106 13.534a1.914 1.914 0 0 0 1.636 2.871h16.214a1.914 1.914 0 0 0 1.636 -2.871l-8.106 -13.534a1.914 1.914 0 0 0 -3.274 0z"/><path d="M12 16h.01"/></svg>
            <div>
                <div class="small fw-medium">{{ h.message }}</div>
                <div class="text-secondary" style="font-size:.7rem;">{{ h.source ?? '' }}</div>
            </div>
        </div>
        {% endfor %}
    </div>
</div>
{% endif %}

{# ── Indexeurs (pleine largeur) ── #}
<div class="card mb-3">
        <div class="card-header">
            <h3 class="card-title">
                {{ 'prowlarr.index.indexers_card_title'|trans }} <span class="badge bg-secondary-lt ms-1">{{ indexers|length }}</span>
            </h3>
            <div class="card-options d-flex gap-2 align-items-center">
                <button class="btn btn-sm btn-ghost-secondary" id="btn-test-all" title="{{ 'prowlarr.index.test_all_title'|trans }}">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><path d="M5 12l5 5l10-10"/></svg>
                    {{ 'prowlarr.index.test_all_btn'|trans }}
                </button>
                <button class="btn btn-sm btn-ghost-secondary" id="btn-sync-indexers" title="{{ 'prowlarr.index.sync_apps_title'|trans }}">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><path d="M20 11A8.1 8.1 0 004.5 9M4 5v4h4M4 13a8.1 8.1 0 0015.5 2m.5 4v-4h-4"/></svg>
                    {{ 'prowlarr.index.sync_apps_btn'|trans }}
                </button>
                <select class="form-select form-select-sm" id="filter-indexer" style="width:auto;min-width:120px;">
                    <option value="all">{{ 'prowlarr.index.filter_all'|trans }}</option>
                    <option value="enabled">{{ 'prowlarr.index.filter_enabled'|trans }}</option>
                    <option value="disabled">{{ 'prowlarr.index.filter_disabled'|trans }}</option>
                    <option value="torrent">{{ 'prowlarr.index.filter_torrent'|trans }}</option>
                    <option value="usenet">{{ 'prowlarr.index.filter_usenet'|trans }}</option>
                </select>
                <button class="btn btn-sm btn-primary" id="btn-add-indexer" style="background:#E88D1A;border-color:#E88D1A;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><path d="M12 5v14M5 12h14"/></svg>
                    {{ 'prowlarr.common.add'|trans }}
                </button>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-vcenter card-table">
                <thead>
                    <tr>
                        <th>{{ 'prowlarr.index.col_name'|trans }}</th>
                        <th>{{ 'prowlarr.index.col_protocol'|trans }}</th>
                        <th>{{ 'prowlarr.index.col_privacy'|trans }}</th>
                        <th>{{ 'prowlarr.index.col_priority'|trans }}</th>
                        <th>{{ 'prowlarr.index.col_functions'|trans }}</th>
                        <th>{{ 'prowlarr.index.col_categories'|trans }}</th>
                        <th>{{ 'prowlarr.index.col_queries'|trans }}</th>
                        <th>{{ 'prowlarr.index.col_grabs'|trans }}</th>
                        <th>{{ 'prowlarr.index.col_failures'|trans }}</th>
                        <th>{{ 'prowlarr.index.col_health'|trans }}</th>
                        <th class="d-none d-xxl-table-cell">{{ 'prowlarr.index.col_added'|trans }}</th>
                        <th class="text-end">{{ 'prowlarr.index.col_actions'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% if indexers is empty %}
                        <tr><td colspan="12" class="text-center text-secondary py-3">{{ 'prowlarr.index.empty_indexers'|trans }}</td></tr>
                    {% else %}
                        {% for idx in indexers %}
                        {% set hasError = status[idx.id] is defined %}
                        <tr class="pw-indexer-row" data-id="{{ idx.id }}">
                            <td>
                                <div class="fw-medium" style="cursor:pointer;color:#E88D1A;" data-info-id="{{ idx.id }}">{{ idx.name }}</div>
                                {% if idx.definitionName %}<div class="text-secondary" style="font-size:.68rem;">{{ idx.definitionName }}</div>{% endif %}
                            </td>
                            <td>
                                {% if idx.protocol == 'torrent' %}
                                    <span class="badge" style="background:rgba(var(--tblr-primary-rgb),.15);color:#818cf8;">Torrent</span>
                                {% elseif idx.protocol == 'usenet' %}
                                    <span class="badge" style="background:rgba(14,165,233,.15);color:#38bdf8;">Usenet</span>
                                {% else %}
                                    <span class="badge bg-secondary-lt">{{ idx.protocol }}</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if idx.privacy == 'private' %}
                                    <span class="badge bg-danger-lt" style="font-size:.6rem;">{{ 'prowlarr.index.privacy_private'|trans }}</span>
                                {% elseif idx.privacy == 'semiPrivate' %}
                                    <span class="badge bg-warning-lt" style="font-size:.6rem;">{{ 'prowlarr.index.privacy_semi'|trans }}</span>
                                {% else %}
                                    <span class="badge bg-green-lt" style="font-size:.6rem;">{{ 'prowlarr.index.privacy_public'|trans }}</span>
                                {% endif %}
                            </td>
                            <td class="text-secondary">{{ idx.priority }}</td>
                            <td>
                                <span class="badge {{ idx.supportsRss ? 'bg-green-lt' : 'bg-secondary-lt' }}" style="font-size:.55rem;">RSS</span>
                                <span class="badge {{ idx.supportsSearch ? 'bg-green-lt' : 'bg-secondary-lt' }}" style="font-size:.55rem;">Search</span>
                            </td>
                            <td>
                                {% set catCount = idx.capabilities.categories is defined ? idx.capabilities.categories|length : 0 %}
                                <span class="text-secondary small">{{ catCount }}</span>
                            </td>
                            {% set iStats = idxStats[idx.id] ?? null %}
                            <td class="small text-secondary">{{ iStats ? iStats.numberOfQueries : '—' }}</td>
                            <td class="small">
                                {% if iStats and iStats.numberOfGrabs > 0 %}
                                    <span class="text-success">{{ iStats.numberOfGrabs }}</span>
                                {% else %}
                                    <span class="text-secondary">0</span>
                                {% endif %}
                            </td>
                            <td class="small">
                                {% if iStats and (iStats.numberOfFailedQueries + iStats.numberOfFailedGrabs) > 0 %}
                                    <span class="text-danger">{{ iStats.numberOfFailedQueries + iStats.numberOfFailedGrabs }}</span>
                                {% else %}
                                    <span class="text-secondary">0</span>
                                {% endif %}
                            </td>
                            <td>
                                {% if not idx.enabled %}
                                    <span class="text-secondary small">{{ 'prowlarr.index.status_disabled'|trans }}</span>
                                {% elseif hasError %}
                                    <span class="d-flex align-items-center gap-1 text-danger small"><span class="status-dot bg-danger"></span> {{ 'prowlarr.index.status_error'|trans }}</span>
                                {% else %}
                                    <span class="d-flex align-items-center gap-1 text-success small"><span class="status-dot status-dot-animated bg-success"></span> {{ 'prowlarr.index.status_ok'|trans }}</span>
                                {% endif %}
                            </td>
                            <td class="text-secondary small text-nowrap d-none d-xxl-table-cell">{{ idx.added ? idx.added|date('d/m/Y') : '—' }}</td>
                            <td class="text-end">
                                <div class="d-flex gap-1 justify-content-end">
                                    <button class="btn btn-sm btn-ghost-secondary p-1" data-edit-id="{{ idx.id }}" title="{{ 'prowlarr.common.edit'|trans }}">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 20h4l10.5-10.5a2.828 2.828 0 10-4-4L4 16v4M13.5 6.5l4 4"/></svg>
                                    </button>
                                    <button class="btn btn-sm btn-ghost-secondary p-1" data-test-id="{{ idx.id }}" title="{{ 'prowlarr.common.test'|trans }}">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5l10-10"/></svg>
                                    </button>
                                    {# Enabled state as a switch: position IS the state, so it can't
                                       read as a mislabeled action button; the destructive delete is
                                       separated from it by an extra gap. #}
                                    <label class="form-check form-switch m-0 d-inline-flex align-items-center" title="{{ idx.enabled ? 'prowlarr.index.toggle_disable_title'|trans : 'prowlarr.index.toggle_enable_title'|trans }}">
                                        <input class="form-check-input" type="checkbox" data-toggle-id="{{ idx.id }}" {% if idx.enabled %}checked{% endif %}>
                                    </label>
                                    <button class="btn btn-sm btn-ghost-danger p-1 ms-2" data-delete-id="{{ idx.id }}" data-delete-name="{{ idx.name }}" title="{{ 'prowlarr.common.delete'|trans }}">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 7h16M10 11v6M14 11v6M5 7l1 12a2 2 0 002 2h8a2 2 0 002-2l1-12M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3"/></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    {% endif %}
                </tbody>
            </table>
        </div>
    </div>

<div class="row g-3">

{# ── Search Prowlarr ── #}
<div class="col-lg-8">
    <div class="card mb-3">
        <div class="card-header">
            <h3 class="card-title">{{ 'prowlarr.index.search_card_title'|trans }}</h3>
        </div>
        <div class="card-body">
            <div class="d-flex gap-2 mb-3">
                <input type="text" id="pw-search-input" class="form-control" placeholder="{{ 'prowlarr.index.search_placeholder'|trans }}" autocomplete="off">
                <button id="pw-search-btn" class="btn btn-primary flex-shrink-0">{{ 'prowlarr.index.search_btn'|trans }}</button>
            </div>
            <div id="pw-search-loading" style="display:none;" class="text-center py-2"><div class="spinner-border spinner-border-sm text-secondary"></div> <span class="small text-secondary">{{ 'prowlarr.index.searching'|trans }}</span></div>
            <div id="pw-search-results"></div>
        </div>
    </div>
</div>{# /col-lg-8 #}

{# ── Right column ── #}
<div class="col-lg-4">

    {# Connected applications #}
    <div class="card mb-3">
        <div class="card-header">
            <h3 class="card-title">{{ 'prowlarr.index.apps_card_title'|trans }}</h3>
        </div>
        <div class="card-body p-2">
            {% if apps is empty %}
                <div class="text-center text-secondary small py-2">{{ 'prowlarr.index.apps_empty'|trans }}</div>
            {% else %}
                {% for app in apps %}
                <div class="pw-app-card mb-2">
                    <div class="flex-grow-1">
                        <div class="fw-medium small">{{ app.name ?? '—' }}</div>
                        <div class="text-secondary" style="font-size:.7rem;">{{ app.implementationName ?? '' }}</div>
                    </div>
                    <span class="badge bg-green-lt" style="font-size:.6rem;">{{ 'prowlarr.index.apps_connected'|trans }}</span>
                </div>
                {% endfor %}
            {% endif %}
        </div>
    </div>


</div>
</div>



{% endif %} {# /if not error #}

</div>{# /container-xl #}
</div>{# /page-body #}

{# ══ Add indexer modal ══ #}
<div class="modal modal-blur fade" id="modal-add-indexer" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable" style="margin-top:2rem;">
        <div class="modal-content" style="background:var(--tblr-bg-surface);">
            <div class="modal-header">
                <h4 class="modal-title">{{ 'prowlarr.index.modal_add_title'|trans }}</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="add-idx-filters">
                    <div class="d-flex gap-2 mb-2">
                        <input type="text" id="add-idx-search" class="form-control" placeholder="{{ 'prowlarr.index.modal_search_placeholder'|trans }}" autocomplete="off">
                    </div>
                    <div class="d-flex gap-2 mb-3">
                        <select class="form-select form-select-sm" id="add-filter-protocol">
                            <option value="">{{ 'prowlarr.index.filter_protocol'|trans }}</option>
                            <option value="torrent">Torrent</option>
                            <option value="usenet">Usenet</option>
                        </select>
                        <select class="form-select form-select-sm" id="add-filter-privacy">
                            <option value="">{{ 'prowlarr.index.filter_privacy'|trans }}</option>
                            <option value="public">{{ 'prowlarr.index.privacy_public'|trans }}</option>
                            <option value="semiPrivate">{{ 'prowlarr.index.privacy_semiprivate'|trans }}</option>
                            <option value="private">{{ 'prowlarr.index.privacy_private'|trans }}</option>
                        </select>
                        <select class="form-select form-select-sm" id="add-filter-lang">
                            <option value="">{{ 'prowlarr.index.filter_lang'|trans }}</option>
                        </select>
                        <select class="form-select form-select-sm" id="add-filter-cat">
                            <option value="">{{ 'prowlarr.index.filter_category'|trans }}</option>
                        </select>
                    </div>
                </div>
                <div id="add-idx-list" class="row g-2" style="max-height:450px;overflow-y:auto;"></div>
                <div id="add-idx-form" style="display:none;" class="mt-3 p-3 border border-primary rounded">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 id="add-idx-form-title" class="mb-0"></h5>
                        <button id="add-idx-back" class="btn btn-sm btn-ghost-secondary">{{ 'prowlarr.common.back'|trans }}</button>
                    </div>
                    <div id="add-idx-fields"></div>
                    <div class="d-flex gap-2 mt-3">
                        <button id="add-idx-test" class="btn btn-sm btn-outline-secondary">{{ 'prowlarr.common.test'|trans }}</button>
                        <button id="add-idx-save" class="btn btn-sm btn-primary" style="background:#E88D1A;border-color:#E88D1A;">{{ 'prowlarr.common.add'|trans }}</button>
                    </div>
                    <div id="add-idx-result" class="mt-2 alert d-none" style="font-size:.85rem;"></div>
                </div>
            </div>
        </div>
    </div>
</div>

{# ══ Edit indexer modal ══ #}
<div class="modal modal-blur fade" id="modal-edit-indexer" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable" style="margin-top:2rem;">
        <div class="modal-content" style="background:var(--tblr-bg-surface);">
            <div class="modal-header">
                <h4 class="modal-title" id="edit-idx-title">{{ 'prowlarr.index.modal_edit_title'|trans }}</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="edit-idx-fields"></div>
                <div class="d-flex gap-2 mt-3">
                    <button id="edit-idx-test" class="btn btn-sm btn-outline-secondary">{{ 'prowlarr.common.test'|trans }}</button>
                    <button id="edit-idx-save" class="btn btn-sm btn-primary" style="background:#E88D1A;border-color:#E88D1A;">{{ 'prowlarr.common.save'|trans }}</button>
                </div>
                <div id="edit-idx-result" class="mt-2 alert d-none" style="font-size:.85rem;"></div>
            </div>
        </div>
    </div>
</div>

{# ══ Modal Info indexeur (3 onglets) ══ #}
<div class="modal modal-blur fade" id="modal-info-indexer" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable" style="margin-top:2rem;">
        <div class="modal-content" style="background:var(--tblr-bg-surface);">
            <div class="modal-header">
                <h4 class="modal-title" id="info-idx-title">{{ 'prowlarr.nav.indexers'|trans }}</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                {# Onglets #}
                <div class="d-flex border-bottom" style="background:rgba(255,255,255,.02);">
                    <button class="btn btn-ghost-secondary rounded-0 flex-fill pw-info-tab active" data-tab="details" style="border-bottom:2px solid #E88D1A;">{{ 'prowlarr.index.info_tab_details'|trans }}</button>
                    <button class="btn btn-ghost-secondary rounded-0 flex-fill pw-info-tab" data-tab="categories">{{ 'prowlarr.index.info_tab_categories'|trans }}</button>
                    <button class="btn btn-ghost-secondary rounded-0 flex-fill pw-info-tab" data-tab="history">{{ 'prowlarr.index.info_tab_history'|trans }}</button>
                </div>
                <div class="p-3">
                    <div id="info-tab-details"></div>
                    <div id="info-tab-categories" style="display:none;"></div>
                    <div id="info-tab-history" style="display:none;"></div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-sm btn-ghost-danger" id="info-idx-delete">{{ 'prowlarr.common.delete'|trans }}</button>
                <div class="ms-auto d-flex gap-2">
                    <button class="btn btn-sm btn-outline-secondary" id="info-idx-edit">{{ 'prowlarr.common.edit'|trans }}</button>
                    <button class="btn btn-sm btn-ghost-secondary" data-bs-dismiss="modal">{{ 'prowlarr.common.close'|trans }}</button>
                </div>
            </div>
        </div>
    </div>
</div>

{% endblock %}

