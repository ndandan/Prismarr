        var musicParams = cap.musicSearchParams || [];
        var bookParams = cap.bookSearchParams || [];

        var protoBadge = raw.protocol === 'torrent' ? '<span class="badge" style="background:rgba(var(--tblr-primary-rgb),.15);color:#818cf8;">Torrent</span>' : '<span class="badge" style="background:rgba(14,165,233,.15);color:#38bdf8;">Usenet</span>';
        var privBadge = raw.privacy === 'private' ? '<span class="badge bg-danger-lt">' + esc(_I18N.infoPrivacyPrivate) + '</span>' : (raw.privacy === 'semiPrivate' ? '<span class="badge bg-warning-lt">' + esc(_I18N.infoPrivacySemi) + '</span>' : '<span class="badge bg-green-lt">' + esc(_I18N.infoPrivacyPublic) + '</span>');

        var torznabUrl = '';
        if (raw.indexerUrls && raw.indexerUrls.length) {
            torznabUrl = window.location.origin + '/prowlarr/indexer/' + raw.id;
        }

        var h = '<h6 class="mb-3" style="color:#E88D1A;">' + esc(_I18N.infoDetailsHeading) + '</h6>';
        h += '<div class="row g-2 mb-3">';
        h += '<div class="col-4 col-sm-3 text-secondary small">' + esc(_I18N.infoLabelType) + '</div><div class="col-8 col-sm-9">' + protoBadge + '</div>';
        h += '<div class="col-4 col-sm-3 text-secondary small">' + esc(_I18N.infoLabelDescription) + '</div><div class="col-8 col-sm-9 small">' + esc(raw.description || '—') + '</div>';
        h += '<div class="col-4 col-sm-3 text-secondary small">' + esc(_I18N.infoLabelLanguage) + '</div><div class="col-8 col-sm-9 small">' + esc(raw.language || '—') + '</div>';
        h += '<div class="col-4 col-sm-3 text-secondary small">' + esc(_I18N.infoLabelProtocol) + '</div><div class="col-8 col-sm-9 small">' + esc(raw.protocol || '—') + '</div>';
        h += '<div class="col-4 col-sm-3 text-secondary small">' + esc(_I18N.infoLabelPrivacy) + '</div><div class="col-8 col-sm-9">' + privBadge + '</div>';
        if (raw.indexerUrls && raw.indexerUrls.length) {
            h += '<div class="col-4 col-sm-3 text-secondary small">' + esc(_I18N.infoLabelUrls) + '</div><div class="col-8 col-sm-9 small" style="word-break:break-all;">' + raw.indexerUrls.map(function(u) { return '<a href="' + esc(u) + '" target="_blank" class="text-secondary">' + esc(u) + '</a>'; }).join('<br>') + '</div>';
        }
        h += '</div>';

        // Search Capabilities (like the native — label + parameter badges)
        h += '<h6 class="mb-2" style="color:#E88D1A;">' + esc(_I18N.infoSearchCapabilities) + '</h6>';
        var capRows = [
            { label: _I18N.infoCapRss, supported: raw.supportsRss },
            { label: _I18N.infoCapRawSearch, supported: cap.supportsRawSearch || false },
            { label: _I18N.infoCapSearch, params: searchParams },
            { label: _I18N.infoCapTvSearch, params: tvParams },
            { label: _I18N.infoCapMovieSearch, params: movieParams },
            { label: _I18N.infoCapMusicSearch, params: musicParams },
            { label: _I18N.infoCapBookSearch, params: bookParams },
        ];
        h += '<div class="row g-1">';
        capRows.forEach(function(c) {
            h += '<div class="col-12 d-flex align-items-center gap-2 py-1">';
            h += '<div class="small" style="width:130px;flex-shrink:0;color:rgba(255,255,255,.6);">' + esc(c.label) + '</div>';
            if (c.supported !== undefined) {
                h += c.supported
                    ? '<span class="badge bg-green-lt" style="font-size:.6rem;">' + esc(_I18N.infoCapSupported) + '</span>'
                    : '<span class="badge bg-secondary-lt" style="font-size:.6rem;">' + esc(_I18N.infoCapUnsupported) + '</span>';
            } else {
                var params = c.params || [];
                if (!params.length) {
                    h += '<span class="badge bg-secondary-lt" style="font-size:.6rem;">' + esc(_I18N.infoCapUnsupported) + '</span>';
                } else {
                    var unique = params.filter(function(p, i) { return params.indexOf(p) === i; });
                    unique.forEach(function(p) {
                        h += '<span class="badge" style="font-size:.58rem;background:rgba(56,189,248,.15);color:#38bdf8;margin-right:2px;">' + esc(_I18N.infoParam[p] || p) + '</span>';
                    });
                }
            }
            h += '</div>';
        });
        h += '</div>';

        document.getElementById('info-tab-details').innerHTML = h;
    }

    function renderInfoCategories(raw) {
        var cats = (raw.capabilities || {}).categories || [];
        if (!cats.length) { document.getElementById('info-tab-categories').innerHTML = '<div class="text-center text-secondary small py-3">' + esc(_I18N.infoNoCategories) + '</div>'; return; }
        var total = 0;
        cats.forEach(function(c) { total++; (c.subCategories || []).forEach(function() { total++; }); });
        var countLabel = (total <= 1 ? _I18N.infoCategoriesCountOne : _I18N.infoCategoriesCountOther).replace('1', total).replace('2', total).replace('#', total);
        var h = '<div class="small text-secondary mb-2">' + esc(countLabel) + '</div>';
        h += '<div class="table-responsive" style="max-height:350px;overflow-y:auto;"><table class="table table-sm table-vcenter">';
        h += '<thead><tr><th style="width:80px;">' + esc(_I18N.infoColId) + '</th><th>' + esc(_I18N.infoColName) + '</th></tr></thead><tbody>';
        cats.forEach(function(c) {
            h += '<tr><td class="text-secondary small fw-medium">' + c.id + '</td><td class="fw-medium small">' + esc(c.name) + '</td></tr>';
            (c.subCategories || []).forEach(function(s) {
                h += '<tr style="opacity:.7;"><td class="text-secondary" style="font-size:.7rem;padding-left:1.5rem;">' + s.id + '</td><td style="font-size:.75rem;padding-left:1.5rem;">' + esc(s.name) + '</td></tr>';
            });
        });
        h += '</tbody></table></div>';
        document.getElementById('info-tab-categories').innerHTML = h;
    }

    function renderInfoHistory(records) {
        if (!records.length) { document.getElementById('info-tab-history').innerHTML = '<div class="text-center text-secondary small py-3">' + esc(_I18N.infoNoHistory) + '</div>'; return; }
        var h = '<div class="table-responsive"><table class="table table-sm table-vcenter">';
        h += '<thead><tr><th>' + esc(_I18N.infoColDate) + '</th><th>' + esc(_I18N.infoColType) + '</th><th>' + esc(_I18N.infoColQuery) + '</th><th>' + esc(_I18N.infoColSource) + '</th></tr></thead><tbody>';
        records.forEach(function(r) {
            var typeBadge = r.eventType === 'indexerRss' ? '<span class="badge bg-cyan-lt" style="font-size:.55rem;">' + esc(_I18N.infoEventRss) + '</span>'
                : r.eventType === 'indexerQuery' ? '<span class="badge bg-indigo-lt" style="font-size:.55rem;">' + esc(_I18N.infoEventQuery) + '</span>'
                : '<span class="badge bg-secondary-lt" style="font-size:.55rem;">' + esc(r.eventType || '—') + '</span>';
            var locale = (document.documentElement.lang || 'fr-FR');
            h += '<tr class="small"><td class="text-secondary text-nowrap">' + (r.date ? new Date(r.date).toLocaleString(locale, {day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'}) : '—') + '</td>';
            h += '<td>' + typeBadge + '</td>';
            h += '<td class="text-truncate" style="max-width:200px;">' + esc(r.data && r.data.query ? r.data.query : '—') + '</td>';
            h += '<td class="text-secondary">' + esc(r.data && r.data.source ? r.data.source : '—') + '</td></tr>';
        });
        h += '</tbody></table></div>';
        document.getElementById('info-tab-history').innerHTML = h;
    }

    // Boutons footer modal info
    document.getElementById('info-idx-edit').addEventListener('click', function() {
        if (!infoRaw) return;
        closeModal('modal-info-indexer');
        // Trigger the edit
        var editBtn = document.querySelector('[data-edit-id="' + infoRaw.id + '"]');
        if (editBtn) editBtn.click();
    });
    document.getElementById('info-idx-delete').addEventListener('click', function() {
        if (!infoRaw) return;
        if (!confirm(_I18N.confirmDeleteIndexerTpl.replace('__NAME__', infoRaw.name || ''))) return;
        fetch('/prowlarr/indexer/' + infoRaw.id + '/delete', { method: 'POST' })
            .then(function(r) { return r.json(); })
            .then(function(d) { if (d.ok) { closeModal('modal-info-indexer'); window.location.reload(); } });
    });

    // Fermer modal info
    document.getElementById('modal-info-indexer').addEventListener('click', function(e) { if (e.target === this) closeModal('modal-info-indexer'); });
})();
</script>
{% endblock %}
