        },
        infoNoCategories: {{ 'prowlarr.index.info_no_categories'|trans|json_encode|raw }},
        infoCategoriesCountOne: {{ 'prowlarr.index.info_categories_count_tpl'|trans({count: 1})|json_encode|raw }},
        infoCategoriesCountOther: {{ 'prowlarr.index.info_categories_count_tpl'|trans({count: 2})|json_encode|raw }},
        infoColId: {{ 'prowlarr.index.info_col_id'|trans|json_encode|raw }},
        infoColName: {{ 'prowlarr.common.name'|trans|json_encode|raw }},
        infoNoHistory: {{ 'prowlarr.index.info_no_history'|trans|json_encode|raw }},
        infoColDate: {{ 'prowlarr.index.info_col_date'|trans|json_encode|raw }},
        infoColType: {{ 'prowlarr.index.info_col_type'|trans|json_encode|raw }},
        infoColQuery: {{ 'prowlarr.index.info_col_query'|trans|json_encode|raw }},
        infoColSource: {{ 'prowlarr.index.info_col_source'|trans|json_encode|raw }},
        infoEventRss: {{ 'prowlarr.index.info_event_rss'|trans|json_encode|raw }},
        infoEventQuery: {{ 'prowlarr.index.info_event_query'|trans|json_encode|raw }},
        infoPrivacyPrivate: {{ 'prowlarr.index.privacy_private'|trans|json_encode|raw }},
        infoPrivacySemi: {{ 'prowlarr.index.privacy_semiprivate'|trans|json_encode|raw }},
        infoPrivacyPublic: {{ 'prowlarr.index.privacy_public'|trans|json_encode|raw }},
        listPrivacySemi: {{ 'prowlarr.index.privacy_semi'|trans|json_encode|raw }}
    };

    // ── Helpers ──
    function esc(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }
    function showAlert(el, cls, msg) { el.className = 'mt-2 alert ' + cls; el.textContent = msg; el.style.display = ''; }
    // Clean the payload before sending to the Prowlarr API (remove empty selectOptions that cause type errors)
    function cleanPayload(data) {
        var clean = JSON.parse(JSON.stringify(data));
        if (clean.fields) {
            clean.fields.forEach(function(f) {
                delete f.selectOptions;
                delete f._injectedOptions;
                delete f.selectOptionsProviderAction;
            });
        }
        return clean;
    }
    function openModal(id) { var m = document.getElementById(id); m.classList.add('show'); m.style.display = 'block'; m.style.overflowY = 'auto'; document.body.classList.add('modal-open'); document.body.style.overflow = 'hidden'; if (!document.querySelector('.modal-backdrop')) { var b = document.createElement('div'); b.className = 'modal-backdrop fade show'; document.body.appendChild(b); } }
    function closeModal(id) { var m = document.getElementById(id); m.classList.remove('show'); m.style.display = 'none'; document.body.classList.remove('modal-open'); document.body.style.overflow = ''; var b = document.querySelector('.modal-backdrop'); if (b) b.remove(); }

    var appProfilesCache = null;

    function renderFields(fields, container, topLevel) {
        var h = '';
        // Champs de niveau indexeur (Name, Enabled, Redirect, App Profile, Priority)
        if (topLevel) {
            h += '<div class="row g-2 mb-3 pb-3" style="border-bottom:1px solid var(--tblr-border-color);">';
            h += '<div class="col-12 col-sm-6"><label class="form-label small mb-1">' + esc(_I18N.name) + '</label><input type="text" class="form-control form-control-sm pw-top" data-top="name" value="' + esc(topLevel.name || '') + '"></div>';
            h += '<div class="col-12 col-sm-6"><label class="form-label small mb-1">' + esc(_I18N.appProfile) + '</label><select class="form-select form-select-sm pw-top" data-top="appProfileId" id="pw-app-profile-sel"><option>' + esc(_I18N.appProfileLoading) + '</option></select></div>';
            h += '<div class="col-6 col-sm-3"><label class="form-label small mb-1">' + esc(_I18N.priority) + '</label><input type="number" class="form-control form-control-sm pw-top" data-top="priority" value="' + (topLevel.priority ?? 25) + '"></div>';
            h += '<div class="col-6 col-sm-3 d-flex align-items-end gap-3">';
            h += '<label class="form-check form-switch mb-1"><input class="form-check-input pw-top" data-top="enable" type="checkbox"' + (topLevel.enable !== false ? ' checked' : '') + '><span class="form-check-label small">' + esc(_I18N.enabled) + '</span></label>';
            h += '<label class="form-check form-switch mb-1"><input class="form-check-input pw-top" data-top="redirect" type="checkbox"' + (topLevel.redirect ? ' checked' : '') + '><span class="form-check-label small">' + esc(_I18N.redirect) + '</span></label>';
            h += '</div>';
            h += '<div class="col-12"><label class="form-label small mb-1">' + esc(_I18N.tagsLabel) + '</label><div class="d-flex flex-wrap gap-1 align-items-center p-2" id="pw-tags-wrap" style="background:rgba(255,255,255,.02);border:1px solid var(--tblr-border-color);border-radius:.4rem;min-height:38px;"></div></div>';
            h += '</div>';
            // Charger app profiles
            if (!appProfilesCache) {
                fetch('/prowlarr/app-profiles').then(function(r){return r.json();}).then(function(profiles) {
                    appProfilesCache = profiles;
                    fillAppProfileSelect(topLevel.appProfileId);
                });
            } else {
                setTimeout(function() { fillAppProfileSelect(topLevel.appProfileId); }, 0);
            }
        }
        // Indexer-specific fields
        h += '<div class="row g-2">';
        fields.forEach(function (f) {
            if (f.type === 'info') {
                var infoHtml = f.value || f.helpText || '';
                var infoLabel = f.label ? '<strong>' + esc(f.label) + '</strong><br>' : '';
                h += '<div class="col-12"><div class="small text-secondary" style="font-size:.75rem;padding:.5rem .7rem;background:rgba(255,255,255,.03);border-radius:.35rem;line-height:1.4;">' + infoLabel + infoHtml + '</div></div>';
                return;
            }
            if (f.name === 'definitionFile') return;
            var label = esc(f.label || f.name);
            var name = esc(f.name);
            var helpText = f.helpText ? '<div class="form-text" style="font-size:.65rem;">' + esc(f.helpText) + '</div>' : '';
            h += '<div class="col-12 col-sm-6">';
            h += '<label class="form-label small mb-1">' + label + '</label>';
            if (f.type === 'checkbox') {
                h += '<div><label class="form-check form-switch"><input class="form-check-input pw-field" data-name="' + name + '" type="checkbox"' + (f.value ? ' checked' : '') + '><span class="form-check-label small">' + label + '</span></label></div>';
            } else if (f.type === 'select' && f.selectOptions) {
                h += '<select class="form-select form-select-sm pw-field" data-name="' + name + '">';
                (f.selectOptions || []).forEach(function (opt) {
                    var sel = (opt.value !== undefined && String(opt.value) === String(f.value)) ? ' selected' : '';
                    h += '<option value="' + esc(String(opt.value)) + '"' + sel + '>' + esc(opt.name || opt.value) + '</option>';
                });
                h += '</select>';
            } else if (f.type === 'number') {
                h += '<input type="number" class="form-control form-control-sm pw-field" data-name="' + name + '" value="' + (f.value ?? '') + '">';
            } else if (f.type === 'password') {
                h += '<input type="password" class="form-control form-control-sm pw-field" data-name="' + name + '" value="' + esc(f.value ?? '') + '" autocomplete="off">';
            } else {
                h += '<input type="text" class="form-control form-control-sm pw-field" data-name="' + name + '" value="' + esc(String(f.value ?? '')) + '">';
            }
            h += helpText + '</div>';
        });
        h += '</div>';
        container.innerHTML = h;
    }

    function fillAppProfileSelect(selectedId) {
        var sel = document.getElementById('pw-app-profile-sel');
        if (!sel || !appProfilesCache) return;
        sel.innerHTML = appProfilesCache.map(function(p) {
            return '<option value="' + p.id + '"' + (p.id === selectedId ? ' selected' : '') + '>' + esc(p.name) + '</option>';
        }).join('');
    }

    var tagsCache = null;
    var selectedTags = [];

    function loadAndRenderTags(currentTags) {
        selectedTags = currentTags || [];
        if (!tagsCache) {
            fetch('/prowlarr/tags').then(function(r) { return r.json(); }).then(function(tags) {
                tagsCache = tags;
                renderTagsUI();
            });
        } else {
            renderTagsUI();
        }
    }

    function renderTagsUI() {
        var wrap = document.getElementById('pw-tags-wrap');
        if (!wrap) return;
        var h = '';
        // Tags existants (cliquables)
        (tagsCache || []).forEach(function(t) {
            var active = selectedTags.indexOf(t.id) !== -1;
            h += '<span class="badge ' + (active ? '' : '') + '" style="cursor:pointer;font-size:.7rem;padding:.3em .6em;border-radius:2rem;transition:all .15s;'
              + (active ? 'background:var(--tblr-primary);color:#fff;box-shadow:0 0 6px rgba(var(--tblr-primary-rgb),.4);' : 'background:rgba(255,255,255,.06);color:rgba(255,255,255,.5);border:1px solid rgba(255,255,255,.1);')
              + '" data-tag-id="' + t.id + '">'
              + (active ? '<svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" style="margin-right:3px;"><path d="M5 12l5 5l10-10"/></svg>' : '')
              + esc(t.label) + '</span>';
        });
        // Create-new input
        h += '<div class="d-flex gap-1 align-items-center ms-1" style="border-left:1px solid rgba(255,255,255,.08);padding-left:.5rem;">'
           + '<input type="text" class="form-control form-control-sm" id="pw-tag-new" placeholder="' + esc(_I18N.newTag) + '" style="width:90px;font-size:.7rem;background:rgba(255,255,255,.04);border-color:rgba(255,255,255,.1);">'
           + '<button class="btn btn-sm btn-icon" id="pw-tag-add-btn" style="width:28px;height:28px;background:rgba(var(--tblr-primary-rgb),.15);color:#818cf8;border:none;border-radius:.3rem;" title="' + esc(_I18N.createTagTitle) + '">'
           + '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg></button></div>';
        wrap.innerHTML = h;

        // Bind toggle tags
        wrap.querySelectorAll('[data-tag-id]').forEach(function(badge) {
            badge.addEventListener('click', function() {
                var id = parseInt(badge.dataset.tagId);
                var idx = selectedTags.indexOf(id);
                if (idx !== -1) selectedTags.splice(idx, 1);
                else selectedTags.push(id);
                renderTagsUI();
            });
        });

        // Bind create-tag
        var addBtn = document.getElementById('pw-tag-add-btn');
        var addInput = document.getElementById('pw-tag-new');
        if (addBtn && addInput) {
            addBtn.addEventListener('click', createNewTag);
            addInput.addEventListener('keydown', function(e) { if (e.key === 'Enter') { e.preventDefault(); createNewTag(); } });
        }
    }

    function createNewTag() {
        var input = document.getElementById('pw-tag-new');
        var label = (input.value || '').trim();
        if (!label) return;
        input.disabled = true;
        fetch('/prowlarr/tag/create', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ label: label }) })
            .then(function(r) { return r.json(); })
            .then(function(d) {
                input.disabled = false;
                if (d.ok && d.tag) {
                    tagsCache.push(d.tag);
                    selectedTags.push(d.tag.id);
                    renderTagsUI();
                }
            });
    }

    function collectTopLevel(container, base) {
        var data = JSON.parse(JSON.stringify(base));
        container.querySelectorAll('.pw-top').forEach(function(el) {
            var key = el.dataset.top;
            if (el.type === 'checkbox') data[key] = el.checked;
            else if (key === 'appProfileId' || key === 'priority') data[key] = el.value !== '' ? parseInt(el.value) : data[key];
            else data[key] = el.value;
        });
        data.tags = selectedTags;
        return data;
    }

    function collectFields(container, baseFields) {
        var fields = JSON.parse(JSON.stringify(baseFields));
        fields.forEach(function (field) {
            // Remove client-side injected selectOptions to avoid type errors
            if (field.name === 'baseUrl' && field._injectedOptions) {
                delete field.selectOptions;
                delete field._injectedOptions;
            }
        });
        container.querySelectorAll('.pw-field').forEach(function (el) {
            var name = el.dataset.name;
            var field = fields.find(function (f) { return f.name === name; });
            if (!field) return;
            if (el.type === 'checkbox') field.value = el.checked;
            else if (el.type === 'number') field.value = el.value !== '' ? parseFloat(el.value) : null;
            else if (field.type === 'select' && field.selectOptions && field.selectOptions.length) {
                // Garder le type original de la valeur (int vs string)
                var origOpt = field.selectOptions.find(function(o) { return String(o.value) === el.value; });
                field.value = origOpt ? origOpt.value : el.value;
            }
            else field.value = el.value;
        });
        return fields;
    }

    // ── Toggle ON/OFF (Tabler switch — checked state mirrors the server) ──
    document.querySelectorAll('[data-toggle-id]').forEach(function (input) {
        input.addEventListener('change', function () {
            input.disabled = true;
            fetch('/prowlarr/indexer/' + input.dataset.toggleId + '/toggle', { method: 'POST' })
                .then(function (r) { return r.json(); })
                .then(function (d) { input.disabled = false; input.checked = d.ok ? d.enabled : !input.checked; })
                .catch(function () { input.disabled = false; input.checked = !input.checked; });
        });
    });

    // ── Supprimer ──
    document.querySelectorAll('[data-delete-id]').forEach(function (btn) {
        btn.addEventListener('click', function () {
            if (!confirm(_I18N.confirmDeleteIndexerTpl.replace('__NAME__', btn.dataset.deleteName))) return;
            fetch('/prowlarr/indexer/' + btn.dataset.deleteId + '/delete', { method: 'POST' })
                .then(function (r) { return r.json(); })
                .then(function (d) { if (d.ok) { var row = btn.closest('tr'); if (row) row.remove(); } });
        });
    });

    // ── Test indexeur ──
    document.querySelectorAll('[data-test-id]').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var id = btn.dataset.testId;
            var orig = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm" style="width:.7rem;height:.7rem;"></span>';
            btn.disabled = true;
            fetch('/prowlarr/indexer/' + id, { method: 'GET' })
                .then(function (r) { return r.json(); })
                .then(function (raw) {
                    return fetch('/prowlarr/indexer/test', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(cleanPayload(raw)) });
                })
                .then(function (r) { return r.json(); })
                .then(function (d) {
                    btn.disabled = false;
                    if (d.ok) { btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2"><path d="M5 12l5 5l10-10"/></svg>'; }
                    else { btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>'; }
                    setTimeout(function () { btn.innerHTML = orig; }, 3000);
                });
        });
    });

    // ── Tester tous les indexeurs (API native testall) ──
    document.getElementById('btn-test-all').addEventListener('click', function () {
        var btn = this;
