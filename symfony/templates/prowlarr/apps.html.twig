{% extends 'base.html.twig' %}
{% block title %}{{ 'prowlarr.apps.page_title_full'|trans }}{% endblock %}
{% block head_meta %}<meta name="turbo-visit-control" content="reload">{% endblock %}

{% block stylesheets %}
<style>
.pw-app-card { }
.pw-schema-card:hover { border-color:#E88D1A !important; background:rgba(232,141,26,.05) !important; }
</style>
{% endblock %}

{% block body %}
<div class="page-header d-print-none">
    <div class="container-xl">
        <div class="row g-2 align-items-center">
            <div class="col">
                <h2 class="page-title d-flex align-items-center gap-2">
                    <svg width="28" height="28" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg"><path d="M256 32C132.3 32 32 132.3 32 256s100.3 224 224 224 224-100.3 224-224S379.7 32 256 32zm0 400c-97 0-176-79-176-176S159 80 256 80s176 79 176 176-79 176-176 176z" fill="#E88D1A"/><path d="M256 120c-75 0-136 61-136 136s61 136 136 136 136-61 136-136-61-136-136-136zm0 224c-48.6 0-88-39.4-88-88s39.4-88 88-88 88 39.4 88 88-39.4 88-88 88z" fill="#E88D1A"/><circle cx="256" cy="256" r="48" fill="#E88D1A"/></svg>
                    {{ 'prowlarr.apps.title'|trans }} <span class="badge bg-secondary-lt ms-1">{{ apps|length }}</span>
                </h2>
            </div>
            <div class="col-auto ms-auto d-flex gap-2 align-items-center">
                {% include 'prowlarr/_prowlarr_nav.html.twig' %}
            </div>
        </div>
    </div>
</div>

<div class="page-body">
<div class="container-xl">

{% if error %}
    <div class="alert alert-danger">{{ 'prowlarr.common.error_unreachable'|trans }}</div>
{% endif %}

{# ── Cards Applications ── #}
<div class="row g-3 mb-3">
    {% for app in apps %}
    <div class="col-12 col-md-6 col-lg-4">
        <div class="card pw-app-card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <div class="d-flex align-items-center gap-2">
                        {% if 'Radarr' in (app.implementationName ?? '') %}
                            <svg width="24" height="24" viewBox="0 0 1024 1024" xmlns="http://www.w3.org/2000/svg"><g transform="translate(70 21)"><path d="M105.3 154.9L112.8 869.5C52.7 877 7.5 846.9 7.5 786.8L0 192.6C0 4.5 173-40.6 278.3 34.6L812.3 343C887.5 395.6 902.6 493.4 865 561.1C857.5 508.5 834.9 478.4 789.8 448.3L188 109.8C142.9 79.7 105.3 87.2 105.3 154.9Z" fill="#FFC230"/><path d="M0 376.1C45.1 391.1 90.3 383.6 127.9 361L744.6 0C782.2 52.7 774.7 105.3 729.6 135.4L210.6 436.3C135.4 473.9 37.6 436.3 0 376.1Z" transform="translate(60.2 531)" fill="#FFC230"/><path d="M0 413.7L368.6 203.1L7.5 0L0 413.7Z" transform="translate(240.7 282.8)" fill="#FFC230"/></g></svg>
                        {% elseif 'Sonarr' in (app.implementationName ?? '') %}
                            <svg width="24" height="24" viewBox="0 0 216.7 216.9" xmlns="http://www.w3.org/2000/svg"><path d="M194.65 42.5l-22.4 22.4C159.15 78 158 89.4 158 109.5c0 17.93 2.85 34.35 16.2 47.7l19 18.95c-2.5 3.07-5.2 6.07-8.1 9-.7.83-1.48 1.6-2.35 2.3-2.53 2.5-5.17 4.82-7.9 6.95l-17.55-17.55c-15.6-15.6-28-17.1-48.6-17.1-19.77 0-33.22 1.82-47.7 16.3l-18.55 18.6c-3.77-2.87-7.33-6.03-10.7-9.5-2.8-2.8-5.42-5.67-7.85-8.6l19.15-19.2c13.85-13.85 16.1-29.92 16.1-47.85 0-17.5-2.87-33.82-15.6-46.55L22.45 43.85c2.83-3.6 5.92-7.07 9.25-10.4 2.93-2.87 5.93-5.55 9-8.05L61.1 43.85C74.1 56.85 90.77 60.2 108.7 60.2c18.47 0 35.08-3.58 48.6-17.1l19.3-19.25c2.9 2.37 5.73 4.93 8.5 7.7 3.47 3.53 6.65 7.18 9.55 10.95z" fill="#0CF"/><circle cx="108.35" cy="108.45" r="29.5" fill="#0CF" opacity=".8"/></svg>
                        {% else %}
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E88D1A" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                        {% endif %}
                        <div>
                            <h3 class="mb-0">{{ app.name ?? '—' }}</h3>
                            <div class="text-secondary small">{{ app.implementationName ?? '' }}</div>
                        </div>
                    </div>
                </div>

                {# Key info #}
                <div class="d-flex flex-wrap gap-1 mb-2">
                    <span class="badge bg-indigo-lt" style="font-size:.6rem;">{{ app.syncLevel ?? '—' }}</span>
                    {% for field in app.fields ?? [] %}
                        {% if field.name == 'baseUrl' and field.value is defined %}
                            <span class="badge bg-secondary-lt" style="font-size:.6rem;">{{ field.value }}</span>
                        {% endif %}
                    {% endfor %}
                </div>

                {# Actions compactes #}
                <div class="d-flex gap-1 mt-auto pt-2" style="border-top:1px solid rgba(255,255,255,.04);">
                    <button class="btn btn-sm btn-ghost-secondary p-1 pw-edit-btn" data-id="{{ app.id }}" title="{{ 'prowlarr.common.edit'|trans }}">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 20h4l10.5-10.5a2.828 2.828 0 10-4-4L4 16v4M13.5 6.5l4 4"/></svg>
                    </button>
                    <button class="btn btn-sm btn-ghost-secondary p-1 pw-test-btn" data-id="{{ app.id }}" title="{{ 'prowlarr.common.test'|trans }}">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5l10-10"/></svg>
                    </button>
                    <button class="btn btn-sm btn-ghost-danger p-1 ms-auto pw-del-btn" data-id="{{ app.id }}" data-name="{{ app.name ?? '' }}" title="{{ 'prowlarr.common.delete'|trans }}">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 7h16M10 11v6M14 11v6M5 7l1 12a2 2 0 002 2h8a2 2 0 002-2l1-12M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3"/></svg>
                    </button>
                </div>
            </div>
        </div>
    </div>
    {% endfor %}
</div>

{# Small add button #}
<div class="mb-3">
    <button class="btn btn-sm btn-outline-secondary pw-add-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#E88D1A" stroke-width="2" class="me-1"><path d="M12 5v14M5 12h14"/></svg>
        {{ 'prowlarr.apps.add_btn'|trans }}
    </button>
</div>

{# ── Sync Profiles ── #}
<div class="card">
    <div class="card-header">
        <h3 class="card-title">{{ 'prowlarr.apps.profiles_title'|trans }}</h3>
        <div class="card-options">
            <button class="btn btn-sm btn-outline-secondary" id="btn-add-profile">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><path d="M12 5v14M5 12h14"/></svg>
                {{ 'prowlarr.common.add'|trans }}
            </button>
        </div>
    </div>
    <div class="card-body" id="sync-profiles-body">
        <div class="text-center py-2"><div class="spinner-border spinner-border-sm text-secondary"></div></div>
    </div>
</div>

{# Modal Sync Profile #}
<div class="modal modal-blur fade" id="pw-modal-profile" tabindex="-1">
    <div class="modal-dialog modal-md" style="margin-top:3rem;">
        <div class="modal-content" style="background:var(--tblr-bg-surface);">
            <div class="modal-header">
                <h4 class="modal-title" id="profile-modal-title">{{ 'prowlarr.apps.profile_modal_title'|trans }}</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label small mb-1">{{ 'prowlarr.apps.profile_name'|trans }}</label>
                        <input type="text" class="form-control form-control-sm" id="profile-name">
                    </div>
                    <div class="col-6">
                        <label class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="profile-rss" checked>
                            <span class="form-check-label">{{ 'prowlarr.apps.profile_rss'|trans }}</span>
                        </label>
                    </div>
                    <div class="col-6">
                        <label class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="profile-auto" checked>
                            <span class="form-check-label">{{ 'prowlarr.apps.profile_auto_search'|trans }}</span>
                        </label>
                    </div>
                    <div class="col-6">
                        <label class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="profile-interactive" checked>
                            <span class="form-check-label">{{ 'prowlarr.apps.profile_interactive_search'|trans }}</span>
                        </label>
                    </div>
                    <div class="col-6">
                        <label class="form-label small mb-1">{{ 'prowlarr.apps.profile_min_seeders'|trans }}</label>
                        <input type="number" class="form-control form-control-sm" id="profile-seeders" value="1" min="0">
                    </div>
                </div>
                <div id="profile-result" class="mt-3 alert d-none" style="font-size:.85rem;"></div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-sm btn-ghost-danger" id="profile-delete" style="display:none;">{{ 'prowlarr.common.delete'|trans }}</button>
                <button class="btn btn-sm btn-primary ms-auto" id="profile-save" style="background:#E88D1A;border-color:#E88D1A;">{{ 'prowlarr.common.save'|trans }}</button>
            </div>
        </div>
    </div>
</div>

{# Add modal #}
<div class="modal modal-blur fade" id="pw-modal-add" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable" style="margin-top:2rem;">
        <div class="modal-content" style="background:var(--tblr-bg-surface);">
            <div class="modal-header"><h4 class="modal-title">{{ 'prowlarr.apps.add_modal_title'|trans }}</h4><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div id="pw-add-filters"><input type="text" id="pw-add-search" class="form-control mb-3" placeholder="{{ 'prowlarr.common.search_placeholder'|trans }}" autocomplete="off"></div>
                <div id="pw-add-list" class="row g-2" style="max-height:400px;overflow-y:auto;"></div>
                <div id="pw-add-form" style="display:none;" class="mt-3 p-3 border border-primary rounded">
                    <div class="d-flex justify-content-between align-items-center mb-3"><h5 id="pw-add-form-title" class="mb-0"></h5><button id="pw-add-back" class="btn btn-sm btn-ghost-secondary">{{ 'prowlarr.common.back'|trans }}</button></div>
                    <div id="pw-add-fields"></div>
                    <div class="d-flex gap-2 mt-3"><button id="pw-add-test" class="btn btn-sm btn-outline-secondary">{{ 'prowlarr.common.test'|trans }}</button><button id="pw-add-save" class="btn btn-sm btn-primary" style="background:#E88D1A;border-color:#E88D1A;">{{ 'prowlarr.common.add'|trans }}</button></div>
                    <div id="pw-add-result" class="mt-2 alert d-none" style="font-size:.85rem;"></div>
                </div>
            </div>
        </div>
    </div>
</div>

{# Edit modal #}
<div class="modal modal-blur fade" id="pw-modal-edit" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable" style="margin-top:2rem;">
        <div class="modal-content" style="background:var(--tblr-bg-surface);">
            <div class="modal-header"><h4 class="modal-title" id="pw-edit-title">{{ 'prowlarr.apps.edit_modal_title'|trans }}</h4><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div id="pw-edit-fields"></div>
                <div class="d-flex gap-2 mt-3"><button id="pw-edit-test" class="btn btn-sm btn-outline-secondary">{{ 'prowlarr.common.test'|trans }}</button><button id="pw-edit-save" class="btn btn-sm btn-primary" style="background:#E88D1A;border-color:#E88D1A;">{{ 'prowlarr.common.save'|trans }}</button></div>
                <div id="pw-edit-result" class="mt-2 alert d-none" style="font-size:.85rem;"></div>
            </div>
        </div>
    </div>
</div>

</div>
</div>
{% endblock %}

{% block javascripts %}
<script>
(function () {
    var SCHEMA_URL = '{{ app.request.getBasePath() }}/prowlarr/application/schema';
    var GET_URL = '{{ app.request.getBasePath() }}/prowlarr/application/{id}';
    var ADD_URL = '{{ app.request.getBasePath() }}/prowlarr/application/add';
    var UPDATE_URL = '{{ app.request.getBasePath() }}/prowlarr/application/{id}/update';
    var DELETE_URL = '{{ app.request.getBasePath() }}/prowlarr/application/{id}/delete';
    var TEST_URL = '{{ app.request.getBasePath() }}/prowlarr/application/test';

    var _I18N = {
        name: {{ 'prowlarr.common.name'|trans|json_encode|raw }},
        syncLevelLabel: {{ 'prowlarr.apps.sync_level_label'|trans|json_encode|raw }},
        syncDisabled: {{ 'prowlarr.apps.sync_disabled'|trans|json_encode|raw }},
        syncAddOnly: {{ 'prowlarr.apps.sync_add_only'|trans|json_encode|raw }},
        syncFull: {{ 'prowlarr.apps.sync_full'|trans|json_encode|raw }},
        confirmDeleteTpl: {{ 'prowlarr.common.confirm_delete_tpl'|trans|json_encode|raw }},
        confirmDeleteProfile: {{ 'prowlarr.apps.confirm_delete_profile'|trans|json_encode|raw }},
        editTitleTpl: {{ 'prowlarr.schema_modal.edit_title_tpl'|trans|json_encode|raw }},
        test: {{ 'prowlarr.common.test'|trans|json_encode|raw }},
        testing: {{ 'prowlarr.common.testing'|trans|json_encode|raw }},
        testSuccess: {{ 'prowlarr.common.test_success'|trans|json_encode|raw }},
        testFailureTpl: {{ 'prowlarr.common.test_failure_tpl'|trans|json_encode|raw }},
        save: {{ 'prowlarr.common.save'|trans|json_encode|raw }},
        saving: {{ 'prowlarr.common.saving'|trans|json_encode|raw }},
        saved: {{ 'prowlarr.common.saved'|trans|json_encode|raw }},
        add: {{ 'prowlarr.common.add'|trans|json_encode|raw }},
        adding: {{ 'prowlarr.common.adding'|trans|json_encode|raw }},
        ok: {{ 'prowlarr.common.ok'|trans|json_encode|raw }},
        failed: {{ 'prowlarr.common.failed'|trans|json_encode|raw }},
        errorTpl: {{ 'prowlarr.common.error_tpl'|trans|json_encode|raw }},
        noResults: {{ 'prowlarr.common.no_results'|trans|json_encode|raw }},
        profileNewTitle: {{ 'prowlarr.apps.profile_new_title'|trans|json_encode|raw }},
        profileEditTitleTpl: {{ 'prowlarr.apps.profile_edit_title_tpl'|trans|json_encode|raw }},
        profilesEmpty: {{ 'prowlarr.apps.profile_empty'|trans|json_encode|raw }},
        profileColRss: {{ 'prowlarr.apps.profile_col_rss'|trans|json_encode|raw }},
        profileColAuto: {{ 'prowlarr.apps.profile_col_auto'|trans|json_encode|raw }},
        profileColInteractive: {{ 'prowlarr.apps.profile_col_interactive'|trans|json_encode|raw }},
        profileColSeeders: {{ 'prowlarr.apps.profile_col_seeders'|trans|json_encode|raw }},
        profileSaveError: {{ 'prowlarr.apps.profile_save_error'|trans|json_encode|raw }},
        commonName: {{ 'prowlarr.common.name'|trans|json_encode|raw }},
        actions: {{ 'prowlarr.common.actions'|trans|json_encode|raw }},
        edit: {{ 'prowlarr.common.edit'|trans|json_encode|raw }},
        on: {{ 'prowlarr.common.on'|trans|json_encode|raw }},
        off: {{ 'prowlarr.common.off'|trans|json_encode|raw }}
    };

    function esc(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }
    function showAlert(el, cls, msg) { el.className = 'mt-2 alert ' + cls; el.textContent = msg; }
    function openModal(id) { var m = document.getElementById(id); m.classList.add('show'); m.style.display = 'block'; document.body.classList.add('modal-open'); document.body.style.overflow = 'hidden'; if (!document.querySelector('.modal-backdrop')) { var b = document.createElement('div'); b.className = 'modal-backdrop fade show'; document.body.appendChild(b); } }
    function closeModal(id) { var m = document.getElementById(id); m.classList.remove('show'); m.style.display = 'none'; document.body.classList.remove('modal-open'); document.body.style.overflow = ''; var b = document.querySelector('.modal-backdrop'); if (b) b.remove(); }
    function cleanPayload(data) { var c = JSON.parse(JSON.stringify(data)); if (c.fields) c.fields.forEach(function(f) { delete f.selectOptions; delete f._injectedOptions; delete f.selectOptionsProviderAction; }); return c; }

    function renderFields(fields, container, topLevel) {
        var h = '';
        if (topLevel) {
            h += '<div class="row g-2 mb-3 pb-3" style="border-bottom:1px solid var(--tblr-border-color);">';
            h += '<div class="col-12 col-sm-6"><label class="form-label small mb-1">' + esc(_I18N.name) + '</label><input type="text" class="form-control form-control-sm pw-top" data-top="name" value="' + esc(topLevel.name || '') + '"></div>';
            h += '<div class="col-12 col-sm-6"><label class="form-label small mb-1">' + esc(_I18N.syncLevelLabel) + '</label><select class="form-select form-select-sm pw-top" data-top="syncLevel"><option value="disabled"' + (topLevel.syncLevel === 'disabled' ? ' selected' : '') + '>' + esc(_I18N.syncDisabled) + '</option><option value="addOnly"' + (topLevel.syncLevel === 'addOnly' ? ' selected' : '') + '>' + esc(_I18N.syncAddOnly) + '</option><option value="fullSync"' + (topLevel.syncLevel === 'fullSync' ? ' selected' : '') + '>' + esc(_I18N.syncFull) + '</option></select></div>';
            h += '</div>';
        }
        h += '<div class="row g-2">';
        fields.forEach(function(f) {
            if (f.type === 'info') { h += '<div class="col-12"><div class="small text-secondary" style="font-size:.75rem;padding:.5rem .7rem;background:rgba(255,255,255,.03);border-radius:.35rem;">' + (f.label ? '<strong>' + esc(f.label) + '</strong><br>' : '') + (f.value || f.helpText || '') + '</div></div>'; return; }
            var label = esc(f.label || f.name || '');
            var name = esc(f.name || '');
            h += '<div class="col-12 col-sm-6"><label class="form-label small mb-1">' + label + '</label>';
            if (f.type === 'checkbox') h += '<div><label class="form-check form-switch"><input class="form-check-input pw-field" data-name="' + name + '" type="checkbox"' + (f.value ? ' checked' : '') + '><span class="form-check-label small">' + label + '</span></label></div>';
            else if (f.type === 'select' && f.selectOptions && f.selectOptions.length && Array.isArray(f.value)) { var vals = f.value.map(String); h += '<div class="pw-multi-field" data-name="' + name + '" style="display:flex;flex-wrap:wrap;gap:.25rem;max-height:150px;overflow-y:auto;padding:.3rem;border:1px solid var(--tblr-border-color);border-radius:.35rem;">'; f.selectOptions.forEach(function(o) { var sel = vals.indexOf(String(o.value)) !== -1; var indent = o.parentValue ? 'margin-left:.6rem;' : 'font-weight:600;'; h += '<button type="button" class="pw-cat-pill' + (sel ? ' active' : '') + '" data-val="' + esc(String(o.value)) + '" style="padding:.15rem .45rem;border-radius:.25rem;border:1px solid var(--tblr-border-color);background:' + (sel ? '#6366f1' : 'transparent') + ';color:' + (sel ? '#fff' : 'var(--tblr-body-color)') + ';font-size:.65rem;cursor:pointer;transition:all .1s;' + indent + '">' + esc(o.name || o.value) + ' <span style="opacity:.5;font-size:.55rem;">' + esc(o.hint || '') + '</span></button>'; }); h += '</div>'; }
            else if (f.type === 'select' && f.selectOptions && f.selectOptions.length) { h += '<select class="form-select form-select-sm pw-field" data-name="' + name + '">'; f.selectOptions.forEach(function(o) { h += '<option value="' + esc(String(o.value)) + '"' + (String(o.value) === String(f.value) ? ' selected' : '') + '>' + esc(o.name || o.value) + '</option>'; }); h += '</select>'; }
            else if (f.type === 'password') h += '<input type="password" class="form-control form-control-sm pw-field" data-name="' + name + '" value="' + esc(f.value ?? '') + '" autocomplete="off">';
            else h += '<input type="text" class="form-control form-control-sm pw-field" data-name="' + name + '" value="' + esc(String(f.value ?? '')) + '">';
            if (f.helpText) h += '<div class="form-text" style="font-size:.6rem;">' + esc(f.helpText) + '</div>';
            h += '</div>';
        });
        h += '</div>';
        container.innerHTML = h;
        // Toggle pills multi-select
        container.querySelectorAll('.pw-cat-pill').forEach(function(pill) {
            pill.addEventListener('click', function() {
                pill.classList.toggle('active');
                pill.style.background = pill.classList.contains('active') ? '#6366f1' : 'transparent';
                pill.style.color = pill.classList.contains('active') ? '#fff' : 'var(--tblr-body-color)';
            });
        });
    }

    function collectFields(container, baseFields) { var f = JSON.parse(JSON.stringify(baseFields)); container.querySelectorAll('.pw-field').forEach(function(el) { var x = f.find(function(y) { return y.name === el.dataset.name; }); if (!x) return; if (el.type === 'checkbox') x.value = el.checked; else x.value = el.value; }); container.querySelectorAll('.pw-multi-field').forEach(function(el) { var x = f.find(function(y) { return y.name === el.dataset.name; }); if (!x) return; var selected = []; el.querySelectorAll('.pw-cat-pill.active').forEach(function(p) { var v = p.dataset.val; selected.push(isNaN(v) ? v : parseInt(v)); }); x.value = selected; }); return f; }
    function collectTopLevel(container, base) { var d = JSON.parse(JSON.stringify(base)); container.querySelectorAll('.pw-top').forEach(function(el) { if (el.type === 'checkbox') d[el.dataset.top] = el.checked; else d[el.dataset.top] = el.value; }); return d; }

    // Delete
    document.querySelectorAll('.pw-del-btn').forEach(function(b) { b.addEventListener('click', function() { if (!confirm(_I18N.confirmDeleteTpl.replace('__NAME__', b.dataset.name))) return; fetch(DELETE_URL.replace('{id}', b.dataset.id), { method:'POST' }).then(function(r){return r.json();}).then(function(d){ if(d.ok) b.closest('.col-12').remove(); }); }); });

    // Test
    document.querySelectorAll('.pw-test-btn').forEach(function(b) { b.addEventListener('click', function() { var orig = b.innerHTML; b.innerHTML = '<span class="spinner-border spinner-border-sm" style="width:.7rem;height:.7rem;"></span> ' + _I18N.testing; b.disabled = true; fetch(GET_URL.replace('{id}', b.dataset.id)).then(function(r){return r.json();}).then(function(raw){ return fetch(TEST_URL, {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(cleanPayload(raw))}); }).then(function(r){return r.json();}).then(function(d){ b.disabled=false; b.innerHTML = d.ok ? '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2"><path d="M5 12l5 5l10-10"/></svg> ' + _I18N.ok : '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg> ' + _I18N.failed; setTimeout(function(){b.innerHTML=orig;},3000); }); }); });

    // Add modal
    var schemaCache = null, selectedSchema = null;
    document.querySelector('.pw-add-btn').addEventListener('click', function() { document.getElementById('pw-add-form').style.display='none'; document.getElementById('pw-add-filters').style.display=''; document.getElementById('pw-add-list').style.display=''; document.getElementById('pw-add-search').value=''; openModal('pw-modal-add'); if(!schemaCache){ document.getElementById('pw-add-list').innerHTML='<div class="col-12 text-center py-3"><div class="spinner-border spinner-border-sm text-secondary"></div></div>'; fetch(SCHEMA_URL).then(function(r){return r.json();}).then(function(d){schemaCache=d;renderList('');}); } else renderList(''); });
    document.getElementById('pw-add-search').addEventListener('input', function(){ if(schemaCache) renderList(this.value.trim().toLowerCase()); });
    function renderList(q) { var c=document.getElementById('pw-add-list'); var f=schemaCache.filter(function(s){ if(!q)return true; return((s.name||'')+(s.implementationName||'')).toLowerCase().includes(q); }).slice(0,20); if(!f.length){c.innerHTML='<div class="col-12 text-center text-secondary small py-2">'+esc(_I18N.noResults)+'</div>';return;} c.innerHTML=f.map(function(s){return '<div class="col-12 col-sm-6"><div class="card pw-schema-card" data-idx="'+schemaCache.indexOf(s)+'" style="cursor:pointer;"><div class="card-body py-2 px-3"><div class="fw-semibold small">'+esc(s.name||s.implementationName||'—')+'</div></div></div></div>';}).join(''); c.querySelectorAll('.pw-schema-card').forEach(function(card){card.addEventListener('click',function(){selectedSchema=JSON.parse(JSON.stringify(schemaCache[parseInt(card.dataset.idx)]));document.getElementById('pw-add-form-title').textContent=selectedSchema.name||selectedSchema.implementationName||'—';document.getElementById('pw-add-filters').style.display='none';document.getElementById('pw-add-list').style.display='none';document.getElementById('pw-add-form').style.display='';document.getElementById('pw-add-result').className='mt-2 alert d-none';renderFields(selectedSchema.fields||[],document.getElementById('pw-add-fields'),selectedSchema);});}); }
    document.getElementById('pw-add-back').addEventListener('click', function(){document.getElementById('pw-add-form').style.display='none';document.getElementById('pw-add-filters').style.display='';document.getElementById('pw-add-list').style.display='';});
    document.getElementById('pw-add-test').addEventListener('click', function(){var btn=this,r=document.getElementById('pw-add-result');var p=collectTopLevel(document.getElementById('pw-add-fields'),selectedSchema);p.fields=collectFields(document.getElementById('pw-add-fields'),selectedSchema.fields||[]);btn.disabled=true;btn.textContent=_I18N.testing;fetch(TEST_URL,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(cleanPayload(p))}).then(function(res){return res.json();}).then(function(d){btn.disabled=false;btn.textContent=_I18N.test;showAlert(r,d.ok?'alert-success':'alert-danger',d.ok?_I18N.testSuccess:_I18N.testFailureTpl.replace('__ERROR__',d.error||'—'));});});
    document.getElementById('pw-add-save').addEventListener('click', function(){var btn=this,r=document.getElementById('pw-add-result');var p=collectTopLevel(document.getElementById('pw-add-fields'),selectedSchema);p.fields=collectFields(document.getElementById('pw-add-fields'),selectedSchema.fields||[]);btn.disabled=true;btn.textContent=_I18N.adding;fetch(ADD_URL,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(cleanPayload(p))}).then(function(res){return res.json();}).then(function(d){btn.disabled=false;btn.textContent=_I18N.add;if(d.ok){showAlert(r,'alert-success',_I18N.saved);setTimeout(function(){window.location.reload();},800);}else showAlert(r,'alert-danger',_I18N.errorTpl.replace('__ERROR__',d.error||'—'));});});

    // Edit modal
    var editRaw = null;
    document.querySelectorAll('.pw-edit-btn').forEach(function(b){b.addEventListener('click',function(){document.getElementById('pw-edit-fields').innerHTML='<div class="text-center py-3"><div class="spinner-border spinner-border-sm text-secondary"></div></div>';document.getElementById('pw-edit-result').className='mt-2 alert d-none';openModal('pw-modal-edit');fetch(GET_URL.replace('{id}',b.dataset.id)).then(function(r){return r.json();}).then(function(raw){editRaw=raw;document.getElementById('pw-edit-title').textContent=_I18N.editTitleTpl.replace('__NAME__',raw.name||'—');renderFields(raw.fields||[],document.getElementById('pw-edit-fields'),raw);});});});
    document.getElementById('pw-edit-test').addEventListener('click', function(){var btn=this,r=document.getElementById('pw-edit-result');var p=collectTopLevel(document.getElementById('pw-edit-fields'),editRaw);p.fields=collectFields(document.getElementById('pw-edit-fields'),editRaw.fields||[]);btn.disabled=true;btn.textContent=_I18N.testing;fetch(TEST_URL,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(cleanPayload(p))}).then(function(res){return res.json();}).then(function(d){btn.disabled=false;btn.textContent=_I18N.test;showAlert(r,d.ok?'alert-success':'alert-danger',d.ok?_I18N.testSuccess:_I18N.testFailureTpl.replace('__ERROR__',d.error||'—'));});});
    document.getElementById('pw-edit-save').addEventListener('click', function(){var btn=this,r=document.getElementById('pw-edit-result');var p=collectTopLevel(document.getElementById('pw-edit-fields'),editRaw);p.fields=collectFields(document.getElementById('pw-edit-fields'),editRaw.fields||[]);btn.disabled=true;btn.textContent=_I18N.saving;fetch(UPDATE_URL.replace('{id}',editRaw.id),{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(cleanPayload(p))}).then(function(res){return res.json();}).then(function(d){btn.disabled=false;btn.textContent=_I18N.save;if(d.ok){showAlert(r,'alert-success',_I18N.saved);setTimeout(function(){window.location.reload();},800);}else showAlert(r,'alert-danger',_I18N.errorTpl.replace('__ERROR__',d.error||'—'));});});

    // Sync Profiles
    var profilesData = [];
    function loadProfiles() {
        fetch('{{ app.request.getBasePath() }}/prowlarr/app-profiles').then(function(r){return r.json();}).then(function(profiles) {
            profilesData = profiles;
            var body = document.getElementById('sync-profiles-body');
            if (!profiles.length) { body.innerHTML = '<div class="text-center text-secondary small">' + esc(_I18N.profilesEmpty) + '</div>'; return; }
            var h = '<div class="table-responsive"><table class="table table-vcenter table-sm card-table"><thead><tr><th>' + esc(_I18N.commonName) + '</th><th>' + esc(_I18N.profileColRss) + '</th><th>' + esc(_I18N.profileColAuto) + '</th><th>' + esc(_I18N.profileColInteractive) + '</th><th>' + esc(_I18N.profileColSeeders) + '</th><th class="text-end">' + esc(_I18N.actions) + '</th></tr></thead><tbody>';
            profiles.forEach(function(p) {
                var onBadge = '<span class="badge bg-green-lt" style="font-size:.55rem;">' + esc(_I18N.on) + '</span>';
                var offBadge = '<span class="badge bg-secondary-lt" style="font-size:.55rem;">' + esc(_I18N.off) + '</span>';
                h += '<tr><td class="fw-medium">' + esc(p.name) + '</td>';
                h += '<td>' + (p.enableRss ? onBadge : offBadge) + '</td>';
                h += '<td>' + (p.enableAutomaticSearch ? onBadge : offBadge) + '</td>';
                h += '<td>' + (p.enableInteractiveSearch ? onBadge : offBadge) + '</td>';
                h += '<td class="text-secondary">' + (p.minimumSeeders ?? 1) + '</td>';
                h += '<td class="text-end"><button class="btn btn-sm btn-ghost-secondary p-1 profile-edit-btn" data-profile-id="' + p.id + '" title="' + esc(_I18N.edit) + '"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 20h4l10.5-10.5a2.828 2.828 0 10-4-4L4 16v4M13.5 6.5l4 4"/></svg></button></td>';
                h += '</tr>';
            });
            h += '</tbody></table></div>';
            body.innerHTML = h;
            // Bind edit
            body.querySelectorAll('.profile-edit-btn').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    var p = profilesData.find(function(x) { return x.id === parseInt(btn.dataset.profileId); });
                    if (p) openProfileModal(p);
                });
            });
        });
    }
    loadProfiles();

    var editingProfileId = null;
    function openProfileModal(p) {
        editingProfileId = p ? p.id : null;
        document.getElementById('profile-modal-title').textContent = p ? _I18N.profileEditTitleTpl.replace('__NAME__', p.name) : _I18N.profileNewTitle;
        document.getElementById('profile-name').value = p ? p.name : '';
        document.getElementById('profile-rss').checked = p ? !!p.enableRss : true;
        document.getElementById('profile-auto').checked = p ? !!p.enableAutomaticSearch : true;
        document.getElementById('profile-interactive').checked = p ? !!p.enableInteractiveSearch : true;
        document.getElementById('profile-seeders').value = p ? (p.minimumSeeders ?? 1) : 1;
        document.getElementById('profile-delete').style.display = p ? '' : 'none';
        document.getElementById('profile-result').className = 'mt-3 alert d-none';
        openModal('pw-modal-profile');
    }

    document.getElementById('btn-add-profile').addEventListener('click', function() { openProfileModal(null); });

    document.getElementById('profile-save').addEventListener('click', function() {
        var btn = this;
        var payload = {
            name: document.getElementById('profile-name').value,
            enableRss: document.getElementById('profile-rss').checked,
            enableAutomaticSearch: document.getElementById('profile-auto').checked,
            enableInteractiveSearch: document.getElementById('profile-interactive').checked,
            minimumSeeders: parseInt(document.getElementById('profile-seeders').value) || 1,
        };
        var url = editingProfileId ? '{{ app.request.getBasePath() }}/prowlarr/app-profile/' + editingProfileId + '/update' : '{{ app.request.getBasePath() }}/prowlarr/app-profile/add';
        if (editingProfileId) payload.id = editingProfileId;
        btn.disabled = true; btn.textContent = _I18N.saving;
        fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) })
            .then(function(r) { return r.json(); })
            .then(function(d) {
                btn.disabled = false; btn.textContent = _I18N.save;
                var r = document.getElementById('profile-result');
                if (d.ok) { showAlert(r, 'alert-success', _I18N.saved); setTimeout(function() { closeModal('pw-modal-profile'); loadProfiles(); }, 600); }
                else showAlert(r, 'alert-danger', _I18N.profileSaveError);
            });
    });

    document.getElementById('profile-delete').addEventListener('click', function() {
        if (!editingProfileId || !confirm(_I18N.confirmDeleteProfile)) return;
        fetch('{{ app.request.getBasePath() }}/prowlarr/app-profile/' + editingProfileId + '/delete', { method: 'POST' })
            .then(function(r) { return r.json(); })
            .then(function(d) { if (d.ok) { closeModal('pw-modal-profile'); loadProfiles(); } });
    });

    // Fermer modal profile
    document.getElementById('pw-modal-profile').addEventListener('click', function(e) { if (e.target === this) closeModal('pw-modal-profile'); });

    // Close modals
    document.querySelectorAll('[data-bs-dismiss="modal"]').forEach(function(b){b.addEventListener('click',function(){var m=b.closest('.modal');if(m)closeModal(m.id);});});
    ['pw-modal-add','pw-modal-edit','pw-modal-profile'].forEach(function(id){var m=document.getElementById(id);if(m)m.addEventListener('click',function(e){if(e.target===m)closeModal(id);});});
    document.addEventListener('keydown',function(e){if(e.key==='Escape'){['pw-modal-add','pw-modal-edit','pw-modal-profile'].forEach(function(id){var m=document.getElementById(id);if(m&&m.classList.contains('show'))closeModal(id);});}});
})();
</script>
{% endblock %}
