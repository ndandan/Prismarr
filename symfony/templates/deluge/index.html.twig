            queued:      {{ 'qbittorrent.state.queued'|trans|json_encode|raw }},
            checking:    {{ 'qbittorrent.state.checking'|trans|json_encode|raw }},
            error:       {{ 'qbittorrent.state.error'|trans|json_encode|raw }},
            completed:   {{ 'qbittorrent.state.completed'|trans|json_encode|raw }},
            stalled:     {{ 'qbittorrent.state.stalled'|trans|json_encode|raw }},
