    /** Helper template : remplace tous les __KEY__ par les valeurs du map */
    function tpl(template, map) {
        var s = String(template == null ? '' : template);
        for (var k in map) {
            if (Object.prototype.hasOwnProperty.call(map, k)) {
                s = s.split('__' + k + '__').join(map[k]);
            }
        }
        return s;
    }

    /** Helper plural : choisit la chaîne ICU one/many et substitue le sentinel par le compte.
     *  Les variants _one sont pré-rendus avec count: 1, les _many avec count: 42 (sentinel),
     *  ICU substitue # → 1 / 42 au render Twig, on remplace 42 par le vrai count côté JS. */
    function plural(n, oneStr, manyStr) {
        if (n === 1) return String(oneStr == null ? n : oneStr);
        return String(manyStr == null ? n : manyStr).replace('42', n);
    }

    // ── Helpers ──────────────────────────────────────────────────────────────
    // Defer to the global locale-aware helpers from base.html.twig so qBit
    // sizes and speeds match the rest of the app (and the server-rendered
    // |prismarr_bytes / |prismarr_speed Twig output).
    function fmtSize(bytes) { return window.prismarrBytes(bytes); }
    function fmtSpeed(bytes) { return bytes > 0 ? window.prismarrBytes(bytes) + '/s' : '-'; }
    function fmtEta(sec) {
        if (!sec || sec >= 8640000) return '∞';
        var h = Math.floor(sec / 3600);
        var m = Math.round((sec % 3600) / 60);
        return tpl(QBT_I18N.eta_tpl, { H: h, M: (m < 10 ? '0' : '') + m });
    }
    function fmtDuration(sec) {
        if (!sec || sec < 0) return '-';
        var d = Math.floor(sec / 86400);
        var h = Math.floor((sec % 86400) / 3600);
        var m = Math.floor((sec % 3600) / 60);
        if (d > 0) return tpl(QBT_I18N.duration_d_tpl, { D: d, H: h });
        if (h > 0) return tpl(QBT_I18N.duration_h_tpl, { H: h, M: m });
        return tpl(QBT_I18N.duration_m_tpl, { M: m });
    }
    function fmtDate(ts) {
        if (!ts || ts < 0) return '-';
        var d = new Date(ts * 1000);
        var loc = (LOCALE === 'en') ? 'en-US' : 'fr-FR';
        return d.toLocaleDateString(loc) + ' ' + d.toLocaleTimeString(loc, {hour:'2-digit',minute:'2-digit'});
    }
    function escapeHtml(s) { return String(s == null ? '' : s).replace(/[&<>"']/g, function(c){ return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]; }); }

    var STATE_LABELS = QBT_I18N.state;
    var TRACKER_STATUS = {
        0: '<span class="badge bg-secondary-lt">' + escapeHtml(QBT_I18N.modal_detail.tracker_status['0']) + '</span>',
        1: '<span class="badge bg-warning-lt">'   + escapeHtml(QBT_I18N.modal_detail.tracker_status['1']) + '</span>',
        2: '<span class="badge bg-success-lt">'   + escapeHtml(QBT_I18N.modal_detail.tracker_status['2']) + '</span>',
        3: '<span class="badge bg-info-lt">'      + escapeHtml(QBT_I18N.modal_detail.tracker_status['3']) + '</span>',
        4: '<span class="badge bg-danger-lt">'    + escapeHtml(QBT_I18N.modal_detail.tracker_status['4']) + '</span>'
    };

    var RADARR_CATS = ['films', 'movies', 'radarr'];
    var SONARR_CATS = ['tv', 'tv-sonarr', 'series', 'sonarr'];

    /** Source unique pour le bouton Pause ou Reprendre d'une row (createRow + updateRow). */
    function buildPauseResumeBtn(hash, state) {
        var open = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">';
        if (state === 'paused') {
            return '<button class="btn btn-sm btn-ghost-success qbt-act" data-action="resume" data-hash="'+hash+'" title="'+escapeHtml(QBT_I18N.row.resume_title)+'">'+open+'<path d="M7 4v16l13-8z"/></svg></button>';
        }
        return '<button class="btn btn-sm btn-ghost-warning qbt-act" data-action="pause" data-hash="'+hash+'" title="'+escapeHtml(QBT_I18N.row.pause_title)+'">'+open+'<path d="M6 4h4v16H6z"/><path d="M14 4h4v16h-4z"/></svg></button>';
    }

    function buildCatTag(category, torrentName, hash) {
        var cat = (category || '').toLowerCase();
        var safeCat  = escapeHtml(category);
        var safeName = escapeHtml(torrentName || '');
        if (RADARR_CATS.indexOf(cat) !== -1) {
            return '<span class="qbt-tag qbt-tag-radarr qbt-cat-link" data-pipeline="radarr" data-name="' + safeName + '" data-hash="' + hash + '" title="' + escapeHtml(QBT_I18N.row.radarr_title) + '">'
                + '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="4"/></svg>'
                + safeCat + '</span>';
        }
        if (SONARR_CATS.indexOf(cat) !== -1) {
            return '<span class="qbt-tag qbt-tag-sonarr qbt-cat-link" data-pipeline="sonarr" data-name="' + safeName + '" data-hash="' + hash + '" title="' + escapeHtml(QBT_I18N.row.sonarr_title) + '">'
                + '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="6" width="18" height="12" rx="1"/><path d="M8 3l4 3 4-3"/></svg>'
                + safeCat + '</span>';
        }
        return '<span class="qbt-tag qbt-tag-generic">' + safeCat + '</span>';
    }

    function getIcoType(cat) {
        cat = (cat || '').toLowerCase();
        if (['films','movies','radarr'].indexOf(cat) !== -1) return 'movie';
        if (['tv','tv-sonarr','series','sonarr'].indexOf(cat) !== -1) return 'tv';
        return 'generic';
    }
    function getStateIcoSvg(state) {
        var open = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round">';
        switch (state) {
            case 'downloading': return open+'<path d="M12 4v13"/><path d="M6 11l6 6 6-6"/></svg>';
            case 'seeding':     return open+'<path d="M12 20V7"/><path d="M6 13l6-6 6 6"/></svg>';
            case 'paused':      return open+'<rect x="6" y="5" width="4" height="14" rx="1"/><rect x="14" y="5" width="4" height="14" rx="1"/></svg>';
            case 'completed':   return open.replace('2.3','2.5')+'<path d="M5 12l5 5L20 7"/></svg>';
            case 'stalled':     return open.replace('2.3','2')+'<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>';
            case 'error':       return open+'<path d="M12 9v4"/><path d="M12 17h.01"/><path d="M10.24 3.957l-8.422 14.06a1.989 1.989 0 0 0 1.7 2.983h16.845a1.989 1.989 0 0 0 1.7 -2.983l-8.423 -14.06a1.989 1.989 0 0 0 -3.4 0z"/></svg>';
            case 'queued':      return open.replace('2.3','2')+'<path d="M4 6h16M4 12h16M4 18h10"/></svg>';
            case 'checking':    return open.replace('2.3','2')+'<path d="M20 11a8.1 8.1 0 0 0-15.5-2m-.5-4v4h4"/><path d="M4 13a8.1 8.1 0 0 0 15.5 2m.5 4v-4h-4"/></svg>';
            case 'moving':      return open.replace('2.3','2')+'<path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg>';
            default:            return open.replace('2.3','2')+'<circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/></svg>';
        }
    }

    // ── API ─────────────────────────────────────────────────────────────────
    function qbtPost(url, body) {
        return fetch(url, { method:'POST', headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'}, body: JSON.stringify(body || {}) }).then(function(r){ return r.json(); });
    }

    // Wrapper avec feedback visuel : désactive le bouton + spinner + toast
    function qbtAction(btn, url, body, successMsg) {
        if (btn) {
            btn.disabled = true;
            btn.dataset.qbtOriginalHtml = btn.innerHTML;
            if (btn.offsetWidth > 40) {
                btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>';
            } else {
                btn.style.opacity = '.55';
            }
        }
        return qbtPost(url, body)
            .then(function(d){
                var ok = d && d.ok !== false && !d.error;
                if (window._prismarrToast) {
                    var errMsg = (d && d.error) ? d.error : QBT_I18N.toast.error_generic;
                    window._prismarrToast(
                        ok ? (successMsg || QBT_I18N.toast.action_sent) : tpl(QBT_I18N.toast.failed_tpl, { ERROR: errMsg }),
                        ok ? 'success' : 'danger'
                    );
                }
                return d;
            })
            .catch(function(){
                if (window._prismarrToast) window._prismarrToast(QBT_I18N.toast.network_error, 'danger');
            })
            .finally(function(){
                if (btn) {
                    btn.disabled = false;
                    if (btn.dataset.qbtOriginalHtml !== undefined) {
                        btn.innerHTML = btn.dataset.qbtOriginalHtml;
                        delete btn.dataset.qbtOriginalHtml;
                    }
                    btn.style.opacity = '';
                }
            });
    }

    // ── Helper Turbo-safe : remplace au lieu d'empiler ──────────────────────
    function bindDoc(event, key, handler) {
        var fullKey = '_prismarrQbt_' + key;
        if (window[fullKey]) document.removeEventListener(event, window[fullKey]);
        window[fullKey] = handler;
        document.addEventListener(event, handler);
    }

    // ── Pagination / tri / filtre — état partagé ───────────────────────────
    var pagState = {
        page:     1,
        perPage:  parseInt(localStorage.getItem('qbt_per_page') || '50', 10),
        sort:     localStorage.getItem('qbt_sort_field') || 'added',
        desc:     localStorage.getItem('qbt_sort_desc') !== '0',
        filter:   'all',
        search:   '',
        category: '',
    };

    // ── Refresh temps réel ──────────────────────────────────────────────────
    var REFRESH_INTERVAL = 3000; // 3s — compromis entre fluidité et charge qBit

    function startRefresh() {
        if (refreshTimer) clearInterval(refreshTimer);
        if (document.hidden) return;  // pas de poll si onglet masqué
        refreshTimer = setInterval(refreshData, REFRESH_INTERVAL);
    }
    function stopRefresh() {
        if (refreshTimer) { clearInterval(refreshTimer); refreshTimer = null; }
        if (refreshCtrl) { refreshCtrl.abort(); refreshCtrl = null; }
    }

    // Pause/reprend le polling selon la visibilité de l'onglet (Page Visibility API)
    bindDoc('visibilitychange', 'visibility', function() {
        if (document.hidden) {
            stopRefresh();
        } else {
            refreshData();   // rattrape un fetch à l'instant où on revient
            startRefresh();
        }
    });

    var refreshCtrl = null;
    function refreshData() {
        // Annule le fetch précédent s'il est encore en vol (évite empilement)
        if (refreshCtrl) refreshCtrl.abort();
        refreshCtrl = new AbortController();
        var q = new URLSearchParams({
            page: pagState.page,
            perPage: pagState.perPage,
            sort: pagState.sort,
            desc: pagState.desc ? '1' : '0',
            filter: pagState.filter,
            search: pagState.search,
            category: pagState.category,
        }).toString();
        fetch(BASE + '/api/torrents?' + q, { signal: refreshCtrl.signal, headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.error) return;
            updateStats(data.stats);
            updateList(data.torrents);
            updatePagination(data.pagination);
        })
        .catch(function() {});
    }

    // ── Tracking session ────────────────────────────────────────────────────
    var sessionStartTs = Date.now();
    var peakDl = 0, peakUp = 0;

    function fmtUptime(ms) {
        var s = Math.floor(ms / 1000);
        var h = Math.floor(s / 3600);
        var m = Math.floor((s % 3600) / 60);
        if (h > 0) return tpl(QBT_I18N.uptime.hm_tpl, { H: h, M: m });
        if (m > 0) return tpl(QBT_I18N.uptime.min_tpl, { M: m });
        return tpl(QBT_I18N.uptime.sec_tpl, { S: s });
    }

    function updateStats(s) {
        function set(id, val) { var el = document.getElementById(id); if (el) el.textContent = val; }
        set('qbt-stat-total', s.total); set('qbt-stat-dl', s.downloading); set('qbt-stat-seed', s.seeding);
        set('qbt-stat-paused', s.paused); set('qbt-stat-error', s.errored);
        // Semantic hues must be earned: orange/red only when the count is
        // nonzero, otherwise the numeral goes neutral like the total.
        function hue(id, n, c) { var el = document.getElementById(id); if (el) el.style.color = n > 0 ? c : 'var(--tblr-text-secondary)'; }
        hue('qbt-stat-paused', s.paused, '#f59e0b'); hue('qbt-stat-error', s.errored, '#ef4444');
        var dlEl = document.getElementById('qbt-speed-dl'); if (dlEl) dlEl.innerHTML = s.dl_speed > 0 ? ('&#8595; ' + fmtSpeed(s.dl_speed)) : '&nbsp;';
        var upEl = document.getElementById('qbt-speed-up'); if (upEl) upEl.innerHTML = s.up_speed > 0 ? ('&#8593; ' + fmtSpeed(s.up_speed)) : '&nbsp;';
        var dot = document.getElementById('qbt-conn-dot');
        if (dot) dot.className = 'qbt-connection ' + (s.connection === 'connected' ? 'connected' : s.connection === 'firewalled' ? 'firewalled' : 'disconnected');
        // Totaux globaux — uses the global locale-aware byte formatter
        // (defined in base.html.twig) so EN gets GB and FR gets Go.
        set('qbt-total-dl', window.prismarrBytes(s.dl_alltime || 0));
        set('qbt-total-up', window.prismarrBytes(s.up_alltime || 0));
        set('qbt-session-dl', window.prismarrBytes(s.dl_session || 0));
        set('qbt-session-up', window.prismarrBytes(s.up_session || 0));
        set('qbt-total-ratio', (s.global_ratio || 0).toFixed(2));
        set('qbt-free-space', window.prismarrBytes(s.free_space || 0));
        // Pics DL/UP
        if (s.dl_speed > peakDl) { peakDl = s.dl_speed; set('qbt-peak-dl', fmtSpeed(peakDl)); }
        if (s.up_speed > peakUp) { peakUp = s.up_speed; set('qbt-peak-up', fmtSpeed(peakUp)); }
        // Uptime session
        set('qbt-session-uptime', '· ' + fmtUptime(Date.now() - sessionStartTs));
    }

    function updateList(torrents) {
        var list = document.getElementById('qbt-list');
        if (!list) return;

        var existing = {};
        var rows = list.querySelectorAll('.qbt-torrent');
        for (var i = 0; i < rows.length; i++) existing[rows[i].dataset.hash] = rows[i];

        var keep = {};
        // 1) MAJ ou création en préservant l'ordre serveur
        var fragments = [];
        for (var j = 0; j < torrents.length; j++) {
            var t = torrents[j];
            keep[t.hash] = true;
            var row = existing[t.hash];
            if (row) {
                updateRow(row, t);
            } else {
                row = createRow(t);
            }
            var cb = row.querySelector('.qbt-check');
            if (cb) cb.checked = !!selectedHashes[t.hash];
            row.classList.toggle('selected', !!selectedHashes[t.hash]);
            fragments.push(row);
        }
        // 2) Supprimer ceux qui ne sont plus dans la page
        for (var hash in existing) {
            if (!keep[hash]) existing[hash].remove();
        }
        // 3) Réordonner en respectant l'ordre serveur (sans flash visuel)
        //    Optimisation : skip si l'ordre est déjà bon (zéro mutation DOM, zéro reflow)
        var needsReorder = false;
        for (var check = 0; check < fragments.length; check++) {
            if (list.children[check] !== fragments[check]) { needsReorder = true; break; }
        }
        if (needsReorder) {
            for (var k = 0; k < fragments.length; k++) list.appendChild(fragments[k]);
        }
        // Empty state
        var empty = document.getElementById('qbt-empty');
        if (empty) empty.style.display = torrents.length === 0 ? '' : 'none';
    }

    function updatePagination(p) {
        if (!p) return;
        var bar = document.getElementById('qbt-pagination-bar');
        var links = document.getElementById('qbt-pagination-links');
        var info = document.getElementById('qbt-page-info');
        var cnt  = document.getElementById('qbt-count');
        if (!bar || !links) return;

        pagState.page = p.page;
        bar.style.display = p.total > 0 ? 'flex' : 'none';

        var from = p.total === 0 ? 0 : ((p.page - 1) * p.perPage + 1);
        var to   = Math.min(p.page * p.perPage, p.total);
        if (info) info.textContent = tpl(QBT_I18N.pagination.info_tpl, { FROM: from, TO: to, TOTAL: p.total });
        if (cnt)  cnt.textContent  = plural(p.total, QBT_I18N.count.one, QBT_I18N.count.many);

        // Construction des liens avec ellipses
        var html = '';
        function liBtn(pg, label, opts) {
            opts = opts || {};
            var cls = 'page-item' + (opts.disabled ? ' disabled' : '') + (opts.active ? ' active' : '');
            var lbl = (label === undefined || label === null) ? pg : label;
            // <button> au lieu de <a> : pas d'interception Turbo
            return '<li class="' + cls + '"><button type="button" class="page-link" data-page="' + pg + '"' + (opts.disabled ? ' disabled' : '') + '>' + lbl + '</button></li>';
        }
        html += liBtn(Math.max(1, p.page - 1), '‹', { disabled: p.page <= 1 });
        var pages = [];
        var tp = p.totalPages;
        var cp = p.page;
        var push = function(n) { if (pages.indexOf(n) === -1 && n >= 1 && n <= tp) pages.push(n); };
        push(1); push(2); push(tp - 1); push(tp); push(cp - 1); push(cp); push(cp + 1);
        pages.sort(function(a,b){return a-b;});
        var prev = 0;
        for (var i = 0; i < pages.length; i++) {
            if (pages[i] - prev > 1) html += '<li class="page-item disabled"><span class="page-link">…</span></li>';
            html += liBtn(pages[i], null, { active: pages[i] === cp });
            prev = pages[i];
        }
        html += liBtn(Math.min(tp, p.page + 1), '›', { disabled: p.page >= tp });
        links.innerHTML = html;
    }

    function updateRow(row, t) {
        row.dataset.state = t.state;
        row.dataset.name = (t.name || '').toLowerCase();
        row.dataset.size = t.size;
        row.dataset.progress = t.progress;
        row.dataset.dlspeed = t.dlspeed;
        row.dataset.upspeed = t.upspeed;
        row.dataset.seeds = t.num_seeds;
        row.dataset.ratio = t.ratio || 0;
        row.dataset.added = t.added_on || 0;

        // icône de statut
        var ico = row.querySelector('.qbt-ico');
        if (ico && ico.dataset.state !== t.state) {
            ico.innerHTML = getStateIcoSvg(t.state);
            ico.title = STATE_LABELS[t.state] || t.state;
            ico.dataset.state = t.state;
        }

        // bar
        var bar = row.querySelector('.qbt-bar');
        if (bar) { bar.style.width = t.progress + '%'; bar.className = 'qbt-bar qbt-bar-' + t.state; }

        // stats line
        var statsLine = row.querySelector('.qbt-stats-line');
        if (statsLine) statsLine.innerHTML = buildStatsLine(t);

        // cellules mode tableau
        var cSize = row.querySelector('.qbt-cell-size'); if (cSize) cSize.textContent = fmtSize(t.size);
        var cProg = row.querySelector('.qbt-cell-progress'); if (cProg) cProg.innerHTML = '<div class="qbt-cell-progress-fill" style="width:' + t.progress + '%"></div><span>' + t.progress + '%</span>';
        var cDl   = row.querySelector('.qbt-cell-dl'); if (cDl) cDl.textContent = t.dlspeed > 0 ? fmtSpeed(t.dlspeed) : '—';
        var cUp   = row.querySelector('.qbt-cell-up'); if (cUp) cUp.textContent = t.upspeed > 0 ? fmtSpeed(t.upspeed) : '—';
        var cells = row.querySelectorAll('.qbt-table-cell');
        if (cells.length >= 6) {
            cells[4].textContent = t.num_seeds;
            cells[5].textContent = (t.ratio || 0).toFixed(2);
        }
        var cUploaded = row.querySelector('.qbt-cell-uploaded'); if (cUploaded) cUploaded.textContent = fmtSize(t.uploaded || 0);
        var cCompleted = row.querySelector('.qbt-cell-completed'); if (cCompleted) cCompleted.textContent = t.completion_on ? fmtShortDate(t.completion_on) : '—';

        // cellule compact
        var cPct = row.querySelector('.qbt-compact-pct'); if (cPct) cPct.textContent = t.progress + '%';

        // action button — remplace le 1er .qbt-act par le bon (Pause ou Reprendre) via source unique
        var actions = row.querySelector('.qbt-row-actions');
        if (actions) {
            var firstBtn = actions.querySelector('.qbt-act');
            var currentAction = firstBtn ? firstBtn.dataset.action : null;
            var expectedAction = t.state === 'paused' ? 'resume' : 'pause';
            if (firstBtn && currentAction !== expectedAction) {
                firstBtn.outerHTML = buildPauseResumeBtn(t.hash, t.state);
            }
        }
    }

    function fmtRelativeDate(ts) {
        if (!ts) return '—';
        var diff = Math.floor(Date.now() / 1000) - ts;
        if (diff < 60) return QBT_I18N.date.just_now;
        if (diff < 3600)    return tpl(QBT_I18N.date.minutes_ago_tpl, { N: Math.floor(diff / 60) });
        if (diff < 86400)   return tpl(QBT_I18N.date.hours_ago_tpl,   { N: Math.floor(diff / 3600) });
        if (diff < 2592000) return tpl(QBT_I18N.date.days_ago_tpl,    { N: Math.floor(diff / 86400) });
        if (diff < 31536000) return tpl(QBT_I18N.date.months_ago_tpl, { N: Math.floor(diff / 2592000) });
        var years = Math.floor(diff / 31536000);
        return plural(years, QBT_I18N.date.years_ago_one, QBT_I18N.date.years_ago_many);
    }
    function fmtShortDate(ts) {
        if (!ts) return '—';
        var d = new Date(ts * 1000);
        return ('0' + d.getDate()).slice(-2) + '/' + ('0' + (d.getMonth() + 1)).slice(-2) + '/' + String(d.getFullYear()).slice(-2);
    }
    function fmtLongDate(ts) {
        if (!ts) return '—';
        var d = new Date(ts * 1000);
        return ('0' + d.getDate()).slice(-2) + '/' + ('0' + (d.getMonth() + 1)).slice(-2) + '/' + d.getFullYear()
            + ' ' + ('0' + d.getHours()).slice(-2) + ':' + ('0' + d.getMinutes()).slice(-2);
    }

    function buildStatsLine(t) {
        var ratio = (t.ratio || 0).toFixed(2);
        var leech = t.num_leechs || 0;
        var html = '<span class="item"><strong>' + t.progress + '%</strong></span>'
            + '<span class="sep"></span>'
            + '<span class="item">' + fmtSize(t.size) + '</span>'
            + '<span class="sep"></span>'
            + '<span class="item">' + (STATE_LABELS[t.state] || t.state) + '</span>';
        if (t.dlspeed > 0) html += '<span class="sep"></span><span class="item dl-speed">&#8595; ' + fmtSpeed(t.dlspeed) + '</span>';
        if (t.upspeed > 0) html += '<span class="sep"></span><span class="item up-speed">&#8593; ' + fmtSpeed(t.upspeed) + '</span>';
        if (t.state === 'downloading' && t.eta < 8640000) html += '<span class="sep"></span><span class="item">' + {{ ico.icon('clock', '', 14)|json_encode|raw }} + ' ' + fmtEta(t.eta) + '</span>';
        html += '<span class="sep"></span><span class="item" title="' + escapeHtml(QBT_I18N.row.seeds_leech) + '">' + {{ ico.icon('seeding', '', 14)|json_encode|raw }} + ' ' + t.num_seeds + '/' + leech + '</span>';
        html += '<span class="sep"></span><span class="item" title="' + escapeHtml(QBT_I18N.row.ratio_title) + '">' + {{ ico.icon('scale', '', 14)|json_encode|raw }} + ' ' + ratio + '</span>';
        if (t.added_on) {
            var addedTitle = tpl(QBT_I18N.row.added_title_tpl, { DATE: fmtLongDate(t.added_on) });
            html += '<span class="sep"></span><span class="item" title="' + escapeHtml(addedTitle) + '">' + {{ ico.icon('calendar', '', 14)|json_encode|raw }} + ' ' + fmtRelativeDate(t.added_on) + '</span>';
        }
        return html;
    }

    function createRow(t) {
        var div = document.createElement('div');
        div.className = 'qbt-torrent';
        div.dataset.hash = t.hash;
        div.dataset.state = t.state;
        div.dataset.name = (t.name || '').toLowerCase();
        div.dataset.cat = (t.category || '').toLowerCase();
        div.dataset.size = t.size;
        div.dataset.progress = t.progress;
        div.dataset.dlspeed = t.dlspeed;
        div.dataset.upspeed = t.upspeed;
        div.dataset.seeds = t.num_seeds;
        div.dataset.ratio = t.ratio || 0;
        div.dataset.added = t.added_on || 0;

        var ico = getStateIcoSvg(t.state);
        var catTag = t.category ? buildCatTag(t.category, t.name, t.hash) : '';
        var pauseResume = buildPauseResumeBtn(t.hash, t.state);

        div.innerHTML = '<input type="checkbox" class="form-check-input qbt-check" data-hash="'+t.hash+'">'
            + '<div class="qbt-ico" title="'+(STATE_LABELS[t.state]||t.state)+'">'+ico+'</div>'
            + '<div class="qbt-main">'
            +   '<div class="qbt-name-row"><div class="qbt-name" title="'+escapeHtml(t.name)+'">'+escapeHtml(t.name)+'</div>'+catTag+'</div>'
            +   '<div class="qbt-bar-wrap"><div class="qbt-bar qbt-bar-'+t.state+'" style="width:'+t.progress+'%"></div></div>'
            +   '<div class="qbt-stats-line">' + buildStatsLine(t) + '</div>'
            + '</div>'
            + '<div class="qbt-table-cell qbt-cell-size">' + fmtSize(t.size) + '</div>'
            + '<div class="qbt-table-cell qbt-cell-progress"><div class="qbt-cell-progress-fill" style="width:' + t.progress + '%"></div><span>' + t.progress + '%</span></div>'
            + '<div class="qbt-table-cell qbt-cell-dl">' + (t.dlspeed > 0 ? fmtSpeed(t.dlspeed) : '—') + '</div>'
            + '<div class="qbt-table-cell qbt-cell-up">' + (t.upspeed > 0 ? fmtSpeed(t.upspeed) : '—') + '</div>'
            + '<div class="qbt-table-cell">' + t.num_seeds + '</div>'
            + '<div class="qbt-table-cell">' + (t.ratio || 0).toFixed(2) + '</div>'
            + '<div class="qbt-table-cell qbt-cell-uploaded">' + fmtSize(t.uploaded || 0) + '</div>'
            + '<div class="qbt-table-cell qbt-cell-completed">' + (t.completion_on ? fmtShortDate(t.completion_on) : '—') + '</div>'
            + '<div class="qbt-table-cell qbt-cell-added" title="' + fmtShortDate(t.added_on) + '">' + fmtShortDate(t.added_on) + '</div>'
            + '<div class="qbt-compact-pct">' + t.progress + '%</div>'
            + '<div class="qbt-row-actions">'+pauseResume
            +   '<button class="btn btn-sm btn-ghost-danger qbt-act" data-action="delete" data-hash="'+t.hash+'" data-name="'+escapeHtml(t.name)+'" title="'+escapeHtml(QBT_I18N.row.delete_title)+'"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 7h16"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M5 7l1 12a2 2 0 002 2h8a2 2 0 002-2l1-12"/><path d="M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3"/></svg></button>'
            + '</div>';
        return div;
    }

    // ── Vue & tri ───────────────────────────────────────────────────────────
    var currentView = localStorage.getItem('qbt_view') || 'list';

    function applyView(view) {
        currentView = view;
        localStorage.setItem('qbt_view', view);
        var list = document.getElementById('qbt-list');
        if (list) list.dataset.view = view;
        var hdr = document.getElementById('qbt-table-header');
        if (hdr) hdr.classList.toggle('show', view === 'table');
        var btns = document.querySelectorAll('.view-btn');
        for (var i = 0; i < btns.length; i++) btns[i].classList.toggle('active', btns[i].dataset.view === view);
        syncSortUI();
    }

    function syncSortUI() {
        // Header tableau
        var sortBtns = document.querySelectorAll('#qbt-table-header .qbt-sort');
        for (var j = 0; j < sortBtns.length; j++) {
            sortBtns[j].classList.toggle('active', sortBtns[j].dataset.sort === pagState.sort);
            sortBtns[j].classList.toggle('desc', sortBtns[j].dataset.sort === pagState.sort && pagState.desc);
        }
        // Dropdown liste
        var sel = document.getElementById('qbt-list-sort');
        if (sel) sel.value = pagState.sort + '|' + (pagState.desc ? '1' : '0');
        // Dropdown perPage
        var pp = document.getElementById('qbt-per-page');
        if (pp) pp.value = String(pagState.perPage);
    }

    function setSort(field, desc) {
        pagState.sort = field;
        pagState.desc = !!desc;
        pagState.page = 1;
        localStorage.setItem('qbt_sort_field', field);
        localStorage.setItem('qbt_sort_desc', desc ? '1' : '0');
        syncSortUI();
        refreshData();
    }

    bindDoc('click', 'viewSortPag', function(e) {
        var vb = e.target.closest('.view-btn');
        if (vb) { applyView(vb.dataset.view); return; }
        var sb = e.target.closest('#qbt-table-header .qbt-sort');
        if (sb) {
            var f = sb.dataset.sort;
            if (pagState.sort === f) setSort(f, !pagState.desc);
            else setSort(f, f !== 'name');
            return;
        }
        var pg = e.target.closest('#qbt-pagination-links .page-link');
        if (pg) {
            var li = pg.closest('.page-item');
            if (!li || li.classList.contains('disabled') || li.classList.contains('active')) return;
            var n = parseInt(pg.dataset.page, 10);
            if (n > 0 && n !== pagState.page) { pagState.page = n; refreshData(); window.scrollTo({top:0, behavior:'smooth'}); }
        }
    });

    bindDoc('change', 'listSort', function(e) {
        if (e.target && e.target.id === 'qbt-list-sort') {
            var parts = e.target.value.split('|');
            setSort(parts[0], parts[1] === '1');
        }
    });

    // ── Filtres ─────────────────────────────────────────────────────────────
    var filterBtns = document.querySelectorAll('.qbt-filter-btn');
    for (var i = 0; i < filterBtns.length; i++) {
        // onclick (pas addEventListener) — évite les doublons après re-exec Turbo
        filterBtns[i].onclick = function(){
            for (var j = 0; j < filterBtns.length; j++) filterBtns[j].classList.remove('active');
            this.classList.add('active');
            currentFilter = this.dataset.filter;
            pagState.filter = currentFilter;
            pagState.page = 1;
            refreshData();
        };
    }

    var searchInput = document.getElementById('qbt-search');
    if (searchInput) {
        var searchTimeout;
        searchInput.oninput = function() {
            clearTimeout(searchTimeout);
            var val = searchInput.value;
            searchTimeout = setTimeout(function(){
                pagState.search = val;
                pagState.page = 1;
                refreshData();
            }, 250);
        };
    }

    // Sélecteur perPage + filtres catégorie/tag
    bindDoc('change', 'perPage', function(e) {
        if (!e.target) return;
        if (e.target.id === 'qbt-per-page') {
            pagState.perPage = parseInt(e.target.value, 10) || 50;
            pagState.page = 1;
            localStorage.setItem('qbt_per_page', String(pagState.perPage));
            refreshData();
        } else if (e.target.id === 'qbt-cat-filter') {
            pagState.category = e.target.value;
            pagState.page = 1;
            refreshData();
        }
    });

    // ── Actions par torrent ─────────────────────────────────────────────────
    bindDoc('click', 'torrentActs', function(e) {
        var btn = e.target.closest('.qbt-act');
        if (!btn) return;
        e.stopPropagation();
        var action = btn.dataset.action;
        var hash = btn.dataset.hash;

        if (action === 'pause') qbtAction(btn, BASE + '/api/torrent/' + hash + '/pause', null, QBT_I18N.toast.paused).then(refreshData);
        else if (action === 'resume') qbtAction(btn, BASE + '/api/torrent/' + hash + '/resume', null, QBT_I18N.toast.resumed).then(refreshData);
        else if (action === 'delete') {
            deleteTarget = { hashes: [hash], mode: 'single' };
            var msg = document.getElementById('qbt-delete-msg');
            if (msg) msg.textContent = tpl(QBT_I18N.modal_delete.msg_named_tpl, { NAME: (btn.dataset.name || hash).substring(0, 60) });
            document.getElementById('qbt-delete-files').checked = false;
            document.getElementById('qbt-delete-trigger').click();
        }
    });

    // ── Badge Radarr/Sonarr : résolution + redirection ──────────────────────
    bindDoc('click', 'catLink', function(e) {
        var tag = e.target.closest('.qbt-cat-link');
        if (!tag) return;
        e.stopPropagation();
        e.preventDefault();
        var pipeline = tag.dataset.pipeline;
        var hash = tag.dataset.hash;
        var name = tag.dataset.name;
        if (!pipeline || !hash) return;
        // Feedback visuel
        var original = tag.innerHTML;
        tag.innerHTML = '<span class="spinner-border spinner-border-sm" style="width:10px;height:10px;border-width:1px;"></span> ' + escapeHtml(QBT_I18N.toast.cat_resolve_search);
        fetch(BASE + '/api/resolve/' + pipeline + '/' + hash, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(function(r){ return r.json(); })
            .then(function(d){
                if (d && d.found && d.url) {
                    window.location.href = d.url;
                } else {
                    tag.innerHTML = original;
                    if (window._prismarrToast) window._prismarrToast(tpl(QBT_I18N.toast.cat_resolve_no_match_tpl, { NAME: (name || '').substring(0, 50) }), 'warning');
                }
            })
            .catch(function(){
                tag.innerHTML = original;
                if (window._prismarrToast) window._prismarrToast(QBT_I18N.toast.cat_resolve_error, 'danger');
            });
    });

    // ── Clic ligne = modal détail ───────────────────────────────────────────
    bindDoc('click', 'rowDetail', function(e) {
        var row = e.target.closest('.qbt-torrent');
        if (!row) return;
        if (e.target.closest('.qbt-act') || e.target.closest('.qbt-check') || e.target.closest('.qbt-cat-link') || e.target.tagName === 'INPUT') return;
        openDetail(row.dataset.hash);
    });

    function openDetail(hash) {
        document.getElementById('qbt-detail-title').textContent = QBT_I18N.modal_detail.loading;
        document.getElementById('qbt-detail-props').innerHTML = '<div class="col-12 text-center text-muted py-3">' + escapeHtml(QBT_I18N.modal_detail.loading) + '</div>';
        document.getElementById('qbt-detail-files').innerHTML = '';
        document.getElementById('qbt-detail-trackers').innerHTML = '';
        document.getElementById('qbt-detail-peers').innerHTML = '';
        document.getElementById('qbt-detail-actions').innerHTML = '';
        document.getElementById('qbt-detail-trigger').click();

        fetch(BASE + '/api/torrent/' + hash, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(function(r) { return r.json(); })
        .then(function(data) { renderDetail(hash, data); })
        .catch(function() { document.getElementById('qbt-detail-props').innerHTML = '<div class="col-12 text-center text-danger py-3">' + escapeHtml(QBT_I18N.modal_detail.error_load) + '</div>'; });
    }

    function renderDetail(hash, data) {
        var p = data.properties || {};
        document.getElementById('qbt-detail-title').textContent = p.name || hash;

        // ── Propriétés simplifiées ──
        var pp = QBT_I18N.modal_detail.props;
        var props = [
            [pp.downloaded, fmtSize(p.total_downloaded || 0)],
            [pp.uploaded,   fmtSize(p.total_uploaded || 0)],
            [pp.ratio,      (p.share_ratio || 0).toFixed(2)],
            [pp.dl_speed,   fmtSpeed(p.dl_speed || 0)],
            [pp.up_speed,   fmtSpeed(p.up_speed || 0)],
            [pp.eta,        (p.eta || 0) >= 8640000 ? '-' : fmtDuration(p.eta)],
            [pp.seeds,      (p.seeds || 0) + ' / ' + (p.seeds_total || 0)],
            [pp.peers,      (p.peers || 0) + ' / ' + (p.peers_total || 0)],
            [pp.total_size, fmtSize(p.total_size || 0)],
            [pp.added,      fmtDate(p.addition_date)],
            [pp.completed,  fmtDate(p.completion_date)],
        ];
        var html = '';
        for (var i = 0; i < props.length; i++) {
            html += '<div class="col-6 col-md-4"><div class="qbt-prop-card"><div class="qbt-prop-label">' + escapeHtml(props[i][0]) + '</div><div class="qbt-prop-value">' + props[i][1] + '</div></div></div>';
        }
        if (p.save_path) {
            html += '<div class="col-12"><div class="qbt-prop-card"><div class="qbt-prop-label">' + escapeHtml(pp.save_path) + '</div><div class="qbt-prop-value" style="font-family:monospace;font-size:.75rem;word-break:break-all;">' + escapeHtml(p.save_path) + '</div></div></div>';
        }
        document.getElementById('qbt-detail-props').innerHTML = html;

        // ── Fichiers ──
        var filesEl = document.getElementById('qbt-detail-files');
        if (data.files && data.files.length) {
            var fhtml = '';
            for (var fi = 0; fi < data.files.length; fi++) {
                var f = data.files[fi];
                var fprog = Math.round((f.progress || 0) * 100);
                var fname = (f.name || '').split('/').pop();
                fhtml += '<tr class="qbt-file-row" data-file-id="' + f.index + '">'
                    + '<td title="' + escapeHtml(f.name || '') + '">' + escapeHtml(fname) + '</td>'
                    + '<td>' + fmtSize(f.size || 0) + '</td>'
                    + '<td><div class="d-flex align-items-center gap-2"><div class="qbt-mini-bar"><div style="width:' + fprog + '%"></div></div><span style="font-size:.7rem;">' + fprog + '%</span></div></td>'
                    + '</tr>';
            }
            filesEl.innerHTML = fhtml;
        } else {
            filesEl.innerHTML = '<tr><td colspan="3" class="text-center text-muted">' + escapeHtml(QBT_I18N.modal_detail.files_empty) + '</td></tr>';
        }

        // ── Trackers ──
        var trackersEl = document.getElementById('qbt-detail-trackers');
        // TRACKER_STATUS hissé au module-level (éviter redéclaration à chaque ouverture de modal)
        if (data.trackers && data.trackers.length) {
            var thtml = '';
            for (var ti = 0; ti < data.trackers.length; ti++) {
                var tr = data.trackers[ti];
                if (tr.url === '** [DHT] **' || tr.url === '** [PeX] **' || tr.url === '** [LSD] **') continue;
                thtml += '<tr class="qbt-tracker-row">'
                    + '<td class="text-truncate" style="max-width:320px;" title="' + escapeHtml(tr.url) + '">' + escapeHtml(tr.url) + '</td>'
                    + '<td>' + (TRACKER_STATUS[tr.status] || escapeHtml(tr.status)) + '</td>'
                    + '<td>' + (tr.num_seeds || 0) + '</td>'
                    + '<td>' + (tr.num_leeches || 0) + '</td>'
                    + '</tr>';
            }
            trackersEl.innerHTML = thtml || '<tr><td colspan="4" class="text-center text-muted">' + escapeHtml(QBT_I18N.modal_detail.trackers_empty) + '</td></tr>';
        }

        // ── Peers ──
        var peersEl = document.getElementById('qbt-detail-peers');
        if (data.peers && data.peers.length) {
            var phtml = '';
            for (var pi = 0; pi < data.peers.length; pi++) {
                var peer = data.peers[pi];
                var ipPort = escapeHtml((peer.ip || '') + ':' + (peer.port || ''));
                var cc     = escapeHtml(peer.country_code || '');
                var prog   = parseFloat(peer.progress) || 0;
                phtml += '<tr class="qbt-peer-row">'
                    + '<td>' + ipPort + (cc ? ' <span class="text-muted">(' + cc + ')</span>' : '') + '</td>'
                    + '<td class="text-truncate" style="max-width:180px;">' + escapeHtml(peer.client || '-') + '</td>'
                    + '<td>' + prog + '%</td>'
                    + '<td>' + fmtSpeed(peer.dl_speed) + '</td>'
                    + '<td>' + fmtSpeed(peer.up_speed) + '</td>'
                    + '</tr>';
            }
            peersEl.innerHTML = phtml;
        } else {
            peersEl.innerHTML = '<tr><td colspan="5" class="text-center text-muted">' + escapeHtml(QBT_I18N.modal_detail.peers_empty) + '</td></tr>';
        }

        // ── Actions — boutons conditionnés selon l'état du torrent ──
        var row = document.querySelector('.qbt-torrent[data-hash="'+hash+'"]');
        var state = row ? row.dataset.state : '';
        var pauseResumeBtn = state === 'paused'
            ? '<button class="btn btn-sm btn-outline-success qbt-detail-act" data-action="resume" data-hash="'+hash+'"><svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 4v16l13-8z"/></svg> '+escapeHtml(QBT_I18N.modal_detail.actions.resume)+'</button>'
            : '<button class="btn btn-sm btn-outline-warning qbt-detail-act" data-action="pause" data-hash="'+hash+'"><svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 4h4v16H6z"/><path d="M14 4h4v16h-4z"/></svg> '+escapeHtml(QBT_I18N.modal_detail.actions.pause)+'</button>';
        document.getElementById('qbt-detail-actions').innerHTML = ''
            + pauseResumeBtn
            + '<button class="btn btn-sm btn-outline-info qbt-detail-act" data-action="recheck" data-hash="'+hash+'"><svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5L20 7"/></svg> '+escapeHtml(QBT_I18N.modal_detail.actions.recheck)+'</button>'
            + '<button class="btn btn-sm btn-outline-secondary qbt-detail-act" data-action="reannounce" data-hash="'+hash+'"><svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 1 0 9 -9m-9 9l3 -3m-3 3l3 3"/></svg> '+escapeHtml(QBT_I18N.modal_detail.actions.reannounce)+'</button>'
            + '<button class="btn btn-sm btn-outline-danger qbt-detail-act ms-auto" data-action="delete" data-hash="'+hash+'"><svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 7h16"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M5 7l1 12a2 2 0 002 2h8a2 2 0 002-2l1-12"/></svg> '+escapeHtml(QBT_I18N.modal_detail.actions['delete'])+'</button>';
    }

    // ── Actions modal détail ────────────────────────────────────────────────
    bindDoc('click', 'detailActs', function(e) {
        var btn = e.target.closest('.qbt-detail-act');
        if (!btn) return;
        var action = btn.dataset.action;
        var hash = btn.dataset.hash;

        if (action === 'delete') {
            deleteTarget = { hashes: [hash], mode: 'single' };
            document.getElementById('qbt-delete-msg').textContent = QBT_I18N.modal_delete.msg_single;
            document.getElementById('qbt-delete-files').checked = false;
            document.getElementById('qbt-delete-trigger').click();
            return;
        }
        var labels = { pause: QBT_I18N.toast.paused, resume: QBT_I18N.toast.resumed, recheck: QBT_I18N.toast.recheck_started, reannounce: QBT_I18N.toast.reannounce_sent };
        qbtAction(btn, BASE + '/api/torrent/' + hash + '/' + action, null, labels[action] || QBT_I18N.toast.action_sent).then(refreshData);
    });

    // ── Sélection multiple ──────────────────────────────────────────────────
    var selectAll = document.getElementById('qbt-select-all');
    if (selectAll) selectAll.onchange = function() {
        var checked = this.checked;
        var cbs = document.querySelectorAll('.qbt-check');
        selectedHashes = {};
        for (var i = 0; i < cbs.length; i++) {
            var row = cbs[i].closest('.qbt-torrent');
            if (row && row.style.display !== 'none') {
                cbs[i].checked = checked;
                if (checked) selectedHashes[cbs[i].dataset.hash] = true;
                row.classList.toggle('selected', checked);
            }
        }
        updateBulkBar();
    };

    bindDoc('change', 'rowCheck', function(e) {
        if (!e.target.classList.contains('qbt-check')) return;
        var hash = e.target.dataset.hash;
        if (e.target.checked) selectedHashes[hash] = true; else delete selectedHashes[hash];
        var row = e.target.closest('.qbt-torrent');
        if (row) row.classList.toggle('selected', e.target.checked);
        updateBulkBar();
    });

    function updateBulkBar() {
        var count = Object.keys(selectedHashes).length;
        var bar = document.getElementById('qbt-bulk-bar');
        var lbl = document.getElementById('qbt-bulk-count-label');
        if (lbl) lbl.textContent = plural(count, QBT_I18N.bulk.sel_one, QBT_I18N.bulk.sel_many);
        if (bar) bar.classList.toggle('show', count > 0);
    }

    function getSelectedHashes() { return Object.keys(selectedHashes); }

    function bindBulk(id, fn) { var el = document.getElementById(id); if (el) el.onclick = function(e){ fn(e.currentTarget); }; }
    bindBulk('qbt-bulk-resume', function(btn){ var h = getSelectedHashes(); qbtAction(btn, BASE + '/api/bulk/resume',  { hashes: h }, plural(h.length, QBT_I18N.toast.bulk_resumed_one, QBT_I18N.toast.bulk_resumed_many)).then(refreshData); });
    bindBulk('qbt-bulk-pause',  function(btn){ var h = getSelectedHashes(); qbtAction(btn, BASE + '/api/bulk/pause',   { hashes: h }, plural(h.length, QBT_I18N.toast.bulk_paused_one, QBT_I18N.toast.bulk_paused_many)).then(refreshData); });
    bindBulk('qbt-bulk-recheck',function(btn){ var h = getSelectedHashes(); qbtAction(btn, BASE + '/api/bulk/recheck', { hashes: h }, plural(h.length, QBT_I18N.toast.bulk_recheck_one, QBT_I18N.toast.bulk_recheck_many)).then(refreshData); });
    bindBulk('qbt-bulk-delete', function(){
        deleteTarget = { hashes: getSelectedHashes(), mode: 'bulk' };
        document.getElementById('qbt-delete-msg').textContent = plural(deleteTarget.hashes.length, QBT_I18N.modal_delete.msg_bulk_one, QBT_I18N.modal_delete.msg_bulk_many);
        document.getElementById('qbt-delete-files').checked = false;
        document.getElementById('qbt-delete-trigger').click();
    });
    bindBulk('qbt-bulk-clear', function(){
        selectedHashes = {};
        var cbs = document.querySelectorAll('.qbt-check');
        for (var i = 0; i < cbs.length; i++) { cbs[i].checked = false; cbs[i].closest('.qbt-torrent').classList.remove('selected'); }
        if (selectAll) selectAll.checked = false;
        updateBulkBar();
    });

    // ── Delete confirm ──────────────────────────────────────────────────────
    var deleteConfirm = document.getElementById('qbt-delete-confirm');
    if (deleteConfirm) deleteConfirm.onclick = function(e) {
        var btn = e.currentTarget;
        var deleteFiles = document.getElementById('qbt-delete-files').checked;
        var url = deleteTarget.mode === 'bulk' ? BASE + '/api/bulk/delete' : BASE + '/api/torrent/' + deleteTarget.hashes[0] + '/delete';
        var body = deleteTarget.mode === 'bulk' ? { hashes: deleteTarget.hashes, deleteFiles: deleteFiles } : { deleteFiles: deleteFiles };
        var msg = plural(deleteTarget.hashes.length, QBT_I18N.toast.bulk_deleted_one, QBT_I18N.toast.bulk_deleted_many)
            + (deleteFiles ? QBT_I18N.toast.bulk_deleted_with_files_suffix : '');

        qbtAction(btn, url, body, msg).then(function() {
            document.querySelector('#qbt-modal-delete .btn-close').click();
            for (var i = 0; i < deleteTarget.hashes.length; i++) {
                var row = document.querySelector('.qbt-torrent[data-hash="' + deleteTarget.hashes[i] + '"]');
                if (row) row.style.opacity = '0';
                delete selectedHashes[deleteTarget.hashes[i]];
            }
            updateBulkBar();
            setTimeout(function() {
                for (var i = 0; i < deleteTarget.hashes.length; i++) {
                    var row = document.querySelector('.qbt-torrent[data-hash="' + deleteTarget.hashes[i] + '"]');
                    if (row) row.remove();
                }
                refreshData();
            }, 300);
        });
    };

    // ── Pause all / Resume all ──────────────────────────────────────────────
    bindBulk('qbt-btn-pause-all',  function(btn){ qbtAction(btn, BASE + '/api/pause-all',  null, QBT_I18N.toast.pause_all).then(refreshData); });
    bindBulk('qbt-btn-resume-all', function(btn){ qbtAction(btn, BASE + '/api/resume-all', null, QBT_I18N.toast.resume_all).then(refreshData); });

    // ── Ajout torrent ───────────────────────────────────────────────────────
    // ── Ajouter torrent : reset URL + fichiers ──
    bindBulk('qbt-btn-add', function(){
        document.getElementById('qbt-add-urls').value = '';
        pendingTorrentFiles = [];
        renderPendingFiles();
        document.getElementById('qbt-add-trigger').click();
    });

    // ── Drag-drop + input file (pattern Turbo-safe : re-bind à chaque exec) ──
    var pendingTorrentFiles = [];
    var dropZone = document.getElementById('qbt-drop-zone');
    var fileInput = document.getElementById('qbt-file-input');

    var FILE_REMOVE_TITLE = {{ 'qbittorrent.modal_add.file_remove_title'|trans|json_encode|raw }};

    function renderPendingFiles() {
        var ul = document.getElementById('qbt-drop-files');
        if (!ul) return;
        if (!pendingTorrentFiles.length) { ul.innerHTML = ''; return; }
        var html = '';
        pendingTorrentFiles.forEach(function(f, i){
            html += '<li>' + {{ ico.icon('file', '', 14)|json_encode|raw }} + ' <strong>' + escapeHtml(f.name) + '</strong> <span class="text-muted" style="font-size:.7rem;">(' + fmtSize(f.size) + ')</span><span class="remove" data-i="' + i + '" title="' + escapeHtml(FILE_REMOVE_TITLE) + '">×</span></li>';
        });
        ul.innerHTML = html;
    }

    function addFiles(fileList) {
        for (var i = 0; i < fileList.length; i++) {
            var f = fileList[i];
            if (f.name.toLowerCase().endsWith('.torrent')) pendingTorrentFiles.push(f);
            else if (window._prismarrToast) window._prismarrToast(tpl(QBT_I18N.toast.file_ignored_tpl, { NAME: f.name }), 'warning');
        }
        renderPendingFiles();
    }

    if (dropZone && fileInput) {
        dropZone.onclick = function(e) { if (!e.target.classList.contains('remove')) fileInput.click(); };
        fileInput.onchange = function() { addFiles(fileInput.files); fileInput.value = ''; };
        dropZone.ondragover = function(e) { e.preventDefault(); dropZone.classList.add('drag-over'); };
        dropZone.ondragleave = function() { dropZone.classList.remove('drag-over'); };
        dropZone.ondrop = function(e) {
            e.preventDefault();
            dropZone.classList.remove('drag-over');
            if (e.dataTransfer && e.dataTransfer.files) addFiles(e.dataTransfer.files);
        };
    }
    bindDoc('click', 'dropFileRemove', function(e) {
        var rm = e.target.closest('#qbt-drop-files .remove');
        if (!rm) return;
        pendingTorrentFiles.splice(parseInt(rm.dataset.i, 10), 1);
        renderPendingFiles();
    });

    var addSubmitInFlight = false;
    bindBulk('qbt-add-submit', function(btn){
        if (addSubmitInFlight) return;  // garde anti double-submit globale

        var urls = document.getElementById('qbt-add-urls').value.trim();
        var savepath = document.getElementById('deluge-add-savepath').value.trim();
        var paused = document.getElementById('qbt-add-paused').value === 'true';
        var hasFiles = pendingTorrentFiles.length > 0;
        var hasUrls = urls.length > 0;

        if (!hasFiles && !hasUrls) {
            if (window._prismarrToast) window._prismarrToast(QBT_I18N.toast.add_required, 'warning');
            return;
        }

        addSubmitInFlight = true;
        if (btn) { btn.disabled = true; btn.dataset.qbtOriginalHtml = btn.innerHTML; btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>'; }

        var restoreBtn = function() {
            addSubmitInFlight = false;
            if (btn) { btn.disabled = false; if (btn.dataset.qbtOriginalHtml) { btn.innerHTML = btn.dataset.qbtOriginalHtml; delete btn.dataset.qbtOriginalHtml; } }
        };

        var closeAndRefresh = function() {
            document.querySelector('#qbt-modal-add .btn-close').click();
            pendingTorrentFiles = []; renderPendingFiles();
            setTimeout(refreshData, 1000);
        };

        // 1) Envoi des fichiers d'abord si présents
        var filesDone = Promise.resolve(true);
        if (hasFiles) {
            var fd = new FormData();
            pendingTorrentFiles.forEach(function(f){ fd.append('torrents[]', f); });
            if (savepath) fd.append('savepath', savepath);
            if (paused)   fd.append('paused', 'true');
            filesDone = fetch(BASE + '/api/add-file', { method: 'POST', body: fd })
                .then(function(r){ return r.json(); })
                .then(function(d){
                    if (window._prismarrToast) {
                        var msg = (d && d.ok)
                            ? plural(d.count, QBT_I18N.toast.add_files_ok_one, QBT_I18N.toast.add_files_ok_many)
                            : QBT_I18N.toast.add_files_ko;
                        window._prismarrToast(msg, d && d.ok ? 'success' : 'danger');
                    }
                    return d && d.ok;
                })
                .catch(function(){ return false; });
        }

        filesDone.then(function(filesOk){
            // 2) Puis les URLs si présentes
            if (hasUrls) {
                return qbtPost(BASE + '/api/add', { urls: urls, savepath: savepath || null, paused: paused })
                    .then(function(d){
                        var ok = d && d.ok;
                        var msg = ok ? QBT_I18N.toast.add_url_ok : ((d && d.error) ? d.error : QBT_I18N.toast.add_url_ko);
                        if (window._prismarrToast) window._prismarrToast(msg, ok ? 'success' : 'danger');
                        return ok;
                    })
                    .catch(function(){ return false; });
            }
            return filesOk;
        }).then(function(ok){
            restoreBtn();
            if (ok) closeAndRefresh();
        });
    });

    // ── Init ────────────────────────────────────────────────────────────────
    applyView(currentView);
    syncSortUI();
    // Aligne l'état avec le filtre actif (.qbt-filter-btn.active)
    var activeFilter = document.querySelector('.qbt-filter-btn.active');
    if (activeFilter) pagState.filter = activeFilter.dataset.filter || 'all';
    refreshData();    // premier fetch immédiat (applique pagination+tri+filtre serveur)
    startRefresh();
    var initDl = {{ (stats.dl_speed ?? 0)|json_encode|raw }};
    var initUp = {{ (stats.up_speed ?? 0)|json_encode|raw }};
    var speedDl = document.getElementById('qbt-speed-dl');
    var speedUp = document.getElementById('qbt-speed-up');
    if (speedDl && initDl > 0) speedDl.innerHTML = '&#8595; ' + fmtSpeed(initDl);
    if (speedUp && initUp > 0) speedUp.innerHTML = '&#8593; ' + fmtSpeed(initUp);
    var connDot = document.getElementById('qbt-conn-dot');
    var connStatus = {{ (stats.connection ?? "unknown")|json_encode|raw }};
    if (connDot) connDot.className = 'qbt-connection ' + (connStatus === 'connected' ? 'connected' : connStatus === 'firewalled' ? 'firewalled' : 'disconnected');
})();
</script>
{% endblock %}
