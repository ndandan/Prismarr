            pause_title:   {{ 'qbittorrent.row.pause_title'|trans|json_encode|raw }},
            resume_title:  {{ 'qbittorrent.row.resume_title'|trans|json_encode|raw }},
            delete_title:  {{ 'qbittorrent.row.delete_title'|trans|json_encode|raw }},
            seeds_leech:   {{ 'qbittorrent.row.title_seeds_leechers'|trans|json_encode|raw }},
            ratio_title:   {{ 'qbittorrent.row.title_ratio'|trans|json_encode|raw }},
            added_title_tpl: {{ 'qbittorrent.row.title_added_tpl'|trans|json_encode|raw }}
        },
        modal_detail: {
