{% extends 'base.html.twig' %}
{% import '_icons.html.twig' as ico %}
{% block title %}{{ 'deluge.title'|trans }}{% endblock %}
{% block page_title %}<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2f67ba" stroke-width="2"><path d="M4 17v2a2 2 0 002 2h12a2 2 0 002-2v-2"/><path d="M7 11l5 5 5-5"/><path d="M12 4v12"/></svg> {{ 'deluge.title'|trans }}{% endblock %}

{% block stylesheets %}
<style>
/* ══════════════════════════════════════════════════════════════════════════
   Stats cards
   ══════════════════════════════════════════════════════════════════════════ */
.qbt-stat-card { position:relative; overflow:hidden; height:100%; }
.qbt-stat-card .card-body { min-height:88px; display:flex; flex-direction:column; justify-content:center; }
.qbt-stat-card .stat-val { font-size:1.5rem; font-weight:700; line-height:1; letter-spacing:-.5px; }
.qbt-stat-card .stat-lbl { font-size:.7rem; text-transform:uppercase; letter-spacing:.4px; color:var(--tblr-text-secondary); font-weight:600; }
.qbt-stat-card .stat-speed { font-size:.72rem; font-weight:600; margin-top:2px; font-family:'SF Mono', Menlo, monospace; min-height:1em; }
.qbt-stat-card .stat-icon { position:absolute; right:-8px; top:-8px; opacity:.08; }
/* 2e ligne — cards totaux un peu plus hautes, stat-val à droite */
.qbt-total-card .card-body { min-height:96px; justify-content:center; }

.qbt-connection { width:9px; height:9px; border-radius:50%; display:inline-block; }
.qbt-connection.connected    { background:#22c55e; box-shadow:0 0 8px #22c55e; animation:pulse-connected 2s infinite; }
.qbt-connection.firewalled   { background:#f59e0b; box-shadow:0 0 8px #f59e0b; }
.qbt-connection.disconnected { background:#ef4444; box-shadow:0 0 8px #ef4444; }
@keyframes pulse-connected { 0%,100% { opacity:1; } 50% { opacity:.5; } }

/* ══════════════════════════════════════════════════════════════════════════
   Torrent row — style cards horizontales
   ══════════════════════════════════════════════════════════════════════════ */
.qbt-torrent-list { display:flex; flex-direction:column; gap:.3rem; }

.qbt-torrent {
    display:grid;
    grid-template-columns: 22px 32px 1fr auto;
    gap:.6rem;
    align-items:center;
    padding:.45rem .7rem;
    background:var(--tblr-bg-surface);
    border:1px solid var(--tblr-border-color);
    border-left:3px solid var(--tblr-border-color);
    border-radius:6px;
    transition:all .12s;
    cursor:pointer;
    position:relative;
    overflow:hidden;
}
.qbt-torrent:hover { border-color:rgba(47,103,186,.4); box-shadow:0 2px 6px rgba(0,0,0,.05); }
.qbt-torrent.selected { background:rgba(47,103,186,.05); border-color:#2f67ba; }

/* bordure gauche colorée par état */
.qbt-torrent[data-state="downloading"] { border-left-color:#3b82f6; }
.qbt-torrent[data-state="seeding"]     { border-left-color:#22c55e; }
.qbt-torrent[data-state="paused"]      { border-left-color:#f59e0b; }
.qbt-torrent[data-state="completed"]   { border-left-color:#14b8a6; }
.qbt-torrent[data-state="stalled"]     { border-left-color:#f97316; }
.qbt-torrent[data-state="error"]       { border-left-color:#ef4444; }
.qbt-torrent[data-state="queued"]      { border-left-color:#6b7280; }
.qbt-torrent[data-state="checking"]    { border-left-color:#06b6d4; }
.qbt-torrent[data-state="unknown"]     { border-left-color:#9ca3af; }

/* Colonne 1 — checkbox */
.qbt-torrent .qbt-check { width:15px; height:15px; cursor:pointer; }

/* Colonne 2 — icône catégorie */
.qbt-ico {
    width:32px; height:32px;
    display:flex; align-items:center; justify-content:center;
    border-radius:7px;
    background:linear-gradient(135deg, rgba(47,103,186,.08), rgba(47,103,186,.03));
    color:#2f67ba;
    flex-shrink:0;
}
.qbt-ico svg { width:16px; height:16px; }
.qbt-torrent[data-state="downloading"] .qbt-ico { background:linear-gradient(135deg, rgba(59,130,246,.15), rgba(59,130,246,.05)); color:#3b82f6; animation:pulse-ico 2s infinite; }
.qbt-torrent[data-state="seeding"] .qbt-ico { background:linear-gradient(135deg, rgba(34,197,94,.12), rgba(34,197,94,.03)); color:#22c55e; }
.qbt-torrent[data-state="paused"] .qbt-ico { background:linear-gradient(135deg, rgba(245,158,11,.12), rgba(245,158,11,.03)); color:#f59e0b; }
.qbt-torrent[data-state="completed"] .qbt-ico { background:linear-gradient(135deg, rgba(20,184,166,.12), rgba(20,184,166,.03)); color:#14b8a6; }
.qbt-torrent[data-state="error"] .qbt-ico { background:linear-gradient(135deg, rgba(239,68,68,.15), rgba(239,68,68,.03)); color:#ef4444; }
@keyframes pulse-ico { 0%,100% { transform:scale(1); } 50% { transform:scale(1.06); } }

/* Colonne 3 — contenu principal */
.qbt-main { min-width:0; }
.qbt-name-row { display:flex; align-items:center; gap:.4rem; margin-bottom:.2rem; }
.qbt-name { font-size:.78rem; font-weight:600; color:var(--tblr-body-color); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; min-width:0; flex:1; line-height:1.2; }
.qbt-meta { font-size:.68rem; color:var(--tblr-text-secondary); }
.qbt-tag { display:inline-flex; align-items:center; gap:3px; font-size:.6rem; padding:1px 6px; border-radius:3px; font-weight:600; text-transform:uppercase; letter-spacing:.3px; line-height:1.4; }
.qbt-tag svg { width:10px; height:10px; }
.qbt-tag-cat { background:rgba(47,103,186,.12); color:#2f67ba; }
.qbt-tag-tag { background:rgba(162,89,255,.12); color:#a259ff; }
/* Catégories colorées par type */
.qbt-tag-radarr { background:rgba(255,194,48,.15); color:#d99400; border:1px solid rgba(255,194,48,.25); cursor:pointer; }
.qbt-tag-radarr:hover { background:rgba(255,194,48,.28); }
.qbt-tag-sonarr { background:rgba(0,204,255,.15); color:#0094c4; border:1px solid rgba(0,204,255,.25); cursor:pointer; }
.qbt-tag-sonarr:hover { background:rgba(0,204,255,.28); }
.qbt-tag-generic { background:rgba(var(--tblr-primary-rgb),.12); color:var(--tblr-primary); }

/* progress bar visuelle */
.qbt-bar-wrap { position:relative; height:4px; background:rgba(0,0,0,.06); border-radius:3px; overflow:hidden; }
body[data-bs-theme="dark"] .qbt-bar-wrap { background:rgba(255,255,255,.06); }
.qbt-bar { height:100%; border-radius:4px; transition:width .6s ease; position:relative; }
.qbt-bar-downloading { background:linear-gradient(90deg, #3b82f6, #60a5fa); }
.qbt-bar-seeding     { background:linear-gradient(90deg, #22c55e, #4ade80); }
.qbt-bar-paused      { background:linear-gradient(90deg, #f59e0b, #fbbf24); }
.qbt-bar-completed   { background:linear-gradient(90deg, #14b8a6, #2dd4bf); }
.qbt-bar-stalled     { background:linear-gradient(90deg, #f97316, #fb923c); }
.qbt-bar-error       { background:linear-gradient(90deg, #ef4444, #f87171); }
.qbt-bar-queued      { background:linear-gradient(90deg, #6b7280, #9ca3af); }
.qbt-bar-checking    { background:linear-gradient(90deg, #06b6d4, #22d3ee); }
.qbt-bar-unknown     { background:linear-gradient(90deg, #9ca3af, #cbd5e1); }

/* shimmer pendant download */
.qbt-bar-downloading::after {
    content:''; position:absolute; top:0; left:-50%; width:50%; height:100%;
    background:linear-gradient(90deg, transparent, rgba(255,255,255,.35), transparent);
    animation:shimmer 1.8s infinite linear;
}
@keyframes shimmer { 0% { left:-50%; } 100% { left:150%; } }

.qbt-stats-line { display:flex; align-items:center; gap:.7rem; margin-top:.2rem; font-size:.68rem; color:var(--tblr-text-secondary); flex-wrap:wrap; line-height:1.3; }
.qbt-stats-line .item { display:flex; align-items:center; gap:.2rem; }
.qbt-stats-line .item strong { color:var(--tblr-body-color); font-weight:600; font-family:'SF Mono', Menlo, monospace; }
.qbt-stats-line .sep { width:2px; height:2px; border-radius:50%; background:var(--tblr-border-color); }
.qbt-stats-line .dl-speed { color:#3b82f6; font-weight:600; font-family:'SF Mono', Menlo, monospace; }
.qbt-stats-line .up-speed { color:#22c55e; font-weight:600; font-family:'SF Mono', Menlo, monospace; }

/* Colonne 4 — actions */
.qbt-row-actions { display:flex; gap:.15rem; flex-shrink:0; }
.qbt-row-actions .btn { padding:3px 6px; border-radius:5px; }
.qbt-row-actions .btn svg { width:13px; height:13px; }

/* ══════════════════════════════════════════════════════════════════════════
   Filtres + recherche
   ══════════════════════════════════════════════════════════════════════════ */
.qbt-filter-btn { border-radius:6px !important; background:transparent !important; font-size:.78rem; padding:4px 10px; transition:all .15s; }
.qbt-filter-btn:hover { background:rgba(47,103,186,.06) !important; }
.qbt-filter-btn.active { font-weight:600; }
.qbt-filter-btn[data-filter="all"].active         { background:rgba(107,114,128,.15) !important; color:#6b7280 !important; }
.qbt-filter-btn[data-filter="active"].active      { background:rgba(250,204,21,.18) !important; color:#b45309 !important; }
.qbt-filter-btn[data-filter="downloading"].active { background:rgba(59,130,246,.15) !important; color:#3b82f6 !important; }
.qbt-filter-btn[data-filter="seeding"].active     { background:rgba(34,197,94,.15) !important; color:#22c55e !important; }
.qbt-filter-btn[data-filter="paused"].active      { background:rgba(245,158,11,.15) !important; color:#f59e0b !important; }
.qbt-filter-btn[data-filter="completed"].active   { background:rgba(20,184,166,.15) !important; color:#14b8a6 !important; }
.qbt-filter-btn[data-filter="error"].active       { background:rgba(239,68,68,.15) !important; color:#ef4444 !important; }

.qbt-filter-badge { display:inline-block; margin-left:4px; padding:0 5px; font-size:.6rem; background:rgba(0,0,0,.08); border-radius:8px; font-weight:700; }

/* ══════════════════════════════════════════════════════════════════════════
   Barre bulk
   ══════════════════════════════════════════════════════════════════════════ */
.qbt-bulk-bar { position:fixed; bottom:0; left:15rem; right:0; z-index:1050; background:var(--tblr-bg-surface); border-top:2px solid #2f67ba; padding:.7rem 1.25rem; display:none; align-items:center; gap:.6rem; box-shadow:0 -6px 18px rgba(0,0,0,.12); }
.qbt-bulk-bar.show { display:flex; }
@media(max-width:991px){ .qbt-bulk-bar { left:0; } }

/* ══════════════════════════════════════════════════════════════════════════
   Add modal — drop zone fichiers .torrent
   ══════════════════════════════════════════════════════════════════════════ */
.qbt-drop-zone { position:relative; border:2px dashed var(--tblr-border-color); border-radius:8px; padding:1rem; text-align:center; cursor:pointer; transition:all .15s; background:var(--tblr-bg-surface-secondary); }
.qbt-drop-zone:hover { border-color:#2f67ba; background:rgba(47,103,186,.04); }
.qbt-drop-zone.drag-over { border-color:#2f67ba; background:rgba(47,103,186,.1); transform:scale(1.01); }
.qbt-drop-inner { display:flex; flex-direction:column; align-items:center; gap:.4rem; color:var(--tblr-text-secondary); }
.qbt-drop-inner svg { color:#2f67ba; opacity:.75; }
.qbt-drop-text { font-size:.78rem; line-height:1.4; }
.qbt-drop-files { list-style:none; padding:0; margin:.7rem 0 0; text-align:left; }
.qbt-drop-files li { font-size:.74rem; padding:3px 8px; background:var(--tblr-bg-surface); border-radius:4px; margin-top:3px; display:flex; align-items:center; gap:6px; }
.qbt-drop-files li .remove { margin-left:auto; color:var(--tblr-text-secondary); cursor:pointer; font-size:.9rem; line-height:1; padding:0 4px; }
.qbt-drop-files li .remove:hover { color:#ef4444; }

/* ══════════════════════════════════════════════════════════════════════════
   Detail modal
   ══════════════════════════════════════════════════════════════════════════ */
.qbt-detail-tab { border-bottom:1px solid var(--tblr-border-color); }
.qbt-detail-tab .nav-link { padding:.5rem 1rem; font-size:.82rem; color:var(--tblr-text-secondary); border:none; border-bottom:2px solid transparent; }
.qbt-detail-tab .nav-link.active { color:#2f67ba; border-bottom-color:#2f67ba; background:transparent; font-weight:600; }

.qbt-file-row { font-size:.78rem; }
.qbt-file-row:hover { background:rgba(47,103,186,.04); }
.qbt-tracker-row { font-size:.78rem; }
.qbt-peer-row { font-size:.75rem; }

.qbt-prop-card { padding:.6rem .85rem; background:var(--tblr-bg-surface-secondary); border-radius:8px; }
.qbt-prop-label { font-size:.68rem; color:var(--tblr-text-secondary); text-transform:uppercase; letter-spacing:.3px; font-weight:600; margin-bottom:3px; }
.qbt-prop-value { font-size:.85rem; font-weight:600; color:var(--tblr-body-color); }

/* mini progress bar dans fichiers */
.qbt-mini-bar { width:70px; height:5px; background:rgba(0,0,0,.08); border-radius:3px; overflow:hidden; }
body[data-bs-theme="dark"] .qbt-mini-bar { background:rgba(255,255,255,.08); }
.qbt-mini-bar > div { height:100%; background:linear-gradient(90deg, #3b82f6, #60a5fa); }

/* ══════════════════════════════════════════════════════════════════════════
   Empty state
   ══════════════════════════════════════════════════════════════════════════ */
.qbt-empty { padding:3rem 1rem; text-align:center; }
.qbt-empty svg { opacity:.25; margin-bottom:.6rem; }
.qbt-empty p { color:var(--tblr-text-secondary); font-size:.9rem; }

/* ══════════════════════════════════════════════════════════════════════════
   Sélecteur de vue
   ══════════════════════════════════════════════════════════════════════════ */

/* ══════════════════════════════════════════════════════════════════════════
   Mode COMPACT
   ══════════════════════════════════════════════════════════════════════════ */
.qbt-torrent-list[data-view="compact"] { gap:2px; }
.qbt-torrent-list[data-view="compact"] .qbt-torrent { grid-template-columns: 18px 22px 1fr 55px auto; padding:.25rem .55rem; gap:.5rem; }
.qbt-torrent-list[data-view="compact"] .qbt-ico { width:22px; height:22px; border-radius:5px; }
.qbt-torrent-list[data-view="compact"] .qbt-ico svg { width:12px; height:12px; }
.qbt-torrent-list[data-view="compact"] .qbt-name-row { margin-bottom:2px; }
.qbt-torrent-list[data-view="compact"] .qbt-name { font-size:.73rem; }
.qbt-torrent-list[data-view="compact"] .qbt-tag:not(.qbt-tag-radarr):not(.qbt-tag-sonarr) { display:none; }
.qbt-torrent-list[data-view="compact"] .qbt-tag-radarr,
.qbt-torrent-list[data-view="compact"] .qbt-tag-sonarr { font-size:.52rem; padding:0 4px; }
.qbt-torrent-list[data-view="compact"] .qbt-tag-radarr svg,
.qbt-torrent-list[data-view="compact"] .qbt-tag-sonarr svg { width:8px; height:8px; }
.qbt-torrent-list[data-view="compact"] .qbt-bar-wrap { height:3px; }
.qbt-torrent-list[data-view="compact"] .qbt-stats-line { display:none; }
.qbt-torrent-list[data-view="compact"] .qbt-compact-pct { font-size:.7rem; font-weight:600; font-family:'SF Mono', Menlo, monospace; color:var(--tblr-text-secondary); text-align:right; align-self:center; }
.qbt-torrent-list[data-view="compact"] .qbt-row-actions .btn { padding:2px 4px; }
.qbt-torrent-list[data-view="compact"] .qbt-row-actions .btn svg { width:11px; height:11px; }
.qbt-torrent-list:not([data-view="compact"]) .qbt-compact-pct { display:none; }

/* ══════════════════════════════════════════════════════════════════════════
   Mode TABLEAU
   ══════════════════════════════════════════════════════════════════════════ */
#qbt-table-header { display:none; grid-template-columns: 22px 26px 1fr 80px 70px 85px 85px 70px 75px 85px 90px 95px 90px; gap:.6rem; align-items:center; padding:.5rem .7rem; background:var(--tblr-bg-surface-secondary); border:1px solid var(--tblr-border-color); border-radius:6px 6px 0 0; font-size:.66rem; font-weight:700; text-transform:uppercase; letter-spacing:.04em; color:var(--tblr-text-secondary); position:sticky; top:0; z-index:5; margin-bottom:-1px; }
#qbt-table-header.show { display:grid; }
#qbt-table-header .qbt-sort { cursor:pointer; user-select:none; display:flex; align-items:center; gap:3px; }
#qbt-table-header .qbt-sort:hover { color:#2f67ba; }
#qbt-table-header .qbt-sort.active { color:#2f67ba; }
#qbt-table-header .qbt-sort svg { width:9px; height:9px; opacity:.35; transition:transform .15s; }
#qbt-table-header .qbt-sort.active svg { opacity:1; }
#qbt-table-header .qbt-sort.active.desc svg { transform:rotate(180deg); }

.qbt-torrent-list[data-view="table"] { gap:0; border-radius:0 0 6px 6px; overflow:hidden; border:1px solid var(--tblr-border-color); border-top:none; }
.qbt-torrent-list[data-view="table"] .qbt-torrent {
    grid-template-columns: 22px 26px 1fr 80px 70px 85px 85px 70px 75px 85px 90px 95px 90px;
    gap:.6rem;
    padding:.5rem .7rem;
    border-radius:0;
    border:none;
    border-bottom:1px solid var(--tblr-border-color);
    border-left:3px solid var(--tblr-border-color);
}
.qbt-torrent-list[data-view="table"] .qbt-torrent:last-child { border-bottom:none; }
.qbt-torrent-list[data-view="table"] .qbt-torrent[data-state="downloading"] { border-left-color:#3b82f6; }
.qbt-torrent-list[data-view="table"] .qbt-torrent[data-state="seeding"] { border-left-color:#22c55e; }
.qbt-torrent-list[data-view="table"] .qbt-torrent[data-state="paused"] { border-left-color:#f59e0b; }
.qbt-torrent-list[data-view="table"] .qbt-torrent[data-state="completed"] { border-left-color:#14b8a6; }
.qbt-torrent-list[data-view="table"] .qbt-torrent[data-state="error"] { border-left-color:#ef4444; }
.qbt-torrent-list[data-view="table"] .qbt-ico { width:26px; height:26px; border-radius:5px; }
.qbt-torrent-list[data-view="table"] .qbt-ico svg { width:13px; height:13px; }
.qbt-torrent-list[data-view="table"] .qbt-main { display:contents; }
.qbt-torrent-list[data-view="table"] .qbt-name-row { margin:0; min-width:0; }
.qbt-torrent-list[data-view="table"] .qbt-name { font-size:.74rem; font-weight:500; }
.qbt-torrent-list[data-view="table"] .qbt-tag:not(.qbt-tag-radarr):not(.qbt-tag-sonarr) { display:none; }
.qbt-torrent-list[data-view="table"] .qbt-bar-wrap { display:none; }
.qbt-torrent-list[data-view="table"] .qbt-stats-line { display:none; }
.qbt-torrent-list[data-view="table"] .qbt-table-cell { font-size:.72rem; font-family:'SF Mono', Menlo, monospace; text-align:right; color:var(--tblr-body-color); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.qbt-torrent-list[data-view="table"] .qbt-cell-progress { position:relative; background:rgba(0,0,0,.06); border-radius:3px; overflow:hidden; text-align:center; color:var(--tblr-body-color); font-weight:600; font-family:'SF Mono', Menlo, monospace; font-size:.7rem; padding:2px 0; }
body[data-bs-theme="dark"] .qbt-torrent-list[data-view="table"] .qbt-cell-progress { background:rgba(255,255,255,.06); }
.qbt-torrent-list[data-view="table"] .qbt-cell-progress-fill { position:absolute; inset:0; width:0; background:rgba(59,130,246,.3); transition:width .4s; }
.qbt-torrent-list[data-view="table"] .qbt-torrent[data-state="seeding"] .qbt-cell-progress-fill { background:rgba(34,197,94,.3); }
.qbt-torrent-list[data-view="table"] .qbt-torrent[data-state="paused"] .qbt-cell-progress-fill { background:rgba(245,158,11,.3); }
.qbt-torrent-list[data-view="table"] .qbt-torrent[data-state="completed"] .qbt-cell-progress-fill { background:rgba(20,184,166,.3); }
.qbt-torrent-list[data-view="table"] .qbt-cell-progress > span { position:relative; z-index:1; }
.qbt-torrent-list[data-view="table"] .qbt-cell-dl { color:#3b82f6; }
.qbt-torrent-list[data-view="table"] .qbt-cell-up { color:#22c55e; }
.qbt-torrent-list[data-view="table"] .qbt-row-actions .btn { padding:3px 5px; }
.qbt-torrent-list[data-view="table"] .qbt-row-actions .btn svg { width:12px; height:12px; }
.qbt-torrent-list:not([data-view="table"]) .qbt-table-cell,
.qbt-torrent-list:not([data-view="table"]) .qbt-cell-progress { display:none; }
</style>
{% endblock %}

{% block body %}
<div class="container-xl">

{% if error %}
  {% include 'error/_service_banner.html.twig' with {
    service: 'Deluge',
    wizard_route: 'app_setup_downloads',
    configured_url: service_url,
    reason: 'unreachable'
  } %}
{% endif %}

{% if not error %}

{# ══════════════════════════════════════════════════════════════════════════
   Stats cards — row 1: torrent states
   ══════════════════════════════════════════════════════════════════════════ #}
<div class="row g-2 mb-2">
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card card-sm qbt-stat-card"><div class="card-body">
            <div class="d-flex align-items-center gap-2">
                <span class="qbt-connection" id="qbt-conn-dot"></span>
                <span class="stat-val text-secondary" id="qbt-stat-total">{{ stats.total ?? 0 }}</span>
            </div>
            <div class="stat-lbl mt-1">{{ 'qbittorrent.stats.total'|trans }}</div>
            <svg class="stat-icon" xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="1.5"><circle cx="12" cy="12" r="9"/></svg>
        </div></div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card card-sm qbt-stat-card"><div class="card-body">
            <span class="stat-val" style="color:#3b82f6" id="qbt-stat-dl">{{ stats.downloading ?? 0 }}</span>
            <div class="stat-lbl mt-1">{{ 'qbittorrent.stats.downloading'|trans }}</div>
            <div class="stat-speed" style="color:#3b82f6" id="qbt-speed-dl">&nbsp;</div>
            <svg class="stat-icon" xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="1.5"><path d="M12 3v13m-5-5l5 5 5-5"/></svg>
        </div></div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card card-sm qbt-stat-card"><div class="card-body">
            <span class="stat-val" style="color:#22c55e" id="qbt-stat-seed">{{ stats.seeding ?? 0 }}</span>
            <div class="stat-lbl mt-1">{{ 'qbittorrent.stats.seeding'|trans }}</div>
            <div class="stat-speed" style="color:#22c55e" id="qbt-speed-up">&nbsp;</div>
            <svg class="stat-icon" xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="1.5"><path d="M12 21V8m-5 5l5-5 5 5"/></svg>
        </div></div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card card-sm qbt-stat-card"><div class="card-body">
            <span class="stat-val" style="color:{{ (stats.paused ?? 0) > 0 ? '#f59e0b' : 'var(--tblr-text-secondary)' }}" id="qbt-stat-paused">{{ stats.paused ?? 0 }}</span>
            <div class="stat-lbl mt-1">{{ 'qbittorrent.stats.paused'|trans }}</div>
            <svg class="stat-icon" xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="1.5"><path d="M6 5h4v14H6zm8 0h4v14h-4z"/></svg>
        </div></div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card card-sm qbt-stat-card"><div class="card-body">
            <span class="stat-val" style="color:{{ (stats.errored ?? 0) > 0 ? '#ef4444' : 'var(--tblr-text-secondary)' }}" id="qbt-stat-error">{{ stats.errored ?? 0 }}</span>
            <div class="stat-lbl mt-1">{{ 'qbittorrent.stats.errored'|trans }}</div>
            <svg class="stat-icon" xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><path d="M12 8v4m0 4h.01"/></svg>
        </div></div>
    </div>
</div>

{# ══════════════════════════════════════════════════════════════════════════
   Stats cards — row 2: totals + Session
   ══════════════════════════════════════════════════════════════════════════ #}
<div class="row g-2 mb-3">
    <div class="col-12 col-md-6 col-lg-4">
        <div class="card card-sm qbt-stat-card qbt-total-card"><div class="card-body">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="stat-lbl">{{ 'qbittorrent.stats.total_downloaded'|trans }}</div>
                    <span class="stat-val" style="color:#3b82f6" id="qbt-total-dl">{{ (stats.dl_alltime ?? 0)|prismarr_bytes }}</span>
                </div>
                <div class="text-end" style="font-size:.68rem;color:var(--tblr-text-secondary);line-height:1.3;">
                    <div>{{ 'qbittorrent.stats.session'|trans }}</div>
                    <strong id="qbt-session-dl" style="color:#3b82f6;font-family:'SF Mono',Menlo,monospace;">{{ (stats.dl_session ?? 0)|prismarr_bytes }}</strong>
                </div>
            </div>
            <svg class="stat-icon" xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="1.5"><path d="M12 3v13m-5-5l5 5 5-5"/><path d="M4 20h16"/></svg>
        </div></div>
    </div>
    <div class="col-12 col-md-6 col-lg-4">
        <div class="card card-sm qbt-stat-card qbt-total-card"><div class="card-body">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="stat-lbl">{{ 'qbittorrent.stats.total_uploaded'|trans }}</div>
                    <span class="stat-val" style="color:#22c55e" id="qbt-total-up">{{ (stats.up_alltime ?? 0)|prismarr_bytes }}</span>
                </div>
                <div class="text-end" style="font-size:.68rem;color:var(--tblr-text-secondary);line-height:1.3;">
                    <div>{{ 'qbittorrent.stats.session'|trans }}</div>
                    <strong id="qbt-session-up" style="color:#22c55e;font-family:'SF Mono',Menlo,monospace;">{{ (stats.up_session ?? 0)|prismarr_bytes }}</strong>
                </div>
            </div>
            <svg class="stat-icon" xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="1.5"><path d="M12 21V8m-5 5l5-5 5 5"/><path d="M4 4h16"/></svg>
        </div></div>
    </div>
    {# Card Session #}
    <div class="col-12 col-md-6 col-lg-4">
        <div class="card card-sm qbt-stat-card qbt-session-card"><div class="card-body">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="stat-lbl d-flex align-items-center gap-1">
                        <span>{{ 'qbittorrent.session.label'|trans }}</span>
                        <span id="qbt-session-uptime" style="font-size:.6rem;color:var(--tblr-text-secondary);text-transform:none;letter-spacing:0;font-weight:500;">·&nbsp;—</span>
                    </div>
                    <span class="stat-val" style="color:#a259ff;font-size:1.05rem;">{{ 'qbittorrent.session.ratio'|trans }} <span id="qbt-total-ratio" style="font-family:'SF Mono',Menlo,monospace;">{{ (stats.global_ratio ?? 0)|number_format(2) }}</span></span>
                </div>
                <div class="text-end" style="font-size:.68rem;color:var(--tblr-text-secondary);line-height:1.3;white-space:nowrap;">
                    <div>{{ 'qbittorrent.stats.peak_dl'|trans }} <strong id="qbt-peak-dl" style="color:#3b82f6;font-family:'SF Mono',Menlo,monospace;">—</strong></div>
                    <div>{{ 'qbittorrent.stats.peak_up'|trans }} <strong id="qbt-peak-up" style="color:#22c55e;font-family:'SF Mono',Menlo,monospace;">—</strong></div>
                    <div>{{ 'qbittorrent.stats.free_space'|trans }} <strong id="qbt-free-space" style="color:var(--tblr-body-color);font-family:'SF Mono',Menlo,monospace;">{{ (stats.free_space ?? 0)|prismarr_bytes(0) }}</strong></div>
                </div>
            </div>
            <svg class="stat-icon" xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#a259ff" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
        </div></div>
    </div>
</div>

{# ══════════════════════════════════════════════════════════════════════════
   Filter bar + search + actions
   ══════════════════════════════════════════════════════════════════════════ #}
<div class="card mb-3">
    <div class="card-body py-2">
        <div class="d-flex align-items-center gap-3 flex-wrap">
            <div class="input-icon" style="max-width:240px;">
                <span class="input-icon-addon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="10" cy="10" r="7"/><path d="M21 21l-6-6"/></svg>
                </span>
                <input type="text" id="qbt-search" class="form-control form-control-sm" placeholder="{{ 'qbittorrent.filters.search_placeholder'|trans }}" autocomplete="off">
            </div>
            <div class="d-flex gap-1 flex-wrap">
                <button class="btn btn-sm qbt-filter-btn active" data-filter="all">{{ 'qbittorrent.filters.all'|trans }}</button>
                <button class="btn btn-sm qbt-filter-btn" data-filter="active" title="{{ 'qbittorrent.filters.active_title'|trans }}">{{ 'qbittorrent.filters.active'|trans }}</button>
                <button class="btn btn-sm qbt-filter-btn" data-filter="downloading">{{ 'qbittorrent.filters.downloading'|trans }}</button>
                <button class="btn btn-sm qbt-filter-btn" data-filter="seeding">{{ 'qbittorrent.filters.seeding'|trans }}</button>
                <button class="btn btn-sm qbt-filter-btn" data-filter="paused">{{ 'qbittorrent.filters.paused'|trans }}</button>
                <button class="btn btn-sm qbt-filter-btn" data-filter="completed">{{ 'qbittorrent.filters.completed'|trans }}</button>
                <button class="btn btn-sm qbt-filter-btn" data-filter="error">{{ 'qbittorrent.filters.error'|trans }}</button>
            </div>
            <span class="text-muted small ms-auto" id="qbt-count">{{ 'qbittorrent.count_tpl'|trans({count: torrents|length}) }}</span>
            <div class="d-flex gap-1">
                <button class="btn btn-sm btn-primary" id="qbt-btn-add" title="{{ 'qbittorrent.toolbar.add_title'|trans }}" style="background:#2f67ba;border-color:#2f67ba;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
                    {{ 'qbittorrent.toolbar.add'|trans }}
                </button>
                <button class="btn btn-sm btn-outline-secondary" id="qbt-btn-pause-all" title="{{ 'qbittorrent.toolbar.pause_all_title'|trans }}">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 4h4v16H6z"/><path d="M14 4h4v16h-4z"/></svg>
                </button>
                <button class="btn btn-sm btn-outline-secondary" id="qbt-btn-resume-all" title="{{ 'qbittorrent.toolbar.resume_all_title'|trans }}">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 4v16l13-8z"/></svg>
                </button>
            </div>
        </div>
        <div class="d-flex align-items-center gap-2 mt-2 pt-2 flex-wrap" style="border-top:1px solid var(--tblr-border-color);">
            <label class="form-check mb-0" style="font-size:.75rem;">
                <input type="checkbox" class="form-check-input" id="qbt-select-all">
                <span class="form-check-label">{{ 'qbittorrent.filters.select_all'|trans }}</span>
            </label>
            <div class="d-flex align-items-center gap-2" style="font-size:.72rem;">
                <span class="text-muted" style="white-space:nowrap;font-weight:500;">{{ 'deluge.filters.labels'|trans }}</span>
                <select id="qbt-cat-filter" class="form-select form-select-sm" style="min-width:140px;font-size:.75rem;padding:3px 24px 3px 8px;">
                    <option value="">{{ 'qbittorrent.filters.category_all'|trans }}</option>
                    {% for key, cat in categories %}<option value="{{ key }}">{{ cat.name ?? key }}</option>{% endfor %}
                </select>
            </div>
            <div class="ms-auto d-flex align-items-center gap-2 flex-shrink-0" id="qbt-list-sort-wrap">
                <span class="text-muted" style="font-size:.78rem;white-space:nowrap;font-weight:500;">{{ 'qbittorrent.filters.sort_label'|trans }}</span>
                <select id="qbt-list-sort" class="form-select form-select-sm" style="min-width:210px;font-size:.78rem;padding:4px 28px 4px 10px;">
                    <option value="added|1">{{ 'qbittorrent.sort.added_desc'|trans }}</option>
                    <option value="added|0">{{ 'qbittorrent.sort.added_asc'|trans }}</option>
                    <option value="name|0">{{ 'qbittorrent.sort.name_asc'|trans }}</option>
                    <option value="name|1">{{ 'qbittorrent.sort.name_desc'|trans }}</option>
                    <option value="size|1">{{ 'qbittorrent.sort.size_desc'|trans }}</option>
                    <option value="size|0">{{ 'qbittorrent.sort.size_asc'|trans }}</option>
                    <option value="progress|1">{{ 'qbittorrent.sort.progress_desc'|trans }}</option>
                    <option value="dlspeed|1">{{ 'qbittorrent.sort.dlspeed_desc'|trans }}</option>
                    <option value="upspeed|1">{{ 'qbittorrent.sort.upspeed_desc'|trans }}</option>
                    <option value="ratio|1">{{ 'qbittorrent.sort.ratio_desc'|trans }}</option>
                    <option value="seeds|1">{{ 'qbittorrent.sort.seeds_desc'|trans }}</option>
                </select>
            </div>
            {% set vs_icon_list = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>' %}
            {% set vs_icon_table = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 5h18v14H3zM3 10h18M3 15h18M10 5v14"/></svg>' %}
            {% set vs_icon_compact = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>' %}
            {% include '_view_switcher.html.twig' with {
                active: 'list',
                aria_label: 'qbittorrent.view.aria_label'|trans,
                modes: [
                    { view: 'list', label: 'qbittorrent.view.list'|trans, title: 'qbittorrent.view.list_title'|trans, icon: vs_icon_list },
                    { view: 'table', label: 'qbittorrent.view.table'|trans, title: 'qbittorrent.view.table_title'|trans, icon: vs_icon_table },
                    { view: 'compact', label: 'qbittorrent.view.compact'|trans, title: 'qbittorrent.view.compact_title'|trans, icon: vs_icon_compact }
                ]
            } only %}
        </div>
        {# 3rd row of the card: pagination #}
        <div id="qbt-pagination-bar" class="d-flex align-items-center justify-content-between flex-wrap gap-2 mt-2 pt-2" style="display:none;border-top:1px solid var(--tblr-border-color);">
            <div class="d-flex align-items-center gap-2 flex-shrink-0" style="font-size:.78rem;">
                <span class="text-muted" style="white-space:nowrap;font-weight:500;">{{ 'qbittorrent.pagination.per_page'|trans }}</span>
                <select id="qbt-per-page" class="form-select form-select-sm" style="min-width:90px;font-size:.78rem;padding:4px 28px 4px 10px;">
                    <option value="25">25</option>
                    <option value="50" selected>50</option>
                    <option value="100">100</option>
                    <option value="200">200</option>
                </select>
                <span class="text-muted ms-2" id="qbt-page-info" style="white-space:nowrap;">—</span>
            </div>
            <ul class="pagination pagination-sm mb-0" id="qbt-pagination-links"></ul>
        </div>
    </div>
</div>

{# ══════════════════════════════════════════════════════════════════════════
   Table header (visible only in table mode)
   ══════════════════════════════════════════════════════════════════════════ #}
<div id="qbt-table-header">
    <div></div>
    <div></div>
    <div class="qbt-sort active" data-sort="name">{{ 'qbittorrent.table.name'|trans }} <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M6 9l6 6 6-6"/></svg></div>
    <div class="qbt-sort" data-sort="size" style="justify-content:flex-end">{{ 'qbittorrent.table.size'|trans }} <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M6 9l6 6 6-6"/></svg></div>
    <div class="qbt-sort" data-sort="progress" style="justify-content:center">{{ 'qbittorrent.table.progress'|trans }} <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M6 9l6 6 6-6"/></svg></div>
    <div class="qbt-sort" data-sort="dlspeed" style="justify-content:flex-end">{{ 'qbittorrent.table.dl_speed'|trans }} <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M6 9l6 6 6-6"/></svg></div>
    <div class="qbt-sort" data-sort="upspeed" style="justify-content:flex-end">{{ 'qbittorrent.table.up_speed'|trans }} <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M6 9l6 6 6-6"/></svg></div>
    <div class="qbt-sort" data-sort="seeds" style="justify-content:flex-end">{{ 'qbittorrent.table.seeds'|trans }} <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M6 9l6 6 6-6"/></svg></div>
    <div class="qbt-sort" data-sort="ratio" style="justify-content:flex-end">{{ 'qbittorrent.table.ratio'|trans }} <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M6 9l6 6 6-6"/></svg></div>
    <div class="qbt-sort" data-sort="uploaded" style="justify-content:flex-end">{{ 'deluge.table.uploaded'|trans }} <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M6 9l6 6 6-6"/></svg></div>
    <div class="qbt-sort" data-sort="completed" style="justify-content:flex-end">{{ 'deluge.table.completed'|trans }} <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M6 9l6 6 6-6"/></svg></div>
    <div class="qbt-sort" data-sort="added" style="justify-content:flex-end">{{ 'qbittorrent.table.added'|trans }} <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M6 9l6 6 6-6"/></svg></div>
    <div style="text-align:center">{{ 'qbittorrent.table.actions'|trans }}</div>
</div>

{# ══════════════════════════════════════════════════════════════════════════
   Liste torrents
   ══════════════════════════════════════════════════════════════════════════ #}
<div class="qbt-torrent-list" id="qbt-list" data-view="list">
    {% for t in torrents %}
    {{ _self.torrent_row(t) }}
    {% endfor %}
</div>

<div id="qbt-empty" class="card" style="display:none;"><div class="qbt-empty">
    <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 17v2a2 2 0 002 2h12a2 2 0 002-2v-2"/><path d="M7 11l5 5 5-5"/><path d="M12 4v12"/></svg>
    <p>{{ 'qbittorrent.empty.no_match'|trans }}</p>
</div></div>

{# Barre bulk #}
<div class="qbt-bulk-bar" id="qbt-bulk-bar">
    <span class="fw-bold" style="font-size:.82rem;color:#2f67ba;" id="qbt-bulk-count-label">{{ 'qbittorrent.bulk.selected_tpl'|trans({count: 0}) }}</span>
    <button class="btn btn-sm btn-outline-primary" id="qbt-bulk-resume">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 4v16l13-8z"/></svg> {{ 'qbittorrent.bulk.resume'|trans }}
    </button>
    <button class="btn btn-sm btn-outline-warning" id="qbt-bulk-pause">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 4h4v16H6z"/><path d="M14 4h4v16h-4z"/></svg> {{ 'qbittorrent.bulk.pause'|trans }}
    </button>
    <button class="btn btn-sm btn-outline-danger" id="qbt-bulk-delete">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 7h16"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M5 7l1 12a2 2 0 002 2h8a2 2 0 002-2l1-12"/><path d="M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3"/></svg> {{ 'qbittorrent.bulk.delete'|trans }}
    </button>
    <button class="btn btn-sm btn-outline-info" id="qbt-bulk-recheck">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5L20 7"/></svg> {{ 'qbittorrent.bulk.recheck'|trans }}
    </button>
    <button class="btn btn-sm btn-ghost-secondary ms-auto" id="qbt-bulk-clear">{{ 'qbittorrent.bulk.cancel'|trans }}</button>
</div>

</div>{# /container-xl #}

{# ══════════════════════════════════════════════════════════════════════════
   Torrent detail modal
   ══════════════════════════════════════════════════════════════════════════ #}
<div class="modal modal-blur fade" id="qbt-modal-detail" tabindex="-1">
<div class="modal-dialog modal-lg modal-dialog-scrollable">
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title text-truncate" id="qbt-detail-title" style="font-size:.9rem;max-width:90%;"></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>
    <div class="modal-body p-0">
        <ul class="nav nav-tabs qbt-detail-tab px-3 pt-2" role="tablist">
            <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#qbt-tab-general">{{ 'qbittorrent.modal_detail.tab_general'|trans }}</a></li>
            <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#qbt-tab-files">{{ 'qbittorrent.modal_detail.tab_files'|trans }}</a></li>
            <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#qbt-tab-trackers">{{ 'qbittorrent.modal_detail.tab_trackers'|trans }}</a></li>
            <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#qbt-tab-peers">{{ 'qbittorrent.modal_detail.tab_peers'|trans }}</a></li>
        </ul>
        <div class="tab-content p-3">
            <div class="tab-pane active" id="qbt-tab-general">
                <div class="row g-2" id="qbt-detail-props"></div>
            </div>
            <div class="tab-pane" id="qbt-tab-files">
                <div class="table-responsive">
                    <table class="table table-vcenter mb-0" style="font-size:.78rem;">
                        <thead><tr><th>{{ 'qbittorrent.modal_detail.files.col_name'|trans }}</th><th style="width:80px">{{ 'qbittorrent.modal_detail.files.col_size'|trans }}</th><th style="width:110px">{{ 'qbittorrent.modal_detail.files.col_progress'|trans }}</th></tr></thead>
                        <tbody id="qbt-detail-files"></tbody>
                    </table>
                </div>
            </div>
            <div class="tab-pane" id="qbt-tab-trackers">
                <div class="table-responsive">
                    <table class="table table-vcenter mb-0" style="font-size:.78rem;">
                        <thead><tr><th>{{ 'qbittorrent.modal_detail.trackers.col_url'|trans }}</th><th style="width:90px">{{ 'qbittorrent.modal_detail.trackers.col_status'|trans }}</th><th style="width:60px">{{ 'qbittorrent.modal_detail.trackers.col_seeds'|trans }}</th><th style="width:60px">{{ 'qbittorrent.modal_detail.trackers.col_leechs'|trans }}</th></tr></thead>
                        <tbody id="qbt-detail-trackers"></tbody>
                    </table>
                </div>
            </div>
            <div class="tab-pane" id="qbt-tab-peers">
                <div class="table-responsive">
                    <table class="table table-vcenter mb-0" style="font-size:.75rem;">
                        <thead><tr><th>{{ 'qbittorrent.modal_detail.peers.col_ip'|trans }}</th><th>{{ 'qbittorrent.modal_detail.peers.col_client'|trans }}</th><th style="width:60px">{{ 'qbittorrent.modal_detail.peers.col_progress'|trans }}</th><th style="width:80px">{{ 'qbittorrent.modal_detail.peers.col_dl'|trans }}</th><th style="width:80px">{{ 'qbittorrent.modal_detail.peers.col_up'|trans }}</th></tr></thead>
                        <tbody id="qbt-detail-peers"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-footer">
        <div class="d-flex gap-1 w-100 flex-wrap" id="qbt-detail-actions"></div>
    </div>
</div>
</div>
</div>

{# ══════════════════════════════════════════════════════════════════════════
   Modal ajout torrent
   ══════════════════════════════════════════════════════════════════════════ #}
<div class="modal modal-blur fade" id="qbt-modal-add" tabindex="-1">
<div class="modal-dialog modal-lg">
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title" style="font-size:.9rem;">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2f67ba" stroke-width="2" style="vertical-align:-3px;margin-right:4px;"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
            {{ 'qbittorrent.modal_add.title'|trans }}
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>
    <div class="modal-body">
        <div class="mb-3">
            <label class="form-label">{{ 'qbittorrent.modal_add.urls_label'|trans }}</label>
