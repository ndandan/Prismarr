            files_empty:    {{ 'qbittorrent.modal_detail.files.empty'|trans|json_encode|raw }},
            trackers_empty: {{ 'qbittorrent.modal_detail.trackers.empty'|trans|json_encode|raw }},
            peers_empty:    {{ 'qbittorrent.modal_detail.peers.empty'|trans|json_encode|raw }},
            tracker_status: {
                '0': {{ 'qbittorrent.modal_detail.trackers.status_disabled'|trans|json_encode|raw }},
                '1': {{ 'qbittorrent.modal_detail.trackers.status_not_contacted'|trans|json_encode|raw }},
                '2': {{ 'qbittorrent.modal_detail.trackers.status_ok'|trans|json_encode|raw }},
                '3': {{ 'qbittorrent.modal_detail.trackers.status_running'|trans|json_encode|raw }},
                '4': {{ 'qbittorrent.modal_detail.trackers.status_error'|trans|json_encode|raw }}
            },
            props: {
                downloaded: {{ 'qbittorrent.modal_detail.props.downloaded'|trans|json_encode|raw }},
                uploaded:   {{ 'qbittorrent.modal_detail.props.uploaded'|trans|json_encode|raw }},
                ratio:      {{ 'qbittorrent.modal_detail.props.ratio'|trans|json_encode|raw }},
                dl_speed:   {{ 'qbittorrent.modal_detail.props.dl_speed'|trans|json_encode|raw }},
                up_speed:   {{ 'qbittorrent.modal_detail.props.up_speed'|trans|json_encode|raw }},
                eta:        {{ 'qbittorrent.modal_detail.props.eta'|trans|json_encode|raw }},
                seeds:      {{ 'qbittorrent.modal_detail.props.seeds'|trans|json_encode|raw }},
                peers:      {{ 'qbittorrent.modal_detail.props.peers'|trans|json_encode|raw }},
                total_size: {{ 'qbittorrent.modal_detail.props.total_size'|trans|json_encode|raw }},
                added:      {{ 'qbittorrent.modal_detail.props.added'|trans|json_encode|raw }},
                completed:  {{ 'qbittorrent.modal_detail.props.completed'|trans|json_encode|raw }},
                save_path:  {{ 'qbittorrent.modal_detail.props.save_path'|trans|json_encode|raw }}
            },
            actions: {
                pause:      {{ 'qbittorrent.modal_detail.actions.pause'|trans|json_encode|raw }},
