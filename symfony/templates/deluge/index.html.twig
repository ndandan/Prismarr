            <div class="form-hint">{{ 'qbittorrent.modal_add.urls_hint'|trans }}</div>
        </div>
        {# Zone drag-drop fichiers .torrent #}
        <div class="mb-3">
            <label class="form-label">{{ 'qbittorrent.modal_add.files_label'|trans }}</label>
            <div id="qbt-drop-zone" class="qbt-drop-zone">
                <input type="file" id="qbt-file-input" accept=".torrent" multiple style="display:none;">
                <div class="qbt-drop-inner">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2 -2v-2"/><path d="M7 9l5 -5l5 5"/><path d="M12 4l0 12"/></svg>
                    <div class="qbt-drop-text">{{ 'qbittorrent.modal_add.drop_text'|trans|raw }}<br><span class="text-muted" style="font-size:.72rem;">{{ 'qbittorrent.modal_add.drop_browse'|trans }}</span></div>
                </div>
                <ul id="qbt-drop-files" class="qbt-drop-files"></ul>
            </div>
        </div>
        <div class="row g-3">
            <div class="col-6">
                <label class="form-label">{{ 'qbittorrent.modal_detail.props.save_path'|trans }}</label>
                <input type="text" class="form-control form-control-sm" id="deluge-add-savepath" placeholder="{{ 'qbittorrent.modal_detail.props.save_path'|trans }}">
            </div>
            <div class="col-6">
                <label class="form-label">{{ 'qbittorrent.modal_add.start_label'|trans }}</label>
                <select class="form-select form-select-sm" id="qbt-add-paused">
                    <option value="false">{{ 'qbittorrent.modal_add.start_now'|trans }}</option>
                    <option value="true">{{ 'qbittorrent.modal_add.start_paused'|trans }}</option>
                </select>
            </div>
        </div>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'qbittorrent.modal_add.cancel'|trans }}</button>
        <button type="button" class="btn btn-primary" id="qbt-add-submit" style="background:#2f67ba;border-color:#2f67ba;">{{ 'qbittorrent.modal_add.submit'|trans }}</button>
    </div>
</div>
</div>
</div>

{# ══════════════════════════════════════════════════════════════════════════
   Delete modal
   ══════════════════════════════════════════════════════════════════════════ #}
<div class="modal modal-blur fade" id="qbt-modal-delete" tabindex="-1">
<div class="modal-dialog modal-sm">
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title text-danger" style="font-size:.9rem;">{{ 'qbittorrent.modal_delete.title'|trans }}</h5>
