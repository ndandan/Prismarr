{#
  Alert banner displayed at the top of section pages when a third-party service
  is unreachable. For the "not configured" case, ServiceRouteGuardSubscriber
  redirects upstream to the wizard, so this banner mainly covers the
  "configured but unreachable" case (401, 5xx, timeout…).

  Expected parameters:
    service        (string)  — readable name (ex: "Radarr")
    wizard_route   (string)  — Symfony wizard route name (ex: "app_setup_managers")
    configured_url (string)  — configured URL (shown to help diagnostics)
    reason         (?string) — 'unreachable' (default), 'not_configured',
                               'auth' (bad API key / credentials) or
                               'host_whitelist' (host blocked by the service)
#}
{% set _reason = reason|default('unreachable') %}
{% set _is_config = _reason == 'not_configured' %}

<div class="alert {{ _is_config ? 'alert-info' : 'alert-danger' }} mb-3" role="alert" data-reason="{{ _reason }}">
  <div class="d-flex align-items-start gap-3">
    <div class="flex-shrink-0" style="margin-top:2px;">
      {% if _is_config %}
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10.325 4.317c.426 -1.756 2.924 -1.756 3.35 0a1.724 1.724 0 0 0 2.573 1.066c1.543 -.94 3.31 .826 2.37 2.37a1.724 1.724 0 0 0 1.065 2.572c1.756 .426 1.756 2.924 0 3.35a1.724 1.724 0 0 0 -1.066 2.573c.94 1.543 -.826 3.31 -2.37 2.37a1.724 1.724 0 0 0 -2.572 1.065c-.426 1.756 -2.924 1.756 -3.35 0a1.724 1.724 0 0 0 -2.573 -1.066c-1.543 .94 -3.31 -.826 -2.37 -2.37a1.724 1.724 0 0 0 -1.065 -2.572c-1.756 -.426 -1.756 -2.924 0 -3.35a1.724 1.724 0 0 0 1.066 -2.573c-.94 -1.543 .826 -3.31 2.37 -2.37c1 .608 2.296 .07 2.572 -1.065z"/>
          <path d="M9 12l2 2l4 -4"/>
        </svg>
      {% else %}
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="9"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
      {% endif %}
    </div>
    <div class="flex-grow-1">
      <h4 class="alert-title mb-1">
        {% if _is_config %}
          {{ 'error.service_banner.title_not_configured'|trans({service: service}) }}
        {% elseif _reason == 'auth' %}
          {{ 'error.service_banner.title_auth'|trans({service: service}) }}
        {% elseif _reason == 'host_whitelist' %}
          {{ 'error.service_banner.title_host_whitelist'|trans({service: service}) }}
        {% else %}
          {{ 'error.service_banner.title_unreachable'|trans({service: service}) }}
        {% endif %}
      </h4>{# 'service' is already plain text (no HTML) — passed through without raw #}
      <div class="text-muted small mb-2">
        {% if _is_config %}
          {{ 'error.service_banner.body_not_configured'|trans({service: service}) }}
        {% elseif _reason == 'auth' %}
          {{ 'error.service_banner.body_auth'|trans({service: service}) }}
        {% elseif _reason == 'host_whitelist' %}
          {% if configured_url is defined and configured_url %}
            {{ 'error.service_banner.body_host_whitelist_url'|trans({service: service, url: configured_url|e('html')})|raw }}
          {% else %}
            {{ 'error.service_banner.body_host_whitelist'|trans({service: service}) }}
          {% endif %}
        {% else %}
          {% if configured_url is defined and configured_url %}
            {{ 'error.service_banner.body_unreachable_url'|trans({url: configured_url|e('html')})|raw }}
          {% else %}
            {{ 'error.service_banner.body_unreachable_no_url'|trans }}
          {% endif %}
        {% endif %}
      </div>
      <div class="d-flex gap-2">
        {% set _target_route = _is_config ? wizard_route : 'admin_settings_index' %}
        <a href="{{ path(_target_route) }}" class="btn btn-sm {{ _is_config ? 'btn-primary' : 'btn-outline-danger' }}">
          {{ _is_config ? 'error.service_banner.cta_configure'|trans({service: service}) : 'error.service_banner.cta_edit'|trans }}
        </a>
        {% if not _is_config %}
          <button type="button" class="btn btn-sm btn-ghost-secondary"
                  onclick="fetch('{{ path('admin_settings_health_invalidate', {service: service|lower}) }}', {method:'POST'}).finally(function(){ window.location.reload(); });">
            {{ 'error.service_banner.cta_retry'|trans }}
          </button>
        {% endif %}
      </div>
    </div>
  </div>
</div>
