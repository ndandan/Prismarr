{# Async-hydrated fragment (#27) — services health chips, rendered by
   DashboardController::widgetHealth into the card's [data-dash-body]. Only
   configured services get a chip (issue #9); none → a neutral message.
   v1.1.0 — services_health is a list: radarr/sonarr expand to one chip per
   enabled instance (chip.name), color pre-set in HealthService::chips(). #}
{% if services_health is empty %}
  <div class="text-center text-secondary py-3">
    {{ 'dashboard.health.none_configured'|trans }}
  </div>
{% else %}
  <div class="service-grid">
    {% set status_dot = {
      up:        'is-up',
      slow:      'is-slow',
      very_slow: 'is-very-slow',
      degraded:  'is-degraded',
      down:      'is-down',
    } %}
    {% for chip in services_health %}
      <div class="service-chip">
        <span class="service-chip-dot {{ status_dot[chip.status]|default('is-unk') }}"></span>
        <div class="flex-fill">
          <div class="service-chip-name" style="color: {{ chip.color|default('#888') }};">{{ chip.name }}</div>
          <div class="service-chip-state">
            {{ ('dashboard.health.status_' ~ chip.status)|trans }}{% if chip.latencyMs is not null %} · {{ chip.latencyMs }} ms{% endif %}
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
{% endif %}
