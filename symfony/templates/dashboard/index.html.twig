{% extends 'base.html.twig' %}
{% import '_icons.html.twig' as ico %}

{% block title %}{{ 'dashboard.title'|trans }}{% endblock %}
{% block page_title %}{% endblock %}
{# #27 — content is async; don't let Turbo cache the dashboard. Otherwise an
   advance visit flashes the stale hydrated snapshot, then re-renders to
   skeletons ("reloads everything"). no-cache makes every visit render the
   shell + skeletons fresh (index() is fast), then the widgets hydrate. #}
{% block head_meta %}<meta name="turbo-cache-control" content="no-cache">{% endblock %}

{% block stylesheets %}
<style>
  /* ── Cards : délimitation plus contrastée ──────────────────────── */
  .dashboard-scope .card {
    border: 1px solid rgba(148, 163, 184, .18);
    box-shadow: 0 4px 18px rgba(0, 0, 0, .25);
    border-radius: 12px;
  }
  [data-bs-theme="light"] .dashboard-scope .card {
    border-color: rgba(0, 0, 0, .1);
    box-shadow: 0 2px 8px rgba(0, 0, 0, .06);
  }
  .dashboard-scope .card-header {
    border-bottom: 1px solid rgba(148, 163, 184, .14);
    padding: 1rem 1.15rem .85rem;
  }
  [data-bs-theme="light"] .dashboard-scope .card-header { border-bottom-color: rgba(0, 0, 0, .07); }
  .dashboard-scope .card-title {
    display: flex; align-items: center; gap: .55rem;
    font-size: .95rem; font-weight: 600;
    margin: 0;
  }
  .card-title-icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 30px; height: 30px; border-radius: 7px;
    background: rgba(var(--tblr-primary-rgb, 99,102,241), .15);
    color: var(--tblr-primary);
    flex-shrink: 0;
  }

  /* Small button shared by card-header & section-header actions
     (Calendrier →, Tout voir →, Découverte →, Gérer →, Paramètres →). */
  .dash-action-btn,
  .row-section-link {
    display: inline-flex; align-items: center; gap: .25rem;
    padding: .25rem .55rem;
    border-radius: 5px;
    background: rgba(var(--tblr-primary-rgb, 99,102,241), .1);
    border: 1px solid rgba(var(--tblr-primary-rgb, 99,102,241), .22);
    color: var(--tblr-primary);
    font-size: .72rem; font-weight: 500;
    text-decoration: none;
    transition: background .15s ease, border-color .15s ease;
  }
  .dash-action-btn:hover,
  .dash-action-btn:focus,
  .row-section-link:hover,
  .row-section-link:focus {
    background: rgba(var(--tblr-primary-rgb, 99,102,241), .2);
    border-color: rgba(var(--tblr-primary-rgb, 99,102,241), .45);
    color: var(--tblr-primary);
    text-decoration: none;
  }

  /* ── Hero banner ─────────────────────────────────────────────────── */
  .hero {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 1.5rem;
    min-height: 560px;
    display: flex; align-items: flex-end;
    padding: 3.5rem 3.5rem 2.75rem;
    color: #fff;
    box-shadow: 0 18px 70px rgba(0,0,0,.55);
  }
  @media (max-width: 768px) {
    .hero { min-height: 440px; padding: 2rem 1.5rem 1.75rem; }
  }
  .hero-bg {
    position: absolute; inset: 0;
    background-size: cover; background-position: center 25%;
    filter: brightness(.6) saturate(1.15);
    transform: scale(1.05);
  }
  .hero-fade {
    position: absolute; inset: 0;
    background: linear-gradient(to top,
      rgba(10,10,15,.98) 0%,
      rgba(10,10,15,.82) 30%,
      rgba(10,10,15,.45) 55%,
      rgba(var(--tblr-primary-rgb),.18) 100%);
  }
  .hero-noBg { background: linear-gradient(135deg, #4338ca 0%, var(--tblr-primary) 50%, #8b5cf6 100%); }
  .hero-inner { position: relative; z-index: 1; width: 100%; }
  .hero-kicker { font-size: .78rem; opacity: .8; letter-spacing: .1em; text-transform: uppercase; margin-bottom: .35rem; font-weight: 500; }
  .hero-greeting {
    font-size: 3rem; font-weight: 800; line-height: 1.05;
    letter-spacing: -0.025em; margin: 0 0 .25rem; color: #fff;
    text-shadow: 0 2px 16px rgba(0,0,0,.5);
  }
  @media (max-width: 768px) { .hero-greeting { font-size: 2.1rem; } }
  .hero-spotlight {
    margin-top: 1.25rem;
    display: block;
    text-decoration: none;
    color: #fff;
    max-width: 640px;
  }
  .hero-spotlight-label {
    display: inline-block;
    font-size: .7rem; font-weight: 600;
    padding: .28rem .7rem;
    background: rgba(var(--tblr-primary-rgb),.28);
    border: 1px solid rgba(var(--tblr-primary-rgb),.55);
    border-radius: 999px;
    text-transform: uppercase; letter-spacing: .08em;
    backdrop-filter: blur(8px);
    margin-bottom: .9rem;
  }
  .hero-spotlight-title {
    font-size: 1.95rem; font-weight: 700; line-height: 1.15;
    letter-spacing: -0.015em;
    color: #fff;
    text-shadow: 0 2px 12px rgba(0,0,0,.5);
    margin-bottom: .6rem;
  }
  @media (max-width: 768px) { .hero-spotlight-title { font-size: 1.5rem; } }
  .hero-spotlight-meta {
    display: flex; flex-wrap: wrap; gap: .6rem .9rem;
    font-size: .8rem; opacity: .8;
    margin-bottom: .75rem;
    align-items: center;
  }
  .hero-spotlight-meta span { display: inline-flex; align-items: center; gap: .25rem; white-space: nowrap; }
  .hero-spotlight-meta .rating { color: #fbbf24; font-weight: 600; }
  .hero-spotlight-meta .chip {
    padding: .15rem .5rem;
    background: rgba(255,255,255,.12);
    border-radius: 4px;
    backdrop-filter: blur(8px);
    font-size: .7rem;
  }
  .hero-spotlight-overview {
    font-size: .88rem;
    line-height: 1.5;
    opacity: .85;
    margin-bottom: 1rem;
    max-width: 620px;
  }
  .hero-spotlight-cta {
    display: inline-flex; align-items: center; gap: .4rem;
    padding: .65rem 1.2rem;
    background: #fff;
    color: #0f0f14;
    font-weight: 600; font-size: .88rem;
    border-radius: 8px;
    text-decoration: none !important;
    box-shadow: 0 4px 14px rgba(0,0,0,.35);
    transition: transform .15s ease, background .15s ease;
  }
  .hero-spotlight-cta:hover,
  .hero-spotlight-cta:focus {
    transform: translateY(-1px);
    background: #e5e7eb;
    color: #0f0f14;
    text-decoration: none !important;
  }
  .hero-stats {
    display: flex; gap: 1.5rem; flex-wrap: wrap;
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255,255,255,.12);
  }
  .hero-stat { display: flex; align-items: center; gap: .6rem; }
  .hero-stat-icon {
    width: 36px; height: 36px; border-radius: 9px;
    display: flex; align-items: center; justify-content: center;
    background: rgba(255,255,255,.12); backdrop-filter: blur(6px);
  }
  .hero-stat-value { font-size: 1.2rem; font-weight: 600; line-height: 1; }
  .hero-stat-label { font-size: .72rem; opacity: .65; margin-top: .15rem; text-transform: uppercase; letter-spacing: .04em; }

  /* ── Mini-calendar (7 days, one column per day) ───────────────── */
  /* The parent `.card` stays at col-12 width. We want each day column
     to shrink gracefully instead of forcing a min-width that overflows
     the card (that produced a scrollbar on tablet/desktop at common
     widths). `min-width: 0` on the grid items + `min-width: 0` already
     set on `.mini-cal-item-body` lets flex children truncate cleanly. */
  .mini-cal {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 8px;
    padding: 1rem;
  }
  .mini-cal-day { min-width: 0; }
  @media (max-width: 576px) {
    /* Stack vertically on phones — 7 skinny columns become unreadable
       below ~400px. */
    .mini-cal { grid-template-columns: 1fr; }
  }

  .mini-cal-day {
    display: flex; flex-direction: column;
    background: var(--tblr-bg-surface-secondary);
    border: 1px solid var(--tblr-border-color);
    border-radius: 10px;
    padding: .6rem .55rem .65rem;
    min-height: 200px;
    transition: border-color .15s ease, box-shadow .15s ease;
  }
  .mini-cal-day.is-today {
    background: rgba(var(--tblr-primary-rgb), .1);
    border-color: rgba(var(--tblr-primary-rgb), .45);
    box-shadow: 0 0 0 1px rgba(var(--tblr-primary-rgb), .15) inset;
  }
  .mini-cal-day-head {
    text-align: center;
    padding: .1rem 0 .45rem;
    border-bottom: 1px dashed var(--tblr-border-color);
    margin-bottom: .55rem;
  }
  .mini-cal-dow {
    font-size: .65rem; font-weight: 700;
    color: var(--tblr-secondary);
    text-transform: uppercase; letter-spacing: .09em;
  }
  .mini-cal-dom {
    font-size: 1.35rem; font-weight: 800;
    color: var(--tblr-body-color); line-height: 1;
    margin-top: .2rem;
  }
  .mini-cal-day.is-today .mini-cal-dow,
  .mini-cal-day.is-today .mini-cal-dom { color: var(--tblr-primary); }

  .mini-cal-items {
    flex: 1; display: flex; flex-direction: column; gap: 4px;
  }
  .mini-cal-more {
    display: block; text-align: center;
    padding: .3rem .4rem;
    font-size: .65rem; font-weight: 600;
    color: var(--tblr-primary);
    background: rgba(var(--tblr-primary-rgb), .08);
    border: 1px dashed rgba(var(--tblr-primary-rgb), .3);
    border-radius: 5px;
    text-decoration: none;
    transition: background .12s ease, border-color .12s ease;
  }
  .mini-cal-more:hover {
    background: rgba(var(--tblr-primary-rgb), .18);
    border-color: rgba(var(--tblr-primary-rgb), .55);
    color: var(--tblr-primary);
  }
  .mini-cal-item {
    display: flex; align-items: stretch; gap: 0;
    background: var(--tblr-bg-surface);
    border: 1px solid var(--tblr-border-color);
    border-radius: 6px;
    overflow: hidden;
    text-decoration: none !important;
    color: var(--tblr-body-color);
    min-width: 0;
    transition: transform .1s ease, border-color .12s ease, box-shadow .12s ease;
    cursor: pointer;
  }
  @media (hover: hover) and (pointer: fine) {
    .mini-cal-item:hover {
      transform: translateY(-1px);
      border-color: rgba(var(--tblr-primary-rgb), .5);
      box-shadow: 0 4px 10px rgba(0,0,0,.15);
      color: var(--tblr-body-color);
    }
  }
  .mini-cal-item-thumb {
    width: 30px; flex-shrink: 0;
    background-size: cover; background-position: center;
    background-color: var(--tblr-bg-surface-secondary);
  }
  .mini-cal-item-thumb.is-placeholder {
    display: flex; align-items: center; justify-content: center;
    font-size: .85rem;
  }
  .mini-cal-item-body { min-width: 0; flex: 1; padding: .3rem .45rem; }
  .mini-cal-item-type {
    display: inline-block;
    font-size: .55rem; font-weight: 700;
    padding: .05rem .3rem; border-radius: 2px;
    text-transform: uppercase; letter-spacing: .04em;
    margin-bottom: .1rem;
  }
  .mini-cal-item-type.is-movie   { background: rgba(245,158,11,.18); color: #f59e0b; }
  .mini-cal-item-type.is-episode { background: rgba(14,165,233,.18); color: #0ea5e9; }
  .mini-cal-item-title {
    font-size: .72rem; font-weight: 600; line-height: 1.25;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .mini-cal-item-meta {
    font-size: .6rem; color: var(--tblr-secondary); line-height: 1.2;
    margin-top: .12rem;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .mini-cal-empty {
    font-size: .7rem; color: var(--tblr-secondary); opacity: .55;
    text-align: center; margin: auto 0; padding: 1rem 0;
    font-style: italic;
  }

  /* ── List item inside .card (reuses Tabler spacing) ──────────────── */
  .dash-list .list-group-item {
    display: flex; align-items: center; gap: .85rem;
    padding: .7rem 1rem;
  }
  .dash-list .list-group-item + .list-group-item { border-top: 1px solid var(--tblr-border-color); }
  .dash-list .list-group-item:hover { background: rgba(var(--tblr-primary-rgb, 99, 102, 241), .05); }
  .dash-poster {
    width: 40px; height: 60px; border-radius: 5px;
    object-fit: cover; flex-shrink: 0;
    background: var(--tblr-bg-surface-secondary);
    box-shadow: 0 2px 6px rgba(0,0,0,.2);
  }
  .dash-poster-placeholder {
    width: 40px; height: 60px; border-radius: 5px;
    display: flex; align-items: center; justify-content: center;
    background: var(--tblr-bg-surface-secondary);
    color: var(--tblr-secondary);
    font-size: 1.2rem; flex-shrink: 0;
  }
  .dash-item-body { flex: 1; min-width: 0; }
  .dash-item-title { font-weight: 500; font-size: .88rem; line-height: 1.25; color: var(--tblr-body-color); }
  .dash-item-sub { font-size: .75rem; color: var(--tblr-secondary); margin-top: .2rem; }
  .dash-item-aside { text-align: right; flex-shrink: 0; }
  .dash-date-rel { font-weight: 600; font-size: .82rem; color: var(--tblr-body-color); }
  .dash-date-rel.is-soon { color: var(--tblr-primary); }
  .dash-date-time { font-size: .68rem; color: var(--tblr-secondary); margin-top: .1rem; }
  .dash-badge-inline {
    display: inline-block;
    padding: .1rem .4rem; border-radius: 3px; font-size: .65rem; font-weight: 500;
    background: rgba(var(--tblr-primary-rgb, 99, 102, 241), .18);
    color: var(--tblr-primary); margin-left: .25rem;
  }

  /* ── Poster tiles (trending + recent additions) ─────────────────── */
  .row-section { margin-bottom: 1.75rem; }
  .row-section-head {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: .8rem;
    padding-bottom: .55rem;
    border-bottom: 1px solid rgba(148,163,184,.14);
  }
  [data-bs-theme="light"] .row-section-head { border-bottom-color: rgba(0,0,0,.08); }
  .row-section-title {
    font-size: 1rem; font-weight: 600; margin: 0; color: var(--tblr-body-color);
    display: flex; align-items: center; gap: .55rem;
  }
  .row-section-title-icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 30px; height: 30px; border-radius: 7px;
    background: rgba(var(--tblr-primary-rgb, 99,102,241), .15);
    color: var(--tblr-primary);
  }

  /* Fixed column counts that always divide the 16-item payload cleanly →
     no dangling tiles at the end of the last row. Mobile 2 cols (= 8 rows),
     tablet 4 cols (= 4 rows), desktop 8 cols (= 2 full rows of 8). */
  .poster-row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: .75rem;
  }
  @media (min-width: 576px) { .poster-row { grid-template-columns: repeat(4, 1fr); } }
  @media (min-width: 992px) { .poster-row { grid-template-columns: repeat(8, 1fr); } }
  .poster-tile {
    display: flex; flex-direction: column;
    text-decoration: none !important; color: inherit;
    background: var(--tblr-bg-surface);
    border: 1px solid rgba(148,163,184,.18);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,.18);
    transition: transform .15s ease, border-color .15s ease, box-shadow .15s ease;
  }
  [data-bs-theme="light"] .poster-tile {
    border-color: rgba(0,0,0,.1);
    box-shadow: 0 1px 4px rgba(0,0,0,.06);
  }
  /* Keep hover lift only on pointer-capable devices — tap-hover on mobile
     leaves the tile in a "stuck-selected" state until another tap. */
  @media (hover: hover) and (pointer: fine) {
    .poster-tile:hover,
    .poster-tile:focus,
    .poster-tile:hover .poster-tile-title,
    .poster-tile:hover .poster-tile-sub {
      transform: translateY(-2px);
      border-color: rgba(var(--tblr-primary-rgb, 99,102,241), .45);
      box-shadow: 0 6px 16px rgba(var(--tblr-primary-rgb, 99,102,241), .22);
      color: inherit;
      text-decoration: none !important;
    }
  }
  .poster-tile-title, .poster-tile-sub { text-decoration: none !important; }
  .poster-tile-wrap { position: relative; }
  .poster-tile-img {
    display: block; width: 100%; aspect-ratio: 2/3; object-fit: cover;
    background: var(--tblr-bg-surface-secondary);
  }
  .poster-tile-placeholder {
    width: 100%; aspect-ratio: 2/3;
    display: flex; align-items: center; justify-content: center;
    background: var(--tblr-bg-surface-secondary);
    color: var(--tblr-secondary);
    font-size: 1.4rem;
  }
  .poster-tile-info {
    padding: .45rem .55rem .55rem;
  }
  .poster-tile-title { font-size: .76rem; font-weight: 600; line-height: 1.25; color: var(--tblr-body-color); }
  .poster-tile-sub { font-size: .66rem; color: var(--tblr-secondary); margin-top: .12rem; }
  .poster-tile-badge {
    position: absolute; top: .35rem; left: .35rem;
    padding: .12rem .35rem; border-radius: 3px; font-size: .6rem;
    background: rgba(0,0,0,.78); color: #fff; backdrop-filter: blur(6px);
    font-weight: 600; letter-spacing: .02em;
  }
  .poster-tile-badge.is-downloaded { background: rgba(34,197,94,.92); }

  /* ── Service health grid ────────────────────────────────────────── */
  .service-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: .6rem;
  }
  .service-chip {
    display: flex; align-items: center; gap: .6rem;
    padding: .6rem .75rem; border-radius: 8px;
    background: var(--tblr-bg-surface-secondary);
    border: 1px solid var(--tblr-border-color);
  }
  .service-chip-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .service-chip-dot.is-ok { background: #22c55e; box-shadow: 0 0 8px rgba(34,197,94,.55); }
  .service-chip-dot.is-ko { background: #ef4444; }
  .service-chip-dot.is-unk { background: #6b7280; }
  .service-chip-dot.is-up { background: #22c55e; box-shadow: 0 0 8px rgba(34,197,94,.55); }
  .service-chip-dot.is-slow { background: #f59e0b; box-shadow: 0 0 8px rgba(245,158,11,.5); }
  .service-chip-dot.is-very-slow { background: #f97316; box-shadow: 0 0 8px rgba(249,115,22,.5); }
  .service-chip-dot.is-degraded { background: #94a3b8; }
  .service-chip-dot.is-down { background: #ef4444; }
  .service-chip-name { font-size: .82rem; font-weight: 500; line-height: 1; }
  .service-chip-state { font-size: .68rem; color: var(--tblr-secondary); margin-top: .15rem; }
  /* Async widget hydration skeletons (#27) */
  .dash-skel { pointer-events: none; }
  .dash-skel .poster-tile-wrap { aspect-ratio: 2/3; }
  .dash-skel .poster-tile-wrap,
  .dash-skel-line {
    background: linear-gradient(90deg, var(--tblr-bg-surface-secondary) 25%, rgba(128,128,128,.18) 37%, var(--tblr-bg-surface-secondary) 63%);
    background-size: 400% 100%;
    animation: dash-shimmer 1.4s ease infinite;
    border-radius: .5rem;
  }
  .dash-skel-line { height: .7rem; width: 80%; margin-top: .45rem; border-radius: .25rem; }
  @keyframes dash-shimmer { 0% { background-position: 100% 0; } 100% { background-position: -100% 0; } }

  /* ── Mobile/tablet readability floor (responsive audit 2026-06-29) ────
     Floor sub-11px dashboard text at 11px (.6875rem) below the lg
     breakpoint. Same selectors as above so specificity matches; desktop
     (≥992px) keeps the original sizes. */
  @media (max-width: 991.98px) {
    .mini-cal-dow,
    .mini-cal-more,
    .mini-cal-item-type,
    .mini-cal-item-meta,
    .dash-date-time,
    .dash-badge-inline,
    .poster-tile-sub,
    .poster-tile-badge,
    .service-chip-state { font-size: .6875rem; }
  }

  /* ── Tap targets (responsive audit 2026-06-29) ────────────────────────
     The small header/section arrow links measure ~26px tall; on touch
     devices give them a ≥44px hit area. Coarse-pointer only, desktop
     rendering unchanged. */
  @media (pointer: coarse) {
    .dash-action-btn,
    .row-section-link { min-height: 44px; padding-top: .3rem; padding-bottom: .3rem; }
  }
</style>
{% include 'dashboard/_plex_styles.html.twig' %}
{% endblock %}

{% block body %}
{%- set now_ymd = 'today'|date('Y-m-d') -%}
{%- set tomorrow_ymd = '+1 day'|date('Y-m-d') -%}
{%- set hour = 'now'|date('H')|number_format -%}
{%- set greeting_key = hour < 5 ? 'dashboard.greeting.evening' : (hour < 12 ? 'dashboard.greeting.morning' : (hour < 18 ? 'dashboard.greeting.afternoon' : 'dashboard.greeting.evening')) -%}
{%- set greeting = greeting_key|trans -%}
{%- set user = app.user -%}
{%- set username = user ? (user.displayName ?? user.email ?? 'admin') : 'admin' -%}

<div class="page-body dashboard-scope">
  <div class="container-xl">

    {# ── Hero: welcome + spotlight/stats (async-hydrated, #27) ─────────
       Greeting + clock paint instantly; the spotlight and library stats load
       from app_dashboard_widget_hero after first paint. The fanart background
       image was dropped in favour of the gradient to keep the async hero
       robust (the bg can't be injected into a sub-container cleanly). #}
    <div class="hero hero-noBg">
      <div class="hero-fade"></div>
      <div class="hero-inner">
        {% set weekday = ['dashboard.weekdays.mon','dashboard.weekdays.tue','dashboard.weekdays.wed','dashboard.weekdays.thu','dashboard.weekdays.fri','dashboard.weekdays.sat','dashboard.weekdays.sun']['now'|date('N') - 1]|trans %}
        <p class="hero-kicker">{{ weekday }} · {{ 'now'|prismarr_date }} · {{ 'now'|prismarr_time }}</p>
        <h1 class="hero-greeting">{{ greeting }}, {{ username }}</h1>
        <div data-dash-widget="hero" data-dash-url="{{ path('app_dashboard_widget_hero') }}" data-dash-body>
          <div class="hero-stats">
            {% for i in 1..3 %}
              <div class="hero-stat" aria-hidden="true">
                <div class="dash-skel-line" style="width:38px;height:38px;border-radius:8px;margin:0;"></div>
                <div>
                  <div class="dash-skel-line" style="width:44px;height:1.1rem;margin:0;"></div>
                  <div class="dash-skel-line" style="width:64px;margin-top:.35rem;"></div>
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>

    {# ── Prochaines sorties (mini-calendrier, async-hydraté #27) ──────
       Issue #9 — masqué quand ni Radarr ni Sonarr ne sont configurés. Le
       corps (mini-cal ou message vide) est chargé via
       app_dashboard_widget_upcoming après le first paint. #}
    {% if services_configured.radarr or services_configured.sonarr %}
    <div class="row row-cards mb-3" data-dash-widget="upcoming" data-dash-url="{{ path('app_dashboard_widget_upcoming') }}">
      <div class="col-12">
        <div class="card">
          <div class="card-header">
            <h3 class="card-title">
              <span class="card-title-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              </span>
              {{ 'dashboard.upcoming.title'|trans }}
            </h3>
            <div class="card-actions">
              <a href="{{ path('app_calendrier') }}" class="dash-action-btn">{{ 'dashboard.upcoming.calendar_cta'|trans }}</a>
            </div>
          </div>
          <div data-dash-body>
            <div class="card-body text-center text-secondary py-4"><span class="spinner-border spinner-border-sm"></span></div>
          </div>
        </div>
      </div>
    </div>
    {% endif %}

    {# ── Requests + Services health ─────────────────────────────────── #}
    {# Seerr requests masqué quand le service n'est pas configuré.
       La grid se réduit alors à la seule carte "Services health". #}
    <div class="row row-cards mb-3">
      {% if services_configured.jellyseerr %}
      <div class="col-12 col-lg-6" data-dash-widget="requests" data-dash-url="{{ path('app_dashboard_widget_requests') }}">
        <div class="card h-100">
          <div class="card-header">
            <h3 class="card-title">
              <span class="card-title-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12M9 12l3 3l3 -3"/><path d="M21 14v4a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-4"/></svg>
              </span>
              {{ 'dashboard.requests.title'|trans }}
            </h3>
            <div class="card-actions">
              <a href="{{ path('jellyseerr_index') }}" class="dash-action-btn">{{ 'dashboard.requests.manage_cta'|trans }}</a>
            </div>
          </div>
          <div class="list-group list-group-flush dash-list" data-dash-body>
            <div class="card-body text-center text-secondary py-4"><span class="spinner-border spinner-border-sm"></span></div>
          </div>
        </div>
      </div>
      {% endif %}

      {# Services health card spans the full width when the requests card is
         hidden (no Seerr), otherwise sits next to it on the right. #}
      <div class="col-12 {% if services_configured.jellyseerr %}col-lg-6{% endif %}" data-dash-widget="health" data-dash-url="{{ path('app_dashboard_widget_health') }}">
        <div class="card h-100">
          <div class="card-header">
            <h3 class="card-title">
              <span class="card-title-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12h4l3 -9l4 18l3 -9h4"/></svg>
              </span>
              {{ 'dashboard.health.title'|trans }}
            </h3>
            <div class="card-actions">
              <a href="{{ path('admin_settings_index') }}" class="dash-action-btn">{{ 'dashboard.health.settings_cta'|trans }}</a>
            </div>
          </div>
          <div class="card-body" data-dash-body>
            <div class="text-center text-secondary py-3"><span class="spinner-border spinner-border-sm"></span></div>
          </div>
        </div>
      </div>
    </div>

    {# ── Current Plex activity (Tautulli, async-hydrated) ────────────
       Hidden entirely when Tautulli isn't configured/enabled (issue #9
       pattern). The body loads from app_dashboard_widget_plex after first
       paint and refreshes every 10s (see the javascripts block); an empty
       fragment hides the whole card client-side. #}
    {% if services_configured.tautulli %}
    <div class="row row-cards mb-3">
      <div class="col-12" id="plex-activity" data-dash-widget="plex" data-dash-url="{{ path('app_dashboard_widget_plex') }}">
        <div class="card h-100">
          <div class="card-header">
            <h3 class="card-title">
              <span class="card-title-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12h4l3 8l4 -16l3 8h4"/></svg>
              </span>
              {{ 'dashboard.plex.title'|trans }}
            </h3>
            <div class="card-actions">
              <a href="{{ path('admin_settings_index') }}" class="dash-action-btn">{{ 'dashboard.plex.settings_cta'|trans }}</a>
            </div>
          </div>
          <div class="card-body" data-dash-body>
            <div class="text-center text-secondary py-4"><span class="spinner-border spinner-border-sm"></span></div>
          </div>
        </div>
      </div>
    </div>
    {% endif %}

    {# ── Ma watchlist (perso, DB locale) ────────────────────────────── #}
    {% if watchlist is not empty %}
    <div class="row-section">
      <div class="row-section-head">
        <h2 class="row-section-title">
          <span class="row-section-title-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 17.75l-6.172 3.245l1.179 -6.873l-5 -4.867l6.9 -1l3.086 -6.253l3.086 6.253l6.9 1l-5 4.867l1.179 6.873z"/></svg>
          </span>
          {{ 'dashboard.watchlist.title'|trans }}
        </h2>
        <a href="{{ path('tmdb_watchlist') }}" class="row-section-link">{{ 'dashboard.watchlist.view_all'|trans }}</a>
      </div>
      <div class="poster-row">
        {% for w in watchlist %}
          <a href="{{ path('tmdb_index') }}?detail={{ w.mediaType }}/{{ w.tmdbId }}" class="poster-tile"
             data-ql-trigger
             data-ql-source="tmdb"
             data-ql-type="{{ w.mediaType == 'tv' ? 'tv' : 'movie' }}"
             data-ql-id="{{ w.tmdbId }}">
            <div class="poster-tile-wrap">
              {% if w.poster %}
                <img src="https://image.tmdb.org/t/p/w342{{ w.poster }}" alt="{{ w.title }}" loading="lazy" class="poster-tile-img">
              {% else %}
                <div class="poster-tile-placeholder">{{ w.mediaType == 'tv' ? ico.icon('device-tv', '', 28) : ico.icon('movie', '', 28) }}</div>
              {% endif %}
              {% if w.vote and w.vote > 0 %}
                <span class="poster-tile-badge">{{ ico.icon('star-filled', '', 12) }} {{ w.vote|round(1) }}</span>
              {% endif %}
            </div>
            <div class="poster-tile-info">
              <div class="poster-tile-title text-truncate">{{ w.title }}</div>
              <div class="poster-tile-sub">
                {{ w.mediaType == 'tv' ? 'dashboard.type.series'|trans : 'dashboard.type.film'|trans }}
                {%- if w.year %} · {{ w.year }}{% endif -%}
              </div>
            </div>
          </a>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    {# ── TMDb trending (async-hydrated, #27) ─────────────────────────
       Issue #9 — still hidden entirely when TMDb isn't configured. The
       tiles load from app_dashboard_widget_recommendations after first paint;
       an empty fragment hides the section. #}
    {% if services_configured.tmdb %}
    <div class="row-section" data-dash-widget="recommendations" data-dash-url="{{ path('app_dashboard_widget_recommendations') }}">
      <div class="row-section-head">
        <h2 class="row-section-title">
          <span class="row-section-title-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 17 9 11 13 15 21 7"/><polyline points="14 7 21 7 21 14"/></svg>
          </span>
          {{ 'dashboard.trending.title'|trans }}
        </h2>
        <a href="{{ path('tmdb_index') }}" class="row-section-link">{{ 'dashboard.trending.discover_cta'|trans }}</a>
      </div>
      <div class="poster-row" data-dash-body>
        {% for i in 1..7 %}<div class="poster-tile dash-skel" aria-hidden="true"><div class="poster-tile-wrap"></div><div class="poster-tile-info"><div class="dash-skel-line"></div></div></div>{% endfor %}
      </div>
    </div>
    {% endif %}

    {# ── Recent library additions (async-hydrated, #27) ──────────────
       The section shell + skeleton paint instantly; the poster tiles are
       fetched from app_dashboard_widget_recent after first paint and
       injected into [data-dash-body]. An empty fragment hides the section.
       Issue #9 — still skipped entirely when neither service is configured. #}
    {% if services_configured.radarr or services_configured.sonarr %}
    <div class="row-section" data-dash-widget="recent" data-dash-url="{{ path('app_dashboard_widget_recent') }}">
      <div class="row-section-head">
        <h2 class="row-section-title">
          <span class="row-section-title-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M9 12l2 2l4 -4"/></svg>
          </span>
          {{ 'dashboard.recent.title'|trans }}
        </h2>
      </div>
      <div class="poster-row" data-dash-body>
        {% for i in 1..7 %}<div class="poster-tile dash-skel" aria-hidden="true"><div class="poster-tile-wrap"></div><div class="poster-tile-info"><div class="dash-skel-line"></div></div></div>{% endfor %}
      </div>
    </div>
    {% endif %}

  </div>
</div>

{% include 'dashboard/_plex_info_modal.html.twig' with {} only %}
{% endblock %}

{% block javascripts %}
<script>
  (function () {
    // Async dashboard widget hydration (#27): after first paint, fetch each
    // [data-dash-widget] fragment and swap it into its [data-dash-body].
    // Turbo-safe (IIFE + var + .then); the data-dash-loaded guard stops a
    // re-fired turbo:load from double-fetching.
    function applyFragment(node, html) {
      var trimmed = (html || '').trim();
      if (!trimmed) { node.style.display = 'none'; return; }
      var body = node.querySelector('[data-dash-body]') || node;
      body.innerHTML = trimmed;
      // Hero fanart: lift the injected bg up to the .hero so it covers the
      // whole hero (it can't sit inside .hero-inner), dropping the gradient.
      var bg = body.querySelector('[data-dash-hero-bg]');
      if (bg) {
        var hero = node.closest('.hero');
        if (hero) { hero.insertBefore(bg, hero.firstChild); hero.classList.remove('hero-noBg'); }
      }
    }

    // Failure ≠ empty: an empty 200 body means "section not applicable" and
    // hides the node (contract above), but a non-OK response or network error
    // must stay visible — a monitoring dashboard may never answer "is
    // everything OK?" by removing the evidence. Render a retryable state
    // in the card body instead.
    function applyFailure(node) {
      var body = node.querySelector('[data-dash-body]') || node;
      body.innerHTML =
        '<div class="text-center text-secondary py-3" data-dash-error>' +
          '<div class="mb-2">{{ 'dashboard.widget_error.unreachable'|trans|e('js') }}</div>' +
          '<button type="button" class="btn btn-sm btn-outline-secondary" data-dash-retry>{{ 'common.action.retry'|trans|e('js') }}</button>' +
        '</div>';
    }

    function hydrateNode(node) {
      if (node.dataset.dashLoaded === '1') return;
      node.dataset.dashLoaded = '1';
      fetch(node.dataset.dashUrl, { headers: { 'X-Requested-With': 'fetch' }, credentials: 'same-origin' })
        .then(function (r) {
          if (!r.ok) { applyFailure(node); return; }
          return r.text().then(function (html) { applyFragment(node, html); });
        })
        .catch(function () { applyFailure(node); });
    }

    function hydrateDashWidgets() {
      var nodes = document.querySelectorAll('[data-dash-widget][data-dash-url]');
      for (var i = 0; i < nodes.length; i++) { hydrateNode(nodes[i]); }
    }
    document.addEventListener('turbo:load', hydrateDashWidgets);
    if (document.readyState !== 'loading') { hydrateDashWidgets(); }

    // Retry: delegated + bound once per session (window guard) — this block
    // re-executes on every Turbo visit, so a bare addEventListener would stack.
    if (!window._dashRetryBound) {
      window._dashRetryBound = true;
      document.addEventListener('click', function (e) {
        var btn = e.target.closest('[data-dash-retry]');
        if (!btn) return;
        var node = btn.closest('[data-dash-widget]');
        if (!node) return;
        node.dataset.dashLoaded = '';
        var body = node.querySelector('[data-dash-body]') || node;
        body.innerHTML = '<div class="text-center text-secondary py-3"><span class="spinner-border spinner-border-sm"></span></div>';
        hydrateNode(node);
      });
    }

    // Keep the services-health widget live instead of frozen at first paint:
    // re-fetch just that fragment on an interval. It's cheap — isHealthy() is
    // 10s-cached server-side. Turbo-safe singleton (window._dashHealthTimer) so
    // navigating away and back doesn't stack timers; skipped while the tab is
    // hidden so a background dashboard isn't polling.
    function refreshHealth() {
      if (document.hidden) return;
      var node = document.querySelector('[data-dash-widget="health"][data-dash-url]');
      if (!node) return;
      fetch(node.dataset.dashUrl, { headers: { 'X-Requested-With': 'fetch' }, credentials: 'same-origin' })
        .then(function (r) { return r.ok ? r.text() : ''; })
        .then(function (html) { if ((html || '').trim()) applyFragment(node, html); })
        .catch(function () {});
    }
    if (window._dashHealthTimer) { clearInterval(window._dashHealthTimer); }
    window._dashHealthTimer = setInterval(refreshHealth, 30000);

    // Same live-refresh pattern for the Plex activity widget, but on a tighter
    // 10s cadence (stream progress/state move fast). Cheap server-side:
    // TautulliClient is 10s-circuit-breaker-cached and the call is read-only.
    // Skipped while the tab is hidden; re-fetched fragment fails open so a
    // down Tautulli can't break the loop.
    function refreshPlex() {
      if (document.hidden) return;
      var node = document.querySelector('[data-dash-widget="plex"][data-dash-url]');
      if (!node) return;
      fetch(node.dataset.dashUrl, { headers: { 'X-Requested-With': 'fetch' }, credentials: 'same-origin' })
        .then(function (r) { return r.ok ? r.text() : ''; })
        .then(function (html) { if ((html || '').trim()) { applyFragment(node, html); applyPlexTab(node.querySelector('[data-dash-body]') || node); } })
        .catch(function () {});
    }
    if (window._dashPlexTimer) { clearInterval(window._dashPlexTimer); }
    window._dashPlexTimer = setInterval(refreshPlex, 10000);

    // Plex widget tabs: client-side pane toggle, remembers the active tab so the
    // 10s fragment refresh doesn't snap the user back to "Now playing".
    function applyPlexTab(scope) {
      if (!scope) return;
      var want = window._plexActiveTab;
      if (!want) return;
      scope.querySelectorAll('[data-plex-tab]').forEach(function (a) {
        a.classList.toggle('active', a.getAttribute('data-plex-tab') === want);
      });
      scope.querySelectorAll('[data-plex-pane]').forEach(function (p) {
        p.style.display = (p.getAttribute('data-plex-pane') === want) ? '' : 'none';
      });
    }
    if (!window._plexTabsDelegated) {
      window._plexTabsDelegated = true;
      document.addEventListener('click', function (e) {
        var tab = e.target.closest('[data-plex-tab]');
        if (!tab) return;
        e.preventDefault();
        window._plexActiveTab = tab.getAttribute('data-plex-tab');
        var widget = tab.closest('[data-dash-widget="plex"]');
        applyPlexTab(widget ? (widget.querySelector('[data-dash-body]') || widget) : document);
      });
    }

    document.addEventListener('turbo:before-render', function () {
      if (window._dashHealthTimer) { clearInterval(window._dashHealthTimer); window._dashHealthTimer = null; }
      if (window._dashPlexTimer) { clearInterval(window._dashPlexTimer); window._dashPlexTimer = null; }
    });

  })();
</script>
{% endblock %}
