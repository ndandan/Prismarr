{% extends 'base.html.twig' %}

{% import '_icons.html.twig' as ico %}

{% block title %}{{ 'admin.page.title'|trans }}{% endblock %}

{% block stylesheets %}
<style>
  .settings-page {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 2.5rem;
    align-items: start;
  }
  @media (max-width: 960px) {
    .settings-page { grid-template-columns: 1fr; gap: 1rem; }
  }

  .settings-nav {
    position: sticky;
    top: calc(var(--tblr-navbar-height, 3.5rem) + 1rem);
    align-self: start;
    max-height: calc(100vh - 5rem);
    overflow-y: auto;
    padding: .25rem 0;
  }
  @media (max-width: 960px) {
    .settings-nav {
      position: static;
      max-height: none;
      border-bottom: 1px solid rgba(255,255,255,.08);
      padding-bottom: 1rem;
      margin-bottom: .5rem;
    }
  }

  .settings-nav-title {
    font-size: .7rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--tblr-secondary);
    padding: 0 .75rem;
    margin-bottom: .5rem;
  }

  .settings-nav a {
    display: flex;
    align-items: center;
    gap: .55rem;
    padding: .5rem .75rem;
    border-radius: 6px;
    font-size: .88rem;
    color: var(--tblr-body-color);
    text-decoration: none;
    transition: background .15s ease, color .15s ease;
  }
  .settings-nav a:hover { background: rgba(var(--tblr-primary-rgb),.08); color: inherit; }
  .settings-nav a.active {
    background: rgba(var(--tblr-primary-rgb),.15);
    color: #818cf8;
    font-weight: 600;
  }
  .settings-nav a svg {
    width: 16px; height: 16px; flex-shrink: 0;
    opacity: .7;
  }

  .settings-nav-support {
    margin-top: .75rem;
    padding-top: .75rem;
    border-top: 1px solid rgba(255,255,255,.08);
  }

  .settings-content { min-width: 0; }

  .settings-header { margin-bottom: 1.5rem; }
  .settings-header h1 {
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-bottom: .35rem;
  }
  .settings-header .text-secondary { font-size: .9rem; }

  /* Sections work as tabs: only the active one is visible. Click on a
     .settings-nav link swaps which section has `.is-active`. */
  .settings-group { display: none; margin-bottom: 2.5rem; }
  .settings-group.is-active { display: block; }
  .settings-group-title {
    font-size: .75rem;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--tblr-secondary);
    margin-bottom: .35rem;
    padding-bottom: .35rem;
    border-bottom: 1px solid rgba(255,255,255,.06);
  }
  .settings-group-desc {
    font-size: .82rem;
    color: var(--tblr-secondary);
    margin-bottom: 1rem;
  }
  [data-bs-theme="light"] .settings-group-title {
    border-bottom-color: rgba(0,0,0,.08);
  }

  .service-card {
    background: rgba(255,255,255,.02);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 10px;
    padding: 1.1rem 1.25rem;
    transition: border-color .15s ease;
  }
  [data-bs-theme="light"] .service-card {
    background: #ffffff;
    border-color: rgba(0,0,0,.08);
    box-shadow: 0 1px 3px rgba(0,0,0,.03);
  }
  .service-card + .service-card { margin-top: 1rem; }
  .service-card:focus-within { border-color: rgba(var(--tblr-primary-rgb),.55); }

  /* Two-column layout for the service cards so the list doesn't grow into a
     very tall single column. Collapses to one column under ~700px; the grid
     gap replaces the stacked margin, and align-items:start keeps a short card
     from stretching to match a tall neighbour. */
  .service-grid-2col {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1rem;
    align-items: start;
  }
  .service-grid-2col .service-card { margin-top: 0; }
  /* Multi-instance cards (Radarr/Sonarr) hold a 6-column table that can't fit
     a half-width column, so they span the full row; only the simple URL+key
     cards share the two columns. */
  .service-grid-2col .service-card--wide { grid-column: 1 / -1; }
  /* The 6-column instance table can't shrink to phone width, so let it scroll
     horizontally inside the card instead of overflowing the layout. */
  .instance-list { overflow-x: auto; }
  .instance-list > table { min-width: 640px; }

  .service-card-head {
    display: flex;
    align-items: center;
    gap: .7rem;
    margin-bottom: .9rem;
  }
  .service-card-icon {
    width: 34px; height: 34px;
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    flex: 0 0 34px;
    color: #fff;
  }
  /* Real service logos sit on a light chip (full-colour marks would vanish on
     their own brand colour); the brand colour stays as a thin ring so the
     visual association is kept. --brand is set inline per service. */
  .service-card-icon--logo {
    background: #fff;
    padding: 5px;
    box-shadow: inset 0 0 0 1.5px color-mix(in srgb, var(--brand, #cbd5e1) 55%, transparent);
  }
  .service-card-icon--logo img { width: 100%; height: 100%; object-fit: contain; display: block; }
  .service-card-title { font-weight: 600; font-size: 1rem; margin: 0; line-height: 1.2; }
  .service-card-sub { font-size: .78rem; color: var(--tblr-secondary); margin: .1rem 0 0 0; }
  .service-card-actions { margin-left: auto; display: flex; align-items: center; gap: .5rem; }

  .sidebar-visibility-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: .5rem .75rem;
  }
  .sidebar-visibility-row { margin-bottom: 0; }
  .sidebar-visibility-row .form-check-label { font-size: .9rem; }

  .status-pill {
    font-size: .7rem; font-weight: 500;
    padding: .2rem .55rem; border-radius: 999px;
    background: rgba(255,255,255,.06); color: var(--tblr-secondary); white-space: nowrap;
  }
  .status-pill.ok      { background: rgba(34,197,94,.15);   color: #22c55e; }
  .status-pill.ko      { background: rgba(239,68,68,.15);   color: #ef4444; }
  .status-pill.testing { background: rgba(var(--tblr-primary-rgb),.15);  color: var(--tblr-primary); }

  .field-row { margin-bottom: .75rem; }
  .field-row:last-child { margin-bottom: 0; }
  .field-row label {
    display: block;
    font-size: .78rem; font-weight: 500; letter-spacing: .02em; opacity: .75;
    margin-bottom: .3rem;
  }

  .secret-wrapper { position: relative; }
  .secret-wrapper input {
    padding-right: 2.4rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, monospace;
    font-size: .85rem;
  }
  .secret-toggle {
    position: absolute; right: .55rem; top: 50%; transform: translateY(-50%);
    background: transparent; border: 0; padding: 0;
    cursor: pointer; color: inherit; opacity: .5;
    display: inline-flex; align-items: center;
    transition: opacity .15s ease;
  }
  .secret-toggle:hover { opacity: .95; }
  .secret-toggle svg { width: 16px; height: 16px; }

  /* "Clear" button next to qBit user/password (issue #10 — reverse-proxy
     setups need to deliberately wipe these credentials; the default
     empty-value guard would otherwise silently restore the previous value). */
  .field-clear {
    display: inline-flex; align-items: center; gap: .25rem;
    margin-top: .35rem;
    padding: .15rem .5rem;
    border: 1px solid var(--tblr-border-color);
    background: transparent;
    border-radius: 5px;
    font-size: .68rem; font-weight: 500;
    color: var(--tblr-secondary);
    cursor: pointer;
    transition: border-color .15s ease, color .15s ease;
  }
  .field-clear:hover { border-color: #ef4444; color: #ef4444; }
  .field-clear svg { width: 12px; height: 12px; }
  .field-row.is-cleared input { opacity: .55; font-style: italic; }

  .settings-footer {
    position: sticky; bottom: 0;
    padding: 1rem 0 1.5rem;
    background: linear-gradient(to top, var(--tblr-body-bg) 65%, transparent);
    display: flex; justify-content: flex-end; gap: .5rem;
    margin-top: 1rem;
  }

  /* Display preferences grid inside the "Affichage" card */
  .display-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.1rem;
  }
  @media (min-width: 768px) {
    .display-grid { grid-template-columns: 1fr 1fr; }
  }
  .display-row { display: flex; flex-direction: column; gap: .35rem; }
  .display-label {
    font-size: .8rem; font-weight: 500; opacity: .85;
    margin-bottom: 0;
  }
  .display-help { font-size: .72rem; opacity: .55; margin: .1rem 0 0; }
  /* Languages section: dense table per service block. */
  .lang-svc-block { margin-bottom: 1.4rem; }
  .lang-svc-block:last-child { margin-bottom: 0; }
  .lang-svc-head {
    display: flex; align-items: center; gap: .5rem;
    margin-bottom: .55rem; padding-bottom: .4rem;
    border-bottom: 1px solid var(--tblr-border-color);
  }
  .lang-svc-dot {
    display: inline-block; width: 8px; height: 8px;
    border-radius: 50%; flex-shrink: 0;
  }
  .lang-svc-name {
    font-weight: 600; font-size: .9rem;
    letter-spacing: .01em;
  }
  .lang-table-wrap { overflow-x: auto; }
  .lang-table {
    width: 100%; margin: 0;
    font-size: .82rem;
    border-collapse: collapse;
  }
  .lang-table th {
    text-align: left; font-weight: 500;
    opacity: .55;
    font-size: .68rem;
    text-transform: uppercase; letter-spacing: .05em;
    padding: 0 .75rem .35rem 0;
    white-space: nowrap;
  }
  .lang-table th:first-child { padding-left: 0; }
  .lang-table td {
    padding: .35rem .75rem .35rem 0;
    vertical-align: middle;
    border-top: 1px solid var(--tblr-border-color-translucent, rgba(255,255,255,.05));
  }
  .lang-table td:first-child { padding-left: 0; }
  .lang-table tbody tr:first-child td { border-top: 0; }
  .lang-table .lang-instance {
    font-weight: 500;
    width: 1%;       /* shrink to content */
    white-space: nowrap;
    padding-right: 1.5rem;
  }
  .lang-table .form-select-sm {
    min-width: 160px;
    max-width: 100%;
  }
  .lang-empty {
    color: var(--tblr-secondary-color);
    font-style: italic;
    opacity: .7;
  }
  .lang-error {
    color: var(--tblr-danger);
    font-size: .78rem;
    opacity: .85;
  }

  /* Color swatches — 6 clickable circles */
  .color-swatches { display: flex; gap: .5rem; flex-wrap: wrap; }
  .color-swatch {
    width: 28px; height: 28px; border-radius: 50%;
    border: 2px solid transparent; cursor: pointer;
    padding: 0; transition: transform .1s ease, border-color .15s ease;
    box-shadow: 0 1px 3px rgba(0,0,0,.15);
  }
  .color-swatch:hover { transform: scale(1.08); }
  .color-swatch.is-active {
    border-color: currentColor;
    box-shadow: 0 0 0 2px var(--tblr-body-bg) inset, 0 2px 6px rgba(0,0,0,.25);
  }
  .color-swatch-auto {
    background: conic-gradient(from 0deg, #ef4444, #f59e0b, #22c55e, #3b82f6, #6366f1, #ec4899, #ef4444);
  }
</style>
{% endblock %}

{% block body %}
  <div class="container-xl py-4">
    <div class="settings-page">

      {# ── Nav left (sticky on desktop, collapsed on mobile) ───────── #}
      <nav class="settings-nav" aria-label="{{ 'admin.nav.aria_label'|trans }}">
        <div class="settings-nav-title">{{ 'admin.nav.section'|trans }}</div>
        <a href="#section-services" data-settings-nav="section-services">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
               stroke-linecap="round" stroke-linejoin="round">
            <rect x="4" y="4" width="6" height="6" rx="1"/>
            <rect x="14" y="4" width="6" height="6" rx="1"/>
            <rect x="4" y="14" width="6" height="6" rx="1"/>
            <rect x="14" y="14" width="6" height="6" rx="1"/>
          </svg>
          {{ 'admin.nav.services'|trans }}
        </a>
        <a href="#section-display" data-settings-nav="section-display">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
               stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="12" rx="1"/>
            <line x1="8" y1="20" x2="16" y2="20"/>
            <line x1="12" y1="16" x2="12" y2="20"/>
          </svg>
          {{ 'admin.nav.display'|trans }}
        </a>
        <a href="#section-languages" data-settings-nav="section-languages">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
               stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 5h7"/><path d="M9 3v2c0 4.418 -2.239 8 -5 8"/>
            <path d="M5 9c0 2.144 2.952 3.908 6.7 4"/>
            <path d="M12 20l4 -9l4 9"/><path d="M19.1 18h-6.2"/>
          </svg>
          {{ 'admin.languages.tab_label'|trans }}
        </a>

        <a href="#section-backup" data-settings-nav="section-backup">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
               stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 7v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2 -2v-10"/>
            <path d="M12 4l0 12"/><path d="M7 8l5 -4l5 4"/>
          </svg>
          {{ 'admin.nav.backup'|trans }}
        </a>
        <a href="#section-updates" data-settings-nav="section-updates">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
               stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 11a8.1 8.1 0 0 0 -15.5 -2m-.5 -4v4h4"/>
            <path d="M4 13a8.1 8.1 0 0 0 15.5 2m.5 4v-4h-4"/>
          </svg>
          {{ 'admin.nav.updates'|trans }}
          {% if app_update_available %}
            <span class="badge bg-orange ms-auto" style="font-size:.7rem;">{{ 'admin.updates.badge_available'|trans }}</span>
          {% endif %}
        </a>
        <a href="#section-about" data-settings-nav="section-about">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
               stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="9"/>
            <line x1="12" y1="8" x2="12.01" y2="8"/>
            <polyline points="11 12 12 12 12 16 13 16"/>
          </svg>
          {{ 'admin.nav.about'|trans }}
        </a>

        <div class="settings-nav-support">
          <a href="{{ support_donate_url }}" target="_blank" rel="noopener">
            {{ ico.icon('heart', '', 16) }} {{ 'admin.support.nav_donate'|trans }}
          </a>
        </div>
      </nav>

      {# ── Content ───────────────────────────────────────────────── #}
      <div class="settings-content">

        <div class="settings-header">
          <h1>{{ 'admin.page.title'|trans }}</h1>
          <div class="text-secondary">
            {{ 'admin.page.subtitle'|trans }}
          </div>
        </div>

        {% for flash in app.flashes('success') %}
          <div class="alert alert-success mb-3">{{ flash }}</div>
        {% endfor %}
        {% for flash in app.flashes('danger') %}
          <div class="alert alert-danger mb-3">{{ flash }}</div>
        {% endfor %}
        {% for flash in app.flashes('warning') %}
          <div class="alert alert-warning mb-3">{{ flash }}</div>
        {% endfor %}
        {% for error in errors %}
          <div class="alert alert-danger mb-3">{{ error }}</div>
        {% endfor %}

        <form method="post" action="{{ path('admin_settings_index') }}" autocomplete="off" novalidate>
          <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_settings') }}"/>

          {% set service_meta = {
            'tmdb':        { icon_bg: '#0d253f', subtitle: 'admin.services.subtitle.tmdb'|trans },
            'radarr':      { icon_bg: '#ffc230', subtitle: 'admin.services.subtitle.radarr'|trans },
            'sonarr':      { icon_bg: '#35c5f0', subtitle: 'admin.services.subtitle.sonarr'|trans },
            'prowlarr':    { icon_bg: '#e86100', subtitle: 'admin.services.subtitle.prowlarr'|trans },
            'jellyseerr':  { icon_bg: '#6366f1', subtitle: 'admin.services.subtitle.jellyseerr'|trans },
            'qbittorrent': { icon_bg: '#2f67ba', subtitle: 'admin.services.subtitle.qbittorrent'|trans },
            'sabnzbd':     { icon_bg: '#ffa000', subtitle: 'admin.services.subtitle.sabnzbd'|trans },
            'nzbget':      { icon_bg: '#1f9c3a', subtitle: 'admin.services.subtitle.nzbget'|trans },
            'gluetun':     { icon_bg: '#10b981', subtitle: 'admin.services.subtitle.gluetun'|trans },
            'tautulli':    { icon_bg: '#e5a00d', subtitle: 'admin.services.subtitle.tautulli'|trans },
          } %}

          {% set groupings = {
            ('admin.services.group.discovery'|trans):  ['tmdb'],
            ('admin.services.group.managers'|trans):   ['radarr', 'sonarr'],
            ('admin.services.group.indexers'|trans):   ['prowlarr', 'jellyseerr'],
            ('admin.services.group.downloads'|trans):  ['qbittorrent', 'gluetun', 'sabnzbd', 'nzbget'],
            ('admin.services.group.monitoring'|trans): ['tautulli'],
          } %}

          {# ─── Section 1 : Services externes ─────────────────────── #}
          <section id="section-services" class="settings-group" data-section>
            <div class="settings-group-title">{{ 'admin.services.title'|trans }}</div>
            <p class="settings-group-desc">{{ 'admin.services.description'|trans|raw }}</p>

            {% for group_label, service_ids in groupings %}
              <div style="font-size:.75rem; color:var(--tblr-secondary); font-weight:600; margin: 1.25rem 0 .6rem;">
                {{ group_label }}
              </div>

              <div class="service-grid-2col">
              {% for service_id in service_ids %}
                {% set meta = service_meta[service_id] %}
                {# v1.1.0 — radarr/sonarr render as a multi-instance list,
                   not a single URL+API-key form. #}
                {% if service_id in ['radarr', 'sonarr'] %}
                  {% include 'admin/_instance_card.html.twig' with {
                    service_id:    service_id,
                    service_label: service_labels[service_id],
                    instances:     instances_by_type[service_id]|default([]),
                    meta:          meta,
                  } only %}
                {% else %}
                {% set fields = groups[service_id] %}
                <div class="service-card" data-service-card="{{ service_id }}">
                  <div class="service-card-head">
                    <div class="service-card-icon service-card-icon--logo" style="--brand: {{ meta.icon_bg }};">
                      <img src="{{ asset('img/services/' ~ service_id ~ '.svg') }}"
                           alt="{{ service_labels[service_id] }}" width="24" height="24" loading="lazy">
                    </div>
                    <div>
                      <p class="service-card-title">{{ service_labels[service_id] }}</p>
                      <p class="service-card-sub">{{ meta.subtitle }}</p>
                    </div>
                    <div class="service-card-actions">
                      {# Issue #15 — per-service kill switch. Only the flat-config
                         services have it; radarr/sonarr enable/disable per
                         instance. Unchecked box isn't POSTed → disabled. #}
                      {% if service_id in ['tmdb', 'prowlarr', 'jellyseerr', 'qbittorrent', 'sabnzbd', 'nzbget', 'tautulli'] %}
                        <label class="form-check form-switch m-0 me-2" style="padding-left:2.4em;"
                               title="{{ 'admin.services.enabled_title'|trans }}">
                          <input class="form-check-input" type="checkbox"
                                 name="{{ service_id }}_enabled" value="1"
                                 {{ (service_enabled[service_id] ?? true) ? 'checked' : '' }}>
                          <span class="form-check-label" style="font-size:.78rem; color:var(--tblr-secondary);">{{ 'admin.services.enabled'|trans }}</span>
                        </label>
                      {% endif %}
                      {# Gluetun has no health probe in HealthService::probeFor() —
                         it would always come back "unknown". Hide the test
                         affordance until/unless we add a real Gluetun probe. #}
                      {% if service_id != 'gluetun' %}
                        {# v1.1.0 — same compact button as the per-instance
                           Test: lightning icon + state-driven colour, no
                           separate pill. JS handler updates label/class. #}
                        <button type="button"
                                class="btn btn-sm btn-outline-secondary admin-settings-test"
                                data-service="{{ service_id }}">
                          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                               fill="none" stroke="currentColor" stroke-width="2"
                               stroke-linecap="round" stroke-linejoin="round">
                            <path d="M13 3l0 7l6 0l-8 11l0 -7l-6 0l8 -11"/>
                          </svg>
                          <span data-service-test-label="{{ service_id }}">{{ 'admin.services.test'|trans }}</span>
                        </button>
                      {% endif %}
                    </div>
                  </div>

                  {% for field in fields %}
                    <div class="field-row" data-field-key="{{ field.key }}">
                      <label for="{{ field.key }}">{{ field.label|trans }}</label>
                      {% if field.type == 'password' %}
                        <div class="secret-wrapper">
                          <input type="password"
                                 id="{{ field.key }}"
                                 name="{{ field.key }}"
                                 class="form-control"
                                 value="{{ values[field.key] ?? '' }}"
                                 autocomplete="off"
                                 spellcheck="false"
                                 {% if field.placeholder is defined %}placeholder="{{ field.placeholder }}"{% endif %}/>
                          <button type="button" class="secret-toggle" aria-label="{{ 'setup.step.admin.toggle_visibility'|trans }}"
                                  data-toggle-for="{{ field.key }}">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round">
                              <path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"/>
                              <path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6"/>
                            </svg>
                          </button>
                        </div>
                      {% else %}
                        <input type="text"
                               id="{{ field.key }}"
                               name="{{ field.key }}"
                               class="form-control"
                               value="{{ values[field.key] ?? '' }}"
                               autocomplete="off"
                               spellcheck="false"
                               {% if field.placeholder is defined %}placeholder="{{ field.placeholder }}"{% endif %}/>
                      {% endif %}

                      {# Clear button — opt-in via FIELDS[].clearable. Used
                         for qBit user/password where leaving the field empty
                         is a legitimate setup (reverse proxy injects auth,
                         issue #10). Submits a hidden _clear_<key>=1 alongside
                         the form so AdminSettingsController::saveSubmitted()
                         sets the BDD value to null instead of treating empty
                         as "unchanged". #}
                      {% if field.clearable ?? false %}
                        <input type="hidden" id="_clear_{{ field.key }}" name="_clear_{{ field.key }}" value="0">
                        <button type="button" class="field-clear" data-clear-for="{{ field.key }}">
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                               fill="none" stroke="currentColor" stroke-width="2"
                               stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4 7l16 0M10 11l0 6M14 11l0 6M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12M9 7V4a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3"/>
                          </svg>
                          <span>{{ 'admin.field.clear'|trans }}</span>
                        </button>
                      {% endif %}
                    </div>
                  {% endfor %}
                </div>
                {% endif %}
              {% endfor %}
              </div>
            {% endfor %}
          </section>

          {# ─── Section 2: Display / user preferences ──── #}
          <section id="section-display" class="settings-group" data-section>
            <div class="settings-group-title">{{ 'admin.display.title'|trans }}</div>
            <p class="settings-group-desc">{{ 'admin.display.description'|trans }}</p>

            {# --- Preferences ----------------------------------------- #}
            <div class="service-card">
              <div class="service-card-head" style="margin-bottom: .75rem;">
                <div class="service-card-icon" style="background: var(--tblr-primary);">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                       fill="none" stroke="currentColor" stroke-width="2"
                       stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="9"/>
                    <path d="M3.6 9h16.8M3.6 15h16.8M11.5 3a17 17 0 0 0 0 18M12.5 3a17 17 0 0 1 0 18"/>
                  </svg>
                </div>
                <div>
                  <p class="service-card-title">{{ 'admin.display.preferences.title'|trans }}</p>
                  <p class="service-card-sub">{{ 'admin.display.preferences.subtitle'|trans }}</p>
                </div>
              </div>

              <div class="display-grid">
                {% for key, spec in display_options %}
                  {% if not (spec.hidden|default(false)) %}
                  <div class="display-row">
                    <label class="display-label" for="{{ key }}">{{ spec.label|trans }}</label>

                    {% if spec.type == 'switch' %}
                      <label class="form-check form-switch mb-0">
                        <input class="form-check-input" type="checkbox"
                               id="{{ key }}" name="{{ key }}" value="1"
                               {% if display_values[key] == '1' %}checked{% endif %}/>
                        <span class="form-check-label small text-secondary">
                          {{ display_values[key] == '1' ? 'admin.display.switch.on'|trans : 'admin.display.switch.off'|trans }}
                        </span>
                      </label>

                    {% elseif spec.type == 'timezone' %}
                      {# Empty stored value (issue #12) means "follow system",
                         so we pre-select the resolved system timezone — the
                         dropdown stays a single source of truth that the user
                         can then confirm/save explicitly. #}
                      {% set selected_tz = display_values[key] != '' ? display_values[key] : system_timezone %}
                      <select id="{{ key }}" name="{{ key }}" class="form-select form-select-sm">
                        {% for tz in timezones %}
                          <option value="{{ tz }}" {% if selected_tz == tz %}selected{% endif %}>{{ tz }}</option>
                        {% endfor %}
                      </select>

                    {% elseif spec.type == 'color' %}
                      <input type="hidden" id="{{ key }}" name="{{ key }}" value="{{ display_values[key] }}"/>
                      <div class="color-swatches" data-color-target="{{ key }}">
                        {% for color_id, hex in spec.options %}
                          {% set _is_auto = not (hex starts with '#') %}
                          <button type="button"
                                  class="color-swatch {% if _is_auto %}color-swatch-auto{% endif %} {% if display_values[key] == color_id %}is-active{% endif %}"
                                  data-color-value="{{ color_id }}"
                                  style="{% if not _is_auto %}background: {{ hex }};{% endif %}"
                                  aria-label="{{ color_id }}"
                                  title="{{ color_id }}"></button>
                        {% endfor %}
                      </div>

                    {% else %}{# select #}
                      <select id="{{ key }}" name="{{ key }}" class="form-select form-select-sm">
                        {% for value, label in spec.options %}
                          <option value="{{ value }}" {% if display_values[key] == value %}selected{% endif %}>{{ label|trans }}</option>
                        {% endfor %}
                      </select>
                    {% endif %}

                    {% if spec.help is defined %}
                      <p class="display-help">{{ spec.help|trans }}</p>
                    {% endif %}
                  </div>
                  {% endif %}
                {% endfor %}
              </div>
            </div>

            {# --- Sidebar visibility (services + features) ----- #}
            <div class="service-card">
              <div class="service-card-head" style="margin-bottom: .75rem;">
                <div class="service-card-icon" style="background: #64748b;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                       fill="none" stroke="currentColor" stroke-width="2"
                       stroke-linecap="round" stroke-linejoin="round">
                    <line x1="4" y1="6" x2="20" y2="6"/>
                    <line x1="4" y1="12" x2="20" y2="12"/>
                    <line x1="4" y1="18" x2="20" y2="18"/>
                  </svg>
                </div>
                <div>
                  <p class="service-card-title">{{ 'admin.display.sidebar.title'|trans }}</p>
                  <p class="service-card-sub">{{ 'admin.display.sidebar.description'|trans }}</p>
                </div>
              </div>

              <div class="sidebar-visibility-grid">
                {% for service_id, label in service_labels %}
                  <label class="form-check form-switch sidebar-visibility-row">
                    <input class="form-check-input"
                           type="checkbox"
                           name="sidebar_visible_{{ service_id }}"
                           value="1"
                           {% if sidebar_visibility[service_id] ?? true %}checked{% endif %}/>
                    <span class="form-check-label">{{ label }}</span>
                  </label>
                {% endfor %}
                {% for feature_id, meta in internal_features|default([]) %}
                  <label class="form-check form-switch sidebar-visibility-row">
                    <input class="form-check-input"
                           type="checkbox"
                           name="sidebar_visible_{{ feature_id }}"
                           value="1"
                           {% if sidebar_visibility[feature_id] ?? true %}checked{% endif %}/>
                    <span class="form-check-label">{{ meta.label|trans }}</span>
                  </label>
                {% endfor %}
              </div>
            </div>
          </section>

          {# Save button + close main form BEFORE the Backup section.
             Nested <form> tags (import + reset-display) would otherwise
             close the outer form prematurely at their first </form>,
             leaving the Save button orphaned. Backup + About
             render their own buttons below, outside the main form. #}
          <div class="settings-footer" data-settings-footer>
            <button type="submit" class="btn btn-primary">{{ 'admin.save'|trans }}</button>
          </div>
        </form>

        {# v1.1.0 — multi-instance modales rendered OUTSIDE the main form
           (HTML doesn't allow nested forms). The Add / Edit buttons inside
           the cards target these modales by id via data-bs-toggle. #}
        {% for service_id, instances_list in instances_by_type %}
          {% include 'admin/_instance_modals.html.twig' with {
            service_id:    service_id,
            service_label: service_labels[service_id],
            instances:     instances_list,
          } only %}
        {% endfor %}

        {# ─── Section 3: Unified languages ────────────────────── #}
        <section id="section-languages" class="settings-group" data-section>
          <div class="settings-group-title">{{ 'admin.languages.tab_label'|trans }}</div>
          <p class="settings-group-desc">{{ 'admin.languages.description'|trans }}</p>

          <form action="{{ path('admin_settings_languages_save') }}" method="post">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_languages') }}">

            {# ── Prismarr ── #}
            <div class="service-card">
              <div class="service-card-head" style="margin-bottom:.75rem;">
                <div class="service-card-icon" style="background: var(--tblr-primary);">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                       fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 5h7"/><path d="M9 3v2c0 4.418 -2.239 8 -5 8"/>
                    <path d="M5 9c0 2.144 2.952 3.908 6.7 4"/>
                    <path d="M12 20l4 -9l4 9"/><path d="M19.1 18h-6.2"/>
                  </svg>
                </div>
                <div>
                  <p class="service-card-title">{{ 'admin.languages.prismarr_section'|trans }}</p>
                </div>
              </div>

              <div class="display-grid">
                <div class="display-row">
                  <label class="display-label" for="prismarr_ui">{{ 'admin.languages.prismarr_ui_label'|trans }}</label>
                  <div>
                    <select id="prismarr_ui" name="prismarr_ui" class="form-select form-select-sm">
                      <option value="fr" {% if display_values.display_language == 'fr' %}selected{% endif %}>Français</option>
                      <option value="en" {% if display_values.display_language == 'en' %}selected{% endif %}>English</option>
                    </select>
                    <small class="text-secondary d-block mt-1">{{ 'admin.languages.prismarr_ui_help'|trans }}</small>
                  </div>
                </div>
                <div class="display-row">
                  <label class="display-label" for="prismarr_metadata">{{ 'admin.languages.prismarr_metadata_label'|trans }}</label>
                  <div>
                    <select id="prismarr_metadata" name="prismarr_metadata" class="form-select form-select-sm">
                      <option value="fr-FR" {% if display_values.display_metadata_language == 'fr-FR' %}selected{% endif %}>Français (fr-FR)</option>
                      <option value="en-US" {% if display_values.display_metadata_language == 'en-US' %}selected{% endif %}>English (en-US)</option>
                    </select>
                    <small class="text-secondary d-block mt-1">{{ 'admin.languages.prismarr_metadata_help'|trans }}</small>
                  </div>
                </div>
              </div>
            </div>

            {# ── Connected services ── #}
            <div class="service-card" style="margin-top:1rem;">
              <div class="service-card-head" style="margin-bottom:.75rem;">
                <div class="service-card-icon" style="background:#6366f1;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                       fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 3l8 4.5l0 9l-8 4.5l-8 -4.5l0 -9z"/>
                    <path d="M12 12l8 -4.5"/><path d="M12 12l0 9"/><path d="M12 12l-8 -4.5"/>
                  </svg>
                </div>
                <div>
                  <p class="service-card-title">{{ 'admin.languages.services_section'|trans }}</p>
                </div>
              </div>

              {# ── Radarr ── #}
              <div class="lang-svc-block">
                <div class="lang-svc-head">
                  <span class="lang-svc-dot" style="background:#f59f00;"></span>
                  <span class="lang-svc-name">Radarr</span>
                </div>
                <div class="lang-table-wrap">
                  <table class="lang-table">
                    <thead>
                      <tr>
                        <th>{{ 'admin.languages.col_instance'|trans }}</th>
                        <th>{{ 'admin.languages.radarr_ui_label'|trans }}</th>
                        <th>{{ 'admin.languages.radarr_info_label'|trans }}</th>
                      </tr>
                    </thead>
                    <tbody>
                      {% for slug, lang in languages.radarr %}
                        <tr>
                          <td class="lang-instance">{{ lang.name }}</td>
                          {% if lang.error %}
                            <td colspan="2" class="lang-error">{{ 'admin.languages.unreachable'|trans }}</td>
                          {% else %}
                            <td>
                              <select name="radarr_ui[{{ slug }}]" class="form-select form-select-sm">
                                {% for id, name in lang.available %}
                                  <option value="{{ id }}" {% if lang.current == id %}selected{% endif %}>{{ name }}</option>
                                {% endfor %}
                              </select>
                            </td>
                            <td>
                              <select name="radarr_info[{{ slug }}]" class="form-select form-select-sm">
                                {% for id, name in lang.available %}
                                  <option value="{{ id }}" {% if lang.current_info == id %}selected{% endif %}>{{ name }}</option>
                                {% endfor %}
                              </select>
                            </td>
                          {% endif %}
                        </tr>
                      {% else %}
                        <tr><td colspan="3" class="lang-empty">{{ 'admin.languages.not_configured'|trans }}</td></tr>
                      {% endfor %}
                    </tbody>
                  </table>
                </div>
                {% if languages.radarr|length > 0 %}
                  <small class="text-secondary d-block mt-1">{{ 'admin.languages.radarr_info_help'|trans }}</small>
                {% endif %}
              </div>

              {# ── Sonarr — Sonarr v4 doesn't expose a global "Series Info Language", just UI. ── #}
              <div class="lang-svc-block">
                <div class="lang-svc-head">
                  <span class="lang-svc-dot" style="background:#3b82f6;"></span>
                  <span class="lang-svc-name">Sonarr</span>
                </div>
                <div class="lang-table-wrap">
                  <table class="lang-table">
                    <thead>
                      <tr>
                        <th>{{ 'admin.languages.col_instance'|trans }}</th>
                        <th>{{ 'admin.languages.sonarr_ui_label'|trans }}</th>
                      </tr>
                    </thead>
                    <tbody>
                      {% for slug, lang in languages.sonarr %}
                        <tr>
                          <td class="lang-instance">{{ lang.name }}</td>
                          {% if lang.error %}
                            <td class="lang-error">{{ 'admin.languages.unreachable'|trans }}</td>
                          {% else %}
                            <td>
                              <select name="sonarr_ui[{{ slug }}]" class="form-select form-select-sm">
                                {% for id, name in lang.available %}
                                  <option value="{{ id }}" {% if lang.current == id %}selected{% endif %}>{{ name }}</option>
                                {% endfor %}
                              </select>
                            </td>
                          {% endif %}
                        </tr>
                      {% else %}
                        <tr><td colspan="2" class="lang-empty">{{ 'admin.languages.not_configured'|trans }}</td></tr>
                      {% endfor %}
                    </tbody>
                  </table>
                </div>
              </div>

              {# ── Prowlarr (mono-instance) ── #}
              <div class="lang-svc-block">
                <div class="lang-svc-head">
                  <span class="lang-svc-dot" style="background:#8b5cf6;"></span>
                  <span class="lang-svc-name">Prowlarr</span>
                </div>
                <div class="lang-table-wrap">
                  <table class="lang-table">
                    <thead>
                      <tr>
                        <th>{{ 'admin.languages.col_instance'|trans }}</th>
                        <th>{{ 'admin.languages.prowlarr_ui_label'|trans }}</th>
                      </tr>
                    </thead>
                    <tbody>
                      <tr>
                        <td class="lang-instance">Prowlarr</td>
                        {% if not languages.prowlarr.configured %}
                          <td class="lang-empty">{{ 'admin.languages.not_configured'|trans }}</td>
                        {% elseif languages.prowlarr.error %}
                          <td class="lang-error">{{ 'admin.languages.unreachable'|trans }}</td>
                        {% else %}
                          <td>
                            <select name="prowlarr_ui" class="form-select form-select-sm">
                              {% for code, name in languages.prowlarr.available %}
                                <option value="{{ code }}" {% if languages.prowlarr.current == code %}selected{% endif %}>{{ name }}</option>
                              {% endfor %}
                            </select>
                          </td>
                        {% endif %}
                      </tr>
                    </tbody>
                  </table>
                </div>
              </div>

              {# ── Seerr (mono-instance) ── #}
              <div class="lang-svc-block">
                <div class="lang-svc-head">
                  <span class="lang-svc-dot" style="background:#ec4899;"></span>
                  <span class="lang-svc-name">Seerr</span>
                </div>
                <div class="lang-table-wrap">
                  <table class="lang-table">
                    <thead>
                      <tr>
                        <th>{{ 'admin.languages.col_instance'|trans }}</th>
                        <th>{{ 'admin.languages.jellyseerr_ui_label'|trans }}</th>
                      </tr>
                    </thead>
                    <tbody>
                      <tr>
                        <td class="lang-instance">Seerr</td>
                        {% if not languages.jellyseerr.configured %}
                          <td class="lang-empty">{{ 'admin.languages.not_configured'|trans }}</td>
                        {% elseif languages.jellyseerr.error %}
                          <td class="lang-error">{{ 'admin.languages.unreachable'|trans }}</td>
                        {% else %}
                          <td>
                            <select name="jellyseerr_ui" class="form-select form-select-sm">
                              {% for code, name in languages.jellyseerr.available %}
                                <option value="{{ code }}" {% if languages.jellyseerr.current == code %}selected{% endif %}>{{ name }}</option>
                              {% endfor %}
                            </select>
                          </td>
                        {% endif %}
                      </tr>
                    </tbody>
                  </table>
                </div>
                {% if languages.jellyseerr.configured and not languages.jellyseerr.error %}
                  <small class="text-secondary d-block mt-1">{{ 'admin.languages.info_jellyseerr_global'|trans }}</small>
                {% endif %}
              </div>

              <div class="alert alert-info mt-3" style="font-size:.78rem;">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                {{ 'admin.languages.info_existing_items'|trans }}
              </div>
            </div>

            <div class="settings-footer mt-3">
              <button type="submit" class="btn btn-primary">{{ 'admin.languages.save_btn'|trans }}</button>
            </div>
          </form>
        </section>

        {# ─── Section 4 : Backup / Restauration ──────────── #}
        <section id="section-backup" class="settings-group" data-section>
            <div class="settings-group-title">{{ 'admin.backup.title'|trans }}</div>
            <p class="settings-group-desc">{{ 'admin.backup.description'|trans|raw }}</p>

            <div class="service-card">
              <div class="service-card-head" style="margin-bottom:.9rem;">
                <div class="service-card-icon" style="background:#22c55e;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                       fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2 -2v-2"/><path d="M7 11l5 5l5 -5"/><path d="M12 4v12"/>
                  </svg>
                </div>
                <div>
                  <p class="service-card-title">{{ 'admin.backup.export.title'|trans }}</p>
                  <p class="service-card-sub">
                    {{ 'admin.backup.export.count'|trans({safe: export_counts.safe, skipped: export_counts.skipped}) }}
                  </p>
                </div>
                <div class="service-card-actions">
                  <a href="{{ path('admin_settings_export') }}" class="btn btn-sm btn-primary" download>
                    {{ 'admin.backup.export.cta'|trans }}
                  </a>
                </div>
              </div>
            </div>

            <div class="service-card" style="margin-top:1rem;">
              <div class="service-card-head" style="margin-bottom:.9rem;">
                <div class="service-card-icon" style="background:#f59e0b;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                       fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2 -2v-2"/><path d="M7 9l5 -5l5 5"/><path d="M12 4v12"/>
                  </svg>
                </div>
                <div>
                  <p class="service-card-title">{{ 'admin.backup.import.title'|trans }}</p>
                  <p class="service-card-sub">{{ 'admin.backup.import.subtitle'|trans }}</p>
                </div>
              </div>
              <form action="{{ path('admin_settings_import') }}" method="post" enctype="multipart/form-data" class="d-flex gap-2 align-items-center">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_settings_import') }}">
                <input type="file" name="config" accept="application/json,.json" class="form-control form-control-sm" required>
                <button type="submit" class="btn btn-sm btn-primary" onclick="return confirm('{{ 'admin.backup.import.confirm'|trans|e('js') }}')">{{ 'admin.backup.import.cta'|trans }}</button>
              </form>
            </div>

            <div class="service-card" style="margin-top:1rem; border-color: rgba(239,68,68,.3);">
              <div class="service-card-head" style="margin-bottom:.6rem;">
                <div class="service-card-icon" style="background:#ef4444;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                       fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 12a9 9 0 0 0 -9 -9a9 9 0 0 0 -6.36 2.63l-2.64 2.37"/>
                    <path d="M3 4v5h5"/><path d="M21 15a9 9 0 0 1 -15.36 5.37l-2.64 -2.37"/><path d="M16 15h5v5"/>
                  </svg>
                </div>
                <div>
                  <p class="service-card-title">{{ 'admin.backup.reset.title'|trans }}</p>
                  <p class="service-card-sub">{{ 'admin.backup.reset.subtitle'|trans }}</p>
                </div>
              </div>
              <form action="{{ path('admin_settings_reset_display') }}" method="post">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('admin_settings_reset_display') }}">
                <button type="submit" class="btn btn-sm btn-outline-danger"
                        onclick="return confirm('{{ 'admin.backup.reset.confirm'|trans|e('js') }}')">
                  {{ 'admin.backup.reset.cta'|trans }}
                </button>
              </form>
            </div>
          </section>

          {# ─── Section: Updates ────────────────────────────── #}
          <section id="section-updates" class="settings-group" data-section>
            <div class="settings-group-title">{{ 'admin.updates.title'|trans }}</div>
            <p class="settings-group-desc">{{ 'admin.updates.description'|trans }}</p>

            <div class="service-card" style="margin-bottom:1rem;">
              <div class="d-flex align-items-center justify-content-between gap-3 flex-wrap">
                <div>
                  <p class="service-card-title" style="margin-bottom:.25rem;">{{ 'admin.updates.current_version'|trans }}</p>
                  <div class="d-flex align-items-baseline gap-2">
                    <span style="font-family:monospace;font-size:1.4rem;font-weight:600;">v{{ app_current }}</span>
                    {% if app_update_available %}
                      <span class="badge bg-orange">{{ 'admin.updates.update_available'|trans({version: 'v' ~ app_latest}) }}</span>
                    {% elseif app_latest %}
                      <span class="badge bg-green-lt">{{ 'admin.updates.up_to_date'|trans }}</span>
                    {% else %}
                      <span class="text-secondary small">{{ 'admin.updates.no_remote_info'|trans }}</span>
                    {% endif %}
                  </div>
                </div>
                <div class="d-flex flex-wrap gap-2">
                  <a href="https://github.com/Shoshuo/Prismarr/releases" target="_blank" rel="noopener" class="btn btn-sm btn-ghost-primary">
                    {{ ico.icon('brand-github', '', 16) }} {{ 'admin.updates.view_on_github'|trans }}
                  </a>
                  <a href="https://hub.docker.com/r/shoshuo/prismarr/tags" target="_blank" rel="noopener" class="btn btn-sm btn-ghost-primary">
                    {{ ico.icon('brand-docker', '', 16) }} {{ 'admin.updates.docker_hub'|trans }}
                  </a>
                  <a href="https://github.com/users/Shoshuo/projects/4" target="_blank" rel="noopener" class="btn btn-sm btn-ghost-primary">
                    {{ ico.icon('map', '', 16) }} {{ 'admin.updates.roadmap'|trans }}
                  </a>
                </div>
              </div>
              {% if app_update_available %}
                <p class="text-secondary small" style="margin-top:.75rem;margin-bottom:0;">
                  {{ 'admin.updates.upgrade_hint_html'|trans|raw }}
                </p>
              {% endif %}
            </div>

            <div class="service-card">
              <p class="service-card-title">{{ 'admin.updates.release_notes'|trans }}</p>

              {% if app_releases is empty %}
                <p class="text-secondary">{{ 'admin.updates.no_releases'|trans }}</p>
              {% else %}
                <div class="d-flex flex-column gap-3">
                  {% for r in app_releases %}
                    <article style="border-left: 3px solid var(--tblr-primary); padding-left: .75rem;">
                      <div class="d-flex align-items-baseline gap-2 flex-wrap" style="margin-bottom:.4rem;">
                        <a href="{{ r.html_url|e('html_attr') }}" target="_blank" rel="noopener" style="font-family:monospace;font-weight:600;text-decoration:none;">
                          v{{ r.tag }}
                        </a>
                        {% if r.tag == app_current %}
                          <span class="badge bg-blue-lt">{{ 'admin.updates.installed'|trans }}</span>
                        {% endif %}
                        {% if r.published_at %}
                          <span class="text-secondary small">{{ r.published_at|prismarr_date }}</span>
                        {% endif %}
                      </div>
                      {% if r.body_html is defined and r.body_html %}
                        <div class="release-body" style="font-size:.88rem;line-height:1.5;padding:.5rem .75rem;background:var(--tblr-bg-surface-secondary);border-radius:4px;max-height:340px;overflow-y:auto;">
                          {{ r.body_html|raw }}
                        </div>
                      {% elseif r.body %}
                        <div class="release-body" style="font-size:.88rem;line-height:1.5;padding:.5rem .75rem;background:var(--tblr-bg-surface-secondary);border-radius:4px;max-height:340px;overflow-y:auto;white-space:pre-wrap;">{{ r.body }}</div>
                      {% endif %}
                    </article>
                  {% endfor %}
                </div>
              {% endif %}
            </div>
          </section>

          {# ─── Section 4: About ───────────────────────────── #}
          <section id="section-about" class="settings-group" data-section>
            <div class="settings-group-title">{{ 'admin.about.title'|trans }}</div>
            <p class="settings-group-desc">{{ 'admin.about.description'|trans }}</p>

            <div class="service-card">
              <div class="d-flex flex-column gap-2">
                <div class="d-flex justify-content-between border-bottom pb-2">
                  <span class="text-secondary small">{{ 'admin.about.field.version'|trans }}</span>
                  <span class="small fw-medium">{{ system_info.prismarr_version }}</span>
                </div>
                <div class="d-flex justify-content-between border-bottom pb-2">
                  <span class="text-secondary small">{{ 'admin.about.field.environment'|trans }}</span>
                  <span class="small fw-medium"><code>{{ system_info.environment }}</code> · {{ system_info.sapi }}</span>
                </div>
                <div class="d-flex justify-content-between border-bottom pb-2">
                  <span class="text-secondary small">{{ 'admin.about.field.symfony'|trans }}</span>
                  <span class="small fw-medium">{{ system_info.symfony_version }}</span>
                </div>
                <div class="d-flex justify-content-between border-bottom pb-2">
                  <span class="text-secondary small">{{ 'admin.about.field.php'|trans }}</span>
                  <span class="small fw-medium">{{ system_info.php_version }}</span>
                </div>
                <div class="d-flex justify-content-between border-bottom pb-2">
                  <span class="text-secondary small">{{ 'admin.about.field.database'|trans }}</span>
                  <span class="small fw-medium">
                    SQLite ·
                    {% set kb = (system_info.db_size / 1024)|round(1) %}
                    {{ kb >= 1024 ? (kb / 1024)|round(1) ~ ' MB' : kb ~ ' KB' }}
                  </span>
                </div>
                <div class="d-flex justify-content-between border-bottom pb-2">
                  <span class="text-secondary small">{{ 'admin.about.field.server_time'|trans }}</span>
                  <span class="small fw-medium">{{ system_info.server_time|prismarr_datetime }} · {{ system_info.timezone }}</span>
                </div>
                <div class="d-flex justify-content-between border-bottom pb-2">
                  <span class="text-secondary small">{{ 'admin.about.field.memory_limit'|trans }}</span>
                  <span class="small fw-medium">
                    {{ system_info.memory_limit == '-1' ? 'admin.about.field.unlimited'|trans : system_info.memory_limit }}
                  </span>
                </div>
                <div class="d-flex justify-content-between border-bottom pb-2">
                  <span class="text-secondary small">{{ 'admin.about.field.max_execution_time'|trans }}</span>
                  <span class="small fw-medium">
                    {% if system_info.max_execution_time == '0' or system_info.max_execution_time == '-1' %}
                      {{ 'admin.about.field.unlimited'|trans }}
                    {% else %}
                      {{ system_info.max_execution_time }}s
                    {% endif %}
                  </span>
                </div>
              </div>
            </div>

            <div class="service-card" style="margin-top:1rem;">
              <p class="service-card-title" style="margin-bottom:.8rem;">{{ 'admin.about.content.title'|trans }}</p>
              <div class="row g-2 text-center">
                <div class="col-4">
                  <div class="display-6 fw-bold" style="color: var(--tblr-primary);">{{ system_info.user_count ?? '—' }}</div>
                  <div class="small text-secondary">{{ 'admin.about.content.users'|trans({count: system_info.user_count ?? 0}) }}</div>
                </div>
                <div class="col-4">
                  <div class="display-6 fw-bold" style="color: #FFC230;">{{ system_info.film_count ?? '—' }}</div>
                  <div class="small text-secondary">{{ 'admin.about.content.films'|trans({count: system_info.film_count ?? 0}) }}</div>
                </div>
                <div class="col-4">
                  <div class="display-6 fw-bold" style="color: #00CCFF;">{{ system_info.series_count ?? '—' }}</div>
                  <div class="small text-secondary">{{ 'admin.about.content.series'|trans({count: system_info.series_count ?? 0}) }}</div>
                </div>
              </div>
            </div>

            <div class="service-card" style="margin-top:1rem;">
              <p class="service-card-title" style="margin-bottom:.4rem;">{{ 'admin.about.links.title'|trans }}</p>
              <div class="d-flex flex-wrap gap-2">
                <a href="https://github.com/Shoshuo/Prismarr" target="_blank" rel="noopener" class="btn btn-sm btn-ghost-primary">
                  {{ ico.icon('brand-github', '', 16) }} {{ 'admin.about.links.source'|trans }}
                </a>
                <a href="https://github.com/Shoshuo/Prismarr/issues" target="_blank" rel="noopener" class="btn btn-sm btn-ghost-primary">
                  {{ ico.icon('bug', '', 16) }} {{ 'admin.about.links.bug'|trans }}
                </a>
                <a href="https://github.com/Shoshuo/Prismarr#readme" target="_blank" rel="noopener" class="btn btn-sm btn-ghost-primary">
                  {{ ico.icon('book', '', 16) }} {{ 'admin.about.links.docs'|trans }}
                </a>
                <a href="https://github.com/users/Shoshuo/projects/4" target="_blank" rel="noopener" class="btn btn-sm btn-ghost-primary">
                  {{ ico.icon('map', '', 16) }} {{ 'admin.about.links.roadmap'|trans }}
                </a>
              </div>
            </div>

            <div class="service-card" style="margin-top:1rem;">
              <p class="service-card-title" style="margin-bottom:.4rem;">{{ 'admin.support.title'|trans }}</p>
              <div class="d-flex flex-wrap gap-2">
                <a href="{{ support_donate_url }}" target="_blank" rel="noopener" class="btn btn-sm btn-ghost-primary">
                  {{ ico.icon('heart', '', 16) }} {{ 'admin.support.donate'|trans }}
                </a>
                <a href="{{ support_discord_url }}" target="_blank" rel="noopener" class="btn btn-sm btn-ghost-primary">
                  {{ ico.icon('brand-discord', '', 16) }} {{ 'admin.support.discord'|trans }}
                </a>
              </div>
            </div>
        </section>

      </div>
    </div>
  </div>

  <script>
    (function () {
      // Turbo-safe: IIFE + var + .then()

      // ── Toggle secret visibility ────────────────────────────────────
      document.querySelectorAll('.secret-toggle').forEach(function (btn) {
        btn.onclick = function () {
          var input = document.getElementById(btn.dataset.toggleFor);
          if (!input) return;
          input.type = input.type === 'password' ? 'text' : 'password';
        };
      });

      // ── Clear field (issue #10 — qBit user/password trash button) ──
      // Wipes the visible input AND raises the hidden _clear_<key>=1
      // companion flag so the controller bypasses the empty-value guard
      // and writes null to BDD. Also adds an "is-cleared" class on the
      // row for a subtle visual cue (italics + dim).
      document.querySelectorAll('.field-clear').forEach(function (btn) {
        btn.onclick = function () {
          var key = btn.dataset.clearFor;
          var input = document.getElementById(key);
          var flag  = document.getElementById('_clear_' + key);
          var row   = btn.closest('.field-row');
          if (input) input.value = '';
          if (flag)  flag.value  = '1';
          if (row)   row.classList.add('is-cleared');
        };
      });

      // ── Color swatches picker ───────────────────────────────────────
      document.querySelectorAll('.color-swatches').forEach(function (group) {
        var hiddenId = group.dataset.colorTarget;
        var hidden = document.getElementById(hiddenId);
        if (!hidden) return;

        group.querySelectorAll('.color-swatch').forEach(function (sw) {
          sw.onclick = function () {
            hidden.value = sw.dataset.colorValue;
            group.querySelectorAll('.color-swatch').forEach(function (s) {
              s.classList.remove('is-active');
            });
            sw.classList.add('is-active');
          };
        });
      });

      // ── Test connection per service ─────────────────────────────────
      // The button posts the CURRENT form values as an override, so the
      // admin can verify a new URL/key without saving first. Empty inputs
      // are not sent — the server falls back to the saved DB value (handy
      // for password fields the browser may have dropped).
      var TEST_FIELDS = {
        radarr:      ['radarr_url', 'radarr_api_key'],
        sonarr:      ['sonarr_url', 'sonarr_api_key'],
        prowlarr:    ['prowlarr_url', 'prowlarr_api_key'],
        jellyseerr:  ['jellyseerr_url', 'jellyseerr_api_key'],
        tmdb:        ['tmdb_api_key'],
        qbittorrent: ['qbittorrent_url', 'qbittorrent_user', 'qbittorrent_password'],
        sabnzbd:     ['sabnzbd_url', 'sabnzbd_api_key'],
        nzbget:      ['nzbget_url', 'nzbget_user', 'nzbget_password'],
      };
      // Per-service test buttons (TMDb, Prowlarr, Jellyseerr, qBit). Same
      // state-driven look as the per-instance Test (button colour + label
      // change in place). Reuses the INSTANCE_TEST_LABELS / CATEGORIES
      // dicts declared further down — they're hoisted as `var` so the
      // forward reference is fine.
      function setServiceTestBtnState(btn, state, opts) {
        opts = opts || {};
        var label = btn.querySelector('[data-service-test-label]');
        btn.classList.remove('btn-outline-secondary', 'btn-outline-success', 'btn-outline-danger');
        var nextClass = 'btn-outline-secondary';
        var text = INSTANCE_TEST_LABELS.idle;
        if (state === 'testing')     { text = INSTANCE_TEST_LABELS.testing; }
        else if (state === 'ok')     { nextClass = 'btn-outline-success'; text = INSTANCE_TEST_LABELS.connected; }
        else if (state === 'ko')     { nextClass = 'btn-outline-danger';  text = opts.label || INSTANCE_TEST_LABELS.unreachable; }
        btn.classList.add(nextClass);
        if (label) label.textContent = text;
        if (opts.title) btn.title = opts.title;
      }

      document.querySelectorAll('.admin-settings-test').forEach(function (btn) {
        btn.onclick = function () {
          var service = btn.dataset.service;
          setServiceTestBtnState(btn, 'testing');
          btn.disabled = true;

          var formData = new FormData();
          (TEST_FIELDS[service] || []).forEach(function (key) {
            var input = document.getElementById(key);
            if (input && input.value !== '') {
              formData.append(key, input.value);
            }
          });

          fetch('{{ path('admin_settings_index') }}/test/' + encodeURIComponent(service), {
            method: 'POST',
            headers: { 'Accept': 'application/json' },
            credentials: 'same-origin',
            body: formData,
          })
            .then(function (r) { return r.json(); })
            .then(function (data) {
              if (data && data.ok) {
                setServiceTestBtnState(btn, 'ok', {
                  title: INSTANCE_TEST_LABELS.connected + (data.http ? ' (HTTP ' + data.http + ')' : ''),
                });
              } else {
                var category = data && data.category;
                var detail = INSTANCE_TEST_CATEGORIES[category] || INSTANCE_TEST_LABELS.unreachable;
                var title = detail + (data && data.http ? ' (HTTP ' + data.http + ')' : '');
                setServiceTestBtnState(btn, 'ko', { label: detail, title: title });
              }
              btn.disabled = false;
            })
            .catch(function () {
              setServiceTestBtnState(btn, 'ko', { label: INSTANCE_TEST_LABELS.error });
              btn.disabled = false;
            });
        };
      });

      // ── Multi-instance row actions (v1.1.0) ─────────────────────────
      // Inline buttons (set-default, delete, toggle-enabled, test) submit
      // via fetch instead of form POST. The cards live INSIDE the main
      // admin_settings_index <form>, so a nested <form> would break the
      // CSRF chain (HTML doesn't allow nested forms). Fetch sidesteps the
      // problem entirely while keeping CSRF protection on every action.
      function instanceFetch(btn, opts) {
        var fd = new FormData();
        fd.append('_csrf_token', btn.dataset.instanceCsrf || '');
        if (opts && opts.body) {
          Object.keys(opts.body).forEach(function (k) { fd.append(k, opts.body[k]); });
        }
        return fetch(btn.dataset.instanceUrl, {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Accept': 'application/json' },
          body: fd,
        });
      }

      function reloadAfterMutation() {
        // Force a hard reload to pick up the new instance list, default
        // badge moves, sidebar dynamic update, etc.
        window.location.reload();
      }

      // Set as default
      document.querySelectorAll('[data-instance-action="set-default"]').forEach(function (btn) {
        btn.onclick = function () {
          btn.disabled = true;
          instanceFetch(btn).then(reloadAfterMutation).catch(function () {
            btn.disabled = false;
            alert({{ 'admin.services.status.error'|trans|json_encode|raw }});
          });
        };
      });

      // Delete (with confirm — extra-strong wording when removing the
      // last enabled instance of a service, since that hides the service
      // from the sidebar entirely).
      document.querySelectorAll('[data-instance-action="delete"]').forEach(function (btn) {
        btn.onclick = function () {
          var name = btn.dataset.instanceName || '';
          var service = btn.dataset.instanceService || '';
          var isLast = btn.dataset.instanceIsLastEnabled === '1';
          var tpl = isLast
            ? {{ 'admin.instances.action.delete_last_confirm'|trans({ '%name%': '__NAME__', '%service%': '__SERVICE__' })|json_encode|raw }}
            : {{ 'admin.instances.action.delete_confirm'|trans({ '%name%': '__NAME__' })|json_encode|raw }};
          var msg = tpl.replace('__NAME__', name).replace('__SERVICE__', service);
          if (!confirm(msg)) return;
          btn.disabled = true;
          instanceFetch(btn).then(reloadAfterMutation).catch(function () {
            btn.disabled = false;
            alert({{ 'admin.services.status.error'|trans|json_encode|raw }});
          });
        };
      });

      // Toggle enabled (checkbox switch). Disabling the last enabled
      // instance of a service removes it from the sidebar / dashboard,
      // so we ask before going through.
      document.querySelectorAll('[data-instance-action="toggle-enabled"]').forEach(function (cb) {
        cb.onchange = function () {
          var willDisable = !cb.checked;
          if (willDisable && cb.dataset.instanceIsLastEnabled === '1') {
            var tpl = {{ 'admin.instances.action.disable_last_confirm'|trans({ '%service%': '__SERVICE__' })|json_encode|raw }};
            var msg = tpl.replace('__SERVICE__', cb.dataset.instanceService || '');
            if (!confirm(msg)) {
              cb.checked = true; // revert the UI flip the user just did
              return;
            }
          }
          var prev = !cb.checked;
          cb.disabled = true;
          instanceFetch(cb).then(reloadAfterMutation).catch(function () {
            cb.checked = prev;
            cb.disabled = false;
            alert({{ 'admin.services.status.error'|trans|json_encode|raw }});
          });
        };
      });

      // Test connection per instance — single button, state-driven.
      // Button colour switches to outline-success / outline-danger after
      // the probe so the row stays compact (no separate status pill).
      // The category map mirrors HealthService::diagnose() and reuses the
      // setup wizard translations (same probe, same outcomes).
      var INSTANCE_TEST_LABELS = {
        idle:        {{ 'admin.services.test'|trans|json_encode|raw }},
        testing:     {{ 'admin.services.status.testing'|trans|json_encode|raw }},
        connected:   {{ 'admin.services.status.connected'|trans|json_encode|raw }},
        unreachable: {{ 'admin.services.status.unreachable'|trans|json_encode|raw }},
        error:       {{ 'admin.services.status.error'|trans|json_encode|raw }},
      };
      var INSTANCE_TEST_CATEGORIES = {
        network:      {{ 'setup.test.category.network'|trans|json_encode|raw }},
        auth:         {{ 'setup.test.category.auth'|trans|json_encode|raw }},
        forbidden:    {{ 'setup.test.category.forbidden'|trans|json_encode|raw }},
        not_found:    {{ 'setup.test.category.not_found'|trans|json_encode|raw }},
        server_error: {{ 'setup.test.category.server_error'|trans|json_encode|raw }},
        unconfigured: {{ 'setup.test.category.unconfigured'|trans|json_encode|raw }},
        unknown:      {{ 'setup.test.category.unknown'|trans|json_encode|raw }},
      };
      function setInstanceTestBtnState(btn, state, opts) {
        opts = opts || {};
        var label = btn.querySelector('[data-instance-test-label]');
        // Drop any previous outcome class, keep base classes.
        btn.classList.remove('btn-outline-secondary', 'btn-outline-success', 'btn-outline-danger');
        var nextClass = 'btn-outline-secondary';
        var text = INSTANCE_TEST_LABELS.idle;
        if (state === 'testing')     { text = INSTANCE_TEST_LABELS.testing; }
        else if (state === 'ok')     { nextClass = 'btn-outline-success'; text = INSTANCE_TEST_LABELS.connected; }
        else if (state === 'ko')     { nextClass = 'btn-outline-danger';  text = opts.label || INSTANCE_TEST_LABELS.unreachable; }
        btn.classList.add(nextClass);
        if (label) label.textContent = text;
        if (opts.title) btn.title = opts.title;
      }

      document.querySelectorAll('[data-instance-action="test"]').forEach(function (btn) {
        btn.onclick = function () {
          setInstanceTestBtnState(btn, 'testing');
          btn.disabled = true;
          instanceFetch(btn)
            .then(function (r) { return r.json(); })
            .then(function (data) {
              if (data && data.ok) {
                setInstanceTestBtnState(btn, 'ok', {
                  title: INSTANCE_TEST_LABELS.connected + (data.http ? ' (HTTP ' + data.http + ')' : ''),
                });
              } else {
                var category = data && data.category;
                var detail = INSTANCE_TEST_CATEGORIES[category] || INSTANCE_TEST_LABELS.unreachable;
                var title = detail + (data && data.http ? ' (HTTP ' + data.http + ')' : '');
                setInstanceTestBtnState(btn, 'ko', { label: detail, title: title });
              }
              btn.disabled = false;
            })
            .catch(function () {
              setInstanceTestBtnState(btn, 'ko', { label: INSTANCE_TEST_LABELS.error });
              btn.disabled = false;
            });
        };
      });

      // ── Tabs navigation ─────────────────────────────────────────────
      // The sections are hidden via CSS and swapped in/out on click. We
      // persist the active tab in sessionStorage so POST/Redirect cycles
      // (the form submits and the server redirects back) land on the
      // same section the user was editing.
      var navLinks = document.querySelectorAll('.settings-nav a[data-settings-nav]');
      var sections = document.querySelectorAll('.settings-group[data-section]');
      var STORAGE_KEY = 'prismarrSettingsActiveSection';

      var footer = document.querySelector('[data-settings-footer]');
      // Save button applies only to Services + Display (the main form).
      // Sauvegarde + À propos have their own action buttons, so we hide
      // the footer on those tabs to avoid a dangling "Save" with nothing
      // to save.
      var SAVE_SECTIONS = { 'section-services': true, 'section-display': true };

      function activate(id) {
        if (!id) return;
        sections.forEach(function (s) {
          s.classList.toggle('is-active', s.id === id);
        });
        navLinks.forEach(function (a) {
          a.classList.toggle('active', a.dataset.settingsNav === id);
        });
        if (footer) {
          footer.style.display = SAVE_SECTIONS[id] ? '' : 'none';
        }
        try { sessionStorage.setItem(STORAGE_KEY, id); } catch (e) {}
      }

      navLinks.forEach(function (a) {
        if (a.classList.contains('disabled')) return;
        a.onclick = function (e) {
          e.preventDefault();
          var id = a.dataset.settingsNav;
          activate(id);
          history.replaceState(null, '', '#' + id);
        };
      });

      // Initial activation: URL hash wins, then last stored, then first section
      var initial = window.location.hash.slice(1);
      if (!initial) {
        try { initial = sessionStorage.getItem(STORAGE_KEY) || ''; } catch (e) {}
      }
      if (!initial && sections.length) initial = sections[0].id;
      activate(initial);
    })();
  </script>
{% endblock %}
