{% extends 'base.html.twig' %}
{% import '_icons.html.twig' as ico %}

{% block title %}{{ 'media.arr_admin.suggestions.title_sonarr'|trans }}{% endblock %}

{% block body %}
<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col"><h2 class="page-title">{{ 'media.arr_admin.suggestions.page_title_sonarr'|trans }}</h2></div>
      <div class="col-auto ms-auto d-flex gap-2 align-items-center">
        {% include 'media/_sonarr_nav.html.twig' %}
      </div>
    </div>
  </div>
</div>

<div class="page-body">
<div class="container-xl">

{% if error %}
<div class="alert alert-danger">{{ 'media.arr_admin.suggestions.error_unreachable_sonarr'|trans }}</div>
{% endif %}

{% if series is empty %}
  <div class="card">
    <div class="card-body text-center text-muted py-5">
      <div>{{ ico.icon('device-tv', 'text-muted', 40) }}</div>
      <div class="mt-2">{{ 'media.arr_admin.suggestions.empty_sonarr_title'|trans }}</div>
      <div class="small mt-1">{{ 'media.arr_admin.suggestions.empty_sonarr_help'|trans }}</div>
    </div>
  </div>
{% else %}
  <div class="text-muted small mb-3">{{ 'media.arr_admin.suggestions.count_series_tpl'|trans({count: series|length}) }}</div>
  <div class="row g-3">
    {% for s in series %}
    <div class="col-6 col-sm-4 col-md-3 col-lg-2">
      <div class="card h-100" style="cursor:pointer;">
        {% if s.poster %}
          <img src="{{ s.poster }}" alt="{{ s.title }}" class="card-img-top" style="aspect-ratio:2/3;object-fit:cover;" loading="lazy">
        {% else %}
          <div style="aspect-ratio:2/3;background:var(--tblr-bg-surface-secondary);display:flex;align-items:center;justify-content:center;" class="card-img-top">
            <span class="text-muted small">{{ s.title }}</span>
          </div>
        {% endif %}
        <div class="card-body p-2">
          <div class="fw-medium small">{{ s.title }}</div>
          <div class="text-muted" style="font-size:.7rem;">{{ s.year ?? '' }}{% if s.network %} · {{ s.network }}{% endif %}</div>
        </div>
      </div>
    </div>
    {% endfor %}
  </div>
{% endif %}

</div>
</div>
{% endblock %}
