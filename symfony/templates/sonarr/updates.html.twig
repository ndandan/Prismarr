{% extends 'base.html.twig' %}
{% block title %}{{ 'media.arr_admin.updates.title_sonarr'|trans }}{% endblock %}

{% block body %}
<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col"><h2 class="page-title">{{ 'media.arr_admin.updates.page_title'|trans }}</h2></div>
      <div class="col-auto ms-auto">{% include 'media/_sonarr_nav.html.twig' %}</div>
    </div>
  </div>
</div>
<div class="page-body"><div class="container-xl">

{% if error %}<div class="alert alert-danger">{{ 'media.arr_admin.updates.error_unreachable_sonarr'|trans }}</div>{% endif %}

{% if status is defined and status and status.packageUpdateMechanism is defined and status.packageUpdateMechanism == 'docker' %}
<div class="alert alert-warning d-flex align-items-center gap-2 mb-3">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="flex-shrink-0"><path d="M12 9v4"/><path d="M10.363 3.591l-8.106 13.534a1.914 1.914 0 0 0 1.636 2.871h16.214a1.914 1.914 0 0 0 1.636 -2.871l-8.106 -13.534a1.914 1.914 0 0 0 -3.274 0z"/><path d="M12 16h.01"/></svg>
    <div class="small">{{ 'media.arr_admin.updates.docker_warning_sonarr'|trans }}</div>
</div>
{% endif %}

{# Version actuelle #}
{% if status is defined and status %}
<div class="card mb-3">
    <div class="card-body">
        <div class="d-flex align-items-center gap-3">
            <svg width="32" height="32" viewBox="0 0 216.7 216.9" xmlns="http://www.w3.org/2000/svg"><path d="M194.65 42.5l-22.4 22.4C159.15 78 158 89.4 158 109.5c0 17.93 2.85 34.35 16.2 47.7l19 18.95c-2.5 3.07-5.2 6.07-8.1 9-.7.83-1.48 1.6-2.35 2.3-2.53 2.5-5.17 4.82-7.9 6.95l-17.55-17.55c-15.6-15.6-28-17.1-48.6-17.1-19.77 0-33.22 1.82-47.7 16.3l-18.55 18.6c-3.77-2.87-7.33-6.03-10.7-9.5-2.8-2.8-5.42-5.67-7.85-8.6l19.15-19.2c13.85-13.85 16.1-29.92 16.1-47.85 0-17.5-2.87-33.82-15.6-46.55L22.45 43.85c2.83-3.6 5.92-7.07 9.25-10.4 2.93-2.87 5.93-5.55 9-8.05L61.1 43.85C74.1 56.85 90.77 60.2 108.7 60.2c18.47 0 35.08-3.58 48.6-17.1l19.3-19.25c2.9 2.37 5.73 4.93 8.5 7.7 3.47 3.53 6.65 7.18 9.55 10.95z" fill="#0CF"/><circle cx="108.35" cy="108.45" r="29.5" fill="#0CF" opacity=".8"/></svg>
            <div>
                <div class="text-secondary small mb-1">{{ 'media.arr_admin.updates.installed_version'|trans }}</div>
                <div class="fw-bold fs-4" style="color:#0CF;">{{ status.version ?? '—' }}</div>
            </div>
            {% set hasInstallable = updates|filter(u => u.installable ?? false)|length > 0 %}
            <div class="ms-auto">
                {% if hasInstallable %}
                    <span class="badge bg-warning-lt text-warning fs-6">{{ 'media.arr_admin.updates.update_available'|trans }}</span>
                {% else %}
                    <span class="badge bg-success-lt text-success fs-6">{{ 'media.arr_admin.updates.up_to_date'|trans }}</span>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endif %}

{# Version history #}
<div class="card">
    <div class="card-header">
        <h3 class="card-title">{{ 'media.arr_admin.updates.history_title'|trans }}</h3>
        <div class="card-options"><span class="badge bg-secondary-lt">{{ updates|length }}</span></div>
    </div>
    <div class="card-body p-0">
        {% if updates is empty %}
            <div class="text-muted text-center py-5">{{ 'media.arr_admin.updates.empty_sonarr'|trans }}</div>
        {% else %}
        <div class="table-responsive">
            <table class="table table-vcenter table-sm mb-0">
                <thead><tr><th>{{ 'media.arr_admin.updates.col_version'|trans }}</th><th>{{ 'media.arr_admin.updates.col_date'|trans }}</th><th>{{ 'media.arr_admin.updates.col_branch'|trans }}</th><th>{{ 'media.arr_admin.updates.col_status'|trans }}</th><th class="text-end"></th></tr></thead>
                <tbody>
                    {% for update in updates %}
                    <tr>
                        <td class="fw-medium">
                            {{ update.version ?? '—' }}
                            {% if update.latest ?? false %}<span class="badge bg-purple-lt ms-1" style="font-size:.65rem;">{{ 'media.arr_admin.updates.latest'|trans }}</span>{% endif %}
                        </td>
                        <td class="text-muted small">{{ update.releaseDate is defined ? update.releaseDate|date('d/m/Y') : '—' }}</td>
                        <td><span class="badge bg-secondary-lt">{{ update.branch ?? '—' }}</span></td>
                        <td>
                            {% if update.installed ?? false %}<span class="badge bg-success-lt text-success">{{ 'media.arr_admin.updates.installed'|trans }}</span>
                            {% elseif update.installable ?? false %}<span class="badge bg-warning-lt text-warning">{{ 'media.arr_admin.updates.available'|trans }}</span>
                            {% else %}<span class="badge bg-secondary-lt">{{ 'media.arr_admin.updates.old'|trans }}</span>{% endif %}
                        </td>
                        <td class="text-end">
                            {% if (update.installable ?? false) and (status is not defined or status.packageUpdateMechanism is not defined or status.packageUpdateMechanism != 'docker') %}
                                <button class="btn btn-warning btn-sm btn-install" data-version="{{ update.version ?? '' }}">{{ 'media.arr_admin.updates.install'|trans }}</button>
                            {% elseif (update.installable ?? false) %}
                                <span class="text-secondary small fst-italic">{{ 'media.arr_admin.updates.via_docker'|trans }}</span>
                            {% endif %}
                        </td>
                    </tr>
                    {% if update.changes is defined and update.changes %}
                    <tr>
                        <td colspan="5" style="padding:.5rem 1rem;background:rgba(255,255,255,.015);">
                            {% if update.changes.new is defined and update.changes.new %}
                            <div class="mb-2">
                                <div class="small fw-semibold" style="color:#22c55e;">{{ 'media.arr_admin.updates.changes_new'|trans }}</div>
                                <ul class="mb-0" style="font-size:.75rem;padding-left:1.2rem;color:var(--tblr-secondary-color);">
                                    {% for item in update.changes.new %}<li>{{ item }}</li>{% endfor %}
                                </ul>
                            </div>
                            {% endif %}
                            {% if update.changes.fixed is defined and update.changes.fixed %}
                            <div>
                                <div class="small fw-semibold" style="color:#38bdf8;">{{ 'media.arr_admin.updates.changes_fixed'|trans }}</div>
                                <ul class="mb-0" style="font-size:.75rem;padding-left:1.2rem;color:var(--tblr-secondary-color);">
                                    {% for item in update.changes.fixed %}<li>{{ item }}</li>{% endfor %}
                                </ul>
                            </div>
                            {% endif %}
                        </td>
                    </tr>
                    {% endif %}
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% endif %}
    </div>
</div>

</div></div>
{% endblock %}
