{% extends 'base.html.twig' %}

{% block title %}{{ 'media.arr_admin.delay_profiles.title_sonarr'|trans }}{% endblock %}

{% block body %}
<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <h2 class="page-title">{{ 'media.arr_admin.delay_profiles.page_title'|trans }}</h2>
      </div>
      <div class="col-auto ms-auto d-flex gap-2 align-items-center">
        <button class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#modal-dp">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14m-7-7h14"/></svg>
          {{ 'media.arr_admin.delay_profiles.add'|trans }}
        </button>
        {% include 'media/_sonarr_nav.html.twig' %}
      </div>
    </div>
  </div>
</div>

<div class="page-body">
<div class="container-xl">

{% if error %}
<div class="alert alert-danger">{{ 'media.arr_admin.delay_profiles.error_unreachable_sonarr'|trans }}</div>
{% endif %}

<div id="delay-feedback" class="alert d-none mb-3"></div>

<div class="card">
  <div class="card-header">
    <h3 class="card-title">{{ 'media.arr_admin.delay_profiles.card_title'|trans }}</h3>
    <div class="card-options">
      <span class="badge bg-secondary-lt">{{ profiles|length }}</span>
    </div>
  </div>
  <div class="card-body p-0">
    {% if profiles is empty %}
      <div class="text-muted text-center py-5">{{ 'media.arr_admin.delay_profiles.empty'|trans }}</div>
    {% else %}
      <div class="table-responsive">
        <table class="table table-vcenter mb-0">
          <thead>
            <tr>
              <th>{{ 'media.arr_admin.delay_profiles.col_order'|trans }}</th>
              <th>{{ 'media.arr_admin.delay_profiles.col_tags'|trans }}</th>
              <th>{{ 'media.arr_admin.delay_profiles.col_usenet'|trans }}</th>
              <th>{{ 'media.arr_admin.delay_profiles.col_torrent'|trans }}</th>
              <th>{{ 'media.arr_admin.delay_profiles.col_protocol'|trans }}</th>
              <th>{{ 'media.arr_admin.delay_profiles.col_delay_usenet'|trans }}</th>
              <th>{{ 'media.arr_admin.delay_profiles.col_delay_torrent'|trans }}</th>
              <th>{{ 'media.arr_admin.delay_profiles.col_bypass_cutoff'|trans }}</th>
              <th class="text-end">{{ 'media.arr_admin.delay_profiles.col_actions'|trans }}</th>
            </tr>
          </thead>
          <tbody>
            {% for profile in profiles %}
            <tr>
              <td>{{ profile.order ?? '—' }}</td>
              <td>
                {% if profile.tags is defined and profile.tags %}
                  {% for tag in profile.tags %}
                    <span class="badge bg-secondary-lt me-1">{{ tag }}</span>
                  {% endfor %}
                {% else %}
                  <span class="text-muted small">{{ 'media.arr_admin.delay_profiles.tags_global'|trans }}</span>
                {% endif %}
              </td>
              <td>
                {% if profile.enableUsenet ?? false %}
                  <span class="badge bg-success-lt text-success">{{ 'media.arr_admin.delay_profiles.yes'|trans }}</span>
                {% else %}
                  <span class="badge bg-secondary-lt">{{ 'media.arr_admin.delay_profiles.no'|trans }}</span>
                {% endif %}
              </td>
              <td>
                {% if profile.enableTorrent ?? false %}
                  <span class="badge bg-success-lt text-success">{{ 'media.arr_admin.delay_profiles.yes'|trans }}</span>
                {% else %}
                  <span class="badge bg-secondary-lt">{{ 'media.arr_admin.delay_profiles.no'|trans }}</span>
                {% endif %}
              </td>
              <td class="text-muted">{{ profile.preferredProtocol ?? '—' }}</td>
              <td class="text-muted">{{ profile.usenetDelay ?? '—' }}</td>
              <td class="text-muted">{{ profile.torrentDelay ?? '—' }}</td>
              <td>
                {% if profile.bypassIfHighestQuality ?? false %}
                  <span class="badge bg-success-lt text-success">{{ 'media.arr_admin.delay_profiles.yes'|trans }}</span>
                {% else %}
                  <span class="badge bg-secondary-lt">{{ 'media.arr_admin.delay_profiles.no'|trans }}</span>
                {% endif %}
              </td>
              <td class="text-end d-flex gap-2 justify-content-end">
                <button class="btn btn-ghost-secondary btn-icon"
                        data-bs-toggle="modal" data-bs-target="#modal-dp"
                        data-edit-item="{{ profile|json_encode|e('html_attr') }}" title="{{ 'media.arr_admin.delay_profiles.edit'|trans }}">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                </button>
                {% if profile.id is defined and profiles|length > 1 %}
                  <button class="btn btn-ghost-danger btn-icon btn-delay-delete"
                          data-id="{{ profile.id }}" title="{{ 'media.arr_admin.delay_profiles.delete'|trans }}">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                  </button>
                {% else %}
                  <span class="text-muted small">{{ 'media.arr_admin.delay_profiles.default'|trans }}</span>
                {% endif %}
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endif %}
  </div>
</div>

</div>
</div>

{# Delay profile create/edit modal #}
<div class="modal modal-blur fade" id="modal-dp" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="modal-dp-title">{{ 'media.arr_admin.delay_profiles.modal_new'|trans }}</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="row g-3">
          <div class="col-6">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="dp-enable-usenet" checked>
              <label class="form-check-label" for="dp-enable-usenet">{{ 'media.arr_admin.delay_profiles.enable_usenet'|trans }}</label>
            </div>
          </div>
          <div class="col-6">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="dp-enable-torrent" checked>
              <label class="form-check-label" for="dp-enable-torrent">{{ 'media.arr_admin.delay_profiles.enable_torrent'|trans }}</label>
            </div>
          </div>
          <div class="col-12">
            <label class="form-label fw-medium">{{ 'media.arr_admin.delay_profiles.preferred_protocol'|trans }}</label>
            <select class="form-select form-select-sm" id="dp-preferred-protocol">
              <option value="usenet">Usenet</option>
              <option value="torrent">Torrent</option>
            </select>
          </div>
          <div class="col-6">
            <label class="form-label fw-medium">{{ 'media.arr_admin.delay_profiles.usenet_delay'|trans }}</label>
            <input type="number" class="form-control form-control-sm" id="dp-usenet-delay" value="0" min="0">
          </div>
          <div class="col-6">
            <label class="form-label fw-medium">{{ 'media.arr_admin.delay_profiles.torrent_delay'|trans }}</label>
            <input type="number" class="form-control form-control-sm" id="dp-torrent-delay" value="0" min="0">
          </div>
          <div class="col-12">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="dp-bypass-highest">
              <label class="form-check-label" for="dp-bypass-highest">{{ 'media.arr_admin.delay_profiles.bypass_highest'|trans }}</label>
            </div>
          </div>
          <div class="col-12">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="dp-bypass-cf-score">
              <label class="form-check-label" for="dp-bypass-cf-score">{{ 'media.arr_admin.delay_profiles.bypass_cf_score'|trans }}</label>
            </div>
          </div>
          <div class="col-6">
            <label class="form-label fw-medium">{{ 'media.arr_admin.delay_profiles.min_cf_score'|trans }}</label>
            <input type="number" class="form-control form-control-sm" id="dp-min-cf-score" value="0" min="0">
          </div>
          <div class="col-6">
            <label class="form-label fw-medium">{{ 'media.arr_admin.delay_profiles.tags_label'|trans }}</label>
            <input type="text" class="form-control form-control-sm" id="dp-tags" placeholder="{{ 'media.arr_admin.delay_profiles.tags_placeholder'|trans }}">
            <small class="text-muted">{{ 'media.arr_admin.delay_profiles.tags_help'|trans }}</small>
          </div>
        </div>
        <div id="dp-modal-feedback" class="alert d-none mt-3"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'media.arr_admin.delay_profiles.cancel'|trans }}</button>
        <button type="button" class="btn btn-primary" id="btn-dp-save">{{ 'media.arr_admin.delay_profiles.create'|trans }}</button>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
(function(){
  var I18N = {
    modal_new: {{ 'media.arr_admin.delay_profiles.modal_new'|trans|json_encode|raw }},
    modal_edit_tpl: {{ 'media.arr_admin.delay_profiles.modal_edit_tpl'|trans({id: '__ID__'})|json_encode|raw }},
    save: {{ 'media.arr_admin.delay_profiles.save'|trans|json_encode|raw }},
    create: {{ 'media.arr_admin.delay_profiles.create'|trans|json_encode|raw }},
    error_save: {{ 'media.arr_admin.delay_profiles.error_save'|trans|json_encode|raw }},
    error_delete: {{ 'media.arr_admin.delay_profiles.error_delete'|trans|json_encode|raw }},
    error_network_tpl: {{ 'media.arr_admin.delay_profiles.error_network_tpl'|trans({message: '__MSG__'})|json_encode|raw }},
    confirm_delete: {{ 'media.arr_admin.delay_profiles.confirm_delete'|trans|json_encode|raw }}
  };

  var feedback = document.getElementById('delay-feedback');
  var editingItem = null;

  function showFeedback(msg, type) {
    feedback.className = 'alert alert-' + type + ' mb-3';
    feedback.textContent = msg;
    feedback.classList.remove('d-none');
    setTimeout(function(){ feedback.classList.add('d-none'); }, 4000);
  }

  function showModalFeedback(msg, type) {
    var mfb = document.getElementById('dp-modal-feedback');
    mfb.className = 'alert alert-' + type + ' mt-3';
    mfb.textContent = msg;
    mfb.classList.remove('d-none');
  }

  function hideModalFeedback() {
    document.getElementById('dp-modal-feedback').classList.add('d-none');
  }

  document.getElementById('modal-dp').addEventListener('show.bs.modal', function(e) {
    hideModalFeedback();
    var raw = e.relatedTarget ? (e.relatedTarget.dataset.editItem || null) : null;
    editingItem = raw ? JSON.parse(raw) : null;

    if (editingItem) {
      document.getElementById('modal-dp-title').textContent = I18N.modal_edit_tpl.replace('__ID__', editingItem.id);
      document.getElementById('dp-enable-usenet').checked = editingItem.enableUsenet !== false;
      document.getElementById('dp-enable-torrent').checked = editingItem.enableTorrent !== false;
      document.getElementById('dp-preferred-protocol').value = editingItem.preferredProtocol || 'usenet';
      document.getElementById('dp-usenet-delay').value = editingItem.usenetDelay || 0;
      document.getElementById('dp-torrent-delay').value = editingItem.torrentDelay || 0;
      document.getElementById('dp-bypass-highest').checked = editingItem.bypassIfHighestQuality || false;
      document.getElementById('dp-bypass-cf-score').checked = editingItem.bypassIfAboveCustomFormatScore || false;
      document.getElementById('dp-min-cf-score').value = editingItem.minimumCustomFormatScore || 0;
      document.getElementById('dp-tags').value = (editingItem.tags || []).join(',');
      document.getElementById('btn-dp-save').textContent = I18N.save;
    } else {
      document.getElementById('modal-dp-title').textContent = I18N.modal_new;
      document.getElementById('dp-enable-usenet').checked = true;
      document.getElementById('dp-enable-torrent').checked = true;
      document.getElementById('dp-preferred-protocol').value = 'usenet';
      document.getElementById('dp-usenet-delay').value = 0;
      document.getElementById('dp-torrent-delay').value = 0;
      document.getElementById('dp-bypass-highest').checked = false;
      document.getElementById('dp-bypass-cf-score').checked = false;
      document.getElementById('dp-min-cf-score').value = 0;
      document.getElementById('dp-tags').value = '';
      document.getElementById('btn-dp-save').textContent = I18N.create;
    }
  });

  document.getElementById('btn-dp-save').addEventListener('click', function() {
    hideModalFeedback();
    var tagsRaw = document.getElementById('dp-tags').value.trim();
    var tags = [];
    if (tagsRaw) {
      tags = tagsRaw.split(',').map(function(t){ return parseInt(t.trim()); }).filter(function(n){ return !isNaN(n); });
    }

    var payload = {
      enableUsenet: document.getElementById('dp-enable-usenet').checked,
      enableTorrent: document.getElementById('dp-enable-torrent').checked,
      preferredProtocol: document.getElementById('dp-preferred-protocol').value,
      usenetDelay: parseInt(document.getElementById('dp-usenet-delay').value) || 0,
      torrentDelay: parseInt(document.getElementById('dp-torrent-delay').value) || 0,
      bypassIfHighestQuality: document.getElementById('dp-bypass-highest').checked,
      bypassIfAboveCustomFormatScore: document.getElementById('dp-bypass-cf-score').checked,
      minimumCustomFormatScore: parseInt(document.getElementById('dp-min-cf-score').value) || 0,
      tags: tags
    };

    var url;
    if (editingItem) {
      payload.id = editingItem.id;
      payload.order = editingItem.order;
      url = '{{ app.request.getBasePath() }}/medias/' + INSTANCE_SLUG + '/sonarr/profils-delai/' + editingItem.id + '/modifier';
    } else {
      url = {{ instance_path('sonarr_delay_profile_add')|json_encode|raw }};
    }

    fetch(url, {
      method: 'POST',
      headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
      body: JSON.stringify(payload)
    })
    .then(function(r){ return r.json(); })
    .then(function(data){
      if (data.ok) {
        location.reload();
      } else {
        showModalFeedback(data.error || I18N.error_save, 'danger');
      }
    })
    .catch(function(err){
      showModalFeedback(I18N.error_network_tpl.replace('__MSG__', (err.message || err)), 'danger');
    });
  });

  document.querySelectorAll('.btn-delay-delete').forEach(function(btn) {
    btn.addEventListener('click', function() {
      if (!confirm(I18N.confirm_delete)) return;
      fetch('{{ app.request.getBasePath() }}/medias/' + INSTANCE_SLUG + '/sonarr/profils-delai/' + btn.dataset.id + '/supprimer', {
        method: 'POST',
        headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
        body: '{}'
      })
      .then(function(r){ return r.json(); })
      .then(function(data){
        if (data.ok) location.reload();
        else showFeedback(data.error || I18N.error_delete, 'danger');
      });
    });
  });
})();
</script>
{% endblock %}
