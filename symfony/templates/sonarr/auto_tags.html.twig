{% extends 'base.html.twig' %}

{% block title %}{{ 'media.arr_admin.auto_tags.title_sonarr'|trans }}{% endblock %}

{% block body %}
<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <h2 class="page-title">{{ 'media.arr_admin.auto_tags.page_title'|trans }}</h2>
      </div>
      <div class="col-auto ms-auto d-flex gap-2 align-items-center">
        <button class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#modal-at">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14m-7-7h14"/></svg>
          {{ 'media.arr_admin.auto_tags.btn_add'|trans }}
        </button>
        <a href="{{ instance_path('sonarr_tags') }}" class="btn btn-ghost-secondary btn-sm">{{ 'media.arr_admin.auto_tags.btn_tags'|trans }}</a>
        {% include 'media/_sonarr_nav.html.twig' %}
      </div>
    </div>
  </div>
</div>

<div class="page-body">
<div class="container-xl">

{% if error %}
<div class="alert alert-danger">{{ 'media.arr_admin.auto_tags.error_unreachable_sonarr'|trans }}</div>
{% endif %}

<div id="at-feedback" class="alert d-none mb-3"></div>

<div class="card">
  <div class="card-header">
    <h3 class="card-title">{{ 'media.arr_admin.auto_tags.rules_card_title'|trans }}</h3>
    <div class="card-options">
      <span class="badge bg-secondary-lt">{{ tags|length }}</span>
    </div>
  </div>
  <div class="card-body p-0">
    {% if tags is empty %}
      <div class="text-muted text-center py-5">{{ 'media.arr_admin.auto_tags.empty'|trans }}</div>
    {% else %}
      <div class="table-responsive">
        <table class="table table-vcenter mb-0">
          <thead>
            <tr>
              <th>{{ 'media.arr_admin.auto_tags.col_name'|trans }}</th>
              <th>{{ 'media.arr_admin.auto_tags.col_conditions'|trans }}</th>
              <th>{{ 'media.arr_admin.auto_tags.col_tags_applied'|trans }}</th>
              <th>{{ 'media.arr_admin.auto_tags.col_remove_unmatched'|trans }}</th>
              <th class="text-end">{{ 'media.arr_admin.auto_tags.col_actions'|trans }}</th>
            </tr>
          </thead>
          <tbody>
            {% for tag in tags %}
            <tr>
              <td class="fw-medium">{{ tag.name ?? '—' }}</td>
              <td class="text-muted small">{{ 'media.arr_admin.auto_tags.conditions_count_tpl'|trans({count: tag.specifications is defined ? tag.specifications|length : 0}) }}</td>
              <td>
                <div class="d-flex flex-wrap gap-1">
                  {% if tag.tags is defined %}
                    {% for t in tag.tags %}
                      <span class="badge bg-blue-lt">{{ t }}</span>
                    {% endfor %}
                  {% endif %}
                </div>
              </td>
              <td>
                {% if tag.removeTagsAutomatically ?? false %}
                  <span class="badge bg-warning-lt text-warning">{{ 'media.arr_admin.auto_tags.yes'|trans }}</span>
                {% else %}
                  <span class="badge bg-secondary-lt">{{ 'media.arr_admin.auto_tags.no'|trans }}</span>
                {% endif %}
              </td>
              <td class="text-end d-flex gap-2 justify-content-end">
                <button class="btn btn-ghost-secondary btn-icon"
                        data-bs-toggle="modal" data-bs-target="#modal-at"
                        data-edit-item="{{ tag|json_encode|e('html_attr') }}" title="{{ 'media.arr_admin.auto_tags.btn_edit_title'|trans }}">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                </button>
                <button class="btn btn-ghost-danger btn-icon btn-at-delete"
                        data-id="{{ tag.id }}"
                        data-name="{{ tag.name ?? '' }}" title="{{ 'media.arr_admin.auto_tags.btn_delete_title'|trans }}">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                </button>
              </td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endif %}
  </div>
</div>

</div>
</div>

{# Modal creation/edition auto-tag #}
<div class="modal modal-blur fade" id="modal-at" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="modal-at-title">{{ 'media.arr_admin.auto_tags.modal_title_new'|trans }}</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="row g-3">
          <div class="col-12">
            <label class="form-label fw-medium">{{ 'media.arr_admin.auto_tags.label_name'|trans }} <span class="text-danger">*</span></label>
            <input type="text" class="form-control form-control-sm" id="at-name" placeholder="{{ 'media.arr_admin.auto_tags.label_name_placeholder'|trans }}">
          </div>
          <div class="col-6">
            <label class="form-label fw-medium">{{ 'media.arr_admin.auto_tags.label_tags'|trans }}</label>
            <input type="text" class="form-control form-control-sm" id="at-tags" placeholder="{{ 'media.arr_admin.auto_tags.label_tags_placeholder'|trans }}">
            <small class="text-muted">{{ 'media.arr_admin.auto_tags.label_tags_help'|trans }}</small>
          </div>
          <div class="col-6 d-flex align-items-end">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="at-remove-auto">
              <label class="form-check-label" for="at-remove-auto">{{ 'media.arr_admin.auto_tags.label_remove_unmatched'|trans }}</label>
            </div>
          </div>
          <div class="col-12">
            <hr>
            <div class="d-flex align-items-center justify-content-between mb-2">
              <label class="form-label fw-medium mb-0">{{ 'media.arr_admin.auto_tags.specifications_title'|trans }}</label>
              <button type="button" class="btn btn-outline-primary btn-sm" id="btn-at-add-spec">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14m-7-7h14"/></svg>
                {{ 'media.arr_admin.auto_tags.btn_add_spec'|trans }}
              </button>
            </div>
            <div id="at-specs-container"></div>
            <div id="at-no-specs" class="text-muted small text-center py-3">{{ 'media.arr_admin.auto_tags.no_specs'|trans }}</div>
          </div>
        </div>
        <div id="at-modal-feedback" class="alert d-none mt-3"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'media.arr_admin.auto_tags.cancel'|trans }}</button>
        <button type="button" class="btn btn-primary" id="btn-at-save">{{ 'media.arr_admin.auto_tags.btn_create'|trans }}</button>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block stylesheets %}
<style>
.at-spec-card {
  border: 1px solid var(--tblr-border-color);
  border-radius: .5rem;
  padding: .75rem;
  margin-bottom: .5rem;
  background: var(--tblr-bg-surface-secondary);
}
.at-spec-card .at-spec-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: .5rem;
}
.at-spec-card .at-spec-title {
  font-weight: 600;
  font-size: .85rem;
}
</style>
{% endblock %}

{% block javascripts %}
<script>
(function(){
  var _I18N = {
    modal_title_new: {{ 'media.arr_admin.auto_tags.modal_title_new'|trans|json_encode|raw }},
    modal_title_edit: {{ 'media.arr_admin.auto_tags.modal_title_edit_tpl'|trans({name: '__NAME__'})|json_encode|raw }},
    btn_create: {{ 'media.arr_admin.auto_tags.btn_create'|trans|json_encode|raw }},
    btn_save: {{ 'media.arr_admin.auto_tags.btn_save'|trans|json_encode|raw }},
    type_placeholder: {{ 'media.arr_admin.auto_tags.type_placeholder'|trans|json_encode|raw }},
    name_placeholder: {{ 'media.arr_admin.auto_tags.name_placeholder'|trans|json_encode|raw }},
    type_label: {{ 'media.arr_admin.auto_tags.type_label'|trans|json_encode|raw }},
    name_label: {{ 'media.arr_admin.auto_tags.name_label'|trans|json_encode|raw }},
    negate_label: {{ 'media.arr_admin.auto_tags.negate_label'|trans|json_encode|raw }},
    required_label: {{ 'media.arr_admin.auto_tags.required_label'|trans|json_encode|raw }},
    fields_label: {{ 'media.arr_admin.auto_tags.fields_label'|trans|json_encode|raw }},
    fields_help: {{ 'media.arr_admin.auto_tags.fields_help'|trans|json_encode|raw }},
    err_name_required: {{ 'media.arr_admin.auto_tags.err_name_required'|trans|json_encode|raw }},
    err_save: {{ 'media.arr_admin.auto_tags.err_save'|trans|json_encode|raw }},
    err_network_tpl: {{ 'media.arr_admin.auto_tags.err_network_tpl'|trans({error: '__ERR__'})|json_encode|raw }},
    delete_confirm_tpl: {{ 'media.arr_admin.auto_tags.delete_confirm_tpl'|trans({name: '__NAME__'})|json_encode|raw }},
    delete_error: {{ 'media.arr_admin.auto_tags.delete_error'|trans|json_encode|raw }},
    condition_n_tpl: {{ 'media.arr_admin.auto_tags.condition_n_tpl'|trans({n: '__N__'})|json_encode|raw }},
    spec_root_folder: {{ 'media.arr_admin.auto_tags.spec_root_folder'|trans|json_encode|raw }},
    spec_quality_profile: {{ 'media.arr_admin.auto_tags.spec_quality_profile'|trans|json_encode|raw }},
    spec_genre: {{ 'media.arr_admin.auto_tags.spec_genre'|trans|json_encode|raw }},
    spec_year: {{ 'media.arr_admin.auto_tags.spec_year'|trans|json_encode|raw }},
    spec_original_language: {{ 'media.arr_admin.auto_tags.spec_original_language'|trans|json_encode|raw }},
    spec_series_type: {{ 'media.arr_admin.auto_tags.spec_series_type'|trans|json_encode|raw }}
  };

  var feedback = document.getElementById('at-feedback');
  var editingItem = null;
  var specIndex = 0;

  function showFeedback(msg, type) {
    feedback.className = 'alert alert-' + type + ' mb-3';
    feedback.textContent = msg;
    feedback.classList.remove('d-none');
    setTimeout(function(){ feedback.classList.add('d-none'); }, 4000);
  }

  function showModalFeedback(msg, type) {
    var mfb = document.getElementById('at-modal-feedback');
    mfb.className = 'alert alert-' + type + ' mt-3';
    mfb.textContent = msg;
    mfb.classList.remove('d-none');
  }

  function hideModalFeedback() {
    document.getElementById('at-modal-feedback').classList.add('d-none');
  }

  function updateNoSpecsMsg() {
    var container = document.getElementById('at-specs-container');
    var msg = document.getElementById('at-no-specs');
    msg.style.display = container.children.length === 0 ? '' : 'none';
  }

  var SPEC_TYPES = [
    {value: 'RootFolderSpecification', label: _I18N.spec_root_folder},
    {value: 'QualityProfileSpecification', label: _I18N.spec_quality_profile},
    {value: 'GenreSpecification', label: _I18N.spec_genre},
    {value: 'YearSpecification', label: _I18N.spec_year},
    {value: 'OriginalLanguageSpecification', label: _I18N.spec_original_language},
    {value: 'SeriesTypeSpecification', label: _I18N.spec_series_type}
  ];

  function createSpecCard(existingSpec) {
    var idx = specIndex++;
    var card = document.createElement('div');
    card.className = 'at-spec-card';
    card.dataset.specIdx = idx;

    var nameVal = existingSpec ? (existingSpec.name || '') : '';
    var implVal = existingSpec ? (existingSpec.implementation || '') : '';
    var negateChecked = (existingSpec && existingSpec.negate) ? ' checked' : '';
    var requiredChecked = (existingSpec && existingSpec.required) ? ' checked' : '';

    var implOptions = '<option value="">' + _I18N.type_placeholder + '</option>';
    SPEC_TYPES.forEach(function(t) {
      var selected = (t.value === implVal) ? ' selected' : '';
      implOptions += '<option value="' + t.value + '"' + selected + '>' + t.label + '</option>';
    });
    if (implVal && !SPEC_TYPES.some(function(t){ return t.value === implVal; })) {
      implOptions += '<option value="' + implVal + '" selected>' + implVal + '</option>';
    }

    var fieldsJson = '';
    if (existingSpec && existingSpec.fields && existingSpec.fields.length > 0) {
      fieldsJson = JSON.stringify(existingSpec.fields, null, 2);
    }

    card.innerHTML = '<div class="at-spec-header">'
      + '<span class="at-spec-title">' + _I18N.condition_n_tpl.replace('__N__', (idx + 1)) + '</span>'
      + '<button type="button" class="btn btn-ghost-danger btn-sm btn-remove-spec">'
      + '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>'
      + '</button>'
      + '</div>'
      + '<div class="row g-2 mb-2">'
      + '<div class="col-md-5">'
      + '<label class="form-label small">' + _I18N.type_label + '</label>'
      + '<select class="form-select form-select-sm spec-impl-select">' + implOptions + '</select>'
      + '</div>'
      + '<div class="col-md-4">'
      + '<label class="form-label small">' + _I18N.name_label + '</label>'
      + '<input type="text" class="form-control form-control-sm spec-name-input" value="' + nameVal.replace(/"/g, '&quot;') + '" placeholder="' + _I18N.name_placeholder + '">'
      + '</div>'
      + '<div class="col-md-3 d-flex align-items-end gap-2">'
      + '<div class="form-check">'
      + '<input class="form-check-input spec-negate-check" type="checkbox"' + negateChecked + '>'
      + '<label class="form-check-label small">' + _I18N.negate_label + '</label>'
      + '</div>'
      + '<div class="form-check">'
      + '<input class="form-check-input spec-required-check" type="checkbox"' + requiredChecked + '>'
      + '<label class="form-check-label small">' + _I18N.required_label + '</label>'
      + '</div>'
      + '</div>'
      + '</div>'
      + '<div class="mb-1">'
      + '<label class="form-label small">' + _I18N.fields_label + '</label>'
      + '<textarea class="form-control form-control-sm font-monospace spec-fields-json" rows="3" placeholder=\'[{"name":"value","value":"..."}]\'>' + fieldsJson.replace(/</g, '&lt;') + '</textarea>'
      + '<small class="text-muted">' + _I18N.fields_help + '</small>'
      + '</div>';

    card.querySelector('.btn-remove-spec').addEventListener('click', function() {
      card.remove();
      updateNoSpecsMsg();
    });

    document.getElementById('at-specs-container').appendChild(card);
    updateNoSpecsMsg();
    return card;
  }

  function collectSpecs() {
    var cards = document.querySelectorAll('#at-specs-container .at-spec-card');
    var specs = [];
    cards.forEach(function(card) {
      var impl = card.querySelector('.spec-impl-select').value;
      if (!impl) return;
      var name = card.querySelector('.spec-name-input').value.trim() || impl;
      var negate = card.querySelector('.spec-negate-check').checked;
      var required = card.querySelector('.spec-required-check').checked;

      var fieldsRaw = card.querySelector('.spec-fields-json').value.trim();
      var fields = [];
      if (fieldsRaw) {
        try { fields = JSON.parse(fieldsRaw); } catch(e) { /* ignore parse errors */ }
      }

      specs.push({
        name: name,
        implementation: impl,
        negate: negate,
        required: required,
        fields: fields
      });
    });
    return specs;
  }

  document.getElementById('modal-at').addEventListener('show.bs.modal', function(e) {
    hideModalFeedback();
    specIndex = 0;
    document.getElementById('at-specs-container').innerHTML = '';

    var raw = e.relatedTarget ? (e.relatedTarget.dataset.editItem || null) : null;
    editingItem = raw ? JSON.parse(raw) : null;

    if (editingItem) {
      document.getElementById('modal-at-title').textContent = _I18N.modal_title_edit.replace('__NAME__', editingItem.name || '');
      document.getElementById('at-name').value = editingItem.name || '';
      document.getElementById('at-tags').value = (editingItem.tags || []).join(',');
      document.getElementById('at-remove-auto').checked = editingItem.removeTagsAutomatically || false;
      document.getElementById('btn-at-save').textContent = _I18N.btn_save;

      if (editingItem.specifications && editingItem.specifications.length > 0) {
        editingItem.specifications.forEach(function(spec) {
          createSpecCard(spec);
        });
      }
    } else {
      document.getElementById('modal-at-title').textContent = _I18N.modal_title_new;
      document.getElementById('at-name').value = '';
      document.getElementById('at-tags').value = '';
      document.getElementById('at-remove-auto').checked = false;
      document.getElementById('btn-at-save').textContent = _I18N.btn_create;
    }
    updateNoSpecsMsg();
  });

  document.getElementById('btn-at-add-spec').addEventListener('click', function() {
    createSpecCard(null);
  });

  document.getElementById('btn-at-save').addEventListener('click', function() {
    hideModalFeedback();
    var name = document.getElementById('at-name').value.trim();
    if (!name) {
      showModalFeedback(_I18N.err_name_required, 'warning');
      return;
    }

    var tagsRaw = document.getElementById('at-tags').value.trim();
    var tags = [];
    if (tagsRaw) {
      tags = tagsRaw.split(',').map(function(t){ return parseInt(t.trim()); }).filter(function(n){ return !isNaN(n); });
    }

    var payload = {
      name: name,
      removeTagsAutomatically: document.getElementById('at-remove-auto').checked,
      tags: tags,
      specifications: collectSpecs()
    };

    var url;
    if (editingItem) {
      payload.id = editingItem.id;
      url = '{{ app.request.getBasePath() }}/medias/' + INSTANCE_SLUG + '/sonarr/auto-tags/' + editingItem.id + '/modifier';
    } else {
      url = {{ instance_path('sonarr_auto_tag_add')|json_encode|raw }};
    }

    fetch(url, {
      method: 'POST',
      headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
      body: JSON.stringify(payload)
    })
    .then(function(r){ return r.json(); })
    .then(function(data){
      if (data.ok) {
        location.reload();
      } else {
        showModalFeedback(data.error || _I18N.err_save, 'danger');
      }
    })
    .catch(function(err){
      showModalFeedback(_I18N.err_network_tpl.replace('__ERR__', (err.message || err)), 'danger');
    });
  });

  document.querySelectorAll('.btn-at-delete').forEach(function(btn) {
    btn.addEventListener('click', function() {
      if (!confirm(_I18N.delete_confirm_tpl.replace('__NAME__', btn.dataset.name))) return;
      fetch('{{ app.request.getBasePath() }}/medias/' + INSTANCE_SLUG + '/sonarr/auto-tags/' + btn.dataset.id + '/supprimer', {
        method: 'POST',
        headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
        body: '{}'
      })
      .then(function(r){ return r.json(); })
      .then(function(data){
        if (data.ok) location.reload();
        else showFeedback(_I18N.delete_error, 'danger');
      });
    });
  });
})();
</script>
{% endblock %}
