      toast.className = 'prismarr-toast prismarr-toast-' + (type || 'info');
      // Icon via innerHTML (frozen content), message via textContent (XSS-safe even if msg contains HTML)
      toast.innerHTML = window._prismarrTypeIcon(type) + '<span></span>';
