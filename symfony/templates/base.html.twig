{% import '_icons.html.twig' as ico %}
<!doctype html>
<html lang="{{ app.request.locale|default('fr') }}" data-bs-theme="{{ theme().light ? 'light' : 'dark' }}">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover"/>
  <meta http-equiv="X-UA-Compatible" content="ie=edge"/>
  <title>{% block title %}Prismarr{% endblock %} - Prismarr</title>

  <link rel="icon" type="image/x-icon" href="{{ asset('img/prismarr/favicon.ico') }}"/>
  <link rel="icon" type="image/png" sizes="192x192" href="{{ asset('img/prismarr/favicon-192.png') }}"/>
  <link rel="apple-touch-icon" href="{{ asset('img/prismarr/prismarr-icon-512.png') }}"/>

  <script>
    // Pre-apply sidebar-collapsed state from localStorage before the body
    // renders, so users don't see a flash of the expanded sidebar on every
    // page load when they've chosen to keep it collapsed.
    (function () {
      try {
        if (localStorage.getItem('prismarrSidebarCollapsed') === '1') {
          document.documentElement.classList.add('sidebar-collapsed');
        }
      } catch (e) {}
    })();
  </script>

  {# v1.1.0 — instance slugs exposed BEFORE any block body / block
     javascripts script runs. Discovery, dashboard etc. reference these
     during their initial IIFE (renderCardHTML calls the slug eagerly),
     so they MUST be defined before the body parses. Both `var` (lexical
     global, what scripts reference unprefixed) AND window.* (cross-script
     lookup safety net) — strict-mode scripts can't see bare `X` declared
     only on window. #}
  {% set _radarr_default = service_instances('radarr')|first %}
  {% set _sonarr_default = service_instances('sonarr')|first %}
  {% set _slug = app.request.attributes.get('slug') ?: '' %}
  <script>
    var INSTANCE_SLUG = {{ _slug|json_encode|raw }};
    var DEFAULT_RADARR_SLUG = {{ (_radarr_default ? _radarr_default.slug : 'radarr-1')|json_encode|raw }};
    var DEFAULT_SONARR_SLUG = {{ (_sonarr_default ? _sonarr_default.slug : 'sonarr-1')|json_encode|raw }};
    window.INSTANCE_SLUG = INSTANCE_SLUG;
    window.DEFAULT_RADARR_SLUG = DEFAULT_RADARR_SLUG;
    window.DEFAULT_SONARR_SLUG = DEFAULT_SONARR_SLUG;

    // Global locale-aware byte formatter — must be defined here in <head>
    // BEFORE any child template's javascripts block runs. The original
    // location was a media-pages-only conditional script further down the
    // body (see end of this template), but films.html.twig's renderQueue
    // calls window.prismarrBytes() during the initial render and inside
    // setInterval, so defining it later raced with the first call when the
    // queue had items (e.g. blocked import).
    if (!window.prismarrBytes) {
      window.PRISMARR_BYTE_UNITS = {{ prismarr_byte_units()|json_encode|raw }};
      window.prismarrBytes = function (bytes) {
        if (typeof bytes !== 'number' || isNaN(bytes)) return '—';
        var u = window.PRISMARR_BYTE_UNITS || {B:'B',KB:'KB',MB:'MB',GB:'GB',TB:'TB'};
        var abs = Math.abs(bytes);
        if (abs >= 1099511627776) return (bytes / 1099511627776).toFixed(1) + ' ' + u.TB;
        if (abs >= 1073741824)    return (bytes / 1073741824).toFixed(1)    + ' ' + u.GB;
        if (abs >= 1048576)       return (bytes / 1048576).toFixed(1)       + ' ' + u.MB;
        if (abs >= 1024)          return (bytes / 1024).toFixed(1)          + ' ' + u.KB;
        return Math.round(bytes) + ' ' + u.B;
      };
    }
    // Shared sidebar download-count badge updater. Hides at 0, else shows the
    // clamped count. Fires a single state-driven `.dl-bumped` pulse only when
    // the count rises above its previous value (never on first paint), so the
    // motion means "a new download appeared" rather than looping decoratively.
    if (!window.prismarrDlBadge) {
      window.prismarrDlBadge = function (badge, active) {
        if (!badge) return;
        if (active > 0) {
          var prev = badge._dlPrev;
          badge.textContent = active > 99 ? '99+' : String(active);
          badge.style.display = '';
          if (typeof prev === 'number' && active > prev) {
            badge.classList.remove('dl-bumped');
            void badge.offsetWidth; // restart the animation
            badge.classList.add('dl-bumped');
          }
        } else {
          badge.style.display = 'none';
        }
        badge._dlPrev = active;
      };
    }

    // HTML escape helper used wherever JS builds strings via innerHTML with
    // operator-side-controlled values (instance names, search results titles,
    // upstream messages). Self-XSS today (ROLE_ADMIN is the only writer for
    // ServiceInstance.name), but the few innerHTML call sites that surface
    // user-typed strings should always pass through this so a future split
    // ROLE_USER/ROLE_ADMIN doesn't open a cross-user XSS path.
    if (!window.escHtml) {
      window.escHtml = function (s) {
        if (s === null || s === undefined) return '';
        return String(s)
          .replace(/&/g,  '&amp;')
          .replace(/</g,  '&lt;')
          .replace(/>/g,  '&gt;')
          .replace(/"/g,  '&quot;')
          .replace(/'/g, '&#39;');
      };
    }
  </script>

  {% block head_meta %}{% endblock %}

  <style>
    @import url("https://rsms.me/inter/inter.css");
    :root {
      --tblr-font-family-sans-serif: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    }
    {# NOTE: `--tblr-primary` is NOT set here because Tabler's own stylesheet
       (loaded further down) ships with its own `:root { --tblr-primary }`
       rule and would override us. The user-picked theme color is re-injected
       in the post-Tabler `<style>` block at the bottom of <head>, where
       cascade order guarantees it wins. #}

    /* ── Densité UI compacte (opt-in via display_ui_density = 'compact') ── */
    body.density-compact .page-body { padding-top: .5rem; padding-bottom: .5rem; }
    body.density-compact .card { margin-bottom: .6rem; }
    body.density-compact .card-header { padding: .55rem .85rem; }
    body.density-compact .card-body { padding: .7rem .85rem; }
    body.density-compact .list-group-item { padding: .45rem .75rem; }
    body.density-compact .row.g-3 > *, body.density-compact .row.g-2 > * { padding-top: .35rem; padding-bottom: .35rem; }
    /* The global search input keeps fixed horizontal padding for its
       absolutely-positioned icon, so it is exempt from the compact shrink. */
    body.density-compact .form-control:not(.prismarr-search-input),
    body.density-compact .form-select { padding: .35rem .55rem; }

    /* Toasts off (opt-out via display_toasts = '0') — JS also guards, this
       hides any leftover toast DOM in case JS timing lets one slip. */
    body.toasts-off #prismarr-toasts { display: none !important; }

    /* ── Transitions Turbo ── */
    .turbo-progress-bar { background: var(--tblr-primary); height:2px; }
    body { transition: opacity 50ms ease-in-out; }
    body.turbo-loading { opacity: 0; }

    /* ── Skeleton loaders ── */
    .skeleton { background: linear-gradient(90deg, rgba(255,255,255,.04) 25%, rgba(255,255,255,.08) 50%, rgba(255,255,255,.04) 75%); background-size: 200% 100%; animation: skeleton-shimmer 1.5s infinite; border-radius: .35rem; }
    @keyframes skeleton-shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
    .skeleton-text { height: .85rem; margin-bottom: .4rem; }
    .skeleton-text-sm { height: .65rem; margin-bottom: .3rem; width: 60%; }
    .skeleton-card { height: 120px; }
    .skeleton-avatar { width: 40px; height: 40px; border-radius: 50%; }
    .skeleton-bar { height: 8px; border-radius: 4px; }

    /* ── Toasts SSE ── */
    #prismarr-toasts { position: fixed; bottom: 1rem; right: 1rem; z-index: 9999; display: flex; flex-direction: column-reverse; gap: .5rem; max-width: 360px; pointer-events: none; }
    .prismarr-toast { pointer-events: auto; padding: .6rem 1rem; border-radius: .5rem; font-size: .8rem; box-shadow: 0 4px 16px rgba(0,0,0,.3); display: flex; align-items: center; gap: .5rem; animation: toast-in .3s ease-out; backdrop-filter: blur(8px); }
    .prismarr-toast-success { background: rgba(34,197,94,.9); color: #fff; }
    .prismarr-toast-warning { background: rgba(245,158,11,.9); color: #000; }
    .prismarr-toast-danger { background: rgba(239,68,68,.9); color: #fff; }
    .prismarr-toast-info { background: rgba(var(--tblr-primary-rgb),.9); color: #fff; }
    @keyframes toast-in { from { opacity:0; transform:translateX(100px); } to { opacity:1; transform:translateX(0); } }
    .prismarr-toast.toast-out { animation: toast-out .3s ease-in forwards; }
    @keyframes toast-out { from { opacity:1; transform:translateX(0); } to { opacity:0; transform:translateX(100px); } }

    /* ── Badge DL sidebar (visible sur Médias + Téléchargements) ── */
    .sidebar-dl-badge {
      display: inline-flex; align-items: center; justify-content: center;
      min-width: 18px; height: 18px; padding: 0 6px;
      margin-left: 8px;
      font-size: .68rem; font-weight: 700; line-height: 1;
      background: linear-gradient(135deg, #3b82f6, #60a5fa);
      color: #fff; border-radius: 9px;
      box-shadow: 0 0 8px rgba(59,130,246,.5);
    }
    /* The badge's presence is the state signal (downloads active); a static
       glow draws the eye without an always-on decorative loop. When the count
       increases the poller adds `.dl-bumped` for a single state-driven pulse. */
    .sidebar-dl-badge.dl-bumped { animation: dl-bump .45s ease-out; }
    @keyframes dl-bump {
      0%   { transform: scale(1); }
      40%  { transform: scale(1.14); box-shadow: 0 0 14px rgba(59,130,246,.9); }
      100% { transform: scale(1); }
    }
    @media (prefers-reduced-motion: reduce) {
      .sidebar-dl-badge.dl-bumped { animation: none; }
    }

    /* Keyboard focus ring for card DIVs promoted to buttons (media/ex/wl/
       calendar cards carry [data-kb-activate]). outline is not clipped by the
       cards' overflow:hidden, so a positive offset renders cleanly. */
    [data-kb-activate]:focus-visible { outline: 2px solid var(--tblr-primary); outline-offset: 2px; }

    /* ── Live Plex streaming pill (sous le logo) ── */
    .sidebar-plex-pill {
      display: inline-flex; align-items: center; gap: 5px;
      margin: 6px 0 2px; padding: 2px 9px;
      font-size: .75rem; font-weight: 600;
      color: var(--tblr-green); background: var(--tblr-green-lt);
      border-radius: 999px; text-decoration: none;
    }
    html.sidebar-collapsed aside.navbar-vertical .sidebar-plex-pill span { display: none; }

    /* ── Header sticky (recherche + profil) ── */
    .page-header:has(#topbar-actions) { position: sticky; top: 0; z-index: 40; background: var(--prismarr-topbar-bg); backdrop-filter: blur(12px); margin: 0; border-bottom: 1px solid var(--prismarr-border); }
    .page-header:has(#topbar-actions) .container-xl { padding-top: .5rem; padding-bottom: .5rem; }
    .page-header:has(#topbar-actions) .page-title { margin: 0; padding: 0; line-height: 1; }
    .page-header:has(#topbar-actions) .row { margin: 0; align-items: center; }
    /* Shared segmented view-switcher (list-density toggles on the download-client pages) */
    .view-switcher { display:inline-flex; background:rgba(0,0,0,.04); border-radius:6px; padding:2px; gap:1px; }
    [data-bs-theme="dark"] .view-switcher { background:rgba(255,255,255,.05); }
    .view-switcher .view-btn { border:0; background:transparent; color:var(--tblr-body-color); padding:3px 9px; border-radius:4px; font-size:.72rem; font-weight:500; cursor:pointer; display:inline-flex; align-items:center; gap:4px; transition:background .12s ease, color .12s ease; }
    .view-switcher .view-btn:hover { background:rgba(var(--tblr-primary-rgb),.08); }
    .view-switcher .view-btn.active { background:var(--tblr-primary); color:#fff; }
    .view-switcher .view-btn svg { width:13px; height:13px; }
    /* Shared stat-tile vocabulary (header summary metrics) */
    .stat-val { font-size: 1.5rem; font-weight: 700; line-height: 1; letter-spacing: -.5px; }
    .stat-lbl { font-size: .7rem; text-transform: uppercase; letter-spacing: .4px; color: var(--tblr-secondary-color); font-weight: 600; }
    /* Shared filter pill: transparent by default, hue-tinted when active.
       Per-pill semantic colour comes in via --pill-hue (a raw colour or a
       Tabler var); defaults to the theme primary. */
    .filter-pill { border: 1px solid transparent; background: transparent; border-radius: 6px; padding: 4px 11px; font-size: .78rem; font-weight: 500; line-height: 1.3; color: var(--tblr-body-color); cursor: pointer; white-space: nowrap; display: inline-flex; align-items: center; justify-content: center; gap: .35rem; transition: background .12s ease, color .12s ease; }
    .filter-pill:hover { background: rgba(var(--tblr-primary-rgb), .07); }
    .filter-pill.active { font-weight: 600; background: color-mix(in srgb, var(--pill-hue, var(--tblr-primary)) 16%, transparent); color: var(--pill-hue, var(--tblr-primary)); }
    /* ── Mode clair global — plus de profondeur et contraste ── */
    [data-bs-theme="light"] .page-header:has(#topbar-actions) { border-bottom: 1px solid var(--prismarr-border); box-shadow: 0 1px 4px rgba(0,0,0,.05); }
    :root[data-bs-theme="light"] .card { border-color: rgba(0,0,0,.1); box-shadow: 0 1px 6px rgba(0,0,0,.06); }
    :root[data-bs-theme="light"] .card:hover { box-shadow: 0 2px 12px rgba(0,0,0,.1); }
    :root[data-bs-theme="light"] .card-header { border-color: var(--prismarr-border); background: rgba(0,0,0,.015); }
    :root[data-bs-theme="light"] .page-wrapper { background: var(--tblr-body-bg); }
    :root[data-bs-theme="light"] .page-body { background: transparent; }
    :root[data-bs-theme="light"] .table { --tblr-table-striped-bg: rgba(0,0,0,.02); }
    :root[data-bs-theme="light"] .table thead th { background: rgba(0,0,0,.03); color: #444; font-weight: 600; border-bottom: 2px solid rgba(0,0,0,.1); }
    :root[data-bs-theme="light"] .navbar-vertical { background: var(--prismarr-surface) !important; border-right: 1px solid var(--prismarr-border); box-shadow: 2px 0 8px rgba(0,0,0,.04); }
    :root[data-bs-theme="light"] .badge.bg-secondary-lt { background: rgba(0,0,0,.06) !important; color: #555 !important; }
    :root[data-bs-theme="light"] .text-secondary { color: #5a5a6e !important; }
    :root[data-bs-theme="light"] .btn-ghost-secondary:hover { background: rgba(0,0,0,.05) !important; }

    /* ── Readability floor (responsive audit 2026-06-29, extended to desktop
       2026-07-10) ── Sub-12px text (clusters at 8.8/9.6/10.4px) is illegible
       on phones and hard to read anywhere. The shared offenders are floored
       at 11px (.6875rem) at ALL breakpoints. Hierarchy is preserved — floored
       text stays the smallest on the page. Per-page style blocks carry the
       same floor for their local classes below lg. */
    .sidebar-dl-badge,
    .prismarr-search-section,
    .prismarr-search-section .count { font-size: .6875rem; }
    /* Badges/helper text sized via inline style="font-size:.5–.68rem"
       (Twig + JS-built markup across the app): an attribute-substring
       match is the only CSS-only way to floor inline styles. Only values
       starting with ".5"/".6"/"0.5"/"0.6" match — larger sizes such as
       "1.5rem" contain "1.5", never ":.5", and are unaffected. */
    [style*="font-size:.5"], [style*="font-size:.6"],
    [style*="font-size: .5"], [style*="font-size: .6"],
    [style*="font-size:0.5"], [style*="font-size:0.6"] {
      font-size: .6875rem !important;
    }
  </style>

  {# Modal and backdrop cleanup — in <head> to survive Turbo navigations #}
  <script>
    // Backdrop and modal cleanup
    (function() {
      // Before each modal opens: clean up extra backdrops
      document.addEventListener('show.bs.modal', function() {
        var backdrops = document.querySelectorAll('.modal-backdrop');
        backdrops.forEach(function(b) { b.remove(); });
      });

      // After each modal closes
      document.addEventListener('hidden.bs.modal', function() {
        var openModals = document.querySelectorAll('.modal.show');
        if (openModals.length === 0) {
          document.querySelectorAll('.modal-backdrop').forEach(function(b) { b.remove(); });
          document.body.classList.remove('modal-open');
          document.body.style.removeProperty('overflow');
          document.body.style.removeProperty('padding-right');
        }
      });

      // Full cleanup on each Turbo navigation
      document.addEventListener('turbo:before-render', function() {
        document.querySelectorAll('.modal-backdrop').forEach(function(b) { b.remove(); });
        document.querySelectorAll('.modal.show').forEach(function(m) { m.classList.remove('show'); m.style.display = 'none'; });
        document.querySelectorAll('.tooltip, .popover').forEach(function(t) { t.remove(); });
        document.body.classList.remove('modal-open');
        document.body.style.removeProperty('overflow');
        document.body.style.removeProperty('padding-right');
        // Stopper les iframes YouTube
        document.querySelectorAll('iframe[src*="youtube"]').forEach(function(f) { f.src = ''; });
      });

    })();
  </script>

  <link rel="stylesheet" href="{{ asset('static/tabler/css/tabler.min.css') }}"/>
  <link rel="stylesheet" href="{{ asset('static/tabler/css/tabler-themes.min.css') }}"/>

  {# Library filter memory: loaded once in <head> so Turbo runs it a single
     time; it binds its own turbo:load/DOMContentLoaded listeners. #}
  <script defer src="{{ asset('static/js/library-filter-memory.js') }}"></script>

  {# Theme variables + user-picked accent — MUST be set after Tabler's own
     stylesheet, otherwise its own `:root { --tblr-primary }` rule wins the
     cascade and every page resets to Tabler's default blue.

     `data-turbo-track="reload"`: the theme is global, so this block is byte-for-byte
     identical on every page and normal Turbo visits stay fast. But when the admin
     changes the theme/accent, the saved page's block differs → Turbo forces a FULL
     reload, which re-parses `<html data-bs-theme>` AND these vars together. Without
     it, Turbo keeps the persistent <html> element and the old `data-bs-theme`
     sticks, leaving text colours unreadable until a manual refresh. #}
  <style data-turbo-track="reload">
    :root {
      {% for _name, _value in theme().css %}{{ _name }}: {{ _value }};
      {% endfor %}
      --tblr-primary: {{ display_pref('theme_color_hex') }};
      --tblr-primary-rgb: {{ display_pref('theme_color_rgb') }};
    }
  </style>

  {# Override Tabler dark blue background + visual tweaks #}
  <style>
    [data-bs-theme="dark"] {
      --tblr-secondary-bg:  var(--prismarr-surface);
      --tblr-tertiary-bg:   var(--prismarr-surface);
      --tblr-card-bg:       var(--prismarr-surface);
      --tblr-border-color:  var(--prismarr-border);
    }

    /* ── Topbar layout : title left · big search centered · actions right ── */
    .prismarr-topbar-row {
      display: flex;
      align-items: center;
      justify-content: space-between;   /* push actions to the right on mobile once center is hidden */
      gap: 1rem;
      min-height: 56px;
      padding: .35rem 0;
    }
    .prismarr-topbar-left {
      flex: 0 1 auto;
      min-width: 0;
    }
    .prismarr-topbar-left .page-title {
      margin: 0;
      font-size: 1.15rem;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: .45rem;
    }
    .prismarr-topbar-center {
      flex: 1 1 auto;
      display: flex;
      justify-content: center;
      min-width: 0;
    }
    .prismarr-topbar-right {
      flex: 0 1 auto;
    }

    .prismarr-search-input {
      width: 100%;
      height: 42px;
      padding: 0 2.5rem 0 2.75rem;
      background: rgba(255,255,255,.05);
      border: 1px solid rgba(255,255,255,.1);
      border-radius: 10px;
      color: inherit;
      font-size: .92rem;
      transition: border-color .15s ease, background .15s ease, box-shadow .15s ease;
    }
    [data-bs-theme="light"] .prismarr-search-input {
      background: rgba(0,0,0,.03);
      border-color: rgba(0,0,0,.1);
    }
    .prismarr-search-input::placeholder { color: var(--tblr-secondary); opacity: .75; }
    .prismarr-search-input:focus {
      outline: 0;
      border-color: var(--tblr-primary);
      background: var(--tblr-bg-surface);
      box-shadow: 0 0 0 3px rgba(var(--tblr-primary-rgb), .18);
    }
    #global-search-wrap { width: 100%; max-width: 520px; position: relative; }
    .prismarr-search-icon {
      position: absolute; left: .9rem; top: 50%; transform: translateY(-50%);
      opacity: .55; pointer-events: none;
    }
    .prismarr-search-spinner {
      position: absolute; right: .9rem; top: 50%; transform: translateY(-50%);
      pointer-events: none;
    }
    .prismarr-search-results {
      position: absolute; right: 0; left: 0; top: calc(100% + 6px);
      max-height: 480px; overflow-y: auto; display: none;
      border-radius: 10px; border: 1px solid var(--tblr-border-color);
      box-shadow: 0 10px 30px rgba(0,0,0,.25);
      padding: .25rem 0;
    }
    .prismarr-search-clear {
      position: absolute; right: .75rem; top: 50%; transform: translateY(-50%);
      width: 22px; height: 22px;
      background: rgba(255,255,255,.08);
      border: 0; border-radius: 50%;
      color: var(--tblr-secondary);
      cursor: pointer;
      display: inline-flex; align-items: center; justify-content: center;
      transition: background .12s ease, color .12s ease;
    }
    .prismarr-search-clear:hover {
      background: rgba(var(--tblr-primary-rgb), .2);
      color: var(--tblr-primary);
    }
    .prismarr-search-section {
      font-size: .68rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase;
      color: var(--tblr-secondary);
      padding: .6rem .85rem .3rem;
      display: flex; align-items: center; justify-content: space-between;
    }
    .prismarr-search-section .count { font-size: .65rem; opacity: .7; font-weight: 500; }
    .prismarr-search-item {
      display: flex; align-items: center; gap: .55rem;
      padding: .4rem .85rem;
      color: inherit; text-decoration: none;
      cursor: pointer;
      transition: background .1s ease;
    }
    .prismarr-search-item:hover,
    .prismarr-search-item.is-active {
      background: rgba(var(--tblr-primary-rgb), .12);
      color: inherit;
    }
    .prismarr-search-empty {
      padding: 1.2rem; text-align: center; font-size: .82rem; color: var(--tblr-secondary);
    }
    .prismarr-search-recent {
      display: flex; align-items: center; gap: .5rem;
      padding: .35rem .85rem;
      font-size: .85rem; color: var(--tblr-body-color);
      text-decoration: none;
      cursor: pointer;
    }
    .prismarr-search-recent:hover { background: rgba(var(--tblr-primary-rgb), .1); color: inherit; }
    .prismarr-search-recent svg { opacity: .5; flex-shrink: 0; }
    .prismarr-search-recent .clear-x {
      margin-left: auto; opacity: .4; cursor: pointer;
      width: 18px; height: 18px; display: inline-flex; align-items: center; justify-content: center;
      border-radius: 4px;
    }
    .prismarr-search-recent .clear-x:hover { opacity: .9; background: rgba(255,255,255,.06); }

    /* Filter pills under the search */
    .prismarr-search-filters {
      display: flex; gap: .3rem;
      padding: .55rem .85rem .35rem;
      border-bottom: 1px solid var(--tblr-border-color);
    }
    .prismarr-search-pill {
      font-size: .7rem; font-weight: 500;
      padding: .18rem .6rem; border-radius: 999px;
      background: transparent;
      border: 1px solid var(--tblr-border-color);
      color: var(--tblr-body-color);
      cursor: pointer;
      transition: all .15s ease;
    }
    .prismarr-search-pill:hover { border-color: var(--tblr-primary); color: var(--tblr-primary); }
    .prismarr-search-pill.is-active {
      background: var(--tblr-primary); border-color: var(--tblr-primary); color: #fff;
    }

    /* Responsive : hide search on narrow screens, keep left/right actions */
    @media (max-width: 768px) {
      .prismarr-topbar-center { display: none; }
    }

    /* Health dot indicator (topbar button) */
    .prismarr-health-dot {
      display: inline-block;
      width: 10px; height: 10px; border-radius: 50%;
      background: var(--tblr-secondary);
      transition: background .2s ease, box-shadow .2s ease;
    }
    .prismarr-health-dot.is-ok  { background: #22c55e; box-shadow: 0 0 8px rgba(34,197,94,.6); }
    .prismarr-health-dot.is-warn { background: #f59e0b; box-shadow: 0 0 8px rgba(245,158,11,.6); }
    .prismarr-health-dot.is-ko   { background: #ef4444; box-shadow: 0 0 8px rgba(239,68,68,.6); }

    .prismarr-health-menu {
      min-width: 260px;
      max-width: calc(100vw - 1rem);
      position: absolute; right: 0; left: auto; top: 100%;
    }
    /* On narrow viewports switch to `position: fixed` anchored on the
       viewport right edge (not the button) so dropdowns stop sliding off
       screen. The top offset clears the topbar (~56px min-height + padding). */
    @media (max-width: 576px) {
      .prismarr-health-menu,
      #profile-menu {
        position: fixed !important;
        top: 62px !important;
        right: .5rem !important;
        left: auto !important;
        width: 280px !important;
        min-width: 0 !important;
        max-width: calc(100vw - 1rem) !important;   /* safety net viewports < 300px */
      }
    }
    .prismarr-health-row {
      display: flex; align-items: center; gap: .6rem;
      padding: .45rem .9rem;
      font-size: .82rem;
    }
    .prismarr-health-row-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    .prismarr-health-row-dot.is-ok  { background: #22c55e; }
    .prismarr-health-row-dot.is-ko  { background: #ef4444; }
    .prismarr-health-row-dot.is-warn { background: #f59e0b; }
    .prismarr-health-row-dot.is-unk { background: #6b7280; }
    .prismarr-health-row-name { flex: 1; font-weight: 500; }
    .prismarr-health-row-state { font-size: .7rem; color: var(--tblr-secondary); }

    /* Ciblage direct — évite tout conflit de variable */
    [data-bs-theme="dark"] body          { background-color: var(--tblr-body-bg) !important; }
    [data-bs-theme="dark"] .page-wrapper { background-color: var(--tblr-body-bg) !important; }
    [data-bs-theme="dark"] .page-body    { background-color: var(--tblr-body-bg) !important; }

    /* Sidebar fond neutre */
    [data-bs-theme="dark"] .navbar-vertical {
      background-color: var(--prismarr-sidebar) !important;
      border-right: 1px solid var(--prismarr-border) !important;
    }
    [data-bs-theme="light"] body          { background-color: var(--tblr-body-bg) !important; }
    [data-bs-theme="light"] .page-wrapper { background-color: var(--tblr-body-bg) !important; }
    [data-bs-theme="light"] .page-body    { background-color: var(--tblr-body-bg) !important; }
    [data-bs-theme="light"] .navbar-vertical {
      background-color: var(--prismarr-surface) !important;
      border-right: 1px solid var(--prismarr-border) !important;
    }

    /* Cards : fond légèrement surélevé + ombre douce */
    [data-bs-theme="dark"] .card {
      background-color: var(--prismarr-surface) !important;
      border: 1px solid var(--prismarr-border) !important;
      box-shadow: 0 2px 16px rgba(0,0,0,0.35) !important;
    }
    [data-bs-theme="dark"] .card-footer  {
      background-color: var(--prismarr-surface-2) !important;
      border-top: 1px solid var(--prismarr-border) !important;
    }
    [data-bs-theme="light"] .card {
      box-shadow: 0 1px 8px rgba(0,0,0,0.08);
    }

    /* Transition douce au changement de thème */
    body, .card, .navbar, .page-wrapper, .page-body, .card-footer, .card-header, .progress-bar {
      transition: background-color .2s ease, border-color .2s ease, color .1s ease;
    }

    /* Progress bars arrondies */
    .progress { border-radius: 99px; overflow: hidden; }
    .progress-bar { border-radius: 99px; }

    /* Status dot légèrement plus gros */
    .status-dot { width: 9px; height: 9px; }

    /* Scrollbar discrète */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--prismarr-border); border-radius: 99px; }
    [data-bs-theme="light"] ::-webkit-scrollbar-thumb { background: var(--prismarr-border); }

    /* Sous-menu Infrastructure — décalé + plus petit */
    #infra-submenu .nav-link {
      padding-left: 2.8rem;
      font-size: 0.78rem;
    }
    #infra-submenu .nav-link-icon svg {
      width: 16px;
      height: 16px;
    }

    /* Barre bleue active dans la sidebar */
    .navbar-vertical .navbar-nav .nav-link {
      position: relative;
    }
    .navbar-vertical .navbar-nav .nav-link.active {
      color: var(--tblr-primary) !important;
      background-color: rgba(var(--tblr-primary-rgb), 0.07) !important;
    }
    .navbar-vertical .navbar-nav .nav-link.active::before {
      content: '';
      position: absolute;
      left: 0;
      top: 4px;
      bottom: 4px;
      width: 3px;
      background-color: var(--tblr-primary);
      border-radius: 0 3px 3px 0;
    }
    /* nav-link-title prend toute la largeur disponible */
    .navbar-vertical .navbar-nav .nav-link .nav-link-title {
      flex: 1;
    }
    /* Icônes plus petites dans les sous-menus */
    .nav-collapse .navbar-nav .nav-link .nav-link-icon .icon {
      width: 16px !important;
      height: 16px !important;
    }
    /* Sous-items dans nav-collapse — indentés sous le parent */
    .nav-collapse .navbar-nav .nav-link {
      position: relative;
      padding-left: 2.5rem !important;
    }
    .nav-collapse .navbar-nav .nav-link.active {
      color: var(--tblr-primary) !important;
      background-color: rgba(var(--tblr-primary-rgb), 0.07) !important;
    }
    .nav-collapse .navbar-nav .nav-link.active::before {
      content: '';
      position: absolute;
      left: 0;
      top: 4px;
      bottom: 4px;
      width: 3px;
      background-color: var(--tblr-primary);
      border-radius: 0 3px 3px 0;
    }

    /* ── Sidebar collapsible (toggle bouton en bas) ── */
    .sidebar-toggle-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      padding: 0.6rem;
      margin-top: 0.5rem;
      background: transparent;
      border: none;
      border-top: 1px solid rgba(var(--tblr-primary-rgb), 0.08);
      color: inherit;
      opacity: 0.5;
      cursor: pointer;
      transition: opacity 0.15s ease, background 0.15s ease;
    }
    .sidebar-toggle-btn:hover {
      opacity: 1;
      background: rgba(var(--tblr-primary-rgb), 0.06);
    }
    .sidebar-toggle-btn svg {
      transition: transform 0.2s ease;
    }
    html.sidebar-collapsed .sidebar-toggle-btn svg {
      transform: rotate(180deg);
    }

    /* Collapsed state — width reduced, labels hidden, icons centered.
       overflow-x: hidden on both the sidebar and the body prevents the
       labels (still laid out but hidden) from pushing a horizontal
       scrollbar when the user shift-scrolls or two-finger swipes. */
    html.sidebar-collapsed { overflow-x: hidden; }
    html.sidebar-collapsed body { overflow-x: hidden; }
    html.sidebar-collapsed aside.navbar-vertical {
      width: 4rem !important;
      min-width: 4rem !important;
      overflow-x: hidden;
    }
    html.sidebar-collapsed aside.navbar-vertical .navbar-brand span.fw-bold,
    html.sidebar-collapsed aside.navbar-vertical .nav-link-title,
    html.sidebar-collapsed aside.navbar-vertical .sidebar-dl-badge {
      display: none !important;
    }
    html.sidebar-collapsed aside.navbar-vertical .nav-link {
      justify-content: center !important;
      padding: 0.6rem !important;
    }
    html.sidebar-collapsed aside.navbar-vertical .nav-link-icon {
      margin: 0 !important;
    }
    html.sidebar-collapsed aside.navbar-vertical .navbar-brand {
      justify-content: center;
      padding-left: 0;
      padding-right: 0;
    }
    /* Tabler applique margin-left: 15rem sur .page-wrapper via le sibling
       selector `.navbar-vertical~.page-wrapper` — on l'override pour coller
       à la nouvelle largeur de la sidebar. */
    html.sidebar-collapsed .navbar-vertical ~ .page-wrapper,
    html.sidebar-collapsed .navbar-vertical ~ .navbar {
      margin-left: 4rem !important;
    }

    /* Tooltip CSS pur qui s'affiche au hover quand la sidebar est repliée.
       Le data-tooltip est peuplé par le script sidebar-init en bas de page. */
    html.sidebar-collapsed aside.navbar-vertical .nav-link {
      position: relative;
    }
    html.sidebar-collapsed aside.navbar-vertical .nav-link[data-tooltip]::after {
      content: attr(data-tooltip);
      position: absolute;
      left: calc(100% + 0.5rem);
      top: 50%;
      transform: translateY(-50%);
      background: rgba(0, 0, 0, 0.92);
      color: #fff;
      padding: 0.35rem 0.65rem;
      border-radius: 4px;
      font-size: 0.8rem;
      font-weight: 500;
      white-space: nowrap;
      opacity: 0;
      pointer-events: none;
      z-index: 1100;
      transition: opacity 0.12s ease;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    }
    html.sidebar-collapsed aside.navbar-vertical .nav-link:hover[data-tooltip]::after {
      opacity: 1;
    }

    /* Transition douce entre les 2 états */
    aside.navbar-vertical {
      transition: width 0.2s ease, min-width 0.2s ease;
    }
    .navbar-vertical ~ .page-wrapper,
    .navbar-vertical ~ .navbar {
      transition: margin-left 0.2s ease;
    }

    /* ── Tap targets on touch devices (responsive audit 2026-06-29) ────
       Secondary controls measured 22–33px (nav toggle 32px, topbar icon
       buttons, search clear 22px) against the 44px guideline. Coarse-pointer
       only, so desktop rendering is completely unchanged. */
    @media (pointer: coarse) {
      .btn-icon,
      .navbar-toggler {
        min-width: 44px; min-height: 44px;
        display: inline-flex; align-items: center; justify-content: center;
      }
      .prismarr-search-clear { width: 32px; height: 32px; right: .45rem; }
      .prismarr-search-recent .clear-x { width: 32px; height: 32px; }
    }

    /* ── Phone table density (responsive audit 2026-06-29) ─────────────
       Library sub-pages (history/queue…) keep their .table-responsive
       sideways scroll, but slightly tighter type/padding lets noticeably
       more columns fit on a phone. 13px stays above the 11px readability
       floor. */
    @media (max-width: 575.98px) {
      .table-responsive > .table { font-size: .8125rem; }
      .table-responsive > .table th,
      .table-responsive > .table td { padding: .4rem .5rem; }
    }
  </style>

  {% block stylesheets %}{% endblock %}
  {{ importmap('app') }}
</head>
<body class="density-{{ display_pref('ui_density') }} toasts-{{ display_pref('toasts') ? 'on' : 'off' }}">

  {# ── Toasts SSE ── #}
  <div id="prismarr-toasts"></div>

  <div class="page">

    {# ===================== SIDEBAR ===================== #}
    <aside class="navbar navbar-vertical navbar-expand-lg">
      <div class="container-fluid">

        <button class="navbar-toggler" type="button"
                data-bs-toggle="collapse" data-bs-target="#sidebar-menu"
                aria-controls="sidebar-menu" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="navbar-brand navbar-brand-autodark">
          {# Logo → the home route, which resolves the admin's display_home_page
             preference (dashboard/discovery/films/…/last-visited), instead of
             hardcoding Discover. #}
          <a href="{{ path('app_home') }}" class="d-flex align-items-center gap-2 text-decoration-none">
            <img src="{{ asset('img/prismarr/prismarr-icon-512.png') }}" alt="Prismarr" width="28" height="28" style="border-radius:5px;">
            <span class="fw-bold fs-4" style="color: var(--tblr-primary)">Prismarr</span>
          </a>
        </div>

        {% if service_visible_in_sidebar('tautulli') %}
        {# Live Plex streaming pill — hidden until the poller finds active streams. #}
        <a href="{{ path('app_dashboard') }}#plex-activity" id="sidebar-plex-pill" class="sidebar-plex-pill" style="display:none;">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M7 4v16l13 -8z"/></svg>
          <span data-plex-pill-count>0</span>
        </a>
        {% endif %}

        {# Mobile user menu #}
        <div class="navbar-nav flex-row d-lg-none">
          <div class="nav-item">
            <a href="{{ path('app_logout') }}" class="nav-link px-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                   fill="none" stroke="currentColor" stroke-width="2"
                   stroke-linecap="round" stroke-linejoin="round" class="icon">
                <path d="M14 8v-2a2 2 0 0 0 -2 -2h-7a2 2 0 0 0 -2 2v12a2 2 0 0 0 2 2h7a2 2 0 0 0 2 -2v-2"/>
                <path d="M9 12h12l-3 -3m0 6l3 -3"/>
              </svg>
            </a>
          </div>
        </div>

        {# Main menu - Prismarr #}
        <div class="collapse navbar-collapse" id="sidebar-menu">
          <ul class="navbar-nav pt-lg-3">

            {# Dashboard — default homepage since Session 9b #}
            <li class="nav-item">
              <a class="nav-link {{ app.request.attributes.get('_route') == 'app_dashboard' ? 'active' }}"
                 href="{{ path('app_dashboard') }}">
                <span class="nav-link-icon d-md-none d-lg-inline-block">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                       fill="none" stroke="#6366f1" stroke-width="2"
                       stroke-linecap="round" stroke-linejoin="round" class="icon">
                    <rect x="4" y="4" width="6" height="6" rx="1"/>
                    <rect x="14" y="4" width="6" height="6" rx="1"/>
                    <rect x="4" y="14" width="6" height="6" rx="1"/>
                    <rect x="14" y="14" width="6" height="6" rx="1"/>
                  </svg>
                </span>
                <span class="nav-link-title">{{ 'sidebar.nav.dashboard'|trans }}</span>
              </a>
            </li>

            {# Discover TMDb - Prismarr home page #}
            {% if service_visible_in_sidebar('tmdb') %}
            <li class="nav-item">
              <a class="nav-link {{ app.request.attributes.get('_route') starts with 'tmdb_' ? 'active' }}"
                 href="{{ path('tmdb_index') }}">
                <span class="nav-link-icon d-md-none d-lg-inline-block">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon">
                    <path d="M12 2l2.4 7.4h7.6l-6.2 4.5l2.4 7.4l-6.2 -4.6l-6.2 4.6l2.4 -7.4l-6.2 -4.5h7.6z"/>
                  </svg>
                </span>
                <span class="nav-link-title">{{ 'sidebar.nav.discovery'|trans }}</span>
              </a>
            </li>
            {% endif %}

            {% if (service_configured('radarr') or service_configured('sonarr')) and feature_visible_in_sidebar('calendar') %}
            <li class="nav-item">
              <a class="nav-link {{ app.request.attributes.get('_route') == 'app_calendrier' ? 'active' }}"
                 href="{{ path('app_calendrier') }}">
                <span class="nav-link-icon d-md-none d-lg-inline-block">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                       fill="none" stroke="currentColor" stroke-width="2"
                       stroke-linecap="round" stroke-linejoin="round" class="icon">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                  </svg>
                </span>
                <span class="nav-link-title">{{ 'sidebar.nav.calendar'|trans }}</span>
              </a>
            </li>
            {% endif %}

            {# v1.1.0 — Radarr: dynamic sidebar based on configured instances.
                - 0 enabled        → service_visible_in_sidebar() = false, hidden
                - 1 enabled        → single legacy entry "Radarr" → /medias/films
                - 2 or 3 enabled   → flat entries with each instance.name
                - 4+ enabled       → collapsible group "Radarr ▾" #}
            {% if service_visible_in_sidebar('radarr') %}
              {% set _radarr_instances = service_instances('radarr') %}
              {% set _radarr_count = _radarr_instances|length %}
              {% set _radarr_route = app.request.attributes.get('_route') %}
              {# Any route exposed by RadarrController, MediaController films/* or
                 the legacy radarr_* prefix counts as "we're inside Radarr". Used
                 to highlight the right per-instance entry on every sub-page. #}
              {% set _radarr_active = _radarr_route starts with 'app_media_films'
                                    or _radarr_route starts with 'app_media_radarr'
                                    or _radarr_route starts with 'radarr_' %}
              {% set _radarr_slug = app.request.attributes.get('slug') %}
              {% set _radarr_icon %}
                <span class="nav-link-icon d-md-none d-lg-inline-block">
                  <svg width="24" height="24" viewBox="0 0 1024 1024" xmlns="http://www.w3.org/2000/svg" class="icon"><g transform="translate(70 21)"><path d="M105.3 154.9L112.8 869.5C52.7 877 7.5 846.9 7.5 786.8L0 192.6C0 4.5 173-40.6 278.3 34.6L812.3 343C887.5 395.6 902.6 493.4 865 561.1C857.5 508.5 834.9 478.4 789.8 448.3L188 109.8C142.9 79.7 105.3 87.2 105.3 154.9Z" fill="#FFC230"/><path d="M0 376.1C45.1 391.1 90.3 383.6 127.9 361L744.6 0C782.2 52.7 774.7 105.3 729.6 135.4L210.6 436.3C135.4 473.9 37.6 436.3 0 376.1Z" transform="translate(60.2 531)" fill="#FFC230"/><path d="M0 413.7L368.6 203.1L7.5 0L0 413.7Z" transform="translate(240.7 282.8)" fill="#FFC230"/></g></svg>
                </span>
              {% endset %}

              {% if _radarr_count <= 1 %}
                {# Single instance — keep the legacy URL so existing bookmarks survive. #}
                <li class="nav-item">
                  <a class="nav-link {{ _radarr_active ? 'active' }} js-libfilter-link" href="{{ instance_path('app_media_films') }}">
                    {{ _radarr_icon|raw }}
                    <span class="nav-link-title">Radarr</span>
                  </a>
                </li>
              {% elseif _radarr_count <= 3 %}
                {% for _inst in _radarr_instances %}
                  <li class="nav-item">
                    <a class="nav-link {{ _radarr_active and _radarr_slug == _inst.slug ? 'active' }} js-libfilter-link"
                       href="{{ instance_path('app_media_films', { slug: _inst.slug }) }}">
                      {{ _radarr_icon|raw }}
                      <span class="nav-link-title">{{ _inst.name }}</span>
                    </a>
                  </li>
                {% endfor %}
              {% else %}
                <li class="nav-item dropdown">
                  <a class="nav-link dropdown-toggle {{ _radarr_active ? 'active' }}"
                     href="#" data-bs-toggle="dropdown" role="button" aria-expanded="false">
                    {{ _radarr_icon|raw }}
                    <span class="nav-link-title">Radarr</span>
                  </a>
                  <div class="dropdown-menu">
                    {% for _inst in _radarr_instances %}
                      <a class="dropdown-item {{ _radarr_active and _radarr_slug == _inst.slug ? 'active' }} js-libfilter-link"
                         href="{{ instance_path('app_media_films', { slug: _inst.slug }) }}">
                        {{ _inst.name }}
                      </a>
                    {% endfor %}
                  </div>
                </li>
              {% endif %}
            {% endif %}

            {# v1.1.0 — Sonarr: same dynamic logic as Radarr above. #}
            {% if service_visible_in_sidebar('sonarr') %}
              {% set _sonarr_instances = service_instances('sonarr') %}
              {% set _sonarr_count = _sonarr_instances|length %}
              {% set _sonarr_route = app.request.attributes.get('_route') %}
              {% set _sonarr_active = _sonarr_route starts with 'app_media_series'
                                    or _sonarr_route starts with 'app_media_sonarr'
                                    or _sonarr_route starts with 'sonarr_' %}
              {% set _sonarr_slug = app.request.attributes.get('slug') %}
              {% set _sonarr_icon %}
                <span class="nav-link-icon d-md-none d-lg-inline-block">
                  <svg width="24" height="24" viewBox="0 0 216.7 216.9" xmlns="http://www.w3.org/2000/svg" class="icon"><path d="M194.65 42.5l-22.4 22.4C159.15 78 158 89.4 158 109.5c0 17.93 2.85 34.35 16.2 47.7l19 18.95c-2.5 3.07-5.2 6.07-8.1 9-.7.83-1.48 1.6-2.35 2.3-2.53 2.5-5.17 4.82-7.9 6.95l-17.55-17.55c-15.6-15.6-28-17.1-48.6-17.1-19.77 0-33.22 1.82-47.7 16.3l-18.55 18.6c-3.77-2.87-7.33-6.03-10.7-9.5-2.8-2.8-5.42-5.67-7.85-8.6l19.15-19.2c13.85-13.85 16.1-29.92 16.1-47.85 0-17.5-2.87-33.82-15.6-46.55L22.45 43.85c2.83-3.6 5.92-7.07 9.25-10.4 2.93-2.87 5.93-5.55 9-8.05L61.1 43.85C74.1 56.85 90.77 60.2 108.7 60.2c18.47 0 35.08-3.58 48.6-17.1l19.3-19.25c2.9 2.37 5.73 4.93 8.5 7.7 3.47 3.53 6.65 7.18 9.55 10.95z" fill="#0CF"/><circle cx="108.35" cy="108.45" r="29.5" fill="#0CF" opacity=".8"/></svg>
                </span>
              {% endset %}

              {% if _sonarr_count <= 1 %}
                <li class="nav-item">
                  <a class="nav-link {{ _sonarr_active ? 'active' }} js-libfilter-link" href="{{ instance_path('app_media_series') }}">
                    {{ _sonarr_icon|raw }}
                    <span class="nav-link-title">Sonarr</span>
                  </a>
                </li>
              {% elseif _sonarr_count <= 3 %}
                {% for _inst in _sonarr_instances %}
                  <li class="nav-item">
                    <a class="nav-link {{ _sonarr_active and _sonarr_slug == _inst.slug ? 'active' }} js-libfilter-link"
                       href="{{ instance_path('app_media_series', { slug: _inst.slug }) }}">
                      {{ _sonarr_icon|raw }}
