    {# ===================== FIN SIDEBAR ===================== #}

    {# ===================== CONTENU PRINCIPAL ===================== #}
    <div class="page-wrapper">

      {# Argos Command Center removed for Prismarr — a light media command center could be added later if needed #}

      <div class="page-header d-print-none prismarr-topbar">
        <div class="container-xl">
          <div class="prismarr-topbar-row">
            {# Left : page title + breadcrumb #}
            <div class="prismarr-topbar-left">
              <h2 class="page-title">
                {# v1.1.0 — instance-aware page title. We capture whatever
                   the child template rendered into the page_title block,
                   then on Radarr/Sonarr-scoped routes we replace it with
                   "[icon] Instance Name · sub-page" so every admin page
                   reads consistently regardless of which template owns
                   the H2. Films/series index pages have an empty
                   page_title block (their own label is the instance
                   name, rendered here automatically). #}
                {% set _page_title_content %}{% block page_title '' %}{% endset %}
                {% set _route_now = app.request.attributes.get('_route') %}
                {% set _slug_now = app.request.attributes.get('slug') %}
                {% set _inst_type = null %}
                {% if _slug_now %}
                  {% if _route_now starts with 'radarr_' or _route_now starts with 'app_media_radarr' or _route_now starts with 'app_media_films' %}
                    {% set _inst_type = 'radarr' %}
                  {% elseif _route_now starts with 'sonarr_' or _route_now starts with 'app_media_sonarr' or _route_now starts with 'app_media_series' %}
                    {% set _inst_type = 'sonarr' %}
                  {% endif %}
                {% endif %}
                {% set _inst_match = null %}
                {% if _inst_type %}
                  {% set _inst_match = service_instances(_inst_type)|filter(i => i.slug == _slug_now)|first %}
                {% endif %}
                {% if _inst_match %}
                  {% if _inst_type == 'radarr' %}
                    <svg width="22" height="22" viewBox="0 0 1024 1024" xmlns="http://www.w3.org/2000/svg" style="vertical-align:-3px;margin-right:.4rem;"><g transform="translate(70 21)"><path d="M105.3 154.9L112.8 869.5C52.7 877 7.5 846.9 7.5 786.8L0 192.6C0 4.5 173-40.6 278.3 34.6L812.3 343C887.5 395.6 902.6 493.4 865 561.1C857.5 508.5 834.9 478.4 789.8 448.3L188 109.8C142.9 79.7 105.3 87.2 105.3 154.9Z" fill="#FFC230"/><path d="M0 376.1C45.1 391.1 90.3 383.6 127.9 361L744.6 0C782.2 52.7 774.7 105.3 729.6 135.4L210.6 436.3C135.4 473.9 37.6 436.3 0 376.1Z" transform="translate(60.2 531)" fill="#FFC230"/><path d="M0 413.7L368.6 203.1L7.5 0L0 413.7Z" transform="translate(240.7 282.8)" fill="#FFC230"/></g></svg>
                  {% else %}
                    <svg width="22" height="22" viewBox="0 0 216.7 216.9" xmlns="http://www.w3.org/2000/svg" style="vertical-align:-3px;margin-right:.4rem;"><path d="M194.65 42.5l-22.4 22.4C159.15 78 158 89.4 158 109.5c0 17.93 2.85 34.35 16.2 47.7l19 18.95c-2.5 3.07-5.2 6.07-8.1 9-.7.83-1.48 1.6-2.35 2.3-2.53 2.5-5.17 4.82-7.9 6.95l-17.55-17.55c-15.6-15.6-28-17.1-48.6-17.1-19.77 0-33.22 1.82-47.7 16.3l-18.55 18.6c-3.77-2.87-7.33-6.03-10.7-9.5-2.8-2.8-5.42-5.67-7.85-8.6l19.15-19.2c13.85-13.85 16.1-29.92 16.1-47.85 0-17.5-2.87-33.82-15.6-46.55L22.45 43.85c2.83-3.6 5.92-7.07 9.25-10.4 2.93-2.87 5.93-5.55 9-8.05L61.1 43.85C74.1 56.85 90.77 60.2 108.7 60.2c18.47 0 35.08-3.58 48.6-17.1l19.3-19.25c2.9 2.37 5.73 4.93 8.5 7.7 3.47 3.53 6.65 7.18 9.55 10.95z" fill="#0CF"/><circle cx="108.35" cy="108.45" r="29.5" fill="#0CF" opacity=".8"/></svg>
                  {% endif %}
                  {{ _inst_match.name }}
                  {% if _page_title_content|trim and _route_now != 'app_media_films' and _route_now != 'app_media_series' %}
                    <small style="color: var(--tblr-secondary); font-weight: 400; margin-left: .5rem;">{{ _page_title_content|raw }}</small>
                  {% endif %}
                {% else %}
                  {{ _page_title_content|raw }}
                {% endif %}
              </h2>
              {% block breadcrumb %}{% endblock %}
            </div>

            {# Center : big global search #}
            <div class="prismarr-topbar-center">
              <div class="position-relative" id="global-search-wrap">
                <input type="text" id="global-search-input" class="form-control prismarr-search-input"
                       placeholder="{{ 'topbar.search.placeholder'|trans }} ({{ 'topbar.search.shortcut_hint'|trans }})"
                       aria-label="{{ 'topbar.search.label'|trans }}"
                       autocomplete="off" role="combobox"
                       aria-autocomplete="list" aria-controls="global-search-results" aria-expanded="false">
                <svg id="global-search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                     class="prismarr-search-icon">
                  <circle cx="10" cy="10" r="7"/><path d="M21 21l-6-6"/>
                </svg>
                <div id="global-search-spinner" class="prismarr-search-spinner" style="display:none;">
                  <div class="spinner-border spinner-border-sm text-secondary" style="width:.85rem;height:.85rem;border-width:2px;" role="status"></div>
                </div>
                <button type="button" id="global-search-clear" class="prismarr-search-clear" aria-label="{{ 'topbar.search.clear'|trans }}" style="display:none;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                  </svg>
                </button>
                <div id="global-search-results" class="dropdown-menu prismarr-search-results" role="listbox"></div>
              </div>
            </div>

            {# Right : page actions + health + theme + user #}
            <div class="prismarr-topbar-right d-print-none" id="topbar-actions">
              <div class="prismarr-topbar-actions d-flex align-items-center gap-1">

                {% block page_actions %}{% endblock %}

                {# Services health — dropdown lazy-loaded on click #}
                <div class="dropdown" style="position:relative;">
                  <button type="button" class="btn btn-icon btn-ghost-secondary" id="topbar-health-btn"
                          data-prismarr-dropdown="health-menu" title="{{ 'topbar.health.title'|trans }}" aria-label="{{ 'topbar.health.title'|trans }}">
                    <span class="prismarr-health-dot" id="topbar-health-dot"></span>
                  </button>
                  <div class="dropdown-menu prismarr-health-menu" id="health-menu">
                    <div class="dropdown-header">
                      <div class="fw-semibold small">{{ 'topbar.health.title'|trans }}</div>
                      <div class="small text-secondary" id="topbar-health-summary">{{ 'topbar.health.loading'|trans }}</div>
                    </div>
                    <div class="dropdown-divider"></div>
                    <div id="topbar-health-list">
                      <div class="px-3 py-2 small text-secondary">{{ 'common.status.loading'|trans }}</div>
                    </div>
                  </div>
                </div>

                {# Profile #}
                <div class="dropdown" style="position:relative;">
                  <button type="button" class="btn btn-icon btn-ghost-secondary" data-prismarr-dropdown="profile-menu">
                    <span style="display:inline-flex;width:1.375rem;height:1.375rem;border-radius:50%;background-image:url({% if app.user and app.user.avatarPath %}{{ path('app_profile_avatar_serve', {filename: app.user.avatarPath}) }}{% else %}https://ui-avatars.com/api/?name={{ app.user ? app.user.email|url_encode : 'U' }}&background=6366f1&color=fff&size=64{% endif %});background-size:cover;background-position:center;flex-shrink:0;"></span>
                  </button>
                  <div class="dropdown-menu" id="profile-menu" style="min-width:220px;position:absolute;right:0;left:auto;top:100%;">
                    <div class="dropdown-header">
                      <div class="d-flex align-items-center gap-2 mb-1">
                        <span class="avatar" style="width:2rem;height:2rem;background-image:url({% if app.user and app.user.avatarPath %}{{ path('app_profile_avatar_serve', {filename: app.user.avatarPath}) }}{% else %}https://ui-avatars.com/api/?name={{ app.user ? app.user.email|url_encode : 'U' }}&background=6366f1&color=fff&size=64{% endif %});background-size:cover;background-position:center;border-radius:50%;flex-shrink:0;"></span>
                        <div class="overflow-hidden">
                          <div class="small fw-semibold text-truncate">{{ app.user ? app.user.email : '' }}</div>
                          <div class="small text-secondary">{% if is_granted('ROLE_ADMIN') %}{{ 'profile.stats.role_admin'|trans }}{% else %}{{ 'profile.stats.role_user'|trans }}{% endif %}</div>
                        </div>
                      </div>
                    </div>
                    <div class="dropdown-divider"></div>
                    <a href="{{ path('app_profile') }}" class="dropdown-item">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                           fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2 text-secondary">
                        <path d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0"/><path d="M12 10m-3 0a3 3 0 1 0 6 0a3 3 0 1 0 -6 0"/>
                        <path d="M6.168 18.849a4 4 0 0 1 3.832 -2.849h4a4 4 0 0 1 3.834 2.855"/>
                      </svg>
                      {{ 'topbar.profile.profile'|trans }}
                    </a>
                    {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('admin_settings_index') }}" class="dropdown-item">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                           fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-2 text-secondary">
                        <path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 0 0 2.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 0 0 1.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 0 0-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 0 0-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 0 0-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 0 0-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 0 0 1.066-2.573c-.94-1.543.826-3.31 2.37-2.37c1 .608 2.296.07 2.572-1.065z"/>
                        <circle cx="12" cy="12" r="3"/>
                      </svg>
                      {{ 'topbar.profile.settings'|trans }}
                    </a>
                    {% endif %}
                    <div class="dropdown-divider"></div>
