    if (window._prismarrTransmissionPollTimer) clearTimeout(window._prismarrTransmissionPollTimer);
    pollTransmission();

    // Pause when tab is hidden, resume when it returns
    if (!window._prismarrTransmissionVisibilityBound) {
      window._prismarrTransmissionVisibilityBound = true;
      document.addEventListener('visibilitychange', function () {
        if (document.hidden) {
          if (window._prismarrTransmissionPollTimer) { clearTimeout(window._prismarrTransmissionPollTimer); window._prismarrTransmissionPollTimer = null; }
        } else {
          pollTransmission();
        }
      });
    }
  })();
  </script>
  {% endif %}

  {# ══════════════════════════════════════════════════════════════════════════
     Jellyseerr pending-requests poll — sidebar badge. Unlike the qBit poll
     above (media pages only, to avoid hammering the NAS every 15s), this one
     runs on every page that renders the sidebar: the 60s cadence is light
     enough, and a "requests awaiting action" count is useful everywhere.
     Gated on service_configured so a disabled Jellyseerr (#15) isn't chased
     through its route-guard redirect.
     ══════════════════════════════════════════════════════════════════════════ #}
  {% if service_configured('jellyseerr') %}
  <script>
  (function () {
    // No sidebar (login / setup) → no badge → don't poke Jellyseerr.
    if (!document.getElementById('sidebar-seerr-badge')) return;
    var SEERR_POLL_URL = '{{ path('jellyseerr_api_pending_count') }}';
    var SEERR_POLL_INTERVAL = 60000;       // 60s — pending requests move slowly
    var SEERR_POLL_INTERVAL_MAX = 240000;  // back off to 4 min when unreachable
    window._prismarrSeerrFailCount = 0;

    function updateSeerrBadge(pending) {
      window.prismarrDlBadge(document.getElementById('sidebar-seerr-badge'), pending);
    }

    function seerrNextDelay() {
      if (window._prismarrSeerrFailCount === 0) return SEERR_POLL_INTERVAL;
      var scaled = SEERR_POLL_INTERVAL * Math.pow(2, window._prismarrSeerrFailCount - 1);
      return Math.min(scaled, SEERR_POLL_INTERVAL_MAX);
    }

    function scheduleSeerrPoll() {
      if (window._prismarrSeerrPollTimer) clearTimeout(window._prismarrSeerrPollTimer);
      window._prismarrSeerrPollTimer = setTimeout(pollSeerr, seerrNextDelay());
    }

    function pollSeerr() {
      fetch(SEERR_POLL_URL, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(function (r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
        .then(function (d) {
          if (!d || d.error) { window._prismarrSeerrFailCount++; scheduleSeerrPoll(); return; }
          window._prismarrSeerrFailCount = 0;
          updateSeerrBadge(d.pending || 0);
          scheduleSeerrPoll();
        })
        .catch(function () {
          window._prismarrSeerrFailCount++;
          scheduleSeerrPoll();
        });
    }

    // Turbo-safe singleton pattern: a single global poll even with re-exec
    if (window._prismarrSeerrPollTimer) clearTimeout(window._prismarrSeerrPollTimer);
    pollSeerr();

    // Pause when tab is hidden, resume when it returns
    if (!window._prismarrSeerrVisibilityBound) {
      window._prismarrSeerrVisibilityBound = true;
      document.addEventListener('visibilitychange', function () {
        if (document.hidden) {
          if (window._prismarrSeerrPollTimer) { clearTimeout(window._prismarrSeerrPollTimer); window._prismarrSeerrPollTimer = null; }
        } else {
          pollSeerr();
        }
      });
    }
  })();
  </script>
  {% endif %}

  {# ══════════════════════════════════════════════════════════════════════════
     Live Plex streaming pill — hydrates off the existing now-playing endpoint.
     Tautulli has no sidebar nav entry, so the pill is rendered unconditionally
     and hidden by default; this poller reveals it when streams are active and
     stops itself entirely when Tautulli isn't configured (so it doesn't poke a
     disabled service every 30s).
     ══════════════════════════════════════════════════════════════════════════ #}
  {% if service_visible_in_sidebar('tautulli') %}
  <script>
  (function () {
    var pill = document.getElementById('sidebar-plex-pill');
    if (!pill) return;
    var URL = '{{ path('app_tautulli_api_activity') }}';
    var INTERVAL = 30000;
    function tick() {
      if (document.hidden) return;
      fetch(URL, { headers: { 'X-Requested-With': 'fetch' }, credentials: 'same-origin' })
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (d) {
          // Tautulli not set up → stop polling entirely (don't poke it every 30s).
          if (d && (d.configured === false || d.enabled === false)) {
            if (window._plexPillTimer) { clearInterval(window._plexPillTimer); window._plexPillTimer = null; }
            pill.style.display = 'none';
            return;
          }
          var n = d && d.streamCount ? d.streamCount : 0;
          if (n > 0) { pill.querySelector('[data-plex-pill-count]').textContent = n > 99 ? '99+' : n; pill.style.display = ''; }
          else { pill.style.display = 'none'; }
        })
        .catch(function () { pill.style.display = 'none'; });
    }
    tick();
    if (window._plexPillTimer) { clearInterval(window._plexPillTimer); }
    window._plexPillTimer = setInterval(tick, INTERVAL);
  })();
  </script>
  {% endif %}

  {# ══════════════════════════════════════════════════════════════════════════
     Usenet active-downloads badge — one poll per configured client, mirroring
     the qBit/Seerr badge. Light JSON endpoint (active count only); each badge
     hides itself at zero and backs off when the client is unreachable.
     ══════════════════════════════════════════════════════════════════════════ #}
  {% if service_configured('sabnzbd') or service_configured('nzbget') %}
  <script>
  (function () {
    // Turbo-safe singleton: one poll loop for the whole session. Re-running
    // this script on every navigation must NOT spawn a fresh poll (that would
    // hammer a downed client on each page change and reset the backoff, which
    // is what made the whole app lag while SABnzbd was off). The badge is
    // re-queried by id inside poll() so it keeps updating across Turbo swaps.
    if (window._usenetBadgeStarted) return;
    window._usenetBadgeStarted = true;

    // Respect the "disable polling" preference (0 = off), like the qBit badge.
    if (parseInt('{{ display_pref('qbit_refresh_seconds') }}', 10) <= 0) return;

    var CLIENTS = [
      {% if service_configured('sabnzbd') %}{ id: 'sidebar-sabnzbd-badge', url: '{{ path('app_usenet_api_poll_summary', {client: 'sabnzbd'}) }}' },{% endif %}
      {% if service_configured('nzbget') %}{ id: 'sidebar-nzbget-badge', url: '{{ path('app_usenet_api_poll_summary', {client: 'nzbget'}) }}' },{% endif %}
    ];
    var BASE = 60000, MAX = 240000;

    CLIENTS.forEach(function (c) {
      var fails = 0, timer = null;

      function update(active) {
        window.prismarrDlBadge(document.getElementById(c.id), active);
      }
      function schedule() {
        if (timer) clearTimeout(timer);
        var delay = fails === 0 ? BASE : Math.min(BASE * Math.pow(2, fails - 1), MAX);
        timer = setTimeout(poll, delay);
      }
      function poll() {
        fetch(c.url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
          .then(function (r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
          .then(function (d) {
            if (!d || d.error) { fails++; schedule(); return; }
            fails = 0; update(d.active || 0); schedule();
          })
          .catch(function () { fails++; schedule(); });
      }
      poll();
    });
  })();
  </script>
  {% endif %}

  <script>
    // Topbar health indicator — lazy-loaded state + auto-refresh 60s.
    (function () {
      var dot   = document.getElementById('topbar-health-dot');
      var summ  = document.getElementById('topbar-health-summary');
      var list  = document.getElementById('topbar-health-list');
      if (!dot || !summ || !list) return;

      // v1.2 — renders the server-built `chips` list (same rows as the
      // dashboard health section): brand-colored names, latency, 5-state
      // dots, and NO rows for unconfigured services.
      var STATUS_I18N = { up: 'health.status_up', slow: 'health.status_slow', very_slow: 'health.status_very_slow', degraded: 'health.status_degraded', down: 'health.status_down' };
      var DOT_CLS = { up: 'is-ok', slow: 'is-warn', very_slow: 'is-warn', degraded: 'is-warn', down: 'is-ko' };

      function renderHealth(data) {
        var i18n = window._i18n || {};
        var chips = data.chips || [];
        var ok = data.ok || 0;
        var total = data.total || 0;

        dot.classList.remove('is-ok', 'is-warn', 'is-ko');
        if (total === 0)       dot.classList.add('is-ko');
        else if (ok === total) dot.classList.add('is-ok');
        else if (ok > 0)       dot.classList.add('is-warn');
        else                   dot.classList.add('is-ko');

        summ.textContent = total === 0
          ? (i18n['health.no_service'] || 'No service configured')
          : (i18n['health.summary_tpl'] || '__OK__ / __TOTAL__ services up')
              .replace('__OK__', ok).replace('__TOTAL__', total);

        if (!chips.length) {
          list.innerHTML = '<div class="px-3 py-2 small text-secondary">'
            + (i18n['health.no_service'] || 'No service configured') + '</div>';
          return;
        }
        list.innerHTML = chips.map(function (c) {
          var state = i18n[STATUS_I18N[c.status]] || c.status || '';
          if (c.latencyMs !== null && c.latencyMs !== undefined) state += ' · ' + c.latencyMs + ' ms';
          return '<div class="prismarr-health-row">'
            +  '<span class="prismarr-health-row-dot ' + (DOT_CLS[c.status] || 'is-unk') + '"></span>'
            +  '<span class="prismarr-health-row-name" style="color:' + (c.color || 'inherit') + '">' + window.escHtml(c.name) + '</span>'
            +  '<span class="prismarr-health-row-state">' + window.escHtml(state) + '</span>'
            +  '</div>';
        }).join('');
      }

      function fetchHealth() {
        fetch('/api/health/services', { credentials: 'same-origin', headers: { 'Accept': 'application/json' } })
          .then(function (r) { return r.ok ? r.json() : null; })
          .then(function (d) { if (d) renderHealth(d); })
          .catch(function () {});
      }

      fetchHealth();
      // Auto refresh every 60s — HealthService already caches 10s server-side.
      if (!window._prismarrHealthTimer) {
        window._prismarrHealthTimer = setInterval(fetchHealth, 60000);
      }
      document.addEventListener('turbo:load', fetchHealth);
    })();
  </script>

  <script>
    // Sidebar collapsible toggle + tooltip setup (Turbo-safe).
    // - Click on #sidebar-toggle-btn → toggle `html.sidebar-collapsed` + persist
    // - On load/after Turbo nav: copy .nav-link-title → data-tooltip on each
    //   link to feed the CSS tooltip that only shows when collapsed.
    (function () {
      function setupSidebarTooltips() {
        document.querySelectorAll('aside.navbar-vertical .nav-link').forEach(function (a) {
          var title = a.querySelector('.nav-link-title');
          if (title && !a.dataset.tooltip) {
            a.dataset.tooltip = title.textContent.trim();
          }
        });
      }

      function bindToggle() {
        var btn = document.getElementById('sidebar-toggle-btn');
        if (!btn || btn.dataset.init) return;
        btn.dataset.init = '1';
        btn.addEventListener('click', function () {
          var isCollapsed = document.documentElement.classList.toggle('sidebar-collapsed');
          try {
            localStorage.setItem('prismarrSidebarCollapsed', isCollapsed ? '1' : '0');
          } catch (e) {}
        });
      }

      function init() {
        setupSidebarTooltips();
        bindToggle();
      }

      init();
      document.addEventListener('turbo:load', init);
      document.addEventListener('turbo:render', setupSidebarTooltips);
    })();
  </script>

</body>
</html>
