  <script>
  (function () {
    var QBT_POLL_URL = '{{ path('app_qbittorrent_api_poll_summary') }}';
    {# User preference drives the polling cadence — 0 disables qBit polling entirely. #}
    var QBT_POLL_INTERVAL_SECONDS = {{ display_pref('qbit_refresh_seconds') }};
    if (QBT_POLL_INTERVAL_SECONDS <= 0) return;  // poll disabled via /admin/settings
    var QBT_POLL_INTERVAL = QBT_POLL_INTERVAL_SECONDS * 1000;
    var STATE_KEY = 'prismarr_qbt_last_state';
    var NOTIFIED_KEY = 'prismarr_qbt_notified';  // hashes already notified (cross-tab dedup)
    var NOTIFIED_TTL = 60 * 60 * 1000; // 1h — beyond that we re-allow the notification (e.g. torrent re-DL)

    // Cross-tab channel to sync notifications across multiple open tabs
    var bchan = null;
    try { if (typeof BroadcastChannel !== 'undefined') bchan = new BroadcastChannel('prismarr-qbt-toasts'); } catch (e) {}
    if (bchan && !window._prismarrQbtBchanBound) {
      window._prismarrQbtBchanBound = true;
      bchan.onmessage = function (e) {
        // Another tab already notified this hash → mark locally to skip
        if (e.data && e.data.type === 'notified' && e.data.hash) markNotified(e.data.hash);
      };
    }

    function loadNotified() { try { return JSON.parse(localStorage.getItem(NOTIFIED_KEY) || '{}'); } catch (e) { return {}; } }
    function markNotified(hash) {
      var n = loadNotified();
      n[hash] = Date.now();
      // Purge entries that are too old to avoid bloat
      var cutoff = Date.now() - NOTIFIED_TTL;
      Object.keys(n).forEach(function (k) { if (n[k] < cutoff) delete n[k]; });
      try { localStorage.setItem(NOTIFIED_KEY, JSON.stringify(n)); } catch (e) {}
      if (bchan) try { bchan.postMessage({ type: 'notified', hash: hash }); } catch (e) {}
    }
    function alreadyNotified(hash) {
      var n = loadNotified();
      return n[hash] && (Date.now() - n[hash]) < NOTIFIED_TTL;
    }

    function loadPrev() { try { return JSON.parse(localStorage.getItem(STATE_KEY) || '{}'); } catch (e) { return {}; } }
    function savePrev(map) { try { localStorage.setItem(STATE_KEY, JSON.stringify(map)); } catch (e) {} }

    // window.prismarrBytes is defined in the head script at the top of
    // base.html.twig so child templates' javascripts block can rely on it
    // during initial render. Local fmtGo wrapper kept for the qBit poll
    // block below.
    function fmtGo(bytes) { return window.prismarrBytes(bytes); }

    function updateBadge(active) {
      ['sidebar-qbt-badge', 'sidebar-media-badge'].forEach(function (id) {
        window.prismarrDlBadge(document.getElementById(id), active);
      });
    }

    // Circuit breaker: when qBit is unreachable we back off exponentially
    // from 15s up to 2min between polls instead of hammering the NAS every
    // 15s. A single successful poll resets the backoff to the base interval.
    var QBT_POLL_INTERVAL_MAX = 120000; // 2 min
    window._prismarrQbtFailCount = 0;

    function qbtNextDelay() {
      if (window._prismarrQbtFailCount === 0) return QBT_POLL_INTERVAL;
      var scaled = QBT_POLL_INTERVAL * Math.pow(2, window._prismarrQbtFailCount - 1);
      return Math.min(scaled, QBT_POLL_INTERVAL_MAX);
    }

    function schedulePoll() {
      if (window._prismarrQbtPollTimer) clearTimeout(window._prismarrQbtPollTimer);
      window._prismarrQbtPollTimer = setTimeout(pollQbt, qbtNextDelay());
    }

    function pollQbt() {
      fetch(QBT_POLL_URL, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(function (r) {
          if (!r.ok) throw new Error('HTTP ' + r.status);
          return r.json();
        })
        .then(function (d) {
          if (!d || d.error) {
            // Server says qBit is unreachable — count it as a failure.
            window._prismarrQbtFailCount++;
            schedulePoll();
            return;
          }

          // Success: reset backoff and resume base interval.
          window._prismarrQbtFailCount = 0;
          updateBadge(d.active || 0);

          // Detect transitions (vs previous snapshot)
          var prev = loadPrev();
          var next = {};
          var justCompleted = [];
          var justErrored = [];
          (d.items || []).forEach(function (it) {
            next[it.hash] = it.state;
            var was = prev[it.hash];
            if (was === 'downloading' && (it.state === 'completed' || it.state === 'seeding')) {
              justCompleted.push(it);
            }
            if (was && was !== 'error' && it.state === 'error') {
              justErrored.push(it);
            }
          });

          if (window._prismarrToast) {
            justCompleted.forEach(function (it) {
              if (alreadyNotified(it.hash)) return;
              var truncated = (it.name || '').length > 60 ? it.name.substring(0, 60) + '…' : it.name;
              window._prismarrToast(truncated + ' — ' + fmtGo(it.size), 'success', 6000);
              markNotified(it.hash);
            });
            justErrored.forEach(function (it) {
              if (alreadyNotified(it.hash)) return;
              var truncated = (it.name || '').length > 60 ? it.name.substring(0, 60) + '…' : it.name;
              window._prismarrToast('Erreur sur : ' + truncated, 'danger', 8000);
              markNotified(it.hash);
            });
          }

          savePrev(next);
          schedulePoll();
        })
        .catch(function () {
          // Network error / fetch rejected → back off.
          window._prismarrQbtFailCount++;
          schedulePoll();
        });
    }

    // Turbo-safe singleton pattern: a single global poll even with re-exec
    if (window._prismarrQbtPollTimer) clearTimeout(window._prismarrQbtPollTimer);
    pollQbt();

    // Pause when tab is hidden, resume when it returns
    if (!window._prismarrQbtVisibilityBound) {
      window._prismarrQbtVisibilityBound = true;
      document.addEventListener('visibilitychange', function () {
        if (document.hidden) {
          if (window._prismarrQbtPollTimer) { clearTimeout(window._prismarrQbtPollTimer); window._prismarrQbtPollTimer = null; }
        } else {
          pollQbt();
        }
      });
    }
  })();
  </script>
  {% endif %}

