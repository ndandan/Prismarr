{% extends 'base.html.twig' %}
{% block title %}{{ 'jellyseerr.settings.settings_users.title'|trans }} — {{ 'jellyseerr.nav.settings'|trans }}{% endblock %}
{% block page_title %}<svg width="24" height="24" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg"><path d="M256 48C141.1 48 48 141.1 48 256s93.1 208 208 208 208-93.1 208-208S370.9 48 256 48zm0 368c-88.4 0-160-71.6-160-160S167.6 96 256 96s160 71.6 160 160-71.6 160-160 160z" fill="#a259ff"/><circle cx="256" cy="256" r="80" fill="#a259ff"/></svg> {{ 'jellyseerr.settings.settings_users.title'|trans }}{% endblock %}
{% block head_meta %}<meta name="turbo-visit-control" content="reload">{% endblock %}

{% block stylesheets %}
<style>
.js-setting-item { padding:.85rem 1.25rem; }
.js-setting-item .js-label { font-weight:600; font-size:.88rem; }
.js-setting-item .js-desc { font-size:.75rem; color:var(--tblr-text-secondary); margin-top:1px; }
.js-section-header { background:var(--tblr-bg-surface-secondary); padding:.5rem 1.25rem; }
.js-section-header span { font-weight:700; font-size:.75rem; text-transform:uppercase; letter-spacing:.5px; color:#a259ff; }
.js-perm-toggle .form-check-input:checked { background-color:#a259ff; border-color:#a259ff; }
</style>
{% endblock %}

{% block body %}
<div class="container-xl py-2">
    <div class="d-flex align-items-center justify-content-end">{% include 'jellyseerr/_nav.html.twig' %}</div>
</div>
<div class="page-body"><div class="container-xl">

<h3 style="font-weight:700;font-size:1.1rem;margin-bottom:.25rem;">{{ 'jellyseerr.settings.settings_users.title'|trans }}</h3>
<p class="text-secondary mb-3" style="font-size:.82rem;">{{ 'jellyseerr.settings.settings_users.subtitle'|trans }}</p>

{# ── Authentification & Quotas ── #}
<div class="card mb-4">
    <div class="list-group list-group-flush">
        <div class="list-group-item js-section-header"><span>{{ 'jellyseerr.settings.settings_users.section_auth'|trans }}</span></div>

        <div class="list-group-item js-setting-item d-flex align-items-center justify-content-between gap-3">
            <div><div class="js-label">{{ 'jellyseerr.settings.settings_users.enable_local_login'|trans }}</div><div class="js-desc">{{ 'jellyseerr.settings.settings_users.enable_local_login_desc'|trans }}</div></div>
            <label class="form-check form-switch mb-0"><input type="checkbox" class="form-check-input js-main-toggle" data-key="localLogin" {{ main.localLogin ?? false ? 'checked' }} style="width:2.2rem;height:1.1rem;cursor:pointer;"></label>
        </div>

        <div class="list-group-item js-setting-item d-flex align-items-center justify-content-between gap-3">
            <div><div class="js-label">{{ 'jellyseerr.settings.settings_users.enable_jellyfin_login'|trans }}</div><div class="js-desc">{{ 'jellyseerr.settings.settings_users.enable_jellyfin_login_desc'|trans }}</div></div>
            <label class="form-check form-switch mb-0"><input type="checkbox" class="form-check-input js-main-toggle" data-key="mediaServerLogin" {{ main.mediaServerLogin ?? false ? 'checked' }} style="width:2.2rem;height:1.1rem;cursor:pointer;"></label>
        </div>

        <div class="list-group-item js-setting-item d-flex align-items-center justify-content-between gap-3">
            <div><div class="js-label">{{ 'jellyseerr.settings.settings_users.allow_new_jellyfin_login'|trans }}</div><div class="js-desc">{{ 'jellyseerr.settings.settings_users.allow_new_jellyfin_login_desc'|trans }}</div></div>
            <label class="form-check form-switch mb-0"><input type="checkbox" class="form-check-input js-main-toggle" data-key="newPlexLogin" {{ main.newPlexLogin ?? false ? 'checked' }} style="width:2.2rem;height:1.1rem;cursor:pointer;"></label>
        </div>

        <div class="list-group-item js-section-header"><span>{{ 'jellyseerr.settings.settings_users.section_global_quotas'|trans }}</span></div>

        <div class="list-group-item js-setting-item d-flex align-items-center justify-content-between gap-3">
            <div><div class="js-label">{{ 'jellyseerr.settings.settings_users.global_movie_limit'|trans }}</div></div>
            <div class="d-flex align-items-center gap-2">
                <input type="number" class="form-control form-control-sm" id="js-dq-movie-limit" value="{{ main.defaultQuotas.movie.quotaLimit ?? 0 }}" min="0" style="width:70px;">
                <span class="text-secondary" style="font-size:.82rem;">{{ 'jellyseerr.settings.settings_users.movies_every'|trans }}</span>
                <input type="number" class="form-control form-control-sm" id="js-dq-movie-days" value="{{ main.defaultQuotas.movie.quotaDays ?? 7 }}" min="1" style="width:70px;">
                <span class="text-secondary" style="font-size:.82rem;">{{ 'jellyseerr.settings.settings_users.days'|trans }}</span>
            </div>
        </div>

        <div class="list-group-item js-setting-item d-flex align-items-center justify-content-between gap-3">
            <div><div class="js-label">{{ 'jellyseerr.settings.settings_users.global_tv_limit'|trans }}</div></div>
            <div class="d-flex align-items-center gap-2">
                <input type="number" class="form-control form-control-sm" id="js-dq-tv-limit" value="{{ main.defaultQuotas.tv.quotaLimit ?? 0 }}" min="0" style="width:70px;">
                <span class="text-secondary" style="font-size:.82rem;">{{ 'jellyseerr.settings.settings_users.tv_every'|trans }}</span>
                <input type="number" class="form-control form-control-sm" id="js-dq-tv-days" value="{{ main.defaultQuotas.tv.quotaDays ?? 7 }}" min="1" style="width:70px;">
                <span class="text-secondary" style="font-size:.82rem;">{{ 'jellyseerr.settings.settings_users.days'|trans }}</span>
            </div>
        </div>
    </div>
</div>

{# ── Default permissions — native-style toggles ── #}
{% set dp = main.defaultPermissions ?? 0 %}
{% set permList = [
    {bit: 2,        k: 'perm_admin',                   section: 'section_default_perms'},
    {bit: 8,        k: 'perm_manage_users'},
    {bit: 16,       k: 'perm_manage_requests'},
    {bit: 8192,     k: 'perm_advanced_request',        parent: 16},
    {bit: 16384,    k: 'perm_view_requests',           parent: 16},
    {bit: 67108864, k: 'perm_view_recent',             parent: 16},
    {bit: 134217728,k: 'perm_view_jellyfin_playlists', parent: 16},
    {bit: 32,       k: 'perm_request'},
    {bit: 262144,   k: 'perm_request_movies',          parent: 32},
    {bit: 524288,   k: 'perm_request_tv',              parent: 32},

    {bit: 128,   k: 'perm_auto_approve',         section: 'section_auto_approve', requires: [32]},
    {bit: 256,   k: 'perm_auto_approve_movies',  parent: 128, requires: [32, 262144]},
    {bit: 512,   k: 'perm_auto_approve_tv',      parent: 128, requires: [32, 524288]},

    {bit: 8388608,  k: 'perm_auto_request',         section: 'section_auto_request', requires: [32]},
    {bit: 16777216, k: 'perm_auto_request_movies',  parent: 8388608, requires: [32, 262144]},
    {bit: 33554432, k: 'perm_auto_request_tv',      parent: 8388608, requires: [32, 524288]},

    {bit: 1024,  k: 'perm_request_4k',         section: 'section_request_4k', requires: [32]},
    {bit: 2048,  k: 'perm_request_4k_movies',  parent: 1024, requires: [32, 262144]},
    {bit: 4096,  k: 'perm_request_4k_tv',      parent: 1024, requires: [32, 524288]},

    {bit: 32768,  k: 'perm_auto_approve_4k',         section: 'section_auto_approve_4k', requires: [1024]},
    {bit: 65536,  k: 'perm_auto_approve_4k_movies',  parent: 32768, requires: [1024, 2048]},
    {bit: 131072, k: 'perm_auto_approve_4k_tv',      parent: 32768, requires: [1024, 4096]},

    {bit: 1048576,  k: 'perm_manage_issues',  section: 'section_issues'},
    {bit: 4194304,  k: 'perm_create_issues',  parent: 1048576},
    {bit: 2097152,  k: 'perm_view_issues',    parent: 1048576},

    {bit: 268435456,  k: 'perm_manage_blocklist', section: 'section_blocklist'},
    {bit: 1073741824, k: 'perm_view_blocklist',   parent: 268435456}
] %}

<div class="card mb-4">
    <div class="list-group list-group-flush js-perm-toggle">
    {% for p in permList %}
        {% if p.section is defined %}
            <div class="list-group-item js-section-header"><span>{{ ('jellyseerr.settings.settings_users.' ~ p.section)|trans }}</span></div>
        {% endif %}

        {% set isChecked = (dp b-and p.bit) ? true : false %}
        {% set hasParent = p.parent is defined and p.parent %}
        <div class="list-group-item d-flex align-items-center justify-content-between gap-3 js-perm-row"
             style="padding:.85rem 1.25rem;{{ hasParent ? 'padding-left:2.75rem;' : '' }}"
             data-bit="{{ p.bit }}"
             {% if hasParent %}data-parent="{{ p.parent }}"{% endif %}
             {% if p.requires is defined %}data-requires="{{ p.requires|join(',') }}"{% endif %}>
            <div style="min-width:0;">
                <div style="font-weight:{{ hasParent ? '500' : '600' }};font-size:{{ hasParent ? '.84rem' : '.88rem' }};">{{ ('jellyseerr.settings.settings_users.' ~ p.k)|trans }}</div>
                <div class="text-secondary" style="font-size:.75rem;">{{ ('jellyseerr.settings.settings_users.' ~ p.k ~ '_desc')|trans }}</div>
            </div>
            <label class="form-check form-switch mb-0" style="flex-shrink:0;">
                <input type="checkbox" class="form-check-input js-perm-cb" value="{{ p.bit }}"
                       {{ isChecked ? 'checked' }}
                       style="width:2.2rem;height:1.1rem;cursor:pointer;">
            </label>
        </div>
    {% endfor %}
    </div>
</div>

{# Save sticky #}
<div style="position:sticky;bottom:0;z-index:10;padding:.75rem 0;background:var(--tblr-body-bg);border-top:1px solid var(--tblr-border-color);">
    <div class="d-flex justify-content-end">
        <button class="btn btn-primary" id="js-save-users" style="background:#a259ff;border-color:#a259ff;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12l5 5l10 -10"/></svg>
            {{ 'jellyseerr.settings.settings_users.save_changes'|trans }}
        </button>
        <span id="js-save-status" class="ms-2 small d-flex align-items-center"></span>
    </div>
</div>

</div></div>
{% endblock %}

{% block javascripts %}
<script>
(function(){
    var SU_I18N = {
        saved: {{ 'jellyseerr.settings.settings_users.saved'|trans|json_encode|raw }},
        error: {{ 'jellyseerr.settings.settings_users.error'|trans|json_encode|raw }}
    };

    // ── Parent/children permissions (same logic as user_detail) ──
    var ADMIN_BIT = 2;
    function getPermCb(bit) { return document.querySelector('.js-perm-cb[value="' + bit + '"]'); }
    function isPermChecked(bit) { var cb = getPermCb(bit); return cb && cb.checked; }

    function updatePermStates() {
        var isAdmin = isPermChecked(ADMIN_BIT);
        document.querySelectorAll('.js-perm-row').forEach(function(row) {
            var bit = parseInt(row.dataset.bit);
            var cb = row.querySelector('.js-perm-cb');
            var parentBit = row.dataset.parent ? parseInt(row.dataset.parent) : null;
            var requiresBits = row.dataset.requires ? row.dataset.requires.split(',').map(Number) : [];

            cb.disabled = false; row.style.opacity = '1';

            if (isAdmin && bit !== ADMIN_BIT) { cb.checked = true; cb.disabled = true; row.style.opacity = '.5'; return; }
            if (parentBit && isPermChecked(parentBit)) { cb.checked = true; cb.disabled = true; row.style.opacity = '.5'; return; }
            if (requiresBits.length > 0) {
                var hasReq = requiresBits.some(function(r) { return isPermChecked(r); });
                if (!hasReq) { cb.checked = false; cb.disabled = true; row.style.opacity = '.4'; return; }
            }
        });
    }

    document.querySelectorAll('.js-perm-cb').forEach(function(cb) {
        cb.addEventListener('change', function() {
            var bit = parseInt(this.value);
            if (!this.checked) {
                document.querySelectorAll('.js-perm-row[data-parent="' + bit + '"] .js-perm-cb').forEach(function(child) { child.checked = false; });
                if (bit === ADMIN_BIT) { document.querySelectorAll('.js-perm-cb').forEach(function(c) { if (parseInt(c.value) !== ADMIN_BIT) c.checked = false; }); }
            }
            updatePermStates();
        });
    });
    updatePermStates();

    // ── Save ──
    var saveBtn = document.getElementById('js-save-users');
    var statusEl = document.getElementById('js-save-status');
    if (saveBtn) saveBtn.addEventListener('click', function(){
        var payload = {};
        document.querySelectorAll('.js-main-toggle').forEach(function(el){ payload[el.dataset.key] = el.checked; });
        payload.defaultQuotas = {
            movie: { quotaLimit: parseInt(document.getElementById('js-dq-movie-limit').value)||0, quotaDays: parseInt(document.getElementById('js-dq-movie-days').value)||7 },
            tv: { quotaLimit: parseInt(document.getElementById('js-dq-tv-limit').value)||0, quotaDays: parseInt(document.getElementById('js-dq-tv-days').value)||7 }
        };
        var perms = 0;
        document.querySelectorAll('.js-perm-cb').forEach(function(cb) { if (cb.checked && !cb.disabled) perms |= parseInt(cb.value); });
        payload.defaultPermissions = perms;

        saveBtn.disabled = true; var orig = saveBtn.innerHTML;
        saveBtn.innerHTML = '<div class="spinner-border spinner-border-sm" style="width:16px;height:16px;"></div>';
        fetch('{{ app.request.getBasePath() }}/jellyseerr/parametres/save', { method:'POST', credentials:'same-origin', headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'}, body:JSON.stringify(payload) })
        .then(function(r){ return r.json(); })
        .then(function(d){ saveBtn.disabled=false; saveBtn.innerHTML=orig; statusEl.innerHTML=d.ok?'<span class="text-success">'+SU_I18N.saved+'</span>':'<span class="text-danger">'+SU_I18N.error+'</span>'; setTimeout(function(){statusEl.innerHTML='';},3000); })
        .catch(function(){ saveBtn.disabled=false; saveBtn.innerHTML=orig; statusEl.innerHTML='<span class="text-danger">'+SU_I18N.error+'</span>'; });
    });
})();
</script>
{% endblock %}
