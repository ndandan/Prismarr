{% extends 'setup/_layout.html.twig' %}
{% import '_icons.html.twig' as ico %}

{% block title %}{{ 'setup.step.welcome.title'|trans }} - Prismarr{% endblock %}

{% block extra_css %}
.welcome-locale {
  display: flex;
  justify-content: flex-end;
  margin-bottom: -1rem;
}
.welcome-locale-form {
  display: inline-flex;
  align-items: center;
  gap: .5rem;
  font-size: .8rem;
  opacity: .75;
}
.welcome-locale-form select {
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.08);
  color: inherit;
  border-radius: 6px;
  padding: .25rem .5rem;
  font-size: .8rem;
  cursor: pointer;
}
[data-bs-theme="light"] .welcome-locale-form select {
  background: rgba(0,0,0,.03);
  border-color: rgba(0,0,0,.1);
}
.welcome-locale-form select:focus {
  outline: none;
  border-color: rgba(99,102,241,.55);
  box-shadow: 0 0 0 2px rgba(99,102,241,.18);
}
{% endblock %}

{% block wizard_body %}
  <div class="welcome-locale">
    <form method="post" action="{{ path('app_setup_locale') }}" class="welcome-locale-form" data-locale-form>
      <input type="hidden" name="_csrf_token" value="{{ csrf_token('setup_locale') }}"/>
      <label for="setup-locale-select">{{ 'setup.step.welcome.language_label'|trans }}</label>
      <select id="setup-locale-select" name="locale" onchange="this.form.submit()">
        {% for code in supported_locales %}
          <option value="{{ code }}" {% if code == current_locale %}selected{% endif %}>
            {{ ('setup.step.welcome.language.' ~ code)|trans }}
          </option>
        {% endfor %}
      </select>
      <noscript>
        <button type="submit" class="btn btn-sm btn-ghost-primary" style="font-size:.75rem;padding:.2rem .5rem;">OK</button>
      </noscript>
    </form>
  </div>

  <div class="welcome-hero">
    <img src="{{ asset('img/prismarr/prismarr-icon-512.png') }}" alt=""/>
    <h1 class="welcome-title">{{ 'setup.step.welcome.title'|trans }}</h1>
    <p class="welcome-subtitle">{{ 'setup.step.welcome.subtitle'|trans }}</p>

    <div class="welcome-features">
      <div class="welcome-feature">
        <div class="welcome-feature-icon">{{ ico.icon('movie', '', 24) }}</div>
        <div>{{ 'setup.step.welcome.features.media'|trans }}</div>
      </div>
      <div class="welcome-feature">
        <div class="welcome-feature-icon">{{ ico.icon('search', '', 24) }}</div>
        <div>{{ 'setup.step.welcome.features.indexers'|trans }}</div>
      </div>
      <div class="welcome-feature">
        <div class="welcome-feature-icon">{{ ico.icon('download', '', 24) }}</div>
        <div>{{ 'setup.step.welcome.features.downloads'|trans }}</div>
      </div>
      <div class="welcome-feature">
        <div class="welcome-feature-icon">{{ ico.icon('sparkles', '', 24) }}</div>
        <div>{{ 'setup.step.welcome.features.discovery'|trans }}</div>
      </div>
    </div>
  </div>

  <div class="d-flex align-items-center justify-content-between gap-3 mt-4 pt-4 border-top">
    <span></span>
    <a href="{{ path('app_setup_admin') }}" class="btn btn-primary btn-wizard-accent">
      {{ 'setup.step.welcome.cta'|trans }}
    </a>
  </div>
{% endblock %}
