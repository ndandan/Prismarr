{% extends 'setup/_layout.html.twig' %}
{% import '_icons.html.twig' as ico %}

{% block title %}{{ 'setup.stepper.downloads'|trans }} - Prismarr{% endblock %}

{% block max_width %}720px{% endblock %}

{% block wizard_body %}
  <div class="wizard-eyebrow">{{ 'setup.step.downloads.eyebrow'|trans }}</div>
  <h2 class="wizard-title">{{ 'setup.step.downloads.title'|trans }}</h2>
  <p class="wizard-subtitle">{{ 'setup.step.downloads.subtitle'|trans }}</p>

  <form action="{{ path('app_setup_downloads') }}" method="post" autocomplete="off" novalidate>
    <input type="hidden" name="_csrf_token" value="{{ csrf_token('setup_downloads') }}"/>

    <div class="wizard-section">
      <div class="wizard-section-title">{{ 'setup.step.downloads.qbittorrent.section'|trans }}</div>
      <div class="wizard-section-subtitle">{{ 'setup.step.downloads.qbittorrent.subtitle'|trans }}</div>
      <div class="row g-3">
        <div class="col-md-12">
          <label class="form-label" for="qbittorrent_url">{{ 'setup.step.managers.fields.url'|trans }}</label>
          <input type="text" id="qbittorrent_url" name="qbittorrent_url" class="form-control"
                 placeholder="http://host.docker.internal:8080" value="{{ values.qbittorrent_url }}"/>
        </div>
        <div class="col-md-6">
          <label class="form-label" for="qbittorrent_user">{{ 'setup.step.downloads.qbittorrent.user'|trans }}</label>
          <input type="text" id="qbittorrent_user" name="qbittorrent_user" class="form-control"
                 placeholder="admin" value="{{ values.qbittorrent_user }}"
                 autocomplete="off"/>
        </div>
        <div class="col-md-6">
          <label class="form-label" for="qbittorrent_password">{{ 'setup.step.downloads.qbittorrent.password'|trans }}</label>
          <div class="secret-wrapper">
            <input type="password" id="qbittorrent_password" name="qbittorrent_password" class="form-control"
                   placeholder="••••••••" value="{{ values.qbittorrent_password }}"
                   autocomplete="new-password"/>
            <button type="button" class="secret-toggle" aria-label="{{ 'setup.step.admin.toggle_visibility'|trans }}" data-toggle-for="qbittorrent_password">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"/>
                <path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6"/>
              </svg>
            </button>
          </div>
        </div>
        <div class="col-md-12">
          <small class="text-secondary" style="font-size: .78rem; line-height: 1.4;">
            {{ 'setup.step.downloads.qbittorrent.reverse_proxy_hint'|trans }}
          </small>
        </div>
      </div>
      <div class="test-row">
        <button type="button" class="btn btn-sm btn-outline-primary"
                data-test-service="qbittorrent"
                data-test-csrf="{{ csrf_token('setup_test_qbittorrent') }}"
                data-test-fields="qbittorrent_url,qbittorrent_user,qbittorrent_password">{{ 'setup.test.button'|trans }}</button>
        <span class="test-result" data-test-result-for="qbittorrent" aria-live="polite"></span>
      </div>
    </div>

    <div class="wizard-section">
      <div class="wizard-section-title">{{ 'setup.step.downloads.sabnzbd.section'|trans }} <span class="text-muted" style="font-weight:400;font-size:.75rem;">{{ 'setup.step.downloads.usenet_optional'|trans }}</span></div>
      <div class="wizard-section-subtitle">{{ 'setup.step.downloads.sabnzbd.subtitle'|trans }}</div>
      <div class="row g-3">
        <div class="col-md-7">
          <label class="form-label" for="sabnzbd_url">{{ 'setup.step.managers.fields.url'|trans }}</label>
          <input type="text" id="sabnzbd_url" name="sabnzbd_url" class="form-control"
                 placeholder="http://host.docker.internal:8080" value="{{ values.sabnzbd_url }}"/>
        </div>
        <div class="col-md-5">
          <label class="form-label" for="sabnzbd_api_key">{{ 'setup.step.downloads.sabnzbd.api_key'|trans }}</label>
          <div class="secret-wrapper">
            <input type="password" id="sabnzbd_api_key" name="sabnzbd_api_key" class="form-control"
                   placeholder="••••••••" value="{{ values.sabnzbd_api_key }}" autocomplete="new-password"/>
            <button type="button" class="secret-toggle" aria-label="{{ 'setup.step.admin.toggle_visibility'|trans }}" data-toggle-for="sabnzbd_api_key">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"/>
                <path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6"/>
              </svg>
            </button>
          </div>
        </div>
      </div>
      <div class="test-row">
        <button type="button" class="btn btn-sm btn-outline-primary"
                data-test-service="sabnzbd"
                data-test-csrf="{{ csrf_token('setup_test_sabnzbd') }}"
                data-test-fields="sabnzbd_url,sabnzbd_api_key">{{ 'setup.test.button'|trans }}</button>
        <span class="test-result" data-test-result-for="sabnzbd" aria-live="polite"></span>
      </div>
    </div>

    <div class="wizard-section">
      <div class="wizard-section-title">{{ 'setup.step.downloads.nzbget.section'|trans }} <span class="text-muted" style="font-weight:400;font-size:.75rem;">{{ 'setup.step.downloads.usenet_optional'|trans }}</span></div>
      <div class="wizard-section-subtitle">{{ 'setup.step.downloads.nzbget.subtitle'|trans }}</div>
      <div class="row g-3">
        <div class="col-md-12">
          <label class="form-label" for="nzbget_url">{{ 'setup.step.managers.fields.url'|trans }}</label>
          <input type="text" id="nzbget_url" name="nzbget_url" class="form-control"
                 placeholder="http://host.docker.internal:6789" value="{{ values.nzbget_url }}"/>
        </div>
        <div class="col-md-6">
          <label class="form-label" for="nzbget_user">{{ 'setup.step.downloads.qbittorrent.user'|trans }}</label>
          <input type="text" id="nzbget_user" name="nzbget_user" class="form-control"
                 placeholder="nzbget" value="{{ values.nzbget_user }}" autocomplete="off"/>
        </div>
        <div class="col-md-6">
          <label class="form-label" for="nzbget_password">{{ 'setup.step.downloads.qbittorrent.password'|trans }}</label>
          <div class="secret-wrapper">
            <input type="password" id="nzbget_password" name="nzbget_password" class="form-control"
                   placeholder="••••••••" value="{{ values.nzbget_password }}" autocomplete="new-password"/>
            <button type="button" class="secret-toggle" aria-label="{{ 'setup.step.admin.toggle_visibility'|trans }}" data-toggle-for="nzbget_password">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"/>
                <path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6"/>
              </svg>
            </button>
          </div>
        </div>
      </div>
      <div class="test-row">
        <button type="button" class="btn btn-sm btn-outline-primary"
                data-test-service="nzbget"
                data-test-csrf="{{ csrf_token('setup_test_nzbget') }}"
                data-test-fields="nzbget_url,nzbget_user,nzbget_password">{{ 'setup.test.button'|trans }}</button>
        <span class="test-result" data-test-result-for="nzbget" aria-live="polite"></span>
      </div>
    </div>

    <div class="wizard-section">
      <div class="wizard-section-title">{{ ico.icon('shield', '', 18) }} {{ 'setup.step.downloads.gluetun.section'|trans }} <span class="text-muted" style="font-weight:400;font-size:.75rem;">{{ 'setup.step.downloads.gluetun.section_suffix'|trans }}</span></div>
      <div class="wizard-section-subtitle">{{ 'setup.step.downloads.gluetun.subtitle'|trans }}</div>
      <div class="row g-3">
        <div class="col-md-12">
          <label class="form-label" for="gluetun_url">{{ 'setup.step.downloads.gluetun.url'|trans }}</label>
          <input type="text" id="gluetun_url" name="gluetun_url" class="form-control"
                 placeholder="http://host.docker.internal:8000" value="{{ values.gluetun_url }}"/>
        </div>
        <div class="col-md-12">
          <label class="form-label" for="gluetun_api_key">{{ 'setup.step.downloads.gluetun.api_key'|trans }} <span class="text-muted">{{ 'setup.step.downloads.gluetun.api_key_optional'|trans }}</span></label>
          <input type="text" id="gluetun_api_key" name="gluetun_api_key" class="form-control"
                 placeholder="{{ 'setup.step.downloads.gluetun.api_key_placeholder'|trans }}"
                 value="{{ values.gluetun_api_key }}"/>
        </div>
      </div>
    </div>

    <div class="wizard-actions">
      <button type="submit" name="_action" value="back" class="btn-wizard-back" formnovalidate>{{ 'setup.step.common.back'|trans }}</button>
      <div class="wizard-actions-right">
        <button type="submit" name="_action" value="skip" class="btn-wizard-skip" formnovalidate>{{ 'setup.step.common.skip'|trans }}</button>
        <button type="submit" name="_action" value="save" class="btn-wizard-next">{{ 'setup.step.common.save_next'|trans }}</button>
      </div>
    </div>
  </form>
{% endblock %}
