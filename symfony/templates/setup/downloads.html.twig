{% extends 'setup/_layout.html.twig' %}
{% import '_icons.html.twig' as ico %}
{% import '_form.html.twig' as forms %}

{% block title %}{{ 'setup.stepper.downloads'|trans }} - Prismarr{% endblock %}

{% block max_width %}720px{% endblock %}

{% block wizard_body %}
  <div class="subheader mb-1">{{ 'setup.step.downloads.eyebrow'|trans }}</div>
  <h2 class="mb-1">{{ 'setup.step.downloads.title'|trans }}</h2>
  <p class="text-secondary mb-4">{{ 'setup.step.downloads.subtitle'|trans }}</p>

  <form action="{{ path('app_setup_downloads') }}" method="post" autocomplete="off" novalidate>
    <input type="hidden" name="_csrf_token" value="{{ csrf_token('setup_downloads') }}"/>

    <div class="mt-3">
      <div class="hr-text hr-text-left">{{ 'setup.step.downloads.qbittorrent.section'|trans }}</div>
      <p class="text-secondary small mb-3">{{ 'setup.step.downloads.qbittorrent.subtitle'|trans }}</p>
      <div class="row g-3">
        <div class="col-md-12">
          <label class="form-label" for="qbittorrent_url">{{ 'setup.step.managers.fields.url'|trans }}</label>
          <input type="text" id="qbittorrent_url" name="qbittorrent_url" class="form-control"
                 placeholder="http://host.docker.internal:8080" value="{{ values.qbittorrent_url }}"/>
        </div>
        <div class="col-md-6">
          <label class="form-label" for="qbittorrent_user">{{ 'setup.step.downloads.qbittorrent.user'|trans }}</label>
          <input type="text" id="qbittorrent_user" name="qbittorrent_user" class="form-control"
                 placeholder="admin" value="{{ values.qbittorrent_user }}"
                 autocomplete="off"/>
        </div>
        <div class="col-md-6">
          <label class="form-label" for="qbittorrent_password">{{ 'setup.step.downloads.qbittorrent.password'|trans }}</label>
          {{ forms.secret_input('qbittorrent_password', 'qbittorrent_password', { placeholder: '••••••••', value: values.qbittorrent_password, autocomplete: 'new-password' }) }}
        </div>
        <div class="col-md-12">
          <small class="text-secondary" style="font-size: .78rem; line-height: 1.4;">
            {{ 'setup.step.downloads.qbittorrent.reverse_proxy_hint'|trans }}
          </small>
        </div>
      </div>
      <div class="d-flex align-items-center gap-2 mt-2 flex-wrap">
        <button type="button" class="btn btn-sm btn-outline-primary"
                data-test-service="qbittorrent"
                data-test-csrf="{{ csrf_token('setup_test_qbittorrent') }}"
                data-test-fields="qbittorrent_url,qbittorrent_user,qbittorrent_password">{{ 'setup.test.button'|trans }}</button>
        <span data-test-result-for="qbittorrent" aria-live="polite"></span>
      </div>
    </div>

    <div class="mt-3">
      <div class="hr-text hr-text-left">{{ 'setup.step.downloads.deluge.section'|trans }} <span class="text-muted" style="font-weight:400;font-size:.75rem;">{{ 'setup.step.downloads.usenet_optional'|trans }}</span></div>
      <p class="text-secondary small mb-3">{{ 'setup.step.downloads.deluge.subtitle'|trans }}</p>
      <div class="row g-3">
        <div class="col-md-7">
          <label class="form-label" for="deluge_url">{{ 'setup.step.managers.fields.url'|trans }}</label>
          <input type="text" id="deluge_url" name="deluge_url" class="form-control"
                 placeholder="http://host.docker.internal:8112" value="{{ values.deluge_url }}"/>
        </div>
        <div class="col-md-5">
          <label class="form-label" for="deluge_password">{{ 'setup.step.downloads.deluge.password'|trans }}</label>
          {{ forms.secret_input('deluge_password', 'deluge_password', { placeholder: '••••••••', value: values.deluge_password, autocomplete: 'new-password' }) }}
        </div>
        <div class="col-md-12">
          <small class="text-secondary" style="font-size: .78rem; line-height: 1.4;">
            {{ 'setup.step.downloads.deluge.reverse_proxy_hint'|trans }}
          </small>
        </div>
      </div>
      <div class="d-flex align-items-center gap-2 mt-2 flex-wrap">
        <button type="button" class="btn btn-sm btn-outline-primary"
                data-test-service="deluge"
                data-test-csrf="{{ csrf_token('setup_test_deluge') }}"
                data-test-fields="deluge_url,deluge_password">{{ 'setup.test.button'|trans }}</button>
        <span data-test-result-for="deluge" aria-live="polite"></span>
      </div>
    </div>

    <div class="mt-3">
      <div class="hr-text hr-text-left">{{ 'setup.step.downloads.sabnzbd.section'|trans }} <span class="text-muted" style="font-weight:400;font-size:.75rem;">{{ 'setup.step.downloads.usenet_optional'|trans }}</span></div>
      <p class="text-secondary small mb-3">{{ 'setup.step.downloads.sabnzbd.subtitle'|trans }}</p>
      <div class="row g-3">
        <div class="col-md-7">
          <label class="form-label" for="sabnzbd_url">{{ 'setup.step.managers.fields.url'|trans }}</label>
          <input type="text" id="sabnzbd_url" name="sabnzbd_url" class="form-control"
                 placeholder="http://host.docker.internal:8080" value="{{ values.sabnzbd_url }}"/>
        </div>
        <div class="col-md-5">
          <label class="form-label" for="sabnzbd_api_key">{{ 'setup.step.downloads.sabnzbd.api_key'|trans }}</label>
          {{ forms.secret_input('sabnzbd_api_key', 'sabnzbd_api_key', { placeholder: '••••••••', value: values.sabnzbd_api_key, autocomplete: 'new-password' }) }}
        </div>
      </div>
      <div class="d-flex align-items-center gap-2 mt-2 flex-wrap">
        <button type="button" class="btn btn-sm btn-outline-primary"
                data-test-service="sabnzbd"
                data-test-csrf="{{ csrf_token('setup_test_sabnzbd') }}"
                data-test-fields="sabnzbd_url,sabnzbd_api_key">{{ 'setup.test.button'|trans }}</button>
        <span data-test-result-for="sabnzbd" aria-live="polite"></span>
      </div>
    </div>

    <div class="mt-3">
      <div class="hr-text hr-text-left">{{ 'setup.step.downloads.nzbget.section'|trans }} <span class="text-muted" style="font-weight:400;font-size:.75rem;">{{ 'setup.step.downloads.usenet_optional'|trans }}</span></div>
      <p class="text-secondary small mb-3">{{ 'setup.step.downloads.nzbget.subtitle'|trans }}</p>
      <div class="row g-3">
        <div class="col-md-12">
          <label class="form-label" for="nzbget_url">{{ 'setup.step.managers.fields.url'|trans }}</label>
          <input type="text" id="nzbget_url" name="nzbget_url" class="form-control"
                 placeholder="http://host.docker.internal:6789" value="{{ values.nzbget_url }}"/>
        </div>
        <div class="col-md-6">
          <label class="form-label" for="nzbget_user">{{ 'setup.step.downloads.qbittorrent.user'|trans }}</label>
          <input type="text" id="nzbget_user" name="nzbget_user" class="form-control"
                 placeholder="nzbget" value="{{ values.nzbget_user }}" autocomplete="off"/>
        </div>
        <div class="col-md-6">
          <label class="form-label" for="nzbget_password">{{ 'setup.step.downloads.qbittorrent.password'|trans }}</label>
          {{ forms.secret_input('nzbget_password', 'nzbget_password', { placeholder: '••••••••', value: values.nzbget_password, autocomplete: 'new-password' }) }}
        </div>
      </div>
      <div class="d-flex align-items-center gap-2 mt-2 flex-wrap">
        <button type="button" class="btn btn-sm btn-outline-primary"
                data-test-service="nzbget"
                data-test-csrf="{{ csrf_token('setup_test_nzbget') }}"
                data-test-fields="nzbget_url,nzbget_user,nzbget_password">{{ 'setup.test.button'|trans }}</button>
        <span data-test-result-for="nzbget" aria-live="polite"></span>
      </div>
    </div>

    <div class="mt-3">
      <div class="hr-text hr-text-left">{{ ico.icon('shield', '', 18) }} {{ 'setup.step.downloads.gluetun.section'|trans }} <span class="text-muted" style="font-weight:400;font-size:.75rem;">{{ 'setup.step.downloads.gluetun.section_suffix'|trans }}</span></div>
      <p class="text-secondary small mb-3">{{ 'setup.step.downloads.gluetun.subtitle'|trans }}</p>
      <div class="row g-3">
        <div class="col-md-12">
          <label class="form-label" for="gluetun_url">{{ 'setup.step.downloads.gluetun.url'|trans }}</label>
          <input type="text" id="gluetun_url" name="gluetun_url" class="form-control"
                 placeholder="http://host.docker.internal:8000" value="{{ values.gluetun_url }}"/>
        </div>
        <div class="col-md-12">
          <label class="form-label" for="gluetun_api_key">{{ 'setup.step.downloads.gluetun.api_key'|trans }} <span class="text-muted">{{ 'setup.step.downloads.gluetun.api_key_optional'|trans }}</span></label>
          <input type="text" id="gluetun_api_key" name="gluetun_api_key" class="form-control"
                 placeholder="{{ 'setup.step.downloads.gluetun.api_key_placeholder'|trans }}"
                 value="{{ values.gluetun_api_key }}"/>
        </div>
      </div>
    </div>

    <div class="d-flex align-items-center justify-content-between gap-3 mt-4 pt-4 border-top">
      <button type="submit" name="_action" value="back" class="btn btn-outline-secondary" formnovalidate>{{ 'setup.step.common.back'|trans }}</button>
      <div class="d-flex align-items-center gap-2">
        <button type="submit" name="_action" value="skip" class="btn btn-link text-secondary" formnovalidate>{{ 'setup.step.common.skip'|trans }}</button>
        <button type="submit" name="_action" value="save" class="btn btn-primary btn-wizard-accent">{{ 'setup.step.common.save_next'|trans }}</button>
      </div>
    </div>
  </form>
{% endblock %}
