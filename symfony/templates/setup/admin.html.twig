{% extends 'setup/_layout.html.twig' %}
{% import '_form.html.twig' as forms %}

{% block title %}{{ 'setup.stepper.admin'|trans }} - Prismarr{% endblock %}

{% block wizard_body %}
  <div class="subheader mb-1">{{ 'setup.step.admin.eyebrow'|trans }}</div>
  <h2 class="mb-1">{{ 'setup.step.admin.title'|trans }}</h2>
  <p class="text-secondary mb-4">{{ 'setup.step.admin.subtitle'|trans }}</p>

  <form action="{{ path('app_setup_admin') }}" method="post" autocomplete="off" novalidate>
    <input type="hidden" name="_csrf_token" value="{{ csrf_token('setup_admin') }}"/>

    <div class="mb-3">
      <label class="form-label" for="email">{{ 'setup.step.admin.email'|trans }}</label>
      <input type="email" id="email" name="email" class="form-control"
             placeholder="admin@exemple.com"
             value="{{ email }}"
             autocomplete="email" autofocus required/>
    </div>

    <div class="mb-3">
      <label class="form-label" for="display_name">{{ 'setup.step.admin.display_name'|trans }} <span class="text-muted">{{ 'setup.step.admin.display_name_optional'|trans }}</span></label>
      <input type="text" id="display_name" name="display_name" class="form-control"
             placeholder="Admin"
             value="{{ display_name }}"
             autocomplete="name"/>
    </div>

    <div class="row g-3">
      <div class="col-md-6">
        <label class="form-label" for="password">{{ 'setup.step.admin.password'|trans }} <span class="text-muted">{{ 'setup.step.admin.password_hint'|trans }}</span></label>
        {{ forms.secret_input('password', 'password', { placeholder: '••••••••', autocomplete: 'new-password', required: true, minlength: 8 }) }}
      </div>
      <div class="col-md-6">
        <label class="form-label" for="password_confirm">{{ 'setup.step.admin.password_confirm'|trans }}</label>
        {{ forms.secret_input('password_confirm', 'password_confirm', { placeholder: '••••••••', autocomplete: 'new-password', required: true, minlength: 8 }) }}
      </div>
    </div>

    <div class="d-flex align-items-center justify-content-between gap-3 mt-4 pt-4 border-top">
      <a href="{{ path('app_setup_welcome') }}" class="btn btn-outline-secondary">{{ 'setup.step.admin.back'|trans }}</a>
      <button type="submit" class="btn btn-primary btn-wizard-accent">
        {{ 'setup.step.admin.cta'|trans }}
      </button>
    </div>
  </form>
{% endblock %}
