{% extends 'setup/_layout.html.twig' %}

{% block title %}{{ 'setup.stepper.indexers'|trans }} - Prismarr{% endblock %}

{% block max_width %}720px{% endblock %}

{% block wizard_body %}
  <div class="subheader mb-1">{{ 'setup.step.indexers.eyebrow'|trans }}</div>
  <h2 class="mb-1">{{ 'setup.step.indexers.title'|trans }}</h2>
  <p class="text-secondary mb-4">{{ 'setup.step.indexers.subtitle'|trans }}</p>

  <form action="{{ path('app_setup_indexers') }}" method="post" autocomplete="off" novalidate>
    <input type="hidden" name="_csrf_token" value="{{ csrf_token('setup_indexers') }}"/>

    <div class="mt-3">
      <div class="hr-text hr-text-left">{{ 'setup.step.indexers.prowlarr.section'|trans }}</div>
      <p class="text-secondary small mb-3">{{ 'setup.step.indexers.prowlarr.subtitle'|trans }}</p>
      <div class="row g-3">
        <div class="col-md-7">
          <label class="form-label" for="prowlarr_url">{{ 'setup.step.managers.fields.url'|trans }}</label>
          <input type="text" id="prowlarr_url" name="prowlarr_url" class="form-control"
                 placeholder="http://host.docker.internal:9696" value="{{ values.prowlarr_url }}"/>
        </div>
        <div class="col-md-5">
          <label class="form-label" for="prowlarr_api_key">{{ 'setup.step.managers.fields.api_key'|trans }}</label>
          <input type="text" id="prowlarr_api_key" name="prowlarr_api_key" class="form-control"
                 placeholder="X-Api-Key" value="{{ values.prowlarr_api_key }}"/>
        </div>
      </div>
      <div class="d-flex align-items-center gap-2 mt-2 flex-wrap">
        <button type="button" class="btn btn-sm btn-outline-primary"
                data-test-service="prowlarr"
                data-test-csrf="{{ csrf_token('setup_test_prowlarr') }}"
                data-test-fields="prowlarr_url,prowlarr_api_key">{{ 'setup.test.button'|trans }}</button>
        <span data-test-result-for="prowlarr" aria-live="polite"></span>
      </div>
    </div>

    <div class="mt-3">
      <div class="hr-text hr-text-left">{{ 'setup.step.indexers.jellyseerr.section'|trans }}</div>
      <p class="text-secondary small mb-3">{{ 'setup.step.indexers.jellyseerr.subtitle'|trans }}</p>
      <div class="row g-3">
        <div class="col-md-7">
          <label class="form-label" for="jellyseerr_url">{{ 'setup.step.managers.fields.url'|trans }}</label>
          <input type="text" id="jellyseerr_url" name="jellyseerr_url" class="form-control"
                 placeholder="http://host.docker.internal:5055" value="{{ values.jellyseerr_url }}"/>
        </div>
        <div class="col-md-5">
          <label class="form-label" for="jellyseerr_api_key">{{ 'setup.step.managers.fields.api_key'|trans }}</label>
          <input type="text" id="jellyseerr_api_key" name="jellyseerr_api_key" class="form-control"
                 placeholder="X-Api-Key" value="{{ values.jellyseerr_api_key }}"/>
        </div>
      </div>
      <div class="d-flex align-items-center gap-2 mt-2 flex-wrap">
        <button type="button" class="btn btn-sm btn-outline-primary"
                data-test-service="jellyseerr"
                data-test-csrf="{{ csrf_token('setup_test_jellyseerr') }}"
                data-test-fields="jellyseerr_url,jellyseerr_api_key">{{ 'setup.test.button'|trans }}</button>
        <span data-test-result-for="jellyseerr" aria-live="polite"></span>
      </div>
    </div>

    <div class="d-flex align-items-center justify-content-between gap-3 mt-4 pt-4 border-top">
      <button type="submit" name="_action" value="back" class="btn btn-outline-secondary" formnovalidate>{{ 'setup.step.common.back'|trans }}</button>
      <div class="d-flex align-items-center gap-2">
        <button type="submit" name="_action" value="skip" class="btn btn-link text-secondary" formnovalidate>{{ 'setup.step.common.skip'|trans }}</button>
        <button type="submit" name="_action" value="save" class="btn btn-primary btn-wizard-accent">{{ 'setup.step.common.save_next'|trans }}</button>
      </div>
    </div>
  </form>
{% endblock %}
