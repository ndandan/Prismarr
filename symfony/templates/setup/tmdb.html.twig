{% extends 'setup/_layout.html.twig' %}

{% block title %}TMDb - Prismarr{% endblock %}

{% block wizard_body %}
  <div class="wizard-eyebrow">{{ 'setup.step.tmdb.eyebrow'|trans }}</div>
  <h2 class="wizard-title">{{ 'setup.step.tmdb.title'|trans }}</h2>
  <p class="wizard-subtitle">{{ 'setup.step.tmdb.subtitle'|trans|raw }}</p>

  <form action="{{ path('app_setup_tmdb') }}" method="post" autocomplete="off" novalidate>
    <input type="hidden" name="_csrf_token" value="{{ csrf_token('setup_tmdb') }}"/>

    <div class="mb-3">
      <label class="form-label" for="tmdb_api_key">{{ 'setup.step.tmdb.api_key'|trans }}</label>
      <input type="text" id="tmdb_api_key" name="tmdb_api_key" class="form-control"
             placeholder="ex. 7a2f4…"
             value="{{ values.tmdb_api_key }}"
             autocomplete="off"/>
      <div class="form-text mt-1">{{ 'setup.step.tmdb.api_key_hint'|trans }}</div>
      <div class="d-flex align-items-center gap-2 mt-2 flex-wrap">
        <button type="button" class="btn btn-sm btn-outline-primary"
                data-test-service="tmdb"
                data-test-csrf="{{ csrf_token('setup_test_tmdb') }}"
                data-test-fields="tmdb_api_key">{{ 'setup.test.button'|trans }}</button>
        <span data-test-result-for="tmdb" aria-live="polite"></span>
      </div>
    </div>

    <div class="wizard-actions">
      <button type="submit" name="_action" value="back" class="btn-wizard-back" formnovalidate>{{ 'setup.step.common.back'|trans }}</button>
      <div class="wizard-actions-right">
        <button type="submit" name="_action" value="skip" class="btn-wizard-skip" formnovalidate>{{ 'setup.step.common.skip'|trans }}</button>
        <button type="submit" name="_action" value="save" class="btn-wizard-next">{{ 'setup.step.common.save_next'|trans }}</button>
      </div>
    </div>
  </form>
{% endblock %}
