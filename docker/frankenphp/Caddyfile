{
	frankenphp
	order mercure after encode

	# No HTTPS (local or behind a reverse proxy)
	auto_https off

	# Quiet Caddy system logs (cache maintenance, TLS, etc.)
	log {
		level WARN
	}
}

:7070 {
	root * /var/www/html/public

	# Access log on stdout — compact: method, uri, status, duration.
	# level WARN: only logs genuine HTTP issues (Caddy warnings/errors).
	# Successful 2xx/3xx access logs are suppressed to keep the signal/noise
	# ratio usable in Portainer/docker logs. Change to INFO if you need
	# full request telemetry.
	log {
		output stdout
		format filter {
			wrap console
			fields {
				request>headers delete
				request>tls delete
				request>remote_port delete
				request>client_ip delete
				request>proto delete
				request>host delete
				resp_headers delete
				user_id delete
				bytes_read delete
				size delete
				logger delete
			}
		}
		level WARN
	}

	# Compression
	encode zstd gzip

	# Mercure hub (real-time SSE).
	# Bolt DB stored in var/data (volume) so www-data can write to it.
	# cors_origins is exposed via env so public deployments can restrict
	# which origins may subscribe to the hub. Default '*' keeps local/LAN
	# homelab setups working out of the box.
	mercure {
		transport_url bolt:///var/www/html/var/data/mercure.db
		publisher_jwt {env.MERCURE_JWT_SECRET}
		subscriber_jwt {env.MERCURE_JWT_SECRET}
		cors_origins {$PRISMARR_MERCURE_CORS_ORIGINS:*}
		anonymous
	}

	# Symfony front controller
	php_server {
		resolve_root_symlink
	}

	# Security headers
	# CSP and X-Frame-Options are emitted from PHP (CspHeaderSubscriber):
	# CSP so user-configured service hosts (Jellyseerr avatars, etc.) are
	# whitelisted, X-Frame-Options so the PRISMARR_FRAME_ANCESTORS opt-in
	# (issue #25 — embed Prismarr in an iframe) can lift it cleanly.
	# HSTS is a no-op over plain HTTP (ignored by browsers) but is picked
	# up downstream when Prismarr sits behind an HTTPS reverse proxy that
	# forwards response headers (Traefik, nginx, Caddy upstream, Cloudflare).
	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-XSS-Protection "1; mode=block"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
		-Server
	}

	# Upload max 20 MB
	request_body {
		max_size 20MB
	}
}
